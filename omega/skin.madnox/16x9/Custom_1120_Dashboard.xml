<?xml version="1.0" encoding="utf-8" ?>
<window type="dialog" id="1120">
	<defaultcontrol always="true">9009</defaultcontrol>
	<controls>
		<!-- Semi-Transparent Overlay To Dim The Background -->
		<control type="image">
			<texture colordiffuse="A0000000">colors/black.png</texture>
			<animation effect="fade" time="400">WindowOpen</animation>
		</control>

		<!-- The Main Dialog Group -->
		<control type="group">
			<animation type="WindowOpen" reversible="false">
				<effect type="fade" start="0" end="100" time="400" />
				<effect type="slide" start="0,200" end="0,0" time="500" tween="cubic" />
			</animation>
			<animation type="WindowClose" reversible="false">
				<effect type="fade" start="100" end="0" time="300" />
			</animation>

			<centerleft>50%</centerleft>
			<centertop>50%</centertop>
			<width>1400</width>
			<height>800</height>

			<!-- Use The Skin's Native Dialogbackground Include -->
			<include content="DialogBackground">
				<param name="width" value="1400" />
				<param name="height" value="800" />
			</include>

			<!-- Madnox Logo -->
			<control type="image">
				<right>40</right>
				<top>30</top>
				<width>120</width>
				<height>60</height>
				<aspectratio>keep</aspectratio>
				<texture>icons/logo.png</texture>
			</control>

			<!-- Title -->
			<control type="label">
				<top>40</top>
				<left>40</left>
				<right>40</right>
				<height>50</height>
				<!-- <font>Font48_Reg</font> -->
				<textcolor>$VAR[PanelHighlightColorVar]</textcolor>
				<label>$LOCALIZE[31503] $LOCALIZE[14116]...</label>
				<!-- Dashboard Infomation -->
				<align>left</align>
				<include>SettingsLeftLabelWidgetsShortcut</include>
			</control>

			<!-- Fanart Image On The Left -->
			<control type="image">
				<left>40</left>
				<top>120</top>
				<width>600</width>
				<height>540</height>
				<aspectratio>scale</aspectratio>
				<texture border="5">icons/systeminfo/fanart/system.jpg</texture>
				<bordertexture colordiffuse="22FFFFFF" border="5">colors/white.png</bordertexture>
				<bordersize>5</bordersize>
			</control>

			<!-- Stats Group On The Right -->
			<control type="grouplist" id="9001">
				<left>680</left>
				<top>120</top>
				<width>680</width>
				<height>540</height>
				<itemgap>15</itemgap>
				<orientation>vertical</orientation>
				<onright>60</onright>
				<!-- Header -->
				<control type="label">
					<height>40</height>
					<font>Font30_Reg</font>
					<label>[COLOR FF6db9e5][B]$LOCALIZE[857] $LOCALIZE[126]:[/B][/COLOR]</label>
					<include>SettingsLabelNoOffset</include>
				</control>
				<control type="label">
					<height>40</height>
					<font>Font30_Reg</font>
					<label>[COLOR FF6db9e5]$LOCALIZE[169]:[/COLOR] [B]$INFO[System.ScreenResolution][/B]</label>
				</control>
				<control type="label">
					<height>80</height>
					<font>Font30_Reg</font>
					<wrapmultiline>true</wrapmultiline>
					<label>[COLOR FF6db9e5]$LOCALIZE[13283][/COLOR] [B]$INFO[System.OSVersionInfo][/B]</label>
				</control>
				<control type="label">
					<height>80</height>
					<font>Font30_Reg</font>
					<wrapmultiline>true</wrapmultiline>
					<label>[COLOR FF6db9e5]$LOCALIZE[31494] $LOCALIZE[19114]:[/COLOR] [B]$INFO[System.BuildVersion][/B]</label>
				</control>
				<control type="label">
					<height>40</height>
					<font>Font30_Reg</font>
					<label>[COLOR FF6db9e5]$LOCALIZE[248]:[/COLOR] [B]$INFO[System.Language][/B]</label>
				</control>
				<control type="label">
					<height>40</height>
					<font>Font30_Reg</font>
					<label>[COLOR FF6db9e5]$LOCALIZE[31493]:[/COLOR] [B]$INFO[System.Locale(region)][/B]</label>
				</control>
				<control type="label">
					<visible>!String.IsEqual(System.BatteryLevel,0%)</visible>
					<height>40</height>
					<font>Font30_Reg</font>
					<label>[COLOR FF6db9e5]$LOCALIZE[12395]:[/COLOR] [B]$INFO[System.BatteryLevel][/B]</label>
				</control>
				<!-- <control type="label">
					<visible>!String.IsEqual(System.BatteryLevel,0%)</visible>
					<height>30</height>
					<font>Font23_Cond_Bold</font>
					<textcolor>FFFF0000</textcolor>
					<shadowcolor>FF000000</shadowcolor>
					<label>[COLOR=FF00FF00]Battery Debug:[/COLOR] $INFO[System.BatteryLevel]</label>
				</control> -->
			</control>

			<!-- Scrollbar For The Stats Group -->
			<control type="scrollbar" id="60">
				<right>40</right>
				<top>120</top>
				<height>540</height>
				<width>12</width>
				<onleft>9001</onleft>
				<orientation>vertical</orientation>
				<visible>Control.IsVisible(9001) + Container(9001).HasScrollbar</visible>
				<include>DialogScrollBar</include>
			</control>

			<control type="button" id="9009">
				<width>200</width>
				<height>60</height>
				<centerleft>50%</centerleft>
				<bottom>40</bottom>
				<label>$LOCALIZE[186]</label>
				<font>Font30_Bold</font>
				<align>center</align>
				<onclick>Action(Close)</onclick>
				<include>DialogButtonAlwaysFocused</include>
			</control>
		</control>
	</controls>
</window>
