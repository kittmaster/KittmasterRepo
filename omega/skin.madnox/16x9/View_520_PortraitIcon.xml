<?xml version="1.0" encoding="utf-8" ?>
<includes>
	<include name="View520PortraitIcon">
		<!-- Floor -->
		<include content="Floor">
			<param name="visible">Skin.HasSetting(View520HideFloor) + Control.IsVisible(520)</param>
			<param name="highlight">FloorHighlightMiddle</param>
		</include>
		<!-- Panel -->
		<control type="group">
			<visible>Control.IsVisible(520)</visible>
			<!-- Animation To Slide Wall Left When Trailer Plays -->
			<animation type="Conditional" condition="!String.IsEmpty(Window(Home).Property(IsPlayingTrailer))" reversible="true">
				<effect type="slide" end="-680,0" time="400" tween="cubic" easing="out" />
			</animation>
			<include>AnimationZoomWindow</include>
			<include>AnimationZoomVisible</include>
			<include content="PanelDefault">
				<param name="top">108</param>
				<param name="height">862</param>
				<param name="toptexture">128</param>
				<param name="heighttexture">822</param>
				<param name="reflecttop">935</param>
				<param name="reflect">!Skin.HasSetting(View520HideReflect)</param>
			</include>
			<control type="panel" id="520">
				<top>178</top>
				<left>109</left>
				<width>1702</width>
				<height>722</height>
				<!-- Script Trigger and Navigation Cleanup -->
				<onfocus>RunScript(script.skin.madnox, action=trailer_rolling)</onfocus>
				<!-- Global Collection View Sync: backup enforcer fires when list gains focus -->
				<onfocus>RunScript(script.skin.madnox, action=collection_view_sync, mode=focus)</onfocus>
				<onleft>9050</onleft>
				<onunfocus>RunScript(script.skin.madnox, action=trailer_cleanup)</onunfocus>
				<onright>60520</onright>
				<pagecontrol>60520</pagecontrol>
				<include>ContainerScrollTime</include>
				<viewtype label="$LOCALIZE[31248]">bigicon</viewtype>

				<!-- ============================================== -->
				<!-- PORTRAIT ICON NORMAL -->
				<!-- ============================================== -->
				<itemlayout height="361" width="243" condition="!Skin.HasSetting(View520SmallIcons)">
					<control type="group">
						<visible>!Skin.HasSetting(View520VideoCase)</visible>
						<include content="ViewArtwork">
							<param name="texturefadetime">0</param>
							<param name="watchedstatusvisible">!Skin.HasSetting(View520DisableWatchedStatus)</param>
							<param name="diffuse">diffuse/rounded5-223x341.png</param>
						</include>
					</control>
					<control type="group">
						<visible>Skin.HasSetting(View520VideoCase)</visible>
						<include content="ViewArtworkVideoCase">
							<param name="logoheight">27</param>
							<param name="texturefadetime">0</param>
							<param name="bordersize">16,34,16,17</param>
							<param name="watchedstatustop">37</param>
							<param name="watchedstatusvisible">!Skin.HasSetting(View520DisableWatchedStatus)</param>
						</include>
					</control>
					<include content="Object_ProgressBar">
						<param name="left" value="25" />
						<param name="right" value="25" />
						<param name="bottom" value="20" />
						<param name="height" value="8" />
					</include>
				</itemlayout>

				<focusedlayout height="361" width="243" condition="!Skin.HasSetting(View520SmallIcons)">
					<control type="group">
						<camera x="121" y="180" />
						<animation effect="zoom" start="100" end="115" center="auto" time="240">focus</animation>
						<animation effect="zoom" start="115" end="100" center="auto" time="240">unfocus</animation>

						<!-- Focus Border (No Video Case) -->
						<control type="image">
							<visible>!Skin.HasSetting(View520VideoCase)</visible>
							<texture colordiffuse="$VAR[PanelHighlightColorVar]" border="10">buttons/thumb-select-focus.png</texture>
						</control>
						<!-- Focus Border (Video Case Enabled) -->
						<control type="image">
							<visible>Skin.HasSetting(View520VideoCase)</visible>
							<bordersize>16,34,16,17</bordersize>
							<texture colordiffuse="$VAR[PanelHighlightColorVar]" border="10">buttons/thumb-select-focus.png</texture>
						</control>

						<!-- LAYER 1: BACK TRAY & DISC -->
						<control type="group">
							<visible>Skin.HasSetting(View520VideoCase) + Skin.HasSetting(View520OpenCase) + [!String.IsEmpty(ListItem.Art(discart)) | !String.IsEqual(Skin.String(LibraryVideoDiscArtFallback),none)]</visible>
							<animation effect="fade" start="0" end="100" time="300" delay="1000">focus</animation>
							<animation effect="fade" start="100" end="0" time="150">unfocus</animation>
							<control type="image">
								<left>16</left>
								<top>34</top>
								<width>211</width>
								<height>310</height>
								<texture border="20">$VAR[ShowCaseBackVar]</texture>
							</control>
							<control type="image">
								<!-- <left>26</left>
								<top>84</top>
								<width>191</width>
								<height>191</height> -->
								<left>44</left>
								<top>116</top>
								<width>150</width>
								<height>150</height>
								<texture background="true">$VAR[LibraryVideoDiscArtVar]</texture>
								<aspectratio align="center" aligny="center">keep</aspectratio>
							</control>
						</control>

						<!-- LAYER 2: FRONT COVER HINGE -->
						<control type="group">
							<animation effect="rotatey" center="16,0" start="0" end="100" time="400" delay="1000" tween="quadratic" easing="out" condition="Skin.HasSetting(View520VideoCase) + Skin.HasSetting(View520OpenCase) + [!String.IsEmpty(ListItem.Art(discart)) | !String.IsEqual(Skin.String(LibraryVideoDiscArtFallback),none)]">focus</animation>
							<animation effect="rotatey" center="16,0" start="100" end="0" time="250" tween="quadratic" easing="in" condition="Skin.HasSetting(View520VideoCase) + Skin.HasSetting(View520OpenCase) + [!String.IsEmpty(ListItem.Art(discart)) | !String.IsEqual(Skin.String(LibraryVideoDiscArtFallback),none)]">unfocus</animation>

							<control type="group">
								<visible>!Skin.HasSetting(View520VideoCase)</visible>
								<include content="ViewArtwork">
									<param name="texturefadetime">0</param>
									<param name="watchedstatusvisible">!Skin.HasSetting(View520DisableWatchedStatus)</param>
									<param name="diffuse">diffuse/rounded5-223x341.png</param>
								</include>
							</control>
							<control type="group">
								<visible>Skin.HasSetting(View520VideoCase)</visible>
								<include content="ViewArtworkVideoCase">
									<param name="logoheight">27</param>
									<param name="texturefadetime">0</param>
									<param name="bordersize">16,34,16,17</param>
									<param name="watchedstatustop">37</param>
									<param name="watchedstatusvisible">!Skin.HasSetting(View520DisableWatchedStatus)</param>
								</include>
							</control>
							<include content="Object_ProgressBar">
								<param name="left" value="25" />
								<param name="right" value="25" />
								<param name="bottom" value="20" />
								<param name="height" value="8" />
							</include>
						</control>
					</control>
				</focusedlayout>

				<!-- ============================================== -->
				<!-- PORTRAIT ICON SMALL -->
				<!-- ============================================== -->
				<itemlayout height="240.66" width="170.2" condition="Skin.HasSetting(View520SmallIcons)">
					<control type="group">
						<visible>!Skin.HasSetting(View520VideoCase)</visible>
						<include content="ViewArtwork">
							<param name="texturefadetime">0</param>
							<param name="watchedstatusvisible">!Skin.HasSetting(View520DisableWatchedStatus)</param>
							<param name="diffuse">diffuse/rounded5-150x221.png</param>
						</include>
					</control>
					<control type="group">
						<visible>Skin.HasSetting(View520VideoCase)</visible>
						<include content="ViewArtworkVideoCase">
							<param name="logoheight">18</param>
							<param name="texturefadetime">0</param>
							<param name="bordersize">16,27,16,17</param>
							<param name="watchedstatustop">30</param>
							<param name="watchedstatusvisible">!Skin.HasSetting(View520DisableWatchedStatus)</param>
						</include>
					</control>
					<include content="Object_ProgressBar">
						<param name="left" value="25" />
						<param name="right" value="25" />
						<param name="bottom" value="24" />
						<param name="height" value="6" />
					</include>
				</itemlayout>

				<focusedlayout height="240.66" width="170.2" condition="Skin.HasSetting(View520SmallIcons)">
					<control type="group">
						<camera x="85" y="120" />
						<animation effect="zoom" start="100" end="115" center="auto" time="240">focus</animation>
						<animation effect="zoom" start="115" end="100" center="auto" time="240">unfocus</animation>

						<!-- Focus Border (No Video Case) -->
						<control type="image">
							<visible>!Skin.HasSetting(View520VideoCase)</visible>
							<texture colordiffuse="$VAR[PanelHighlightColorVar]" border="10">buttons/thumb-select-focus.png</texture>
						</control>
						<!-- Focus Border (Video Case Enabled) -->
						<control type="image">
							<visible>Skin.HasSetting(View520VideoCase)</visible>
							<bordersize>16,27,16,17</bordersize>
							<texture colordiffuse="$VAR[PanelHighlightColorVar]" border="10">buttons/thumb-select-focus.png</texture>
						</control>

						<!-- LAYER 1: BACK TRAY & DISC -->
						<control type="group">
							<visible>Skin.HasSetting(View520VideoCase) + Skin.HasSetting(View520OpenCase) + [!String.IsEmpty(ListItem.Art(discart)) | !String.IsEqual(Skin.String(LibraryVideoDiscArtFallback),none)]</visible>
							<animation effect="fade" start="0" end="100" time="300" delay="1000">focus</animation>
							<animation effect="fade" start="100" end="0" time="150">unfocus</animation>
							<control type="image">
								<left>16</left>
								<top>27</top>
								<width>138</width>
								<height>196</height>
								<texture border="10">$VAR[ShowCaseBackVar]</texture>
							</control>
							<control type="image">
								<!-- <left>21</left>
								<top>61</top>
								<width>128</width>
								<height>128</height> -->
								<left>34</left>
								<top>77</top>
								<width>100</width>
								<height>100</height>
								<texture background="true">$VAR[LibraryVideoDiscArtVar]</texture>
								<aspectratio align="center" aligny="center">keep</aspectratio>
							</control>
						</control>

						<!-- LAYER 2: FRONT COVER HINGE -->
						<control type="group">
							<animation effect="rotatey" center="16,0" start="0" end="100" time="400" delay="1000" tween="quadratic" easing="out" condition="Skin.HasSetting(View520VideoCase) + Skin.HasSetting(View520OpenCase) + [!String.IsEmpty(ListItem.Art(discart)) | !String.IsEqual(Skin.String(LibraryVideoDiscArtFallback),none)]">focus</animation>
							<animation effect="rotatey" center="16,0" start="100" end="0" time="250" tween="quadratic" easing="in" condition="Skin.HasSetting(View520VideoCase) + Skin.HasSetting(View520OpenCase) + [!String.IsEmpty(ListItem.Art(discart)) | !String.IsEqual(Skin.String(LibraryVideoDiscArtFallback),none)]">unfocus</animation>

							<control type="group">
								<visible>!Skin.HasSetting(View520VideoCase)</visible>
								<include content="ViewArtwork">
									<param name="texturefadetime">0</param>
									<param name="watchedstatusvisible">!Skin.HasSetting(View520DisableWatchedStatus)</param>
									<param name="diffuse">diffuse/rounded5-150x221.png</param>
								</include>
							</control>
							<control type="group">
								<visible>Skin.HasSetting(View520VideoCase)</visible>
								<include content="ViewArtworkVideoCase">
									<param name="logoheight">18</param>
									<param name="texturefadetime">0</param>
									<param name="bordersize">16,27,16,17</param>
									<param name="watchedstatustop">30</param>
									<param name="watchedstatusvisible">!Skin.HasSetting(View520DisableWatchedStatus)</param>
								</include>
							</control>
							<include content="Object_ProgressBar">
								<param name="left" value="25" />
								<param name="right" value="25" />
								<param name="bottom" value="24" />
								<param name="height" value="6" />
							</include>
						</control>
					</control>
				</focusedlayout>
			</control>
			<control type="scrollbar" id="60520">
				<right>80</right>
				<top>167</top>
				<bottom>170</bottom>
				<onleft>511</onleft>
				<onright condition="Control.IsVisible(61301)">61301</onright>
			</control>
		</control>
		<!-- Bottom Info/Media Flags -->
		<control type="group">
			<visible>Control.IsVisible(520)</visible>
			<include content="AnimationSlideBottomWindow">
				<param name="slide">220</param>
			</include>
			<include content="ViewCoverFlowBottomInfo">
				<param name="logovisible">View520Logo</param>
			</include>
			<include condition="Window.IsVisible(MyVideoNav.xml)">MediaFlagsPanelVideos</include>
		</control>

		<!-- Pop-Up Video Player Group -->
		<control type="group">
			<visible>Control.IsVisible(520) + !String.IsEmpty(Window(Home).Property(IsPlayingTrailer))</visible>
			<include>AnimationVideoPreviewPopup400</include>
			<right>50</right>
			<top>120</top>
			<width>700</width>
			<height>800</height>
			<!-- Video Player -->
			<control type="group">
				<width>700</width>
				<height>394</height>
				<control type="image">
					<texture>colors/black.png</texture>
				</control>
				<control type="videowindow">
					<colordiffuse>FFA0A0A0</colordiffuse>
				</control>
				<control type="image">
					<bordersize>-15</bordersize>
					<texture border="20" colordiffuse="$VAR[PanelHighlightColorVar]">thumbs/overlay.png</texture>
				</control>
			</control>
			<!-- Info Panel for Video -->
			<control type="group">
				<top>410</top>
				<control type="image">
					<width>700</width>
					<height>400</height>
					<texture colordiffuse="bb2a2a2a">colors/black.png</texture>
				</control>
				<control type="label">
					<left>20</left>
					<width>660</width>
					<height>90</height>
					<font>Font28_Bold</font>
					<textcolor>ff00aaff</textcolor>
					<shadowcolor>ff000000</shadowcolor>
					<align>left</align>
					<aligny>top</aligny>
					<label>$INFO[ListItem.Title]</label>
					<scroll>true</scroll>
				</control>
				<control type="image">
					<top>90</top>
					<left>20</left>
					<width>660</width>
					<height>4</height>
					<texture colordiffuse="$VAR[PanelListSeparatorColorVar]">panels/separator.png</texture>
				</control>
				<control type="textbox">
					<top>100</top>
					<left>20</left>
					<width>660</width>
					<height>280</height>
					<font>Font28_Reg</font>
					<textcolor>ffcccccc</textcolor>
					<shadowcolor>ff000000</shadowcolor>
					<align>justify</align>
					<label>$INFO[ListItem.Plot]</label>
					<animation effect="scroll" time="20000" delay="5000" end="100%" condition="true" loop="true" reversible="false">Conditional</animation>
				</control>
				<control type="image">
					<top>390</top>
					<left>20</left>
					<width>660</width>
					<height>4</height>
					<texture colordiffuse="$VAR[PanelListSeparatorColorVar]">panels/separator.png</texture>
				</control>
			</control>
		</control>
	</include>
</includes>
