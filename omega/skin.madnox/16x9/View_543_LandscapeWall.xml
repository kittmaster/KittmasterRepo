								<param name="art">$VAR[ClearArtVar]</param>
								<param name="diffuse">diffuse/rounded5-532x395.png</param>
							</include>
						</control>
						<include content="ViewLogoFallback">
							<param name="visible">String.IsEmpty(ListItem.Art(clearart)) + String.IsEmpty(ListItem.Art(tvshow.clearart)) + String.IsEmpty(ListItem.Art(clearlogo)) + String.IsEmpty(ListItem.Art(tvshow.clearlogo))</param>
							<param name="font">Font33_Bold</param>
							<param name="watchedstatusvisible">!Skin.HasSetting(View543DisableWatchedStatus)</param>
						</include>
						<include content="Object_ProgressBar">
							<param name="left" value="25" />
							<param name="right" value="25" />
							<param name="bottom" value="14" />
							<param name="height" value="8" />
						</include>
					</control>
				</focusedlayout>
			</control>
			<include content="ViewWallScrollBar">
				<param name="id">543</param>
			</include>
		</control>
		<!-- Bottom Info/Media Flags -->
		<control type="group">
			<visible>Control.IsVisible(543)</visible>
			<include content="AnimationSlideBottomWindow">
				<param name="slide">220</param>
			</include>
			<include>FloorShadowWall</include>
			<include content="ViewCoverFlowBottomInfo">
				<param name="logovisible">View543Logo</param>
			</include>
			<include content="MediaFlagsPanelVideos" condition="Window.IsVisible(MyVideoNav.xml)">
				<param name="left">50</param>
				<param name="right">50</param>
				<param name="bottom">28</param>
			</include>
			<include content="MediaFlagsPanelAudio" condition="Window.IsVisible(MyMusicNav.xml)">
				<param name="left">50</param>
				<param name="right">50</param>
				<param name="bottom">28</param>
			</include>
		</control>

		<!-- Pop-Up Video Player Group -->
		<control type="group">
			<visible>Control.IsVisible(543) + !String.IsEmpty(Window(Home).Property(IsPlayingTrailer))</visible>
			<include>AnimationVideoPreviewPopup400</include>
			<right>50</right>
			<top>120</top>
			<width>700</width>
			<height>800</height>
			<!-- Video Player -->
			<control type="group">
				<width>700</width>
				<height>394</height>
				<control type="image">
					<texture>colors/black.png</texture>
				</control>
				<control type="videowindow">
					<colordiffuse>FFA0A0A0</colordiffuse>
				</control>
				<control type="image">
					<bordersize>-15</bordersize>
					<texture border="20" colordiffuse="$VAR[PanelHighlightColorVar]">thumbs/overlay.png</texture>
				</control>
			</control>
			<!-- Info Panel for Video -->
			<control type="group">
				<top>410</top>
				<!-- Title -->
				<control type="label">
					<width>700</width>
					<height>90</height>
					<font>Font28_Bold</font>
					<textcolor>ff00aaff</textcolor>
					<shadowcolor>ff000000</shadowcolor>
					<align>left</align>
					<aligny>top</aligny>
					<label>$INFO[ListItem.Title]</label>
					<scroll>true</scroll>
				</control>
				<!-- Top Separator -->
				<control type="image">
					<top>90</top>
					<height>4</height>
					<texture colordiffuse="$VAR[PanelListSeparatorColorVar]">panels/separator.png</texture>
				</control>
				<!-- Plot Textbox -->
				<control type="textbox">
					<top>100</top>
					<width>700</width>
					<height>280</height>
					<font>Font28_Reg</font>
					<textcolor>ffcccccc</textcolor>
					<shadowcolor>ff000000</shadowcolor>
					<align>justify</align>
					<label>$INFO[ListItem.Plot]</label>
					<animation effect="scroll" time="20000" delay="5000" end="100%" condition="true" loop="true" reversible="false">Conditional</animation>
				</control>
				<!-- Bottom Separator -->
				<control type="image">
					<top>390</top>
					<height>4</height>
					<texture colordiffuse="$VAR[PanelListSeparatorColorVar]">panels/separator.png</texture>
				</control>
			</control>
		</control>
	</include>
</includes>
