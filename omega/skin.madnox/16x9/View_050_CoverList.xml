				<!-- Standard Video Player (Visible WHEN trailer IS playing AND Open Case is OFF) -->
				<control type="group">
					<visible>!String.IsEmpty(Window(10000).Property(IsPlayingTrailer)) + !Skin.HasSetting(View50OpenCase)</visible>

					<!-- 1. The black drop shadow base (matches the normal poster exactly) -->
					<control type="image">
						<bordersize>10</bordersize>
						<texture colordiffuse="ff000000" border="10">buttons/thumb-select-focus.png</texture>
					</control>

					<!-- 2. Inner group to restrict the video & fanart to the 10px inset bounds (532x800) -->
					<control type="group">
						<left>10</left>
						<top>10</top>
						<right>10</right>
						<bottom>10</bottom>

						<!-- Solid black backdrop so video doesn't have transparency holes -->
						<control type="image">
							<texture>colors/black.png</texture>
						</control>

						<control type="group">
							<visible>Skin.HasSetting(View50AnimatedFanart)</visible>
							<control type="image">
								<!-- Added the standard diffuse mask to pre-round the Fanart corners -->
								<texture background="true" diffuse="diffuse/rounded5-532x800.png" fallback="colors/black.png">$VAR[FanartVar]</texture>
								<aspectratio scalediffuse="false">scale</aspectratio>
							</control>
							<control type="videowindow">
								<visible>Player.HasVideo</visible>
								<animation effect="fade" time="400" delay="200">Visible</animation>
								<aspectratio>keep</aspectratio>
								<colordiffuse>FFA0A0A0</colordiffuse>
							</control>
						</control>

						<control type="group">
							<visible>!Skin.HasSetting(View50AnimatedFanart)</visible>
							<control type="videowindow">
								<aspectratio>keep</aspectratio>
								<colordiffuse>FFA0A0A0</colordiffuse>
							</control>
						</control>
					</control>

					<!-- 3. The frame overlay drawn at full 552x820 size to cover the inner edges -->
					<control type="image">
						<texture border="20">thumbs/overlay.png</texture>
					</control>
				</control>
			</control>
