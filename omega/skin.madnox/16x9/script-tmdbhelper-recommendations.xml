<?xml version="1.0" encoding="UTF-8" ?>
<!-- [PHASE 4: TMDB EXTERNAL MODULES - COMPLETED] -->
<window type="dialog" id="1190">
	<defaultcontrol always="true">9000</defaultcontrol>
	<onload>SetFocus(9000,0)</onload>
	<onload condition="!Skin.HasSetting(disableautoscrollmoviemetadata)">SetProperty(ItemListCountDownTimerMovie,$INFO[Skin.String(moviemetascrollingdelayvaluevarb)],Home)</onload>
	<onload condition="!Skin.HasSetting(disableautoscrollmoviemetadata)">AlarmClock(MetaData_Slide_Movie,RunScript(script.skin.madnox, action=decrement_movie),00:01,silent,loop)</onload>
	<onload>AlarmClock(Refocus9000,SetFocus(9000,0),00:00:01,silent)</onload>

	<!-- Prevent alarm cancellation if returning to Movie Information -->
	<onunload condition="!Window.IsVisible(movieinformation)">CancelAlarm(MetaData_Slide_Movie,true)</onunload>
	<!-- Ensure timer is restarted and property is reset when returning -->
	<onunload condition="Window.IsVisible(movieinformation) + !Skin.HasSetting(disableautoscrollmoviemetadata)">AlarmClock(MetaData_Slide_Movie,RunScript(script.skin.madnox, action=decrement_movie),00:01,silent,loop)</onunload>
	<onunload condition="Window.IsVisible(movieinformation) + !Skin.HasSetting(disableautoscrollmoviemetadata)">SetProperty(ItemListCountDownTimerMovie,$INFO[Skin.String(moviemetascrollingdelayvaluevarb)],Home)</onunload>

	<!-- Prevent alarm cancellation if returning to Person Information -->
	<onunload condition="!Window.IsVisible(script-embuary-person.xml)">CancelAlarm(MetaData_Slide_Person,true)</onunload>

	<controls>
		<!-- =============================================================== -->
		<!--  Recommended Hidden Lists                                       -->
		<!-- =============================================================== -->
		<control type="list" id="10051">
			<include>HiddenList</include>
		</control>
		<control type="list" id="10055">
			<include>HiddenList</include>
		</control>
		<control type="list" id="10059">
			<include>HiddenList</include>
		</control>
		<control type="list" id="10061">
			<include>HiddenList</include>
		</control>

		<!-- =============================================================== -->
		<!-- Base Visual Template & Layout Call                              -->
		<!-- =============================================================== -->
		<control type="image">
			<include>FullScreenDimensions</include>
		</control>

		<!-- Fanart Background (Using new standardized base) -->
		<include content="DialogInfo_Base">
			<param name="blur">Skin.HasSetting(VideoBlurEnabled)</param>
			<param name="art">$INFO[Window.Property(fanart)]</param>
		</include>

		<!-- Inject the modular layout -->
		<include>DialogInfo_TMDbExternal</include>
	</controls>
</window>
