<?xml version="1.0" encoding="utf-8" ?>
<!-- [PHASE 1: ROUTER - COMPLETED] -->
<window>
	<!-- <defaultcontrol>9000</defaultcontrol> -->
	<defaultcontrol always="true" condition="!Window.IsVisible(1190)">9000</defaultcontrol>
	<onload>SetFocus(9000,0)</onload>
	<!-- Clear the ready flag before script runs (ensures the grouplist hides first) -->
	<onload>ClearProperty(InfoDialog.Ratings.Ready,Home)</onload>

	<!-- Updated RunScript calls — add output_ready param to both -->
	<onload>RunScript(script.skin.madnox, action=process_ratings, output_tmdb=InfoDialog.TMDb.Percent, output_imdb=InfoDialog.IMDb.Percent, output_user=InfoDialog.User.Formatted, output_ready=InfoDialog.Ratings.Ready)</onload>

	<defaultcontrol always="true" condition="Window.IsVisible(1190)">5000</defaultcontrol>
	<onload condition="System.AddonIsEnabled(plugin.video.themoviedb.helper) + Skin.HasSetting(VideoBlurEnabled)">SetProperty(TMDbHelper.Blur.SourceImage,Art(fanart)|Art(tvshow.fanart)|Art(landscape)|Art(thumb)|Icon,Home)</onload>
	<onload condition="System.AddonIsEnabled(plugin.video.themoviedb.helper) + Skin.HasSetting(VideoBlurEnabled)">SetProperty(TMDbHelper.Blur.Fallback,special://home/addons/resource.images.skin.madnox/resources/backgrounds/default_livecases.jpg,Home)</onload>
	<onload condition="System.AddonIsEnabled(plugin.video.themoviedb.helper) + Skin.HasSetting(BlurEnabled)">Skin.SetBool(TMDbHelper.EnableBlur)</onload>
	<onload>ClearProperty(fullscreen_actor, movieinformation)</onload>
	<onload>ClearProperty(InfoDialogPersonView, Home)</onload>

	<!-- Meta Data Slide Timers Movie & Person -->
	<onload condition="!Skin.HasSetting(disableautoscrollmoviemetadata)">SetProperty(ItemListCountDownTimerMovie,$INFO[Skin.String(moviemetascrollingdelayvaluevarb)],Home)</onload>
	<onload condition="!Skin.HasSetting(disableautoscrollpersonmetadata)">SetProperty(ItemListCountDownTimerPerson,$INFO[Skin.String(personmetascrollingdelayvaluevarb)],Home)</onload>
	<onload condition="!Skin.HasSetting(disableautoscrollmoviemetadata)">AlarmClock(MetaData_Slide_Movie,RunScript(script.skin.madnox, action=decrement_movie),00:01,silent,loop)</onload>
	<onload condition="!Skin.HasSetting(disableautoscrollpersonmetadata)">AlarmClock(MetaData_Slide_Person,RunScript(script.skin.madnox, action=decrement_person),00:01,silent,loop)</onload>

	<onload>SetProperty(VideoInfo.Status,$INFO[Window(Home).Property(TMDbHelper.ListItem.Status)])</onload>
	<onload>SetProperty(VideoInfo.Next_Aired,$INFO[Window(Home).Property(TMDbHelper.ListItem.Next_Aired)])</onload>
	<onload>SetProperty(VideoInfo.Next_Aired.Season,$INFO[Window(Home).Property(TMDbHelper.ListItem.Next_Aired.Season)])</onload>
	<onload>SetProperty(VideoInfo.Next_Aired.Episode,$INFO[Window(Home).Property(TMDbHelper.ListItem.Next_Aired.Episode)])</onload>
	<onload>SetProperty(VideoInfo.Last_Aired,$INFO[Window(Home).Property(TMDbHelper.ListItem.Last_Aired)])</onload>
	<onload>SetProperty(VideoInfo.Last_Aired.Season,$INFO[Window(Home).Property(TMDbHelper.ListItem.Last_Aired.Season)])</onload>
	<onload>SetProperty(VideoInfo.Last_Aired.Episode,$INFO[Window(Home).Property(TMDbHelper.ListItem.Last_Aired.Episode)])</onload>

	<onload>RunScript(script.skin.madnox, action=process_ratings, output_tmdb=InfoDialog.TMDb.Percent, output_imdb=InfoDialog.IMDb.Percent, output_user=InfoDialog.User.Formatted)</onload>
	<onunload>ClearProperty(InfoDialog.TMDb.Percent,Home)</onunload>
	<onunload>ClearProperty(InfoDialog.IMDb.Percent,Home)</onunload>
	<onunload>ClearProperty(InfoDialog.User.Formatted,Home)</onunload>
	<onunload>ClearProperty(InfoDialog.Ratings.Ready,Home)</onunload>

	<controls>
		<!-- BASE TEMPLATE: Backgrounds and Blur (Passes param based on Music vs. Video) -->
		<control type="group">
			<visible>![String.IsEqual(ListItem.DBTYPE,musicvideo) | String.IsEqual(ListItem.DBTYPE,artist) | String.IsEqual(ListItem.DBTYPE,album) | String.IsEqual(ListItem.DBTYPE,song)]</visible>
			<include content="DialogInfo_Base">
				<param name="blur">Skin.HasSetting(VideoBlurEnabled)</param>
			</include>
		</control>

		<control type="group">
			<visible>String.IsEqual(ListItem.DBTYPE,musicvideo) | String.IsEqual(ListItem.DBTYPE,artist) | String.IsEqual(ListItem.DBTYPE,album) | String.IsEqual(ListItem.DBTYPE,song)</visible>
			<include content="DialogInfo_Base">
				<param name="blur">Skin.HasSetting(MusicBlurEnabled)</param>
			</include>
		</control>

		<!-- THE ROUTER: Loads isolated contexts. Conditions MUST be mutually exclusive. -->
		<control type="group">
			<visible>!Window.IsVisible(script-tmdbhelper-recommendations.xml)</visible>
			<include>AnimationInfoDialog</include>

			<!-- ROUTE 1: Music & Music Videos -->
			<include condition="String.IsEqual(ListItem.DBTYPE,musicvideo) | String.IsEqual(ListItem.DBTYPE,artist) | String.IsEqual(ListItem.DBTYPE,album) | String.IsEqual(ListItem.DBTYPE,song)">DialogInfo_Music</include>

			<!-- ROUTE 2: Persons / Actors -->
			<include condition="String.IsEqual(ListItem.DBTYPE,person) | String.IsEqual(ListItem.DBTYPE,actor) | String.IsEqual(ListItem.DBTYPE,video)">DialogInfo_Person</include>

			<!-- ROUTE 3: Standard Movies & TV Shows (Catch-all for standard video databases) -->
			<include condition="![String.IsEqual(ListItem.DBTYPE,musicvideo) | String.IsEqual(ListItem.DBTYPE,artist) | String.IsEqual(ListItem.DBTYPE,album) | String.IsEqual(ListItem.DBTYPE,song) | String.IsEqual(ListItem.DBTYPE,person) | String.IsEqual(ListItem.DBTYPE,actor) | String.IsEqual(ListItem.DBTYPE,video)]">DialogInfo_Video</include>
		</control>
	</controls>

	<!-- Cancel The Unified Alarmclock For Movies And The Person Metadata Alarm -->
	<onunload>CancelAlarm(MetaData_Slide_Movie,true)</onunload>
	<onunload>CancelAlarm(MetaData_Slide_Person,true)</onunload>
	<onunload>ClearProperty(InfoDialogPersonView,Home)</onunload>
</window>
