<?xml version="1.0" encoding="utf-8" ?>
<window type="dialog" id="1124">
	<defaultcontrol always="true">9009</defaultcontrol>
	<controls>
		<control type="image">
			<texture colordiffuse="A0000000">colors/black.png</texture>
			<animation effect="fade" time="400">WindowOpen</animation>
		</control>
		<control type="group">
			<animation type="WindowOpen" reversible="false">
				<effect type="fade" start="0" end="100" time="400" />
				<effect type="slide" start="0,200" end="0,0" time="500" tween="cubic" />
			</animation>
			<animation type="WindowClose" reversible="false">
				<effect type="fade" start="100" end="0" time="300" />
			</animation>
			<centerleft>50%</centerleft>
			<centertop>50%</centertop>
			<width>1400</width>
			<height>800</height>
			<!-- SOLID BACKGROUND TO PREVENT TEXT BLEED-THROUGH -->
			<control type="image">
				<width>1400</width>
				<height>800</height>
				<!-- Use the skin's native dialog shape with an opaque color to block bleed-through perfectly -->
				<texture colordiffuse="FF080808" border="40">$VAR[DialogStyleVar]</texture>
				<animation effect="fade" time="400">WindowOpen</animation>
			</control>
			<include content="DialogBackground">
				<param name="width" value="1400" />
				<param name="height" value="800" />
			</include>
			<control type="image">
				<right>40</right>
				<top>30</top>
				<width>120</width>
				<height>60</height>
				<aspectratio>keep</aspectratio>
				<texture>icons/logo.png</texture>
			</control>

			<control type="label">
				<top>40</top>
				<left>40</left>
				<right>40</right>
				<height>50</height>
				<width>520</width>
				<textcolor>$VAR[PanelHighlightColorVar]</textcolor>
				<label>$LOCALIZE[20158]...</label>
				<align>left</align>
				<include>SettingsLeftLabelWidgetsShortcut</include>
			</control>

			<control type="image">
				<left>40</left>
				<top>120</top>
				<width>600</width>
				<height>540</height>
				<aspectratio>scale</aspectratio>
				<texture border="5">icons/systeminfo/fanart/connected.jpg</texture>
				<bordertexture colordiffuse="22FFFFFF" border="5">colors/white.png</bordertexture>
				<bordersize>5</bordersize>
			</control>

			<control type="grouplist" id="9001">
				<left>680</left>
				<top>120</top>
				<width>680</width>
				<height>540</height>
				<itemgap>15</itemgap>
				<orientation>vertical</orientation>
				<!-- Header -->
				<control type="label">
					<height>40</height>
					<font>Font30_Reg</font>
					<label>[COLOR FF6db9e5][B]$LOCALIZE[705] [LOWERCASE]$LOCALIZE[126][/LOWERCASE]:[/B][/COLOR]</label>
					<include>SettingsLabelNoOffset</include>
				</control>
				<!-- IP Address -->
				<control type="label">
					<height>40</height>
					<font>Font30_Reg</font>
					<label>[COLOR FF6db9e5]$LOCALIZE[150]:[/COLOR] [B]$INFO[Network.IPAddress][/B]</label>
					<visible>!String.IsEmpty(Network.IPAddress)</visible>
				</control>
				<!-- Subnet Mask -->
				<control type="label">
					<height>40</height>
					<font>Font30_Reg</font>
					<label>[COLOR FF6db9e5]$LOCALIZE[13159]:[/COLOR] [B]$INFO[Network.SubnetMask][/B]</label>
					<visible>!String.IsEmpty(Network.SubnetMask)</visible>
				</control>
				<!-- Gateway -->
				<control type="label">
					<height>40</height>
					<font>Font30_Reg</font>
					<label>[COLOR FF6db9e5]$LOCALIZE[13160]:[/COLOR] [B]$INFO[Network.GatewayAddress][/B]</label>
					<visible>!String.IsEmpty(Network.GatewayAddress)</visible>
				</control>
				<!-- MAC Address -->
				<control type="label">
					<height>40</height>
					<font>Font30_Reg</font>
					<label>[COLOR FF6db9e5]$LOCALIZE[149]:[/COLOR] [B]$INFO[Network.MacAddress][/B]</label>
					<visible>!String.IsEmpty(Network.MacAddress)</visible>
				</control>
				<!-- DNS Server 1 -->
				<control type="label">
					<height>40</height>
					<font>Font30_Reg</font>
					<label>[COLOR FF6db9e5]$LOCALIZE[13161]:[/COLOR] [B]$INFO[Network.DNS1Address][/B]</label>
					<visible>!String.IsEmpty(Network.DNS1Address)</visible>
				</control>
				<!-- DNS Server 2 -->
				<control type="label">
					<height>40</height>
					<font>Font30_Reg</font>
					<label>[COLOR FF6db9e5]$LOCALIZE[20307]:[/COLOR] [B]$INFO[Network.DNS2Address][/B]</label>
					<visible>!String.IsEmpty(Network.DNS2Address)</visible>
				</control>
				<!-- Internet / Link State -->
				<control type="label">
					<height>40</height>
					<font>Font30_Reg</font>
					<label>[COLOR FF6db9e5]$LOCALIZE[443]:[/COLOR] [B]$INFO[Network.LinkState][/B]</label>
					<visible>!String.IsEmpty(Network.LinkState)</visible>
				</control>
			</control>

			<control type="button" id="9009">
				<width>200</width>
				<height>60</height>
				<centerleft>50%</centerleft>
				<bottom>40</bottom>
				<label>$LOCALIZE[186]</label>
				<font>Font30_Bold</font>
				<align>center</align>
				<onclick>Action(Close)</onclick>
				<include>DialogButtonAlwaysFocused</include>
			</control>
		</control>
	</controls>
</window>
