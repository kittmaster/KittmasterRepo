<?xml version="1.0" encoding="utf-8" ?>
<includes>
	<include name="View522BannerIcon">
		<!-- Floor -->
		<include content="Floor">
			<param name="visible">Skin.HasSetting(View522HideFloor) + Control.IsVisible(522)</param>
			<param name="highlight">FloorHighlightMiddle</param>
		</include>
		<!-- Panel -->
		<control type="group">
			<visible>Control.IsVisible(522)</visible>
			<!-- Animation To Slide Wall Left When Trailer Plays -->
			<animation type="Conditional" condition="!String.IsEmpty(Window(Home).Property(IsPlayingTrailer))" reversible="true">
				<effect type="slide" end="-680,0" time="400" tween="cubic" easing="out" />
			</animation>
			<include>AnimationZoomWindow</include>
			<include>AnimationZoomVisible</include>
			<include content="PanelDefault">
				<param name="top">104</param>
				<param name="height">866</param>
				<param name="toptexture">124</param>
				<param name="heighttexture">826</param>
				<param name="reflecttop">935</param>
				<param name="reflect">!Skin.HasSetting(View522HideReflect)</param>
			</include>
			<control type="panel" id="522">
				<top>174</top>
				<left>110</left>
				<width>1700</width>
				<height>726</height>
				<!-- Script Trigger and Navigation Cleanup -->
				<onfocus>RunScript(script.skin.madnox, action=trailer_rolling)</onfocus>
				<!-- Global Collection View Sync: backup enforcer fires when list gains focus -->
				<onfocus>RunScript(script.skin.madnox, action=collection_view_sync, mode=focus)</onfocus>
				<onleft>9050</onleft>
				<onunfocus>RunScript(script.skin.madnox, action=trailer_cleanup)</onunfocus>
				<onright>60514</onright>
				<pagecontrol>60514</pagecontrol>
				<include>ContainerScrollTime</include>
				<viewtype label="$LOCALIZE[31249]">bigicon</viewtype>
				<itemlayout height="121" width="566.65">
					<control type="group">
						<visible>!String.IsEmpty(ListItem.Art(banner)) | !String.IsEmpty(ListItem.Art(tvshow.banner))</visible>
						<include content="ViewArtwork">
							<param name="art">$VAR[BannerVar]</param>
							<param name="texturefadetime">0</param>
							<param name="watchedstatusvisible">!Skin.HasSetting(View522DisableWatchedStatus)</param>
							<param name="diffuse">diffuse/rounded5-547x103.png</param>
						</include>
					</control>
					<control type="group">
						<visible>String.IsEmpty(ListItem.Art(banner)) + String.IsEmpty(ListItem.Art(tvshow.banner))</visible>
						<include content="ViewBannerFallback">
							<param name="watchedstatusvisible">!Skin.HasSetting(View522DisableWatchedStatus)</param>
							<param name="diffuse">diffuse/rounded5-547x103.png</param>
						</include>
					</control>
					<include content="Object_ProgressBar">
						<param name="left" value="25" />
						<param name="right" value="25" />
						<param name="bottom" value="14" />
						<param name="height" value="8" />
					</include>
				</itemlayout>
				<focusedlayout height="121" width="566.65">
					<control type="image">
						<texture colordiffuse="$VAR[PanelHighlightColorVar]" border="10">buttons/thumb-select-focus.png</texture>
					</control>
					<control type="group">
						<animation type="Focus" reversible="false">
							<effect type="zoom" start="95" end="100" time="240" center="auto" />
						</animation>
						<control type="group">
							<visible>!String.IsEmpty(ListItem.Art(banner)) | !String.IsEmpty(ListItem.Art(tvshow.banner))</visible>
							<include content="ViewArtwork">
								<param name="art">$VAR[BannerVar]</param>
								<param name="texturefadetime">0</param>
								<param name="watchedstatusvisible">!Skin.HasSetting(View522DisableWatchedStatus)</param>
								<param name="diffuse">diffuse/rounded5-547x103.png</param>
							</include>
						</control>
						<control type="group">
							<visible>String.IsEmpty(ListItem.Art(banner)) + String.IsEmpty(ListItem.Art(tvshow.banner))</visible>
							<include content="ViewBannerFallback">
								<param name="watchedstatusvisible">!Skin.HasSetting(View522DisableWatchedStatus)</param>
								<param name="diffuse">diffuse/rounded5-547x103.png</param>
							</include>
						</control>
						<include content="Object_ProgressBar">
							<param name="left" value="25" />
							<param name="right" value="25" />
							<param name="bottom" value="14" />
							<param name="height" value="8" />
						</include>
					</control>
				</focusedlayout>
			</control>
			<control type="scrollbar" id="60514">
				<right>80</right>
				<top>164</top>
				<bottom>170</bottom>
				<onleft>522</onleft>
				<!-- <onright condition="Control.IsVisible(61300)">61300</onright> -->
				<onright condition="Control.IsVisible(61301)">61301</onright>
			</control>
		</control>
		<!-- Bottom Info/Media Flags -->
		<control type="group">
			<visible>Control.IsVisible(522)</visible>
			<include content="AnimationSlideBottomWindow">
				<param name="slide">220</param>
			</include>
			<include content="ViewCoverFlowBottomInfo">
				<param name="logovisible">View522Logo</param>
			</include>
			<include condition="Window.IsVisible(MyVideoNav.xml)">MediaFlagsPanelVideos</include>
			<include condition="Window.IsVisible(MyMusicNav.xml)">MediaFlagsPanelAudio</include>
		</control>

		<!-- Pop-Up Video Player Group -->
		<control type="group">
			<visible>Control.IsVisible(522) + !String.IsEmpty(Window(Home).Property(IsPlayingTrailer))</visible>
			<include>AnimationVideoPreviewPopup400</include>
			<right>50</right>
			<top>120</top>
			<width>700</width>
			<height>800</height>
			<!-- Video Player -->
			<control type="group">
				<width>700</width>
				<height>394</height>
				<control type="image">
					<texture>colors/black.png</texture>
				</control>
				<control type="videowindow">
					<colordiffuse>FFA0A0A0</colordiffuse>
				</control>
				<control type="image">
					<bordersize>-15</bordersize>
					<texture border="20" colordiffuse="$VAR[PanelHighlightColorVar]">thumbs/overlay.png</texture>
				</control>
			</control>
			<!-- Info Panel for Video -->
			<control type="group">
				<top>410</top>
				<control type="image">
					<width>700</width>
					<height>400</height>
					<texture colordiffuse="bb2a2a2a">colors/black.png</texture>
				</control>
				<control type="label">
					<left>20</left>
					<width>660</width>
					<height>90</height>
					<font>Font28_Bold</font>
					<textcolor>ff00aaff</textcolor>
					<shadowcolor>ff000000</shadowcolor>
					<align>left</align>
					<aligny>top</aligny>
					<label>$INFO[ListItem.Title]</label>
					<scroll>true</scroll>
				</control>
				<control type="image">
					<top>90</top>
					<left>20</left>
					<width>660</width>
					<height>4</height>
					<texture colordiffuse="$VAR[PanelListSeparatorColorVar]">panels/separator.png</texture>
				</control>
				<control type="textbox">
					<top>100</top>
					<left>20</left>
					<width>660</width>
					<height>280</height>
					<font>Font28_Reg</font>
					<textcolor>ffcccccc</textcolor>
					<shadowcolor>ff000000</shadowcolor>
					<align>justify</align>
					<label>$INFO[ListItem.Plot]</label>
					<animation effect="scroll" time="20000" delay="5000" end="100%" condition="true" loop="true" reversible="false">Conditional</animation>
				</control>
				<control type="image">
					<top>390</top>
					<left>20</left>
					<width>660</width>
					<height>4</height>
					<texture colordiffuse="$VAR[PanelListSeparatorColorVar]">panels/separator.png</texture>
				</control>
			</control>
		</control>
	</include>
</includes>
