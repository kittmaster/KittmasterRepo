<?xml version="1.0" encoding="utf-8" ?>
<includes>
	<include name="View62Immersive">
		<!-- ============================================================ -->
		<!--  IMMERSIVE — View 062                                        -->
		<!--  Left 75%: massive landscape/fanart art of focused item      -->
		<!--  with clearlogo + meta overlaid                              -->
		<!--  Right 25%: narrow vertical fixedlist of portrait posters   -->
		<!--  Navigation is entirely in the right poster strip            -->
		<!--  The most dramatic single-item focus view in the skin        -->
		<!-- ============================================================ -->

		<!-- Full-bleed dim -->
		<control type="group">
			<visible>Control.IsVisible(62)</visible>
			<include>AnimationVisibleFade</include>
			<include>AnimationWindowFade</include>
			<control type="image">
				<include>FullScreenDimensions</include>
				<texture colordiffuse="77000000">colors/black.png</texture>
			</control>
		</control>

		<!-- ── LEFT: Immersive landscape art panel ── -->
		<control type="group">
			<visible>Control.IsVisible(62)</visible>
			<include content="AnimationSlideLeftWindow">
				<param name="slide">300</param>
			</include>
			<animation type="Conditional" condition="!String.IsEmpty(Window(Home).Property(IsPlayingTrailer))" reversible="true">
				<effect type="slide" end="-680,0" time="400" tween="cubic" easing="out" />
			</animation>

			<!-- Giant landscape art frame -->
			<control type="group">
				<left>0</left>
				<top>55</top>
				<width>1410</width>
				<height>800</height>

				<!-- 1. BASE SHADOW -->
				<control type="image">
					<bordersize>10</bordersize>
					<texture colordiffuse="ff000000" border="10">buttons/thumb-select-focus.png</texture>
				</control>

				<!-- 2. THE INSET GROUP (10px padding on all sides) -->
				<control type="group">
					<left>10</left>
					<top>10</top>
					<right>10</right>
					<bottom>10</bottom>

					<!-- Black base -->
					<control type="image">
						<texture>colors/black.png</texture>
						<aspectratio>stretch</aspectratio>
					</control>

					<!-- Landscape art (Pre-rounded with standard mask) -->
					<control type="image">
						<texture fadetime="400" background="true" diffuse="diffuse/rounded5-543x305.png">$VAR[LandscapeVar]</texture>
						<aspectratio scalediffuse="false">scale</aspectratio>
					</control>

					<!-- Bottom gradient for text legibility -->
					<control type="image">
						<bottom>0</bottom>
						<height>240</height>
						<texture colordiffuse="EE000000">panels/background-gradient.png</texture>
						<aspectratio>stretch</aspectratio>
					</control>

					<!-- Meta strip (Adjusted left by 10px to account for the inset) -->
					<control type="label">
						<left>40</left>
						<bottom>46</bottom>
						<width>800</width>
						<height>28</height>
						<font>Font28_Cond_Bold</font>
						<textcolor>CCffffff</textcolor>
						<shadowcolor>ff000000</shadowcolor>
						<aligny>center</aligny>
						<label>$INFO[ListItem.Year]  ·  $INFO[ListItem.Duration(hh:mm)]$INFO[ListItem.Rating(2),  ·  ,]</label>
					</control>

					<!-- Genre (Adjusted left by 10px to account for the inset) -->
					<control type="label">
						<left>40</left>
						<bottom>18</bottom>
						<width>800</width>
						<height>26</height>
						<font>Font26_Cond_07</font>
						<textcolor>$VAR[PanelHighlightColorVar]</textcolor>
						<shadowcolor>ff000000</shadowcolor>
						<aligny>center</aligny>
						<label>$INFO[ListItem.Genre]</label>
					</control>
				</control>

				<!-- 4. THE OVERLAY FRAME (Drawn at full size, covers the inset content) -->
				<control type="image">
					<texture border="20">thumbs/overlay.png</texture>
				</control>
			</control>
		</control>

		<!-- ── RIGHT: Navigable vertical poster strip ── -->
		<control type="group">
			<visible>Control.IsVisible(62)</visible>
			<include>AnimationZoomWindow</include>
			<include>AnimationZoomVisible</include>

			<!-- Dark background — travels with the zoom group, no gap ever exposed -->
			<control type="image">
				<left>1410</left>
				<top>0</top>
				<width>510</width>
				<height>1080</height>
				<texture colordiffuse="BB000000">colors/black.png</texture>
			</control>

			<!-- 
				Expanded container to fix disc clipping. 
				Original left: 1430, width: 470 
				New left: 1330, width: 570 (provides 100px invisible overflow on the left)
			-->
			<control type="fixedlist" id="62">
				<left>1330</left>
				<top>55</top>
				<width>570</width>
				<height>760</height>
				<onfocus>RunScript(script.skin.madnox, action=trailer_rolling)</onfocus>
				<!-- Global Collection View Sync: backup enforcer fires when list gains focus -->
				<onfocus>RunScript(script.skin.madnox, action=collection_view_sync, mode=focus)</onfocus>
				<onunfocus>RunScript(script.skin.madnox, action=trailer_cleanup)</onunfocus>
				<onleft>9050</onleft>
				<onright>60062</onright>
				<onup>62</onup>
				<ondown>62</ondown>
				<pagecontrol>60062</pagecontrol>
				<focusposition>3</focusposition>
				<include>ContainerScrollTime</include>
				<viewtype label="$LOCALIZE[31533]">bigicon</viewtype>
				<orientation>vertical</orientation>

				<!-- Unfocused poster — small, dimmed -->
				<itemlayout height="154" width="570">
					<control type="group">
						<left>120</left>
						<top>8</top>
						<width>110</width>
						<height>138</height>
						<colordiffuse>77FFFFFF</colordiffuse>
						<include content="ViewArtwork">
							<param name="aspect">scale</param>
							<param name="art">$VAR[PosterVar]</param>
							<param name="texturefadetime">0</param>
							<param name="diffuse">diffuse/rounded5-130x195.png</param>
							<param name="watchedstatusvisible">false</param>
						</include>
					</control>
					<!-- Title next to poster -->
					<control type="label">
						<left>245</left>
						<top>20</top>
						<right>15</right>
						<height>34</height>
						<font>Font28_Reg</font>
						<textcolor>$VAR[PanelTextColorVar]</textcolor>
						<shadowcolor>ff000000</shadowcolor>
						<aligny>center</aligny>
						<label>$INFO[ListItem.Label]</label>
					</control>
					<control type="label">
						<left>245</left>
						<top>58</top>
						<right>15</right>
						<height>26</height>
						<font>Font26_Cond_07</font>
						<textcolor>$VAR[PanelSubTextColorVar]</textcolor>
						<aligny>center</aligny>
						<label>$INFO[ListItem.Year]  ·  $INFO[ListItem.Genre]</label>
					</control>
					<include content="Object_ProgressBar">
						<param name="left" value="120" />
						<param name="right" value="15" />
						<param name="bottom" value="10" />
						<param name="height" value="3" />
					</include>
				</itemlayout>

				<!-- Focused poster — full brightness, highlight -->
				<focusedlayout height="154" width="570">
					<control type="image">
						<left>100</left>
						<width>470</width>
						<texture border="10" colordiffuse="$VAR[PanelHighlightColorVar]">buttons/list-select-focus.png</texture>
					</control>

					<!-- Disc art — slides out LEFT from behind poster on focus -->
					<control type="group">
						<visible>!String.IsEmpty(ListItem.Art(discart))</visible>
						<left>60</left>
						<top>27</top>
						<width>100</width>
						<height>100</height>

						<!-- FOCUS: Distances matched, reversible=false added to stop snapping -->
						<animation effect="slide" start="65,0" end="0,0" time="300" tween="cubic" easing="out" reversible="false">focus</animation>
						<animation effect="fade" start="0" end="100" time="300" reversible="false">focus</animation>

						<!-- UNFOCUS: Distances matched, reversible=false added to stop snapping -->
						<animation effect="slide" start="0,0" end="65,0" time="240" tween="cubic" easing="in" reversible="false">unfocus</animation>
						<animation effect="fade" start="100" end="0" time="240" reversible="false">unfocus</animation>

						<control type="image">
							<texture>$INFO[ListItem.Art(discart)]</texture>
							<aspectratio>keep</aspectratio>
							<include>AnimationDiscArtLibrary</include>
						</control>
					</control>

					<control type="group">
						<left>120</left>
						<top>8</top>
						<width>110</width>
						<height>138</height>
						<include content="ViewArtwork">
							<param name="aspect">scale</param>
							<param name="art">$VAR[PosterVar]</param>
							<param name="texturefadetime">0</param>
							<param name="diffuse">diffuse/rounded5-130x195.png</param>
							<param name="watchedstatusvisible">!Skin.HasSetting(View62DisableWatchedStatus)</param>
						</include>
					</control>
					<control type="label">
						<left>245</left>
						<top>20</top>
						<right>15</right>
						<height>34</height>
						<font>Font28_Bold</font>
						<textcolor>$VAR[PanelFocusTextColorVar]</textcolor>
						<shadowcolor>ff000000</shadowcolor>
						<aligny>center</aligny>
						<label>$INFO[ListItem.Label]</label>
					</control>
					<control type="label">
						<left>245</left>
						<top>58</top>
						<right>15</right>
						<height>26</height>
						<font>Font26_Cond_07</font>
						<textcolor>$VAR[PanelHighlightColorVar]</textcolor>
						<aligny>center</aligny>
						<label>$INFO[ListItem.Year]  ·  $INFO[ListItem.Genre]</label>
					</control>
					<include content="Object_ProgressBar">
						<param name="left" value="120" />
						<param name="right" value="15" />
						<param name="bottom" value="10" />
						<param name="height" value="3" />
					</include>
				</focusedlayout>
			</control>

			<control type="scrollbar" id="60062">
				<right>6</right>
				<top>55</top>
				<bottom>170</bottom>
				<onleft>62</onleft>
				<onright>61301</onright>
			</control>
		</control>
		<!-- Floor -->
		<include content="Floor">
			<param name="visible">Skin.HasSetting(View62HideFloor) + Control.IsVisible(62)</param>
			<param name="highlight">FloorHighlightRight</param>
		</include>

		<!-- Bottom flags bar -->
		<control type="group">
			<visible>Control.IsVisible(62)</visible>
			<include content="AnimationSlideBottomWindow">
				<param name="slide">220</param>
			</include>

			<!-- ========================================================================================= -->
			<!-- RE-ARCHITECTED CLEARLOGO/BANNER/TITLE BLOCKS — Supports banner override and text fallback -->
			<!-- ========================================================================================= -->

			<!-- STATE 1: BANNER OVERRIDE -->
			<control type="group">
				<visible>!ListItem.IsParentFolder + Skin.HasSetting(View62UseBanner) + [!String.IsEmpty(ListItem.Art(banner)) | !String.IsEmpty(ListItem.Art(tvshow.banner))]</visible>
				<animation effect="fade" start="0" end="100" time="480" delay="100">Visible</animation>
				<animation effect="fade" start="100" end="0" time="240">Hidden</animation>
				<left>20</left>
				<bottom>45</bottom>
				<width>1000</width>
				<height>185</height>
				<!-- Scale down to 34% (to match 340px width). Center pinned to absolute Bottom-Left (20, 1080-45). -->
				<animation type="Conditional" condition="true">
					<effect type="zoom" end="34" center="20,1035" time="0" />
				</animation>
				<include content="ViewArtwork">
					<param name="aspect">scale</param>
					<param name="texturefadetime">TextureFadeTime</param>
					<param name="art">$VAR[ClearLogoVar]</param>
					<param name="diffuse">diffuse/rounded5-593x110.png</param>
					<param name="watchedstatusvisible">false</param>
				</include>
			</control>

			<!-- STATE 2: CLEARLOGO -->
			<control type="group">
				<visible>!ListItem.IsParentFolder + [!String.IsEmpty(ListItem.Art(clearlogo)) | !String.IsEmpty(ListItem.Art(tvshow.clearlogo)) | !String.IsEmpty(ListItem.Art(artist.clearlogo))] + ![Skin.HasSetting(View62UseBanner) + [!String.IsEmpty(ListItem.Art(banner)) | !String.IsEmpty(ListItem.Art(tvshow.banner))]]</visible>
				<animation effect="fade" start="0" end="100" time="480" delay="100">Visible</animation>
				<animation effect="fade" start="100" end="0" time="240">Hidden</animation>
				<control type="image">
					<left>20</left>
					<bottom>45</bottom>
					<width>340</width>
					<height>132</height>
					<texture>$VAR[ClearLogoVar]</texture>
					<aspectratio align="left" aligny="center">keep</aspectratio>
					<fadetime>TextureFadeTime</fadetime>
				</control>
			</control>

			<!-- STATE 3: TITLE FALLBACK -->
			<control type="group">
				<visible>!ListItem.IsParentFolder + String.IsEmpty(ListItem.Art(clearlogo)) + String.IsEmpty(ListItem.Art(tvshow.clearlogo)) + String.IsEmpty(ListItem.Art(artist.clearlogo)) + ![Skin.HasSetting(View62UseBanner) + [!String.IsEmpty(ListItem.Art(banner)) | !String.IsEmpty(ListItem.Art(tvshow.banner))]]</visible>
				<animation effect="fade" start="0" end="100" time="480" delay="100">Visible</animation>
				<animation effect="fade" start="100" end="0" time="240">Hidden</animation>
				<control type="label">
					<left>30</left>
					<bottom>28</bottom>
					<width>300</width>
					<height>80</height>
					<font>Font28_Bold</font>
					<!-- <textcolor>ffffffff</textcolor> -->
					<textcolor>$VAR[PanelHighlightColorVar]</textcolor>
					<shadowcolor>ff000000</shadowcolor>
					<align>left</align>
					<aligny>center</aligny>
					<label>$INFO[ListItem.Label]</label>
				</control>
			</control>

			<!-- Title fallback label — shown when no clearlogo -->
			<control type="group">
				<visible>!ListItem.IsParentFolder + String.IsEmpty(ListItem.Art(clearlogo)) + String.IsEmpty(ListItem.Art(tvshow.clearlogo)) + String.IsEmpty(ListItem.Art(artist.clearlogo))</visible>
				<control type="label">
					<left>30</left>
					<bottom>28</bottom>
					<width>300</width>
					<height>80</height>
					<font>Font28_Bold</font>
					<textcolor>ffffffff</textcolor>
					<shadowcolor>ff000000</shadowcolor>
					<align>left</align>
					<aligny>center</aligny>
					<label>$INFO[ListItem.Label]</label>
				</control>
			</control>

			<control type="grouplist">
				<visible>!ListItem.IsParentFolder + [Container.Content(movies) | Container.Content(episodes) | Container.Content(musicvideos)]</visible>
				<bottom>28</bottom>
				<left>50</left>
				<right>50</right>
				<height>80</height>
				<align>center</align>
				<itemgap>20</itemgap>
				<orientation>horizontal</orientation>
				<usecontrolcoords>true</usecontrolcoords>
				<control type="image">
					<visible>!ListItem.IsCollection</visible>
					<bordersize>0,5,0,10</bordersize>
					<texture>$VAR[StudioIconsVar]</texture>
					<include>MediaFlagImage</include>
				</control>
				<control type="image">
					<visible>!ListItem.IsCollection</visible>
					<texture>$VAR[MediaFlagsPathVar]mpaa/$VAR[RatingFlagVar]</texture>
					<include>MediaFlagImage</include>
				</control>
				<control type="image">
					<visible>!String.IsEmpty(ListItem.VideoAspect)</visible>
					<texture>$VAR[MediaFlagsPathVar]videoaspect/$VAR[MediaFlagsPathExpandedAspectRatioVar]$INFO[ListItem.VideoAspect,,.png]</texture>
					<include>MediaFlagImage</include>
				</control>
				<control type="image">
					<visible>!String.IsEmpty(ListItem.VideoCodec)</visible>
					<texture>$VAR[VideoFormatFlagVar]</texture>
					<include>MediaFlagImage</include>
				</control>
				<include>ResolutionFlags</include>
				<control type="image">
					<visible>!String.IsEmpty(ListItem.AudioCodec)</visible>
					<texture>$VAR[AudioCodecFlagVar]</texture>
					<include>MediaFlagImage</include>
				</control>
				<control type="image">
					<visible>!String.IsEmpty(ListItem.AudioChannels)</visible>
					<texture>$VAR[MediaFlagsPathVar]$INFO[ListItem.AudioChannels,audiochannels/,.png]</texture>
					<include>MediaFlagImage</include>
				</control>
				<include>LanguageFlags</include>
				<!-- CC ICON -->
				<control type="image">
					<visible>!String.IsEmpty(ListItem.SubtitleLanguage)</visible>
					<texture>$VAR[MediaFlagsPathVar]cc.png</texture>
					<include>MediaFlagImage</include>
				</control>
				<!-- SUBTITLE LANGUAGES -->
				<include>SubtitleFlags</include>
			</control>
			<control type="grouplist">
				<visible>!ListItem.IsParentFolder + [Container.Content(tvshows) | Container.Content(seasons)]</visible>
				<bottom>28</bottom>
				<left>50</left>
				<right>50</right>
				<height>80</height>
				<align>center</align>
				<itemgap>20</itemgap>
				<orientation>horizontal</orientation>
				<usecontrolcoords>true</usecontrolcoords>
				<control type="image">
					<bordersize>0,5,0,10</bordersize>
					<texture>$VAR[StudioIconsVar]</texture>
					<include>MediaFlagImage</include>
				</control>
				<control type="image">
					<texture>$VAR[MediaFlagsPathVar]mpaa/$VAR[RatingFlagVar]</texture>
					<include>MediaFlagImage</include>
				</control>
				<!-- CC ICON -->
				<control type="image">
					<visible>!String.IsEmpty(ListItem.SubtitleLanguage)</visible>
					<texture>$VAR[MediaFlagsPathVar]cc.png</texture>
					<include>MediaFlagImage</include>
				</control>
				<!-- SUBTITLE LANGUAGES -->
				<include>SubtitleFlags</include>
			</control>
		</control>

		<!-- Trailer popup -->
		<control type="group">
			<visible>Control.IsVisible(62) + !String.IsEmpty(Window(Home).Property(IsPlayingTrailer))</visible>
			<include>AnimationVideoPreviewPopup400</include>
			<right>50</right>
			<top>120</top>
			<width>700</width>
			<height>800</height>
			<control type="group">
				<width>700</width>
				<height>394</height>

				<!-- BASE SHADOW -->
				<control type="image">
					<bordersize>10</bordersize>
					<texture colordiffuse="ff000000" border="10">buttons/thumb-select-focus.png</texture>
				</control>

				<!-- INSET VIDEO -->
				<control type="group">
					<left>10</left>
					<top>10</top>
					<right>10</right>
					<bottom>10</bottom>

					<control type="image">
						<texture>colors/black.png</texture>
					</control>
					<control type="videowindow">
						<colordiffuse>FFA0A0A0</colordiffuse>
					</control>
				</control>

				<!-- OVERLAY FRAME -->
				<control type="image">
					<texture border="20" colordiffuse="$VAR[PanelHighlightColorVar]">thumbs/overlay.png</texture>
				</control>
			</control>
			<control type="group">
				<top>410</top>
				<control type="image">
					<width>700</width>
					<height>400</height>
					<texture colordiffuse="bb2a2a2a">colors/black.png</texture>
				</control>
				<control type="label">
					<left>20</left>
					<width>660</width>
					<height>90</height>
					<font>Font28_Bold</font>
					<textcolor>ff00aaff</textcolor>
					<shadowcolor>ff000000</shadowcolor>
					<align>left</align>
					<aligny>top</aligny>
					<label>$INFO[ListItem.Title]</label>
					<scroll>true</scroll>
				</control>
				<control type="image">
					<top>90</top>
					<left>20</left>
					<width>660</width>
					<height>4</height>
					<texture colordiffuse="$VAR[PanelListSeparatorColorVar]">panels/separator.png</texture>
				</control>
				<control type="textbox">
					<top>100</top>
					<left>20</left>
					<width>660</width>
					<height>280</height>
					<font>Font28_Reg</font>
					<textcolor>ffcccccc</textcolor>
					<shadowcolor>ff000000</shadowcolor>
					<align>justify</align>
					<label>$INFO[ListItem.Plot]</label>
					<animation effect="scroll" time="20000" delay="5000" end="100%" condition="true" loop="true" reversible="false">Conditional</animation>
				</control>
				<control type="image">
					<top>390</top>
					<left>20</left>
					<width>660</width>
					<height>4</height>
					<texture colordiffuse="$VAR[PanelListSeparatorColorVar]">panels/separator.png</texture>
				</control>
			</control>
		</control>
	</include>
</includes>
