<?xml version="1.0" encoding="UTF-8" ?>
<window id="1108">
	<!-- always="true" forces Kodi to constantly seek focus, triggering the exit instantly when the conditions are met -->
	<defaultcontrol always="true">10</defaultcontrol>

	<!-- FAILSAFE: If 5 seconds pass and the video engine completely failed to start, force an exit to Home -->
	<!-- AlarmClock replaces the invalid onend animation attribute approach -->
	<onload>AlarmClock(IntroWaiterFailsafe,ReplaceWindow(1103),00:00:05,true,false)</onload>

	<onunload>CancelAlarm(IntroWaiterFailsafe,true)</onunload>

	<controls>
		<!-- Black background -->
		<control type="image">
			<left>0</left>
			<top>0</top>
			<width>1920</width>
			<height>1080</height>
			<texture>colors/black.png</texture>
		</control>

		<!-- EXIT TRIGGER: Becomes active ONLY after VideoFullScreen has opened and subsequently closed -->
		<control type="button" id="10">
			<left>-1000</left>
			<top>-1000</top>
			<width>1</width>
			<height>1</height>
			<visible>!Window.IsActive(fullscreenvideo) + !String.IsEmpty(Window(Home).Property(IntroStarted))</visible>
			<onfocus>ClearProperty(IntroStarted,Home)</onfocus>
			<onfocus>ReplaceWindow(1103)</onfocus>
		</control>

		<!-- HOLDING PEN: Holds focus quietly while we wait for the video to start, or while it's playing over us -->
		<control type="button" id="11">
			<left>-1000</left>
			<top>-1000</top>
			<width>1</width>
			<height>1</height>
			<visible>String.IsEmpty(Window(Home).Property(IntroStarted)) | Window.IsActive(fullscreenvideo)</visible>
		</control>
	</controls>
</window>
