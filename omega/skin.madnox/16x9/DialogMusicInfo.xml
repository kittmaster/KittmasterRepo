<?xml version="1.0" encoding="utf-8" ?>
<!-- [PHASE 4: MUSIC MODULE - COMPLETED] -->
<window>
	<defaultcontrol always="true">9000</defaultcontrol>
	<onload condition="System.AddonIsEnabled(plugin.video.themoviedb.helper) + Skin.HasSetting(MusicBlurEnabled)">SetProperty(TMDbHelper.Blur.SourceImage,Art(fanart)|Art(tvshow.fanart)|Art(landscape)|Art(thumb)|Icon,Home)</onload>
	<onload condition="System.AddonIsEnabled(plugin.video.themoviedb.helper) + Skin.HasSetting(MusicBlurEnabled)">SetProperty(TMDbHelper.Blur.Fallback,special://home/addons/resource.images.skin.madnox/resources/backgrounds/default_livecases.jpg,Home)</onload>
	<onload condition="System.AddonIsEnabled(plugin.video.themoviedb.helper) + Skin.HasSetting(MusicBlurEnabled)">Skin.SetBool(TMDbHelper.EnableBlur)</onload>
	<onload>SetFocus(9000,0)</onload>
	<controls>
		<!-- BASE TEMPLATE: Backgrounds and Blur -->
		<control type="group">
			<include content="DialogInfo_Base">
				<param name="blur">Skin.HasSetting(MusicBlurEnabled)</param>
			</include>
		</control>

		<!-- Content -->
		<control type="group">
			<include>AnimationInfoDialog</include>
			<include>DialogInfo_Music</include>
		</control>
	</controls>
</window>
