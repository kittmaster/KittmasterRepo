# --- Body texts: top row category selectors (controls 901–904, 905) ---

#: /16x9/includes.xml
msgctxt "#31567"
msgid "Highlight a logo from the palette below and click to assign it to 4K / UHD video files."
msgstr "Theksoni një logo nga paleta më poshtë dhe klikoni për t'ia caktuar skedarëve video 4K / UHD."

#: /16x9/includes.xml
msgctxt "#31568"
msgid "Highlight a logo from the palette below and click to assign it to WebDL and streaming video sources."
msgstr "Theksoni një logo nga paleta më poshtë dhe klikoni për t'ia caktuar burimeve të videove WebDL dhe transmetimeve direkte."

#: /16x9/includes.xml
msgctxt "#31569"
msgid "Highlight a logo from the palette below and click to assign it to 1080p Full HD video files."
msgstr "Theksoni një logo nga paleta më poshtë dhe klikoni për t'ia caktuar skedarëve video 1080p Full HD."

#: /16x9/includes.xml
msgctxt "#31570"
msgid "Highlight a logo from the palette below and click to assign it to 720p HD video files."
msgstr "Theksoni një logo nga paleta më poshtë dhe klikoni për t'ia caktuar skedarëve video 720p HD."

#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "Theksoni një logo nga paleta më poshtë dhe klikoni për t'ia caktuar skedarëve video DVD dhe rezolucionit standard."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "Shfaq vetëm dizajnet e logove 4K dhe ultra-high-definition në rrjetën e paletës."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "Shfaq vetëm dizajnet e logove të kodekut HEVC dhe H.265 në rrjetën e paletës."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Shfaq vetëm dizajnet e logove të kodekut AVC dhe H.264 në rrjetën e paletës."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Shfaq vetëm dizajnet e logove të formateve të vjetra DivX, XviD dhe MPEG-4 në rrjetën e paletës."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Shfaq dizajnet klasike të logove MPEG, DVD dhe transmetimeve standarde televizive në rrjetën e paletës."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Shfaq dizajnet e logove të kodekëve Windows Media Video dhe VC-1 në rrjetën e paletës."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Shfaq dizajnet e logove të kontejnerëve, formateve të disqeve dhe logove të tjera të ndryshme në rrjetën e paletës."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Mbyllni këtë dritare të personalizimit të flamujve dhe kthehuni te cilësimet."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Theksoni çdo dizajn logoje në rrjetën qendrore dhe klikoni për ta ruajtur si flamurin tuaj të personalizuar për kategorinë aktive."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Pastroni zgjedhjen tuaj të personalizuar të flamurit dhe rikthejeni këtë kategori në logjikën automatike të paracaktuar të ndërfaqes."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Ndërroni pamjen globale të flamujve midis dizajneve me ngjyra dhe asaj bardhë e zi parazgjedhur."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Përdorni butonat e drejtimit për të lëvizur nëpër opsione. Shtypni mbrapa ose zgjidhni Dil në çdo kohë për të mbyllur pa ndryshime."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Zgjidhni për të modifikuar"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Personalizimi i ekranit kryesor, widget-eve dhe menusë së shkurtoreve."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Skript për krijuesit e ndërfaqeve për t'u lejuar përdoruesve të zgjedhin një shtesë të burimit të imazhit."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Shton automatikisht imazhe shtesë për mediat në bibliotekat tuaja mediatike."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Tekstet e këngëve për muzikën. Kërkohet për të aktivizuar tekstet e animuara."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Sinkronizoni koleksionin tuaj dhe statusin e të shikuarve me trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Krijoni një të preferuar të personalizuar nga të preferuarat e zgjedhura të Kodi-t."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Ndryshoni menunë e ekranit kryesor, widget-et, sfondet dhe linjat e informacionit."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Riktheni menunë e ekranit kryesor, widget-et, sfondet dhe linjat e informacionit në gjendjen e paracaktuar."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Krijoni një të preferuar të personalizuar nga të preferuarat e zgjedhura të Kodi-t. Për përdorim në widget-et e menusë kryesore. Kërkon që skripti i të preferuarave të jetë i instaluar."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Krijoni një shtesë të preferuar të personalizuar nga shtesat e instaluara. Për përdorim në widget-et e menusë kryesore."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Riktheni temën dhe ngjyrat e ndërfaqes në gjendjen e paracaktuar."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Zgjidhni nga një listë me tema të paradefinuara."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Kyçni preferencat për të çaktivizuar modalitetin e pamjes, opsionet e pamjes, dritaren e informacionit dhe cilësimet e ekranit të plotë."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Personalizoni ekranin kryesor, të preferuarat, temat e paradefinuara dhe modalitetin kioskë."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Ndryshoni teksturat e temës së ndërfaqes."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Personalizoni ngjyrat e teksturës së ndërfaqes."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Personalizoni sfondin dhe rezervat për zona të specifikuara të ndërfaqes."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Aktivizoni ose çaktivizoni veçori të ndryshme të ndërfaqes."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Personalizoni imazhet e artit dhe instaloni paketa të mbështetura të imazheve."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Instaloni dhe konfiguroni shtesat e mbështetura."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Aktivizoni dhe çaktivizoni pamjet e bibliotekës. Çaktivizimi i pamjeve të bibliotekës në sisteme me specifika të ulëta mund të përmirësojë performancën."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Shfaq shkronjën e lëvizjes gjatë rrëshqitjes në pamjet e bibliotekës."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Shfaq alfabetin për të kaluar në një pozicion të caktuar të kontejnerit. Do të funksionojë vetëm për metodat e paracaktuara të renditjes (A-Z)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Shfaq përmbledhjen e shkurtër të subjektit (plot outline) për serialet dhe filmat nëse është e disponueshme, përndryshe do të shfaqet subjekti i paracaktuar."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Lëviz automatikisht subjektin nëse nuk përshtatet me përmasat e kontrollit."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Aktivizoni menunë e shkurtoreve për qasje të menjëhershme në zona të specifikuara të ndërfaqes. Në menunë e medias klikoni majtas për të hapur ose klikoni te ikona e shkurtores."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Ndrysho menunë e shkurtoreve."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Aktivizoni dhe çaktivizoni elementet e shiritit të sipërm."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Ndryshoni cilësimet e informacionit të videos."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Ndryshoni cilësimet e informacionit të muzikës."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Ndryshoni cilësimet e videos në ekran të plotë."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Ndryshoni cilësimet e audios në ekran të plotë."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Zvogëloni madhësinë e njoftimeve kërcyese."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Erreson ekranin pas dritareve të dialogut kërcyes. Nuk zbatohet për video ose audio në ekran të plotë."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Aktivizoni ikonat me ngjyra për shiritit e sipërm, informacionin e medias dhe pamjet e bibliotekës."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Aktivizoni flamujt mediatikë me ngjyra, HDR, thellësi ngjyre dhe gjuhë."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Imazhi rezervë i artit të CD-së audio në të gjithë ndërfaqen."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Imazhi rezervë i artit të CD-së video në të gjithë ndërfaqen."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Zgjidhni dhe instaloni një paketë ikonash të motit për shiritin e sipërm, widget-et dhe motin."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Zgjidhni dhe instaloni një paketë imazhesh fanart të motit për sfondet, widget-et dhe motin."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Instaloni ikona të bardha të studiove për t'u përdorur në të gjithë ndërfaqen."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Instaloni ikona me ngjyra të studiove për t'u përdorur në të gjithë ndërfaqen."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Instaloni ikonat e studiove diskografike për t'u përdorur në të gjithë ndërfaqen."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Instaloni flamujt e gjuhëve për pamjet e bibliotekës dhe përzgjedhjen e titrave."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Instaloni ikonat e zhanreve muzikore për muzikën dhe videoklipet."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Instaloni ikona me ngjyra të zhanreve të filmave për filmat dhe serialet TV."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Instaloni ikona bardh e zi të zhanreve të filmave për filmat dhe serialet TV."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Instaloni ikonat e shteteve për nyjen e shtetit të filmave."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Vendosni vonesën midis tranzicioneve të fanart-it në të gjithë ndërfaqen."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Efektet e sfondit me rënie. Dëborë, gjethe etj."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Shfaq imazhet fanart të muzikës për artikullin që po luhet aktualisht në të gjithë ndërfaqen. Zëvendëson fanart-in e bibliotekës."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Aktivizon vizualizimin e muzikës në sfond ndërsa luhet muzika. Kërkon që vizualizimi të jetë i aktivizuar te Cilësimet - Cilësimet e luajtësit/Muzika."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Shfaq videon që po luhet aktualisht në sfond ndërsa shfletoni bibliotekën. Zëvendëson fanart-in e bibliotekës."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Shkarkoni imazhe dhe informacione shtesë nga fanart.tv dhe theaudiodb.com për artistin që po luhet aktualisht. Për muzikën në ekran të plotë, transmetimet në internet dhe radion."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Cilësimet e skriptit të prezantimit të artistit (Artist slideshow)."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "Një shkurtore për te lista e dëgjimit të videove nëse nuk është bosh."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "Një shkurtore për te lista e dëgjimit të muzikës nëse nuk është bosh."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Shkurtore për në ekran të plotë kur media është duke u luajtur."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Klikoni për të hapur menunë e shkurtoreve."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Kontrollet e luajtësit kur media është duke u luajtur."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Luaj automatikisht episodin e ardhshëm të serialit."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Luaj temat muzikore (themes) gjatë lëvizjes te Serialet TV, Filmat dhe Videoklipet."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "Library Node Editor ju lejon të krijoni dhe personalizoni nyjat e personalizuara të videove dhe muzikës brenda Kodi-t."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Shfaq informacionin e markuesit mbivendosës për artikujt mediatikë të shikuar, të pashikuar dhe në progres."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Një skript për të redaktuar shiritin RSS të integruar në Kodi."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Versioni i ndërfaqes dhe opsionet e rikuperimit. Rikthen të gjitha vlerat e parazgjedhura në gjendjen e ditës së parë të punës."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Shtesat"