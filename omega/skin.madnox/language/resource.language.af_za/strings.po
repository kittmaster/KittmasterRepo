#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "Verlig 'n logo op die palet hieronder en klik om dit aan DVD- en standaard-definisie-videolêers toe te wys."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "Wys slegs ultra-hoë-definisie en 4K-logo-ontwerpe op die paletrooster."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "Wys slegs HEVC- en H.265-kodek-logo-ontwerpe op die paletrooster."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Wys slegs AVC- en H.264-kodek-logo-ontwerpe op die paletrooster."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Wys slegs DivX-, XviD- en ouer MPEG-4-formaat-logo-ontwerpe op die paletrooster."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Wys klassieke MPEG-, DVD- en standaard TV-uitsending-logo-ontwerpe op die paletrooster."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Wys Windows Media Video- en VC-1-kodek-logo-ontwerpe op die paletrooster."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Wys houer-omslae, skyf-formate en ander diverse logo-ontwerpe op die paletrooster."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Sluit hierdie vlag-pasmakingsdialoog en keer terug na instellings."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Verlig enige logo-ontwerp op die middelste rooster en klik om dit te stoor as jou pasgemaakte vlag vir die aktiewe kategorie."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Vee jou pasgemaakte vlagkeuse uit en herstel hierdie kategorie na die vel se outomatiese verstekvlag-logika."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Wissel globale vlag-kunswerk tussen gekleurde ontwerpe en monochromatiese verstek-wit."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Gebruik jou rigtingsleutels om deur opsies te navigeer. Druk Terug of kies Verlaat op enige tydstip om sonder veranderinge te sluit."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Kies om te wysig"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Pasmaking van die tuisskerm, widgets en kortpaaie-kieslys."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Skrip vir vel-ontwerpers om gebruikers 'n beeldhulpbronbyvoeging te laat kies."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Voeg outomaties ekstra kunswerk by vir media in u mediabiblioteke."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Lirieke vir musiek. Vereis om geanimeerde lirieke te aktiveer."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Sinkroniseer u versameling en gekyk-status met trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Skep 'n pasgemaakte gunsteling uit gekose kodi-gunstelinge."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Wysig die tuisskermkieslys, widgets, agtergronde en inligtingslyne."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Herstel die tuisskermkieslys, widgets, agtergronde en inligtingslyne na verstek."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Skep 'n pasgemaakte gunsteling uit gekose kodi-gunstelinge. Vir gebruik in hoofkieslys-widgets. Vereis dat skrip-gunstelinge geïnstalleer is."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Skep 'n pasgemaakte byvoeging-gunsteling uit geïnstalleerde byvoegings. Vir gebruik in hoofkieslys-widgets."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Herstel die veltema en kleure na verstek."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Kies uit 'n lys vooraf-gedefinieerde temas."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Sluit voorkeure om weergavemodus, weergave-opsies, inligtingsdialoog en volskerm-instellings te deaktiveer."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Pasmaak die tuisskerm, gunstelinge, vooraf-gedefinieerde temas en kiosk-modus."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Verander veltema-teksture."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Pasmaak die veltekstuurkleure."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Pasmaak die agtergrond en terugvalle vir spesifieke vel-areas."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Aktiveer of deaktiveer verskeie vel-kenmerke."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Pasmaak kunswerk en installeer ondersteunde kunswerkpakke."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Installeer en stel ondersteunde byvoegings op."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Aktiveer en deaktiveer biblioteekweergawes. Die deaktivering van biblioteekweergawes op lae-spesifikasie stelsels kan prestasie verbeter."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Wys rol-letter wanneer u in biblioteekweergawes rol."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Wys die alfabet om na 'n posisie van die houer te spring. Sal slegs werk vir verstek-sorteringsmetodes (A-Z)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Wys storielyn-oorsig vir TV-programme en flieks indien beskikbaar, andersins sal dit die verstek-storielyn wys."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Outorol die storielyn as dit nie by die beheerdimensies pas nie."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Aktiveer die kortpad-kieslys vir onmiddellike toegang tot spesifieke vel-areas. Klik links in die media-kieslys om oop te maak of klik op die kortpad-ikoon."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Wysig die kortpad-kieslys."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Aktiveer en deaktiveer die boonste balk-elemente."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Verander video-inligtingsinstellings."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Verander musiekinligtingsinstellings."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Verander volskerm-videoinstellings."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Verander volskerm-oudioinstellings."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Verminder die grootte van opspring-kennisgewings."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Verdonker die skerm agter dialoog-opspringers. Nie van toepassing op volskerm-video of -oudio nie."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Aktiveer gekleurde ikone vir die boonste balk, media-inligting en biblioteekweergawes."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Aktiveer gekleurde, HDR-, bitdiepte- en taal-mediavlae."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Oudio-CD-kuns terugval velwyd."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Video-CD-kuns terugval velwyd."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Kies en installeer 'n weer-ikoonsubpak vir die boonste balk, widgets en weer."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Kies en installeer 'n weer-aanhangerkuns-pak vir die agtergronde, widgets en weer."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Installeer wit ateljee-ikone vir gebruik regoor die vel."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Installeer gekleurde ateljee-ikone vir gebruik regoor die vel."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Installeer platemaatskappy-ikone vir gebruik regoor die vel."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Installeer taalvlae vir biblioteekweergawes and onderskrifkeuse."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Installeer musiekgenre-ikone vir musiek en musiekvideo's."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Installeer gekleurde fliekgenre-ikone vir flieks en TV-programme."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Installeer swart-en-wit fliekgenre-ikone vir flieks en TV-programme."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Installeer lande-ikone vir flieks se land-nodus."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Stel die vertraging tussen aanhangerkuns-oorgange velwyd in."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Vallende agtergrondeffekte. Sneeu, blare ens."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Wys musiek-aanhangerkuns van tans speelende item velwyd. Slaan biblioteek-aanhangerkuns oor."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Aktiveer musiek-visualisering in agtergrond terwyl musiek gespeel word. Vereis dat visualisering geaktiveer is in instellings - Spelerinstellings/Musiek."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Wys tans speelende video in agtergrond terwyl biblioteek deurblaai word. Slaan biblioteek-aanhangerkuns oor."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Laai prente en bykomende inligting af vanaf fanart.tv en theaudiodb.com van die tans speelende kunstenaar. Vir volskerm-musiek, internetstrome en radio."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Kunstenaar-skyfievertoning skripinstellings."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "'n Kortpad na die video-snitlys indien nie leeg nie."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "'n Kortpad na die musiek-snitlys indien nie leeg nie."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Kortpad na volskerm wanneer media speel."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Klik om kortpad-kieslys oop te maak."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Spelerkontroles wanneer media speel."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Speel die volgende TV-program episode outomaties."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Speel temas terwyl daar deur TV-programme, flieks en musiekvideo's genavigeer word."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "Die Biblioteek-nodusredigeerder laat jou toe om gepasmaakte video- en musieknodusse binne Kodi te skep en te pasmaak."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Wys oorlegmerker-inligting vir gekykte, ongekykte en tans besige media-items."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "'n Skrip vir die wysiging van Kodi se ingeboude RSS-rolbalk."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Vel-weergawe en herstelopsies. Herstel alle verstekinstellings na dag een werking."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Byvoegings"