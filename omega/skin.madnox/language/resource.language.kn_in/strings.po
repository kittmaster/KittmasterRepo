# --- Body texts: top row category selectors (controls 901–904, 905) ---

#: /16x9/includes.xml
msgctxt "#31567"
msgid "Highlight a logo from the palette below and click to assign it to 4K / UHD video files."
msgstr "ಕೆಳಗಿನ ಪ್ಯಾಲೆಟ್‌ನಿಂದ ಲೋಗೋವನ್ನು ಹೈಲೈಟ್ ಮಾಡಿ ಮತ್ತು ಅದನ್ನು 4K / UHD ವಿಡಿಯೋ ಫೈಲ್‌ಗಳಿಗೆ ನಿಯೋಜಿಸಲು ಕ್ಲಿಕ್ ಮಾಡಿ."

#: /16x9/includes.xml
msgctxt "#31568"
msgid "Highlight a logo from the palette below and click to assign it to WebDL and streaming video sources."
msgstr "ಕೆಳಗಿನ ಪ್ಯಾಲೆಟ್‌ನಿಂದ ಲೋಗೋವನ್ನು ಹೈಲೈಟ್ ಮಾಡಿ ಮತ್ತು ಅದನ್ನು WebDL ಮತ್ತು ಸ್ಟ್ರೀಮಿಂಗ್ ವಿಡಿಯೋ ಮೂಲಗಳಿಗೆ ನಿಯೋಜಿಸಲು ಕ್ಲಿಕ್ ಮಾಡಿ."

#: /16x9/includes.xml
msgctxt "#31569"
msgid "Highlight a logo from the palette below and click to assign it to 1080p Full HD video files."
msgstr "ಕೆಳಗಿನ ಪ್ಯಾಲೆಟ್‌ನಿಂದ ಲೋಗೋವನ್ನು ಹೈಲೈಟ್ ಮಾಡಿ ಮತ್ತು ಅದನ್ನು 1080p ಫುಲ್ ಹೆಚ್‌ಡಿ ವಿಡಿಯೋ ಫೈಲ್‌ಗಳಿಗೆ ನಿಯೋಜಿಸಲು ಕ್ಲಿಕ್ ಮಾಡಿ."

#: /16x9/includes.xml
msgctxt "#31570"
msgid "Highlight a logo from the palette below and click to assign it to 720p HD video files."
msgstr "ಕೆಳಗಿನ ಪ್ಯಾಲೆಟ್‌ನಿಂದ ಲೋಗೋವನ್ನು ಹೈಲೈಟ್ ಮಾಡಿ ಮತ್ತು ಅದನ್ನು 720p ಹೆಚ್‌ಡಿ ವಿಡಿಯೋ ಫೈಲ್‌ಗಳಿಗೆ ನಿಯೋಜಿಸಲು ಕ್ಲಿಕ್ ಮಾಡಿ."

#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "ಕೆಳಗಿನ ಪ್ಯಾಲೆಟ್‌ನಿಂದ ಲೋಗೋವನ್ನು ಹೈಲೈಟ್ ಮಾಡಿ ಮತ್ತು ಅದನ್ನು ಡಿವಿಡಿ ಮತ್ತು ಸ್ಟ್ಯಾಂಡರ್ಡ್-ಡೆಫಿನಿಷನ್ ವಿಡಿಯೋ ಫೈಲ್‌ಗಳಿಗೆ ನಿಯೋಜಿಸಲು ಕ್ಲಿಕ್ ಮಾಡಿ."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "ಪ್ಯಾಲೆಟ್ ಗ್ರಿಡ್‌ನಲ್ಲಿ ಅಲ್ಟ್ರಾ-ಹೈ-ಡೆಫಿನಿಷನ್ ಮತ್ತು 4K ಲೋಗೋ ವಿನ್ಯಾಸಗಳನ್ನು ಮಾತ್ರ ವೀಕ್ಷಿಸಿ."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "ಪ್ಯಾಲೆಟ್ ಗ್ರಿಡ್‌ನಲ್ಲಿ HEVC ಮತ್ತು H.265 ಕೊಡೆಕ್ ಲೋಗೋ ವಿನ್ಯಾಸಗಳನ್ನು ಮಾತ್ರ ವೀಕ್ಷಿಸಿ."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "ಪ್ಯಾಲೆಟ್ ಗ್ರಿಡ್‌ನಲ್ಲಿ AVC ಮತ್ತು H.264 ಕೊಡೆಕ್ ಲೋಗೋ ವಿನ್ಯಾಸಗಳನ್ನು ಮಾತ್ರ ವೀಕ್ಷಿಸಿ."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "ಪ್ಯಾಲೆಟ್ ಗ್ರಿಡ್‌ನಲ್ಲಿ DivX, XviD ಮತ್ತು ಹಳೆಯ MPEG-4 ಸ್ವರೂಪದ ಲೋಗೋ ವಿನ್ಯಾಸಗಳನ್ನು ಮಾತ್ರ ವೀಕ್ಷಿಸಿ."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "ಪ್ಯಾಲೆಟ್ ಗ್ರಿಡ್‌ನಲ್ಲಿ ಕ್ಲಾಸಿಕ್ MPEG, DVD ಮತ್ತು ಸಾಮಾನ್ಯ ಟಿವಿ ಪ್ರಸಾರ ಲೋಗೋ ವಿನ್ಯಾಸಗಳನ್ನು ಮಾತ್ರ ವೀಕ್ಷಿಸಿ."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "ಪ್ಯಾಲೆಟ್ ಗ್ರಿಡ್‌ನಲ್ಲಿ Windows Media Video ಮತ್ತು VC-1 ಕೊಡೆಕ್ ಲೋಗೋ ವಿನ್ಯಾಸಗಳನ್ನು ಮಾತ್ರ ವೀಕ್ಷಿಸಿ."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "ಪ್ಯಾಲೆಟ್ ಗ್ರಿಡ್‌ನಲ್ಲಿ ಕಂಟೈನರ್ ರಾಪರ್‌ಗಳು, ಡಿಸ್ಕ್ ಫಾರ್ಮ್ಯಾಟ್‌ಗಳು ಮತ್ತು ಇತರ ವಿವಿಧ ಲೋಗೋ ವಿನ್ಯಾಸಗಳನ್ನು ವೀಕ್ಷಿಸಿ."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "ಈ ಧ್ವಜ ಕಸ್ಟಮೈಸೇಶನ್ ಸಂವಾದವನ್ನು ಮುಚ್ಚಿ ಮತ್ತು ಸೆಟ್ಟಿಂಗ್ಸ್‌ಗೆ ಹಿಂತಿರುಗಿ."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "ಮಧ್ಯದ ಗ್ರಿಡ್‌ನಲ್ಲಿರುವ ಯಾವುದೇ ಲೋಗೋ ವಿನ್ಯಾಸವನ್ನು ಹೈಲೈಟ್ ಮಾಡಿ ಮತ್ತು ಸಕ್ರಿಯ ವರ್ಗಕ್ಕಾಗಿ ಅದನ್ನು ನಿಮ್ಮ ಕಸ್ಟಮ್ ಧ್ವಜವಾಗಿ ಉಳಿಸಲು ಕ್ಲಿಕ್ ಮಾಡಿ."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "ನಿಮ್ಮ ಕಸ್ಟಮ್ ಧ್ವಜದ ಆಯ್ಕೆಯನ್ನು ತೆರವುಗೊಳಿಸಿ ಮತ್ತು ಈ ವರ್ಗವನ್ನು ಸ್ಕಿನ್‌ನ ಸ್ವಯಂಚಾಲಿತ ಡೀಫಾಲ್ಟ್ ಧ್ವಜ ತರ್ಕಕ್ಕೆ ಮರುಸ್ಥಾಪಿಸಿ."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "ಜಾಗತಿಕ ಧ್ವಜ ಕಲಾಕೃತಿಯನ್ನು ಬಣ್ಣದ ವಿನ್ಯಾಸಗಳು ಮತ್ತು ಏಕವರ್ಣದ ಡೀಫಾಲ್ಟ್ ಬಿಳಿ ಬಣ್ಣದ ನಡುವೆ ಟಾಗಲ್ ಮಾಡಿ."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "ಆಯ್ಕೆಗಳನ್ನು ನ್ಯಾವಿಗೇಟ್ ಮಾಡಲು ನಿಮ್ಮ ಡೈರೆಕ್ಷನಲ್ ಕೀಗಳನ್ನು ಬಳಸಿ. ಯಾವುದೇ ಸಮಯದಲ್ಲಿ ಬದಲಾವಣೆಗಳಿಲ್ಲದೆ ಮುಚ್ಚಲು ಹಿಂದಕ್ಕೆ ಒತ್ತಿರಿ ಅಥವಾ ನಿರ್ಗಮನವನ್ನು ಆರಿಸಿ."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "ಮಾರ್ಪಡಿಸಲು ಆಯ್ಕೆಮಾಡಿ"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "ಹೋಮ್ ಸ್ಕ್ರೀನ್, ವಿಜೆಟ್‌ಗಳು ಮತ್ತು ಶಾರ್ಟ್‌ಕಟ್‌ಗಳ ಮೆನುವಿನ ಕಸ್ಟಮೈಸೇಶನ್."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "ಬಳಕೆದಾರರಿಗೆ ಇಮೇಜ್ ರಿಸೋರ್ಸ್ ಆಡ್-ಆನ್ ಆಯ್ಕೆ ಮಾಡಲು ಸಹಾಯ ಮಾಡುವ ಸ್ಕಿನ್ ತಯಾರಕರ ಸ್ಕ್ರಿಪ್ಟ್."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "ನಿಮ್ಮ ಮಾಧ್ಯಮ ಲೈಬ್ರರಿಗಳಲ್ಲಿನ ಮಾಧ್ಯಮಕ್ಕಾಗಿ ಹೆಚ್ಚುವರಿ ಕಲಾಕೃತಿಯನ್ನು ಸ್ವಯಂಚಾಲಿತವಾಗಿ ಸೇರಿಸುತ್ತದೆ."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "ಸಂಗೀತಕ್ಕಾಗಿ ಸಾಹಿತ್ಯ. ಅನಿಮೇಟೆಡ್ ಸಾಹಿತ್ಯವನ್ನು ಸಕ್ರಿಯಗೊಳಿಸಲು ಅಗತ್ಯವಿದೆ."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "ನಿಮ್ಮ ಸಂಗ್ರಹಣೆ ಮತ್ತು ವೀಕ್ಷಿಸಿದ ಸ್ಥಿತಿಯನ್ನು trakt.tv ನೊಂದಿಗೆ ಸಿಂಕ್ ಮಾಡಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "ಆಯ್ಕೆಮಾಡಿದ ಕೋಡಿ ನೆಚ್ಚಿನವುಗಳಿಂದ ಕಸ್ಟಮ್ ನೆಚ್ಚಿನದನ್ನು ರಚಿಸಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "ಹೋಮ್ ಸ್ಕ್ರೀನ್ ಮೆನು, ವಿಜೆಟ್‌ಗಳು, ಹಿನ್ನೆಲೆಗಳು ಮತ್ತು ಮಾಹಿತಿ ಸಾಲುಗಳನ್ನು ಸಂಪಾದಿಸಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "ಹೋಮ್ ಸ್ಕ್ರೀನ್ ಮೆನು, ವಿಜೆಟ್‌ಗಳು, ಹಿನ್ನೆಲೆಗಳು ಮತ್ತು ಮಾಹಿತಿ ಸಾಲುಗಳನ್ನು ಡೀಫಾಲ್ಟ್‌ಗೆ ಮರುಹೊಂದಿಸಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "ಆಯ್ಕೆಮಾಡಿದ ಕೋಡಿ ನೆಚ್ಚಿನವುಗಳಿಂದ ಕಸ್ಟಮ್ ನೆಚ್ಚಿನದನ್ನು ರಚಿಸಿ. ಮುಖ್ಯ ಮೆನು ವಿಜೆಟ್‌ಗಳಲ್ಲಿ ಬಳಸಲು. ನೆಚ್ಚಿನವುಗಳ ಸ್ಕ್ರಿಪ್ಟ್ ಸ್ಥಾಪಿಸುವ ಅಗತ್ಯವಿದೆ."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "ಸ್ಥಾಪಿಸಲಾದ ಆಡ್-ಆನ್‌ಗಳಿಂದ ಕಸ್ಟಮ್ ಆಡ್-ಆನ್ ನೆಚ್ಚಿನದನ್ನು ರಚಿಸಿ. ಮುಖ್ಯ ಮೆನು ವಿಜೆಟ್‌ಗಳಲ್ಲಿ ಬಳಸಲು."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "ಸ್ಕಿನ್ ಥೀಮ್ ಮತ್ತು ಬಣ್ಣಗಳನ್ನು ಡೀಫಾಲ್ಟ್‌ಗೆ ಮರುಹೊಂದಿಸಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "ಮೊದಲೇ ವ್ಯಾಖ್ಯಾನಿಸಲಾದ ಥೀಮ್‌ಗಳ ಪಟ್ಟಿಯಿಂದ ಆಯ್ಕೆಮಾಡಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "ವೀಕ್ಷಣೆ ಮೋಡ್, ವೀಕ್ಷಣೆ ಆಯ್ಕೆಗಳು, ಮಾಹಿತಿ ಸಂವಾದ ಮತ್ತು ಪೂರ್ಣಪರದೆ ಸೆಟ್ಟಿಂಗ್‌ಗಳನ್ನು ನಿಷ್ಕ್ರಿಯಗೊಳಿಸಲು ಆದ್ಯತೆಗಳನ್ನು ಲಾಕ್ ಮಾಡಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "ಹೋಮ್ ಸ್ಕ್ರೀನ್, ನೆಚ್ಚಿನವುಗಳು, ಪೂರ್ವನಿರ್ಧರಿತ ಥೀಮ್‌ಗಳು ಮತ್ತು ಕಿಯೋಸ್ಕ್ ಮೋಡ್ ಅನ್ನು ಕಸ್ಟಮೈಸ್ ಮಾಡಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "ಸ್ಕಿನ್ ಥೀಮ್ ಟೆಕ್ಸ್ಚರ್‌ಗಳನ್ನು ಬದಲಾಯಿಸಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "ಸ್ಕಿನ್ ಟೆಕ್ಸ್ಚರ್ ಬಣ್ಣಗಳನ್ನು ಕಸ್ಟಮೈಸ್ ಮಾಡಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "ನಿರ್ದಿಷ್ಟ ಸ್ಕಿನ್ ಪ್ರದೇಶಗಳಿಗಾಗಿ ಹಿನ್ನೆಲೆ ಮತ್ತು ಫಾಲ್‌ಬ್ಯಾಕ್‌ಗಳನ್ನು ಕಸ್ಟಮೈಸ್ ಮಾಡಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "ವಿವಿಧ ಸ್ಕಿನ್ ವೈಶಿಷ್ಟ್ಯಗಳನ್ನು ಸಕ್ರಿಯಗೊಳಿಸಿ ಅಥವಾ ನಿಷ್ಕ್ರಿಯಗೊಳಿಸಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "ಕಲಾಕೃತಿಯನ್ನು ಕಸ್ಟಮೈಸ್ ಮಾಡಿ ಮತ್ತು ಬೆಂಬಲಿತ ಕಲಾಕೃತಿ ಪ್ಯಾಕ್‌ಗಳನ್ನು ಸ್ಥಾಪಿಸಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "ಬೆಂಬಲಿತ ಆಡ್-ಆನ್‌ಗಳನ್ನು ಸ್ಥಾಪಿಸಿ ಮತ್ತು ಕಾನ್ಫಿಗರ್ ಮಾಡಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "ಲೈಬ್ರರಿ ವೀಕ್ಷಣೆಗಳನ್ನು ಸಕ್ರಿಯಗೊಳಿಸಿ ಮತ್ತು ನಿಷ್ಕ್ರಿಯಗೊಳಿಸಿ. ಕಡಿಮೆ ಸಾಮರ್ಥ್ಯದ ಸಿಸ್ಟಂಗಳಲ್ಲಿ ಲೈಬ್ರರಿ ವೀಕ್ಷಣೆಗಳನ್ನು ನಿಷ್ಕ್ರಿಯಗೊಳಿಸುವುದರಿಂದ ಕಾರ್ಯಕ್ಷಮತೆ ಸುಧಾರಿಸಬಹುದು."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "ಲೈಬ್ರರಿ ವೀಕ್ಷಣೆಗಳಲ್ಲಿ ಸ್ಕ್ರಾಲ್ ಮಾಡುವಾಗ ಸ್ಕ್ರಾಲ್ ಅಕ್ಷರವನ್ನು ತೋರಿಸುತ್ತದೆ."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "ಕಂಟೈನರ್‌ನ ಸ್ಥಾನಕ್ಕೆ ಜಂಪ್ ಮಾಡಲು ವರ್ಣಮಾಲೆಯನ್ನು ತೋರಿಸುತ್ತದೆ. ಇದು ಡೀಫಾಲ್ಟ್ ವಿಂಗಡಣೆ ವಿಧಾನಗಳಿಗೆ (A-Z) ಮಾತ್ರ ಕಾರ್ಯನಿರ್ವಹಿಸುತ್ತದೆ."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "ಟಿವಿ ಶೋಗಳು ಮತ್ತು ಚಲನಚಿತ್ರಗಳಿಗೆ ಲಭ್ಯವಿದ್ದರೆ ಕಥೆಯ ರೂಪರೇಖೆಯನ್ನು ತೋರಿಸುತ್ತದೆ, ಇಲ್ಲದಿದ್ದರೆ ಡೀಫಾಲ್ಟ್ ಕಥೆಯನ್ನು ಪ್ರದರ್ಶಿಸುತ್ತದೆ."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "ಕಥೆಯು ನಿಯಂತ್ರಣ ಆಯಾಮಗಳಿಗೆ ಹೊಂದಿಕೆಯಾಗದಿದ್ದರೆ ಅದನ್ನು ಸ್ವಯಂಚಾಲಿತವಾಗಿ ಸ್ಕ್ರಾಲ್ ಮಾಡಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "ನಿರ್ದಿಷ್ಟ ಸ್ಕಿನ್ ಪ್ರದೇಶಗಳಿಗೆ ತ್ವರಿತ ಪ್ರವೇಶಕ್ಕಾಗಿ ಶಾರ್ಟ್‌ಕಟ್ ಮೆನುವನ್ನು ಸಕ್ರಿಯಗೊಳಿಸಿ. ಮಾಧ್ಯಮ ಮೆನುವಿನಲ್ಲಿ ತೆರೆಯಲು ಎಡಕ್ಕೆ ಕ್ಲಿಕ್ ಮಾಡಿ ಅಥವಾ ಶಾರ್ಟ್‌ಕಟ್ ಐಕಾನ್ ಮೇಲೆ ಕ್ಲಿಕ್ ಮಾಡಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "ಶಾರ್ಟ್‌ಕಟ್ ಮೆನುವನ್ನು ಸಂಪಾದಿಸಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "ಮೇಲಿನ ಪಟ್ಟಿಯ ಅಂಶಗಳನ್ನು ಸಕ್ರಿಯಗೊಳಿಸಿ ಮತ್ತು ನಿಷ್ಕ್ರಿಯಗೊಳಿಸಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "ವಿಡಿಯೋ ಮಾಹಿತಿ ಸೆಟ್ಟಿಂಗ್‌ಗಳನ್ನು ಬದಲಾಯಿಸಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "ಸಂಗೀತ ಮಾಹಿತಿ ಸೆಟ್ಟಿಂಗ್‌ಗಳನ್ನು ಬದಲಾಯಿಸಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "ಪೂರ್ಣಪರದೆ ವಿಡಿಯೋ ಸೆಟ್ಟಿಂಗ್‌ಗಳನ್ನು ಬದಲಾಯಿಸಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "ಪೂರ್ಣಪರದೆ ಆಡಿಯೋ ಸೆಟ್ಟಿಂಗ್‌ಗಳನ್ನು ಬದಲಾಯಿಸಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "ಪಾಪ್ ಅಪ್ ಅಧಿಸೂಚನೆಗಳ ಗಾತ್ರವನ್ನು ಕಡಿಮೆ ಮಾಡಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "ಸಂವಾದ ಪಾಪ್‌ಅಪ್‌ಗಳ ಹಿಂದಿನ ಪರದೆಯನ್ನು ಕಪ್ಪಾಗಿಸುತ್ತದೆ. ಪೂರ್ಣಪರದೆ ವಿಡಿಯೋ ಅಥವಾ ಆಡಿಯೋಗೆ ಅನ್ವಯಿಸುವುದಿಲ್ಲ."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "ಮೇಲಿನ ಪಟ್ಟಿ, ಮಾಧ್ಯಮ ಮಾಹಿತಿ ಮತ್ತು ಲೈಬ್ರರಿ ವೀಕ್ಷಣೆಗಳಿಗಾಗಿ ಬಣ್ಣದ ಐಕಾನ್‌ಗಳನ್ನು ಸಕ್ರಿಯಗೊಳಿಸಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "ಬಣ್ಣದ, HDR, ಬಿಟ್ ಡೆಪ್ತ್ ಮತ್ತು ಭಾಷೆಯ ಮಾಧ್ಯಮ ಧ್ವಜಗಳನ್ನು ಸಕ್ರಿಯಗೊಳಿಸಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "ಸ್ಕಿನ್‌ನಾದ್ಯಂತ ಆಡಿಯೋ ಸಿಡಿ ಆರ್ಟ್ ಫಾಲ್‌ಬ್ಯಾಕ್."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "ಸ್ಕಿನ್‌ನಾದ್ಯಂತ ವಿಡಿಯೋ ಸಿಡಿ ಆರ್ಟ್ ಫಾಲ್‌ಬ್ಯಾಕ್."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "ಮೇಲಿನ ಪಟ್ಟಿ, ವಿಜೆಟ್‌ಗಳು ಮತ್ತು ಹವಾಮಾನಕ್ಕಾಗಿ ಹವಾಮಾನ ಐಕಾನ್ ಪ್ಯಾಕ್ ಅನ್ನು ಆಯ್ಕೆಮಾಡಿ ಮತ್ತು ಸ್ಥಾಪಿಸಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "ಹಿನ್ನೆಲೆಗಳು, ವಿಜೆಟ್‌ಗಳು ಮತ್ತು ಹವಾಮಾನಕ್ಕಾಗಿ ಹವಾಮಾನ ಫ್ಯಾನ್ ಆರ್ಟ್ ಪ್ಯಾಕ್ ಅನ್ನು ಆಯ್ಕೆಮಾಡಿ ಮತ್ತು ಸ್ಥಾಪಿಸಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "ಸ್ಕಿನ್‌ನಾದ್ಯಂತ ಬಳಸಲು ಬಿಳಿ ಸ್ಟುಡಿಯೋ ಐಕಾನ್‌ಗಳನ್ನು ಸ್ಥಾಪಿಸಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "ಸ್ಕಿನ್‌ನಾದ್ಯಂತ ಬಳಸಲು ಬಣ್ಣದ ಸ್ಟುಡಿಯೋ ಐಕಾನ್‌ಗಳನ್ನು ಸ್ಥಾಪಿಸಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "ಸ್ಕಿನ್‌ನಾದ್ಯಂತ ಬಳಸಲು ರೆಕಾರ್ಡ್ ಲೇಬಲ್ ಐಕಾನ್‌ಗಳನ್ನು ಸ್ಥಾಪಿಸಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "ಲೈಬ್ರರಿ ವೀಕ್ಷಣೆಗಳು ಮತ್ತು ಉಪಶೀರ್ಷಿಕೆ ಆಯ್ಕೆಗಾಗಿ ಭಾಷೆಯ ಧ್ವಜಗಳನ್ನು ಸ್ಥಾಪಿಸಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "ಸಂಗೀತ ಮತ್ತು ಸಂಗೀತ ವಿಡಿಯೋಗಳಿಗಾಗಿ ಸಂಗೀತದ ಪ್ರಕಾರದ ಐಕಾನ್‌ಗಳನ್ನು ಸ್ಥಾಪಿಸಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "ಚಲನಚಿತ್ರಗಳು ಮತ್ತು ಟಿವಿ ಶೋಗಳಿಗಾಗಿ ಬಣ್ಣದ ಚಲನಚಿತ್ರ ಪ್ರಕಾರದ ಐಕಾನ್‌ಗಳನ್ನು ಸ್ಥಾಪಿಸಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "ಚಲನಚಿತ್ರಗಳು ಮತ್ತು ಟಿವಿ ಶೋಗಳಿಗಾಗಿ ಕಪ್ಪು ಮತ್ತು ಬಿಳಿ ಚಲನಚಿತ್ರ ಪ್ರಕಾರದ ಐಕಾನ್‌ಗಳನ್ನು ಸ್ಥಾಪಿಸಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "ಚಲನಚಿತ್ರಗಳ ದೇಶದ ನೋಡ್‌ಗಾಗಿ ದೇಶದ ಐಕಾನ್‌ಗಳನ್ನು ಸ್ಥಾಪಿಸಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "ಸ್ಕಿನ್‌ನಾದ್ಯಂತ ಫ್ಯಾನ್ ಆರ್ಟ್ ಪರಿವರ್ತನೆಗಳ ನಡುವಿನ ವಿಳಂಬವನ್ನು ಹೊಂದಿಸಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "ಬೀಳುವ ಹಿನ್ನೆಲೆ ಪರಿಣಾಮಗಳು. ಹಿಮ, ಎಲೆಗಳು ಇತ್ಯಾದಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "ಪ್ರಸ್ತುತ ಪ್ಲೇ ಆಗುತ್ತಿರುವ ಐಟಂನ ಸಂಗೀತ ಫ್ಯಾನ್ ಆರ್ಟ್ ಅನ್ನು ಸ್ಕಿನ್‌ನಾದ್ಯಂತ ತೋರಿಸಿ. ಲೈಬ್ರರಿ ಫ್ಯಾನ್ ಆರ್ಟ್ ಅನ್ನು ಅತಿಕ್ರಮಿಸುತ್ತದೆ."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "ಸಂಗೀತವನ್ನು ಪ್ಲೇ ಮಾಡುವಾಗ ಹಿನ್ನೆಲೆಯಲ್ಲಿ ಸಂಗೀತ ದೃಶ್ಯೀಕರಣವನ್ನು ಸಕ್ರಿಯಗೊಳಿಸುತ್ತದೆ. ಸೆಟ್ಟಿಂಗ್ಸ್ - ಪ್ಲೇಯರ್ ಸೆಟ್ಟಿಂಗ್ಸ್/ಸಂಗೀತದಲ್ಲಿ ದೃಶ್ಯೀಕರಣವನ್ನು ಸಕ್ರಿಯಗೊಳಿಸುವ ಅಗತ್ಯವಿದೆ."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "ಲೈಬ್ರರಿ ಬ್ರೌಸ್ ಮಾಡುವಾಗ ಪ್ರಸ್ತುತ ಪ್ಲೇ ಆಗುತ್ತಿರುವ ವಿಡಿಯೋವನ್ನು ಹಿನ್ನೆಲೆಯಲ್ಲಿ ತೋರಿಸಿ. ಲೈಬ್ರರಿ ಫ್ಯಾನ್ ಆರ್ಟ್ ಅನ್ನು ಅತಿಕ್ರಮಿಸುತ್ತದೆ."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "ಪ್ರಸ್ತುತ ಪ್ಲೇ ಆಗುತ್ತಿರುವ ಕಲಾವಿದರ ಚಿತ್ರಗಳನ್ನು ಮತ್ತು ಹೆಚ್ಚುವರಿ ಮಾಹಿತಿಯನ್ನು fanart.tv ಮತ್ತು theaudiodb.com ನಿಂದ ಡೌನ್‌ಲೋಡ್ ಮಾಡಿ. ಪೂರ್ಣಪರದೆ ಸಂಗೀತ, ಇಂಟರ್ನೆಟ್ ಸ್ಟ್ರೀಮ್‌ಗಳು ಮತ್ತು ರೇಡಿಯೋಗಾಗಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "ಕಲಾವಿದರ ಸ್ಲೈಡ್‌ಶೋ ಸ್ಕ್ರಿಪ್ಟ್ ಸೆಟ್ಟಿಂಗ್‌ಗಳು."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "ವಿಡಿಯೋ ಪ್ಲೇಲಿಸ್ಟ್ ಖಾಲಿಯಿಲ್ಲದಿದ್ದರೆ ಅದಕ್ಕೆ ಶಾರ್ಟ್‌ಕಟ್."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "ಸಂಗೀತ ಪ್ಲೇಲಿಸ್ಟ್ ಖಾಲಿಯಿಲ್ಲದಿದ್ದರೆ ಅದಕ್ಕೆ ಶಾರ್ಟ್‌ಕಟ್."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "ಮಾಧ್ಯಮ ಪ್ಲೇ ಆಗುತ್ತಿರುವಾಗ ಪೂರ್ಣಪರದೆಗೆ ಶಾರ್ಟ್‌ಕಟ್."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "ಶಾರ್ಟ್‌ಕಟ್ ಮೆನು ತೆರೆಯಲು ಕ್ಲಿಕ್ ಮಾಡಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "ಮಾಧ್ಯಮ ಪ್ಲೇ ಆಗುತ್ತಿರುವಾಗ ಪ್ಲೇಯರ್ ನಿಯಂತ್ರಣಗಳು."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "ಮುಂದಿನ ಟಿವಿ ಶೋ ಎಪಿಸೋಡ್ ಅನ್ನು ಸ್ವಯಂಚಾಲಿತವಾಗಿ ಪ್ಲೇ ಮಾಡಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "ಟಿವಿ ಶೋಗಳು, ಚಲನಚಿತ್ರಗಳು ಮತ್ತು ಸಂಗೀತ ವಿಡಿಯೋಗಳನ್ನು ನ್ಯಾವಿಗೇಟ್ ಮಾಡುವಾಗ ಥೀಮ್‌ಗಳನ್ನು ಪ್ಲೇ ಮಾಡಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "ಲೈಬ್ರರಿ ನೋಡ್ ಎಡಿಟರ್ ನಿಮಗೆ ಕೋಡಿಯಲ್ಲಿ ಕಸ್ಟಮ್ ವಿಡಿಯೋ ನೋಡ್‌ಗಳು ಮತ್ತು ಸಂಗೀತ ನೋಡ್‌ಗಳನ್ನು ರಚಿಸಲು ಮತ್ತು ಕಸ್ಟಮೈಸ್ ಮಾಡಲು ಅನುಮತಿಸುತ್ತದೆ."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "ವೀಕ್ಷಿಸಿದ, ವೀಕ್ಷಿಸದ ಮತ್ತು ಪ್ರಗತಿಯಲ್ಲಿರುವ ಮಾಧ್ಯಮ ಐಟಂಗಳಿಗಾಗಿ ಓವರ್‌ಲೇ ಮಾರ್ಕರ್ ಮಾಹಿತಿಯನ್ನು ತೋರಿಸಿ."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "ಕೋಡಿಯ ಅಂತರ್ನಿರ್ಮಿತ RSS ಟಿಕ್ಕರ್ ಅನ್ನು ಸಂಪಾದಿಸಲು ಒಂದು ಸ್ಕ್ರಿಪ್ಟ್."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "ಸ್ಕಿನ್ ಆವೃತ್ತಿ ಮತ್ತು ಮರುಸ್ಥಾಪನೆ ಆಯ್ಕೆಗಳು. ಎಲ್ಲಾ ಡೀಫಾಲ್ಟ್‌ಗಳನ್ನು ಮೊದಲ ದಿನದ ಸ್ಥಿತಿಗೆ ಮರುಸ್ಥಾಪಿಸುತ್ತದೆ."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "ಆಡ್-ಆನ್‌ಗಳು"