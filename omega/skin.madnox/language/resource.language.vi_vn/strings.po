# --- Body texts: top row category selectors (controls 901–904, 905) ---

#: /16x9/includes.xml
msgctxt "#31567"
msgid "Highlight a logo from the palette below and click to assign it to 4K / UHD video files."
msgstr "Tô sáng một logo từ bảng màu bên dưới và nhấp để gán nó cho các tệp video 4K / UHD."

#: /16x9/includes.xml
msgctxt "#31568"
msgid "Highlight a logo from the palette below and click to assign it to WebDL and streaming video sources."
msgstr "Tô sáng một logo từ bảng màu bên dưới và nhấp để gán nó cho các nguồn video truyền trực tuyến và WebDL."

#: /16x9/includes.xml
msgctxt "#31569"
msgid "Highlight a logo from the palette below and click to assign it to 1080p Full HD video files."
msgstr "Tô sáng một logo từ bảng màu bên dưới và nhấp để gán nó cho các tệp video 1080p Full HD."

#: /16x9/includes.xml
msgctxt "#31570"
msgid "Highlight a logo from the palette below and click to assign it to 720p HD video files."
msgstr "Tô sáng một logo từ bảng màu bên dưới và nhấp để gán nó cho các tệp video 720p HD."

#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "Tô sáng một logo từ bảng màu bên dưới và nhấp để gán nó cho các tệp video độ phân giải tiêu chuẩn và DVD."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "Chỉ hiển thị các thiết kế logo độ phân giải siêu cao và 4K trong lưới bảng màu."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "Chỉ hiển thị các thiết kế logo codec HEVC và H.265 trong lưới bảng màu."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Chỉ hiển thị các thiết kế logo codec AVC và H.264 trong lưới bảng màu."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Chỉ hiển thị các thiết kế logo định dạng MPEG-4 cũ, DivX và XviD trong lưới bảng màu."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Chỉ hiển thị các thiết kế logo phát sóng truyền hình tiêu chuẩn, DVD và MPEG cổ điển trong lưới bảng màu."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Chỉ hiển thị các thiết kế logo codec VC-1 và Windows Media Video trong lưới bảng màu."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Chỉ hiển thị các định dạng tệp chứa, định dạng đĩa và các thiết kế logo hỗn hợp khác trong lưới bảng màu."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Đóng hộp thoại tùy chỉnh nhãn này và quay lại cài đặt."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Tô sáng bất kỳ thiết kế logo nào trong lưới trung tâm và nhấp để lưu nó làm nhãn tùy chỉnh cho danh mục đang hoạt động."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Xóa lựa chọn nhãn tùy chỉnh của bạn và khôi phục danh mục này về logic nhãn mặc định tự động của giao diện."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Chuyển đổi tác phẩm nghệ thuật nhãn toàn cục giữa các thiết kế có màu và màu trắng mặc định đơn sắc."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Sử dụng các phím điều hướng của bạn để duyệt các tùy chọn. Nhấn Quay lại hoặc chọn Thoát bất cứ lúc nào để đóng mà không lưu thay đổi."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Chọn để sửa đổi"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Tùy chỉnh màn hình chính, các tiện ích và menu phím tắt."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Kịch bản dành cho người thiết kế giao diện để cho phép người dùng chọn một tiện ích bổ sung tài nguyên hình ảnh."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Tự động thêm tác phẩm nghệ thuật bổ sung cho các nội dung trong thư viện phương tiện của bạn."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Lời bài hát cho âm nhạc. Cần thiết để kích hoạt lời bài hát động."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Đồng bộ hóa bộ sưu tập và trạng thái đã xem của bạn với trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Tạo một mục yêu thích tùy chỉnh từ các mục yêu thích đã chọn trong Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Chỉnh sửa menu màn hình chính, các tiện ích, hình nền và dòng thông tin."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Đặt lại menu màn hình chính, các tiện ích, hình nền và dòng thông tin về mặc định."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Tạo một mục yêu thích tùy chỉnh từ các mục yêu thích đã chọn trong Kodi. Sử dụng cho các tiện ích của menu chính. Yêu cầu cài đặt tiện ích kịch bản mục yêu thích (script favourites)."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Tạo một tiện ích yêu thích tùy chỉnh từ các tiện ích bổ sung đã cài đặt. Sử dụng cho các tiện ích của menu chính."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Đặt lại chủ đề và màu sắc giao diện về mặc định."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Chọn từ danh sách các chủ đề được xác định trước."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Khóa các tùy chọn ưu tiên để vô hiệu hóa chế độ xem, các tùy chọn xem, hộp thoại thông tin và cài đặt toàn màn hình."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Tùy chỉnh màn hình chính, các mục yêu thích, các chủ đề xác định trước và chế độ Kiosk."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Thay đổi kết cấu chủ đề giao diện."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Tùy chỉnh màu sắc kết cấu giao diện."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Tùy chỉnh hình nền và phương án dự phòng cho các khu vực giao diện cụ thể."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Bật hoặc tắt các tính năng giao diện khác nhau."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Tùy chỉnh tác phẩm nghệ thuật và cài đặt các gói tác phẩm nghệ thuật được hỗ trợ."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Cài đặt và cấu hình các tiện ích bổ sung được hỗ trợ."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Bật và tắt các chế độ xem thư viện. Vô hiệu hóa chế độ xem thư viện trên các hệ thống cấu hình thấp có thể cải thiện hiệu suất."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Hiển thị chữ cái cuộn khi cuộn trong các chế độ xem thư viện."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Hiển thị bảng chữ cái để chuyển đến một vị trí của khung chứa. Chỉ hoạt động đối với các phương thức sắp xếp mặc định (A-Z)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Hiển thị tóm tắt cốt truyện cho các chương trình TV và phim điện ảnh nếu có sẵn, nếu không sẽ hiển thị cốt truyện mặc định."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Tự động cuộn cốt truyện nếu nó không vừa với kích thước điều khiển."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Bật menu phím tắt để truy cập tức thì vào các khu vực giao diện cụ thể. Trong menu phương tiện, nhấp sang trái để mở hoặc nhấp vào biểu tượng phím tắt."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Chỉnh sửa menu phím tắt."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Bật và tắt các thành phần thanh trên cùng."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Thay đổi cài đặt thông tin video."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Thay đổi cài đặt thông tin âm nhạc."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Thay đổi cài đặt video toàn màn hình."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Thay đổi cài đặt âm thanh toàn màn hình."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Giảm kích thước của các thông báo bật lên."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Làm tối màn hình phía sau các hộp thoại bật lên. Không áp dụng cho video hoặc âm thanh toàn màn hình."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Bật biểu tượng có màu cho thanh trên cùng, thông tin phương tiện và các chế độ xem thư viện."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Bật các nhãn phương tiện có màu, HDR, độ sâu bit và ngôn ngữ."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Hình nghệ thuật đĩa CD âm thanh dự phòng trên toàn bộ giao diện."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Hình nghệ thuật đĩa video dự phòng trên toàn bộ giao diện."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Chọn và cài đặt gói biểu tượng thời tiết cho thanh trên cùng, các tiện ích và thời tiết."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Chọn và cài đặt gói fanart thời tiết cho hình nền, các tiện ích và thời tiết."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Cài đặt các biểu tượng hãng phim màu trắng để sử dụng trên toàn bộ giao diện."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Cài đặt các biểu tượng hãng phim có màu để sử dụng trên toàn bộ giao diện."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Cài đặt các biểu tượng hãng đĩa để sử dụng trên toàn bộ giao diện."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Cài đặt các nhãn cờ ngôn ngữ cho chế độ xem thư viện và lựa chọn phụ đề."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Cài đặt các biểu tượng thể loại nhạc cho âm nhạc và video âm nhạc."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Cài đặt các biểu tượng thể loại phim có màu cho phim điện ảnh và chương trình TV."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Cài đặt các biểu tượng thể loại phim đen trắng cho phim điện ảnh và chương trình TV."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Cài đặt các biểu tượng quốc gia cho nhánh quốc gia của phim."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Đặt độ trễ giữa các chuyển đổi fanart trên toàn bộ giao diện."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Hiệu ứng hình nền rơi. Tuyết, Lá cây, v.v."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Hiển thị fanart nhạc của mục đang phát trên toàn bộ giao diện. Ghi đè fanart thư viện."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Bật trực quan hóa âm nhạc ở nền trong khi phát nhạc. Yêu cầu bật tính năng trực quan hóa trong phần cài đặt - Cài đặt trình phát/Âm nhạc."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Hiển thị video đang phát ở nền trong khi duyệt thư viện. Ghi đè fanart thư viện."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Tải xuống hình ảnh và thông tin bổ sung từ fanart.tv và theaudiodb.com của nghệ sĩ đang phát. Dành cho âm nhạc toàn màn hình, các luồng internet và radio."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Cài đặt kịch bản trình chiếu ảnh nghệ sĩ."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "Một phím tắt đến danh sách phát video nếu nó không trống."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "Một phím tắt đến danh sách phát nhạc nếu nó không trống."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Phím tắt đến toàn màn hình khi phương tiện đang phát."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Nhấp để mở menu phím tắt."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Các điều khiển trình phát khi phương tiện đang phát."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Tự động phát tập chương trình TV tiếp theo."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Phát nhạc hiệu chủ đề khi điều hướng qua Chương trình TV, Phim điện ảnh và Video âm nhạc."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "Trình chỉnh sửa nhánh thư viện (Library Node Editor) cho phép bạn tạo và tùy chỉnh các nhánh video và nhánh âm nhạc tùy chỉnh trong Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Hiển thị thông tin ký hiệu lớp phủ cho các mục phương tiện đã xem, chưa xem và đang xem dở."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Một kịch bản để chỉnh sửa Dòng tin RSS tích hợp của Kodi."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Phiên bản giao diện và các tùy chọn khôi phục. Đặt lại tất cả các mặc định về trạng thái hoạt động ban đầu."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Tiện ích bổ sung"