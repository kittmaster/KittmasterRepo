msgstr "Lưu các cài đặt hiện tại của Madnox vào thư mục thiết lập sẵn."

#: /16x9/SkinSettings.xml
msgctxt "#31541"
msgid "Load Madnox previously saved settings from the preset folder."
msgstr "Tải các cài đặt đã lưu trước đó của Madnox từ thư mục thiết lập sẵn."

#: /16x9/SkinSettings.xml
msgctxt "#31542"
msgid "Export current settings to an external file (Used for sharing or collaboration)."
msgstr "Xuất các cài đặt hiện tại ra một tệp bên ngoài (Sử dụng để chia sẻ hoặc cộng tác)."

#: /16x9/SkinSettings.xml
msgctxt "#31543"
msgid "Import settings from an external file (Used for sharing or collaboration). Invalid files/format will not be loaded."
msgstr "Nhập các cài đặt từ một tệp bên ngoài (Sử dụng để chia sẻ hoặc cộng tác). Các tệp/định dạng không hợp lệ sẽ không được tải."

