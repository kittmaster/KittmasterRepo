# --- Body texts: top row category selectors (controls 901–904, 905) ---

#: /16x9/includes.xml
msgctxt "#31567"
msgid "Highlight a logo from the palette below and click to assign it to 4K / UHD video files."
msgstr "Ljómaðu kennimerki á litaspjaldinu hér að neðan og smelltu til að úthluta því á 4K / UHD myndskrár."

#: /16x9/includes.xml
msgctxt "#31568"
msgid "Highlight a logo from the palette below and click to assign it to WebDL and streaming video sources."
msgstr "Ljómaðu kennimerki á litaspjaldinu hér að neðan og smelltu til að úthluta því á WebDL og streymisuppsprettur."

#: /16x9/includes.xml
msgctxt "#31569"
msgid "Highlight a logo from the palette below and click to assign it to 1080p Full HD video files."
msgstr "Ljómaðu kennimerki á litaspjaldinu hér að neðan og smelltu til að úthluta því á 1080p Full HD myndskrár."

#: /16x9/includes.xml
msgctxt "#31570"
msgid "Highlight a logo from the palette below and click to assign it to 720p HD video files."
msgstr "Ljómaðu kennimerki á litaspjaldinu hér að neðan og smelltu til að úthluta því á 720p HD myndskrár."

#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "Ljómaðu kennimerki á litaspjaldinu hér að neðan og smelltu til að úthluta því á DVD og myndskrár í staðalupplausn."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "Sýna aðeins ofur-háupplausnar og 4K kennimerki á litaspjaldinu."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "Sýna aðeins HEVC og H.265 kóðunarkennimerki á litaspjaldinu."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Sýna aðeins AVC og H.264 kóðunarkennimerki á litaspjaldinu."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Sýna aðeins DivX, XviD og eldri MPEG-4 snið á litaspjaldinu."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Sýna klassísk MPEG, DVD og hefðbundin sjónvarpsútvarpsmerki á litaspjaldinu."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Sýna Windows Media Video og VC-1 kóðunarkennimerki á litaspjaldinu."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Sýna gáma, disksnið og önnur ýmis kennimerki á litaspjaldinu."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Loka þessum samskiptaglugga fyrir sérsníðingu fána og fara aftur í stillingar."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Ljómaðu hvaða kennimerki sem er í miðjugrindinni og smelltu til að vista það sem þinn sérsniðna fána fyrir virka flokkinn."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Hreinsa sérsniðna fánavalið þitt og endurheimta þennan flokk í sjálfgefna sjálfvirka flokkun viðmótsins."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Víxla almennu fanalistaverki á milli litaðrar hönnunar og sjálfgefinnar einlita hvítar."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Notaðu áttahnappana til að fletta um valkosti. Ýttu á Til baka eða veldu Hætta hvenær sem er til að loka án breytinga."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Veldu til að breyta"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Sérsníðing heimaskjás, græja og flýtivísana."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Skrifta fyrir hönnuði viðmóta til að leyfa notendum að velja myndauðlindaviðbót."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Bætir sjálfkrafa við auka myndskreytingum fyrir miðla í söfnunum þínum."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Söngtextar fyrir tónlist. Nauðsynlegt til að virkja hreyfða söngtexta."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Samstilla safnið þitt og áhorfsstöðu við trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Búa til sérsniðið eftirlæti úr völdum Kodi eftirlætum."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Breyta heimaskjá, græjum, bakgrunnum og upplýsingalínum."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Endurstilla heimaskjá, græjur, bakgrunna og upplýsingalínur í sjálfgefið."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Búa til sérsniðið eftirlæti úr völdum Kodi eftirlætum. Til notkunar í græjum aðalvalmyndar. Krefst þess að eftirlætisskrifta (script favourites) sé uppsett."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Búa til sérsniðna eftirlætisviðbót úr uppsettum viðbótum. Til notkunar í græjum aðalvalmyndar."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Endurstilla þema og liti viðmótsins í sjálfgefið."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Velja úr lista af fyrirfram skilgreindum þemum."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Læsa kjörstillingum til að gera sýnishami, sýnisvalkosti, upplýsingaglugga og fullskjástillingar óvirkar."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Sérsníða heimaskjá, eftirlæti, fyrirfram skilgreind þemu og söluturnsham (kiosk)."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Breyta þemaáferðum viðmótsins."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Sérsníða áferðarliti viðmótsins."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Sérsníða bakgrunn og sjálfgefin gildi fyrir ákveðin svæði viðmótsins."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Virkja eða gera ýmsa eiginleika viðmótsins óvirka."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Sérsníða myndskreytingar og setja upp studda myndapakka."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Setja upp og stilla studdar viðbætur."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Virkja og gera safnsýnir óvirkar. Að gera þær óvirkar á vekum tækjum getur bætt afköst."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Sýnir skrunstaf þegar skrunað er í safnsýnum."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Sýnir stafrófið til að stökkva á ákveðinn stað í gámi. Virkar aðeins fyrir sjálfgefnar röðunaraðferðir (A-Ö)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Sýnir stutt yfirlit yfir söguþráð sjónvarpsþátta og kvikmynda ef það er tiltækt, annars er sjálfgefinn söguþráður sýndur."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Skruna söguþræði sjálfkrafa ef hann rúmast ekki innan viðmótshlutans."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Virkja flýtivalmynd fyrir skjótan aðgang að ákveðnum svæðum viðmótsins. Í miðlavalmyndinni er smellt til vinstri til að opna eða smellt á flýtitáknið."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Breyta flýtivalmynd."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Virkja og gera óvirka hluta efri stikunnar."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Breyta upplýsingastillingum myndskeiða."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Breyta upplýsingastillingum tónlistar."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Breyta stillingum fyrir myndskeið í fullum skjá."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Breyta stillingum fyrir tónlist í fullum skjá."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Minkka stærð sprettigluggatilkynninga."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Dökknar skjáinn á bak við samskiptaglugga. Gildir ekki þegar horft er á myndskeið eða hlustað á tónlist í fullum skjá."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Virkja lituð tákn fyrir efri stiku, miðlaupplýsingar og safnsýnir."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Virkja lituð miðlaflaggi fyrir HDR, litadýpt og tungumál."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Sjálfgefin geisladiskamynd fyrir alla tónlist í viðmótinu."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Sjálfgefin diskamynd fyrir öll myndskeið í viðmótinu."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Velja og setja upp veðurtáknapakka fyrir efri stiku, græjur og veður."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Velja og setja upp veðurbakgrunnspakka fyrir bakgrunna, græjur og veður."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Setja upp hvít sjónvarps- og kvikmyndastúdíótákn til notkunar í viðmótinu."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Setja upp lituð sjónvarps- og kvikmyndastúdíótákn til notkunar í viðmótinu."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Setja upp tákn fyrir útgáfufyrirtæki til notkunar í viðmótinu."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Setja upp tungumálafána fyrir safnsýnir og val á undirtitlum."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Setja upp tónlistarflokkatákn fyrir tónlist og tónlistarmyndbönd."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Setja upp lituð kvikmyndaflokkatákn fyrir kvikmyndir og sjónvarpsþætti."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Setja upp svarthvít kvikmyndaflokkatákn fyrir kvikmyndir og sjónvarpsþætti."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Setja upp landatákn fyrir landahnút kvikmynda."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Stilla töfina á milli bakgrunnsmyndaskipta í öllu viðmótinu."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Ofanfallshrif í bakgrunni. Snjókoma, laufblaðafall o.s.frv."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Sýna tónlistarbakgrunnsmynd fyrir þat atriði sem er í spilun í öllu viðmótinu. Gengur framar safnbakgrunnsmyndum."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Virkjar sjónræna tónlistartúlkun í bakgrunni þegar tónlist er spiluð. Krefst þess að sjónræn túlkun sé virkjuð í Stillingar - Spilunarstillingar/Tónlist."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Sýna myndskeiðið sem er í spilun í bakgrunni á meðan safnið er skoðað. Gengur framar safnbakgrunnsmyndum."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Sækja myndir og viðbótarupplýsingar frá fanart.tv og theaudiodb.com fyrir flytjandann sem nú er í spilun. Fyrir tónlist í fullum skjá, netstrauma og útvarp."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Stillingar á skriftu fyrir myndasýningu flytjenda."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "Flýtileið í spilunarlista myndskeiða ef hann er ekki tómur."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "Flýtileið í spilunarlista tónlistar ef hann er ekki tómur."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Flýtileið í fullan skjá þegar miðill er í spilun."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Smelltu til að opna flýtivalmynd."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Stýringar spilara þegar miðill er í spilun."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Spila næsta sjónvarpsþátt sjálfkrafa."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Spila stefstef á meðan flett er í gegnum sjónvarpsþætti, kvikmyndir og tónlistarmyndbönd."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "Library Node Editor (hnútastjóri safnsins) gerir þér kleift að búa til og sérsníða myndskeiðshnúta og tónlistarhnúta í Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Sýna yfirborðsmerkingar fyrir séð, óséð og atriði í spilun."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Skrifta til að breyta innbyggða RSS-borða Kodi."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Útgáfa viðmóts og endurheimtuvalkostir. Endurheimtir öll sjálfgefin gildi eins og þau voru í upphafi."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Viðbætur"