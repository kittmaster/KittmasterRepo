#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "Sélectionnez un logo dans la palette ci-dessous et cliquez pour l'attribuer aux fichiers vidéo DVD et en définition standard."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "Afficher uniquement les logos ultra-haute définition et 4K dans la grille de la palette."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "Afficher uniquement les logos de codec HEVC et H.265 dans la grille de la palette."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Afficher uniquement les logos de codec AVC et H.264 dans la grille de la palette."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Afficher uniquement les logos de formats DivX, XviD et anciens MPEG-4 dans la grille de la palette."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Afficher uniquement les logos MPEG classiques, DVD et de diffusion télévisée standard dans la grille de la palette."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Afficher uniquement les logos de codec Windows Media Video et VC-1 dans la grille de la palette."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Afficher uniquement les conteneurs, formats de disques et autres logos divers dans la grille de la palette."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Fermer cette boîte de dialogue de personnalisation des indicateurs et revenir aux paramètres."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Sélectionnez un logo dans la grille centrale et cliquez pour l'enregistrer comme indicateur personnalisé pour la catégorie active."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Effacer votre choix d'indicateur personnalisé et restaurer cette catégorie selon la logique automatique par défaut du thème."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Basculez l'illustration globale des indicateurs entre les motifs en couleur et le blanc monochrome par défaut."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Utilisez vos touches directionnelles pour parcourir les options. Appuyez sur Retour ou sélectionnez Quitter à tout moment pour fermer sans enregistrer de modifications."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Sélectionner pour modifier"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Personnalisation de l'écran d'accueil, des widgets et du menu des raccourcis."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Script permettant aux créateurs de thèmes de laisser l'utilisateur sélectionner une extension de ressources d'images."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Ajoute automatiquement des illustrations supplémentaires pour les médias de vos médiathèques."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Paroles de chansons. Requis pour activer les paroles animées."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Synchronisez votre collection et votre statut de visionnage avec trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Créez un favori personnalisé à partir des favoris Kodi sélectionnés."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Modifiez le menu de l'écran d'accueil, les widgets, les arrière-plans et les lignes d'information."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Réinitialisez par défaut le menu de l'écran d'accueil, les widgets, les arrière-plans et les lignes d'information."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Créez un favori personnalisé à partir des favoris Kodi sélectionnés. Pour une utilisation dans les widgets du menu principal. Nécessite l'installation du script de favoris."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Créez un favori d'extension personnalisé à partir des extensions installées. Pour une utilisation dans les widgets du menu principal."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Réinitialisez par défaut le thème et les couleurs de l'habillage."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Faites votre choix parmi une liste de thèmes prédéfinis."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Verrouillez les préférences pour désactiver le mode d'affichage, les options d'affichage, la boîte de dialogue d'infos et les paramètres de plein écran."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Personnalisez l'écran d'accueil, les favoris, les thèmes prédéfinis et le mode kiosque."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Modifiez les textures de thème de l'habillage."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Personnalisez les couleurs des textures de l'habillage."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Personnalisez l'arrière-plan et les images de secours pour des zones spécifiques de l'habillage."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Activez ou désactivez diverses fonctionnalités du thème."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Personnalisez les illustrations et installez des ensembles d'illustrations pris en charge."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Installez et configurez les extensions prises en charge."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Activez ou désactivez les vues de la médiathèque. La désactivation des vues sur des systèmes à faibles spécifications peut améliorer les performances."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Affiche la lettre de défilement lors du parcours des vues de la médiathèque."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Affiche l'alphabet pour sauter à une position du conteneur. Fonctionne uniquement avec les méthodes de tri par défaut (A-Z)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Affiche le résumé de l'intrigue pour les films et séries télé si disponible; sinon, l'intrigue par défaut s'affichera."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Fait défiler automatiquement l'intrigue si elle ne tient pas dans les dimensions de la zone."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Activez le menu de raccourcis pour un accès instantané à des zones spécifiques du thème. Dans le menu média, cliquez vers la gauche pour ouvrir ou cliquez sur l'icône de raccourci."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Modifiez le menu de raccourcis."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Activez et désactivez les éléments de la barre supérieure."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Modifiez les paramètres d'infos vidéo."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Modifiez les paramètres d'infos musicales."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Modifiez les paramètres vidéo plein écran."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Modifiez les paramètres audio plein écran."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Réduisez la taille des notifications contextuelles."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Assombrit l'écran derrière les boîtes de dialogue contextuelles. Non applicable pour l'audio ou la vidéo plein écran."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Activez les icônes de couleur pour la barre supérieure, les informations de média et les vues de la médiathèque."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Activez les indicateurs de média colorés, HDR, de profondeur de bits et de langue."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Image de secours de pochette CD audio pour tout le thème."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Image de secours de disque vidéo pour tout le thème."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Sélectionnez et installez un ensemble d'icônes météo pour la barre supérieure, les widgets et la météo."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Sélectionnez et installez un ensemble de fanarts météo pour les arrière-plans, les widgets et la météo."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Installez des icônes de studio blanches pour une utilisation dans tout le thème."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Installez des icônes de studio en couleur pour une utilisation dans tout le thème."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Installez des icônes de maisons de disques pour une utilisation dans tout le thème."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Installez des indicateurs de langue pour les vues de la médiathèque et la sélection de sous-titres."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Installez des icônes de genre musical pour la musique et les clips musicaux."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Installez des icônes en couleur de genre de film pour les films et les séries télé."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Installez des icônes en noir et blanc de genre de film pour les films et les séries télé."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Installez des icônes de pays pour le nœud de pays des films."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Définissez le délai entre les transitions de fanart pour tout le thème."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Effets d'arrière-plan de chute. Neige, feuilles, etc."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Affichez le fanart musical de l'élément en cours de lecture sur tout le thème. Remplace le fanart de la médiathèque."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Active la visualisation musicale en arrière-plan lors de la lecture de musique. Nécessite l'activation de la visualisation dans Paramètres - Paramètres du lecteur/Musique."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Affichez la vidéo en cours de lecture en arrière-plan lors du parcours de la médiathèque. Remplace le fanart de la médiathèque."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Téléchargez des images et des informations supplémentaires depuis fanart.tv et theaudiodb.com de l'artiste en cours de lecture. Pour la musique plein écran, les flux Internet et la radio."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Paramètres du script de diaporama d'artiste."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "Un raccourci vers la liste de lecture vidéo si elle n'est pas vide."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "Un raccourci vers la liste de lecture musicale si elle n'est pas vide."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Raccourci vers le plein écran lorsqu'un média est en cours de lecture."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Cliquez pour ouvrir le menu de raccourcis."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Commandes du lecteur lorsqu'un média est en cours de lecture."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Faites jouer l'épisode suivant de la série télé automatiquement."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Faire jouer les thèmes sonores lors de la navigation des séries télé, films et clips musicaux."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "L'éditeur de nœuds de médiathèque (Library Node Editor) vous permet de créer et personnaliser des nœuds vidéo et musicaux personnalisés dans Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Affiche des indicateurs de superposition pour les éléments multimédias vus, non vus et en cours."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Un script pour modifier la bande déroulante RSS intégrée de Kodi."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Version du thème et options de récupération. Restaure toutes les valeurs par défaut au premier jour de fonctionnement."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Extensions"