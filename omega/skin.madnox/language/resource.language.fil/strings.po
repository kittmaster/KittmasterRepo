msgid "Highlight a logo from the palette below and click to assign it to 720p HD video files."
msgstr "I-highlight ang isang logo mula sa paleta sa ibaba at i-click upang i-assign ito sa 720p HD na mga file ng video."

#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "I-highlight ang isang logo mula sa paleta sa ibaba at i-click upang i-assign ito sa DVD at standard-definition na mga file ng video."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "Tumingin lamang ng ultra-high-definition at 4K na mga disenyo ng logo sa palette grid."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "Tumingin lamang ng HEVC at H.265 na mga disenyo ng logo ng codec sa palette grid."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Tumingin lamang ng AVC at H.264 na mga disenyo ng logo ng codec sa palette grid."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Tumingin lamang ng DivX, XviD, at lumang MPEG-4 na mga disenyo ng logo ng format sa palette grid."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Tumingin lamang ng klasikong MPEG, DVD, at karaniwang mga disenyo ng logo ng broadcast ng TV sa palette grid."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Tumingin lamang ng Windows Media Video at VC-1 na mga disenyo ng logo ng codec sa palette grid."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Tumingin lamang ng mga container wrapper, format ng disk, at iba pang sari-saring disenyo ng logo sa palette grid."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Isara ang dialog ng pag-customize ng flag na ito at bumalik sa mga setting."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "I-highlight ang anumang disenyo ng logo sa gitnang grid at i-click upang i-save ito bilang iyong custom na flag para sa aktibong kategorya."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "I-clear ang iyong napiling custom na flag at ibalik ang kategoryang ito sa awtomatikong default na lohika ng flag ng skin."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "I-toggle ang pandaigdigang flag artwork sa pagitan ng may kulay na mga disenyo at monochromatic na default na puti."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Gamitin ang iyong mga directional key upang i-navigate ang mga opsyon. Pindutin ang Back o piliin ang Exit anumang oras upang isara nang walang mga pagbabago."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Piliin upang baguhin"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Pag-customize ng home screen, mga widget, at menu ng mga shortcut."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Script para sa mga skinner upang payagan ang mga user na pumili ng image resource addon."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Awtomatikong nagdaragdag ng karagdagang artwork para sa media sa iyong mga media library."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Mga lyric para sa musika. Kinakailangan upang paganahin ang mga animated na lyric."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "I-sync ang iyong koleksyon at katayuan ng napanood sa trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Gumawa ng custom na paborito mula sa mga napiling paborito sa Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "I-edit ang menu ng home screen, mga widget, mga background, at mga infoline."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "I-reset ang menu ng home screen, mga widget, mga background, at mga infoline sa default."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Gumawa ng custom na paborito mula sa mga napiling paborito sa Kodi. Para gamitin sa mga widget ng pangunahing menu. Kinakailangang naka-install ang script ng mga paborito."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Gumawa ng custom na addon na paborito mula sa mga naka-install na addon. Para gamitin sa mga widget ng pangunahing menu."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "I-reset ang tema at mga kulay ng skin sa default."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Pumili mula sa listahan ng mga pre-defined na tema."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "I-lock ang mga kagustuhan upang i-disable ang view mode, mga opsyon sa view, info dialog, at mga setting ng fullscreen."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "I-customize ang home screen, mga paborito, mga pre-defined na tema, at kiosk mode."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Baguhin ang mga tekstura ng tema ng skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "I-customize ang mga kulay ng tekstura ng skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "I-customize ang background at mga fallback para sa partikular na mga bahagi ng skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Paganahin o i-disable ang iba't ibang tampok ng skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "I-customize ang artwork at i-install ang mga sinusuportahang artwork pack."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "I-install at i-configure ang mga sinusuportahang addon."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Paganahin at i-disable ang mga view ng library. Ang pag-disable sa mga view ng library sa mga system na may mababang spec ay maaaring magpabuti ng pagganap."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Nagpapakita ng titik ng pag-scroll kapag nag-i-scroll sa mga view ng library."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Ipinapakita ang alpabeto upang pumunta sa isang posisyon ng container. Gagana lamang para sa mga default na paraan ng pag-uuri (A-Z)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Ipinapakita ang balangkas ng plot para sa mga palabas sa TV at pelikula kung mayroon, kung hindi ay ipapakita ang default na plot."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Awtomatikong i-scroll ang plot kung hindi ito kasya sa mga sukat ng control."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Paganahin ang shortcut menu para sa agarang pag-access sa partikular na mga bahagi ng skin. Sa media menu, i-click ang pakaliwa para buksan o i-click ang shortcut icon."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "I-edit ang shortcut menu."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Paganahin at i-disable ang mga elemento ng topbar."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Baguhin ang mga setting ng impormasyon ng video."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Baguhin ang mga setting ng impormasyon ng musika."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Baguhin ang mga setting ng fullscreen video."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Baguhin ang mga setting ng fullscreen audio."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Bawasan ang laki ng mga pop-up na notification."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Pinapadilim ang screen sa likod ng mga dialog popup. Hindi naaangkop para sa fullscreen video o audio."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Paganahin ang may kulay na mga icon para sa topbar, impormasyon ng media, at mga view ng library."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Paganahin ang may kulay, HDR, bit depth, at mga wika na media flag."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Fallback ng audio cd art sa buong skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Fallback ng video cd art sa buong skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Pumili at i-install ang weather icon pack para sa topbar, mga widget, at panahon."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Pumili at i-install ang weather fanart pack para sa mga background, mga widget, at panahon."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "I-install ang mga puting icon ng studio para gamitin sa buong skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "I-install ang may kulay na mga icon ng studio para gamitin sa buong skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "I-install ang mga icon ng record label para gamitin sa buong skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "I-install ang mga watawat ng wika para sa mga view ng library at pagpili ng subtitle."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "I-install ang mga icon ng genre ng musika para sa musika at mga music video."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "I-install ang may kulay na mga icon ng genre ng pelikula para sa mga pelikula at palabas sa TV."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "I-install ang itim at puting mga icon ng genre ng pelikula para sa mga pelikula at palabas sa TV."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "I-install ang mga icon ng bansa para sa country node ng mga pelikula."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "I-set ang delay sa pagitan ng mga paglipat ng fanart sa buong skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Mga epekto ng bumabagsak na background. Niyebe, mga dahon atbp."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Ipakita ang fanart ng musika ng kasalukuyang tinutugtog na item sa buong skin. Ino-override nito ang fanart ng library."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Pinapagana ang visualisasyon ng musika sa background habang nagpapatugtog ng musika. Kinakailangang paganahin ang visualisasyon sa mga setting - Mga setting ng Player/Musika."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Ipakita ang kasalukuyang tinutugtog na video sa background habang nagba-browse sa library. Ino-override nito ang fanart ng library."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "I-download ang mga larawan at karagdagang impormasyon mula sa fanart.tv at theaudiodb.com ng kasalukuyang tinutugtog na artist. Para sa fullscreen na musika, mga internet stream, at radyo."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Mga setting ng artist slideshow script."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "Isang shortcut patungo sa playlist ng video kung hindi ito walang laman."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "Isang shortcut patungo sa playlist ng musika kung hindi ito walang laman."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Shortcut patungo sa fullscreen kapag may tinutugtog na media."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "I-click upang buksan ang shortcut menu."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Mga kontrol ng player kapag may tinutugtog na media."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Awtomatikong i-play ang susunod na episodyo ng palabas sa TV."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "I-play ang mga tema habang nagna-navigate sa mga Palabas sa TV, Pelikula, at mga Music Video."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "Ang Library Node Editor ay nagbibigay-daan sa iyo na gumawa at mag-customize ng mga custom na video node at music node sa loob ng Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Ipakita ang impormasyon ng overlay marker para sa mga napanood na, hindi pa napanood, at kasalukuyang pinapanood na mga media item."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Isang script para sa pag-edit ng built-in na RSS Ticker ng Kodi."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Bersyon ng skin at mga opsyon sa pag-recover. Inaibalik ang lahat ng default sa unang araw ng paggamit."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Mga Addon"