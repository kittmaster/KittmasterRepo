#: /16x9/Includes_Settings.xml
msgctxt "#31511"
msgid "Dedicated addon for Madnox required for Piers+. Moves all free running scripts to a dedicated addon for security purposes."
msgstr "Piers+-erako beharrezkoa den Madnoxentzako gehigarri dedikatua. Abian dauden script guztiak segurtasun arrazoiengatik gehigarri dedikatu batera mugitzen ditu."

#: /16x9/Includes_Settings.xml
msgctxt "#31512"
