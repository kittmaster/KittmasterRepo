# --- Body texts: top row category selectors (controls 901–904, 905) ---

#: /16x9/includes.xml
msgctxt "#31567"
msgid "Highlight a logo from the palette below and click to assign it to 4K / UHD video files."
msgstr "Nabarmendu beheko paletako logotipo bat eta egin klik 4K / UHD bideo-fitxategiei esleitzeko."

#: /16x9/includes.xml
msgctxt "#31568"
msgid "Highlight a logo from the palette below and click to assign it to WebDL and streaming video sources."
msgstr "Nabarmendu beheko paletako logotipo bat eta egin klik WebDL eta streaming bideo-iturburuei esleitzeko."

#: /16x9/includes.xml
msgctxt "#31569"
msgid "Highlight a logo from the palette below and click to assign it to 1080p Full HD video files."
msgstr "Nabarmendu beheko paletako logotipo bat eta egin klik 1080p Full HD bideo-fitxategiei esleitzeko."

#: /16x9/includes.xml
msgctxt "#31570"
msgid "Highlight a logo from the palette below and click to assign it to 720p HD video files."
msgstr "Nabarmendu beheko paletako logotipo bat eta egin klik 720p HD bideo-fitxategiei esleitzeko."

#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "Nabarmendu beheko paletako logotipo bat eta egin klik DVD eta definizio estandarreko (SD) bideo-fitxategiei esleitzeko."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "Bistaratu ultra-definizio handiko eta 4K logotipoen diseinuak soilik paleta-saretan."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "Bistaratu HEVC eta H.265 kodeken logotipoen diseinuak soilik paleta-saretan."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Bistaratu AVC eta H.264 kodeken logotipoen diseinuak soilik paleta-saretan."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Bistaratu DivX, XviD eta MPEG-4 formatu zaharren logotipoen diseinuak soilik paleta-saretan."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Bistaratu MPEG klasikoen, DVDen eta telebista bidezko emisio estandarren logotipoen diseinuak soilik paleta-saretan."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Bistaratu Windows Media Video eta VC-1 kodeken logotipoen diseinuak soilik paleta-saretan."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Bistaratu edukiontzi, disko formatu eta bestelako logotipoen diseinuak soilik paleta-saretan."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Itxi banderak pertsonalizatzeko elkarrizketa-leiho hau eta itzuli ezarpenetara."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Nabarmendu erdiko saretako edozein logotipo-diseinu eta egin klik kategoria aktiborako pertsonalizatutako bandera gisa gordetzeko."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Garbitu hautatutako bandera pertsonalizatua eta leheneratu kategoria hau azalaren bandera-logika lehenetsi automatikora."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Txandakatu bandera orokorren diseinua koloreztatutakoen eta zuri monokromatiko lehenetsiaren artean."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Erabili norabide-teklak aukeren artean nabigatzeko. Sakatu Atzera edo hautatu Irten nahi duzunean aldaketarik gabe ixteko."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Hautatu aldatzeko"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Hasierako pantailaren, widgeten eta lasterbideen menuaren pertsonalizazioa."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Azalen sortzaileentzako script-a, erabiltzaileei irudi-baliabideen gehigarri bat hautatzen uzteko."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Automatikoki gehitzen ditu arte-lan gehigarriak zure multimedia liburutegietan."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Musikarako letrak. Letra animatuak gaitzeko beharrezkoa."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Sinkronizatu zure bilduma eta ikusitakoen egoera trakt.tv zerbitzuarekin."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Sortu gogoko pertsonalizatu bat hautatutako Kodiko gogokoetatik."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Editatu hasierako pantailako menua, widgetak, atzeko planoak eta informazio-lerroak."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Berrezarri hasierako pantailako menua, widgetak, atzeko planoak eta informazio-lerroak lehenetsitako balioetara."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Sortu gogoko pertsonalizatu bat hautatutako Kodiko gogokoetatik. Menu nagusiko widget-etan erabiltzeko. Gogokoen script-a instalatuta egon behar da."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Sortu gogoko gehigarri pertsonalizatu bat instalatutako gehigarrietatik. Menu nagusiko widget-etan erabiltzeko."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Berrezarri azalaren gaia eta koloreak lehenetsitako balioetara."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Hautatu aurrez definitutako gaien zerrenda batetik."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Blokeatu hobespenak ikuspegi modua, ikuspegi aukerak, informazio-elkarrizketa eta pantaila osoko ezarpenak desgaitzeko."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Pertsonalizatu hasierako pantaila, gogokoak, aurrez definitutako gaiak eta kiosko modua."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Aldatu azalaren gaiaren testurak."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Pertsonalizatu azalaren testuren koloreak."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Pertsonalizatu atzeko planoa eta ordezkoak azaleko gune zehatzetarako."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Gaitu edo desgaitu azalaren hainbat ezaugarri."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Pertsonalizatu arte-lanak eta instalatu onartutako arte-paketeak."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Instalatu eta konfiguratu onartutako gehigarriak."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Gaitu eta desgaitu liburutegiko ikuspegiak. Ezaugarri baxuko sistemetan liburutegiko ikuspegiak desgaitzeak errendimendua hobetu dezake."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Erakutsi mugitze-letra liburutegiko ikuspegietan mugitzean."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Edukiontziaren posizio batera salto egiteko alfabetoa erakusten du. Lehenetsitako ordenatze-metodoekin soilik funtzionatuko du (A-Z)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Telesaio eta pelikulen argumentuaren laburpena erakusten du erabilgarri badago; bestela, lehenetsitako argumentua bistaratuko du."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Automatikoki desplazatu argumentu-testua kontrol-neurrietan sartzen ez bada."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Gaitu lasterbideen menua azaleko eremu zehatzetara berehala sartzeko. Multimedia-menuan egin klik ezkerrean irekitzeko edo egin klik lasterbidearen ikonoan."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Editatu lasterbideen menua."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Gaitu eta desgaitu goiko barrako elementuak."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Aldatu bideo-informazioaren ezarpenak."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Aldatu musika-informazioaren ezarpenak."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Aldatu pantaila osoko bideo ezarpenak."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Aldatu pantaila osoko audio ezarpenak."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Murriztu jakinarazpen leihoen tamaina."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Elkarrizketa-leihoen atzean dagoen pantaila iluntzen du. Ez da aplikatzen pantaila osoko bideo edo audioan."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Gaitu kolorezko ikonoak goiko barrarako, multimedia-informaziorako eta liburutegi-ikuspegietarako."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Gaitu kolorezko, HDR, bit-sakonera eta hizkuntza multimedia-banderak."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Audio CD azalaren ordezkoa azal osoan."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Bideo CD azalaren ordezkoa azal osoan."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Hautatu eta instalatu eguraldi-ikonoen pakete bat goiko barrarako, widgetetarako eta eguraldirako."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Hautatu eta instalatu eguraldi-fanart pakete bat atzeko planoetarako, widgetetarako eta eguraldirako."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Instalatu estudioen ikono zuriak azal osoan erabiltzeko."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Instalatu estudioen kolorezko ikonoak azal osoan erabiltzeko."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Instalatu diskoetxeen ikonoak azal osoan erabiltzeko."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Instalatu hizkuntza-banderak liburutegi-ikuspegietarako eta azpitituluen hautapenerako."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Instalatu musika-generoen ikonoak musika eta musika-bideoetarako."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Instalatu zinema-generoen kolorezko ikonoak pelikula eta telesaioetarako."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Instalatu zinema-generoen zuri-beltzeko ikonoak pelikula eta telesaioetarako."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Instalatu herrialdeetako ikonoak pelikula herrialdeen nodorako."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Ezarri fanart trantsizioen arteko atzerapena azal osoan."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Atzeko planoko erorketa-efektuak. Elurra, hostoak, etab."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Erakutsi orain erreproduzitzen ari den elementuaren musika-fanarta azal osoan. Liburutegiko fanarta gainidazten du."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Musika erreproduzitzean atzeko planoko musika-bistaratzek gaitu egiten ditu. Bistaraztea Player ezarpenetan / Musikan gaituta egotea eskatzen du."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Erakutsi orain erreproduzitzen ari den bideoa atzeko planoan liburutegia arakatzen duzun bitartean. Liburutegiko fanarta gainidazten du."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Deskargatu irudiak eta informazio gehigarria fanart.tv eta theaudiodb.com webguneetatik erreproduzitzen ari den artistarentzat. Pantaila osoko musikarako, interneteko korronteetarako eta irratietarako."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Artista diapositiba-aurkezpen script-aren ezarpenak."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "Lasterbide bat bideoen erreprodukzio-zerrendara, hutsik ez badago."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "Lasterbide bat musikaren erreprodukzio-zerrendara, hutsik ez badago."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Lasterbidea pantaila osora edukia erreproduzitzen ari denean."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Egin klik lasterbideen menua irekitzeko."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Erreproduzitzailearen kontrolak edukia erreproduzitzen ari denean."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Erreproduzitu telesaioaren hurrengo atala automatikoki."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Erreproduzitu gaiak Telesaioetan, Pelikuletan eta Musika Bideoetan zehar nabigatzen duzun bitartean."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "Library Node Editor-ek bideo- eta musika-nodo pertsonalizatuak sortzea eta pertsonalizatzea ahalbidetzen dizu Kodiren barruan."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Erakutsi gainjarritako markatzailearen informazioa ikusitako, ikusi gabeko eta martxan dauden multimedia elementuentzat."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Kodiren integratutako RSS Ticker-a editatzeko script bat."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Azalaren bertsioa eta berreskuratze-aukerak. Ezarpen guztiak jatorrizko egoerara leheneratzen ditu."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Gehigarriak"