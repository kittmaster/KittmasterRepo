msgstr "Sérger WebDL merki:"

#: /16x9/includes.xml
msgctxt "#31561"
msgid "Customise 1080p flag:"
msgstr "Sérger 1080p merki:"

#: /16x9/includes.xml
msgctxt "#31562"
msgid "Customise 720p flag:"
msgstr "Sérger 720p merki:"

#: /16x9/includes.xml
msgctxt "#31563"
msgid "Customise DVD / SD flag:"
msgstr "Sérger DVD / SD merki:"

#: /16x9/includes.xml
msgctxt "#31564"
msgid "Category filter:"
msgstr "Bólkasía:"

#: /16x9/includes.xml
msgctxt "#31565"
msgid "Restore default:"
msgstr "Endurstovna standard:"

#: /16x9/includes.xml
msgctxt "#31566"
msgid "Toggle Color Scheme:"
msgstr "Skift litaskipan:"

# --- Body texts: top row category selectors (controls 901–904, 905) ---

#: /16x9/includes.xml
msgctxt "#31567"
msgid "Highlight a logo from the palette below and click to assign it to 4K / UHD video files."
msgstr "Framhev eitt logo úr palettuni niðanfyri og trýst fyri at knýta tað til 4K / UHD videofílur."

#: /16x9/includes.xml
msgctxt "#31568"
msgid "Highlight a logo from the palette below and click to assign it to WebDL and streaming video sources."
msgstr "Framhev eitt logo úr palettuni niðanfyri og trýst fyri at knýta tað til WebDL- og streymingarkeldur."

#: /16x9/includes.xml
msgctxt "#31569"
msgid "Highlight a logo from the palette below and click to assign it to 1080p Full HD video files."
msgstr "Framhev eitt logo úr palettuni niðanfyri og trýst fyri at knýta tað til 1080p Full HD videofílur."

#: /16x9/includes.xml
msgctxt "#31570"
msgid "Highlight a logo from the palette below and click to assign it to 720p HD video files."
msgstr "Framhev eitt logo úr palettuni niðanfyri og trýst fyri at knýta tað til 720p HD videofílur."

#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "Framhev eitt logo úr palettuni niðanfyri og trýst fyri at knýta tað til DVD- og SD-videofílur."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "Vís bert Ultra HD- og 4K-logohamsir í palettunetunum."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "Vís bert HEVC- og H.265-codec-logohamsir í palettunetunum."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Vís bert AVC- og H.264-codec-logohamsir í palettunetunum."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Vís bert DivX-, XviD- og gomul MPEG-4-sniðlogohamsir í palettunetunum."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Vís klassisk MPEG-, DVD- og vanlig sjónvarps-logohamsir í palettunetunum."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Vís Windows Media Video- og VC-1-codec-logohamsir í palettunetunum."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Vís hylkisumsløg, fløgusnið og aðrar ymiskar logohamsir í palettunetunum."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Lat henda dialogin fyri merkisgerð aftur og far aftur til stillingar."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Framhev eitt og hvørt logo í miðnetinum og trýst fyri at vista tað som títt egna merki fyri tann virkna bólkin."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Rudda títt sérgjørda merkival og endurstovna henda bólkin til ta sjálvvirkandi merkilogikkina hjá skininum."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Skift alheims listaprýði fyri merki millum litaðar hamsir og einlitað hvítt sum standard."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Nýt pílatastarnar til at stýra millum møguleikar. Trýst á Aftur ella vel Far út nær sum helst fyri at lata aftur uttan broytingar."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Vel fyri at broyta"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Sérgerð av heimaskíggjanum, widgetum og snarvegamenuni."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Skript til skin-evnarar, ið loyvir brúkarum at velja eitt myndatilfeingis-ískoyti."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Leggur sjálvvirkandi eyka listaprýði til miðlar í tínum miðlasøvnum."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Sangtekstir til tónleik. Krevst fyri at kveikja rørsluligar sangtekstir."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Samrita títt savn og sætt-støðu við trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Búgva til eitt sérgjørt yndi úr völdum Kodi-yndum."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Broyt heimaskíggjamenuna, widgetir, bakgrundir og kunningarlinjur."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Endurstovna heimaskíggjamenuna, widgetir, bakgrundir og kunningarlinjur til standard."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Búgva til eitt sérgjørt yndi úr völdum Kodi-yndum. Til nýtslu í høvuðsmeny-widgetum. Krevst at script.favourites er lagt inn."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Búgva til eitt sérgjørt ískoytis-yndi úr völdum ískoytum. Til nýtslu í høvuðsmeny-widgetum."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Endurstovna skin-evni og litir til standard."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Vel úr einum lista av fyriskipaðum evnum."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Læs stillingar fyri at sløkkja fyri vísingarstøðu, vísingarmøguleikum, kunningardialogi og fullskíggjastillingum."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Sérger heimaskíggjan, yndi, forstillað evni og kiosk-støðu."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Broyt skin-evnis-teksturar."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Sérger litirnar á skin-teksturi."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Sérger bakgrundina og varaloysnir fyri ávís skin-økir."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Kveik ella sløkk ymiskar skin-eginleikar."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Sérger listaprýði og legg stuðlaðar listapakkar inn."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Legg inn og stilla stuðlað ískoyti."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Kveik ella sløkk savnsvísingar. At sløkkja fyri savnsvísingum á minni framkomnum skipanum kann betra um kervið."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Vísir rullibókstav, tá ið rullað verður í savnsvísingum."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Vísir stavraðið fyri at hoppa til eina ávísa støðu í hylkinum. Virkar bert við standardsortering (A-Z)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Vísir leikgongdarstuttumrøðu fyri sjónvarpsrøðir og filmar, um tøk, annars verður tann vanliga leikgongdin víst."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Rulla sjálvvirkandi leikgongdina, um hon ikki rúmast innan fyri víddirnar á stýringini."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Kveik snarvegamenuna fyri skjóta atgongd til ávís skin-økir. Í miðlamenuni, trýst til vinstru fyri at lata upp ella trýst á snarvegaíkonið."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Broyt snarvegamenuna."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Kveik og sløkk evni á toppbjálkanum."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Broyt stillingar fyri videokunning."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Broyt stillingar fyri tónleikakunning."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Broyt stillingar fyri fullskíggjavideo."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Broyt stillingar fyri fullskíggjaljóð."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Minka um støddina á sprettfráboðanum."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Myrkir skíggjan handan dialogsprett. Virkar ikke fyri fullskíggjavideo ella -ljóð."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Kveik litað íkon fyri toppbjálkan, miðlaupplýsingar og savnsvísingar."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Kveik litað, HDR, bitdýpt og málslig miðlamerki."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Varaloysn fyri ljóðfløgumynd yvir alt skinið."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Varaloysn fyri videofløgumynd yvir alt skinið."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Vel og legg inn ein veðuríkonpakka fyri toppbjálkan, widgetir og veður."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Vel og legg inn ein veðurfanartpakka fyri bakgrundir, widgetir og veður."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Legg inn hvít studioíkon til nýtslu í skininum."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Legg inn litað studioíkon til nýtslu í skininum."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Legg inn plátufelagsíkon til nýtslu í skininum."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Legg inn málfløgg fyri savnsvísingar og undirtekstaval."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Legg inn tónleika-sjangruíkon fyri tónleik og tónleikavideo."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Legg inn litað films-sjangruíkon fyri filmar og sjónvarpsrøðir."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Legg inn svørt/hvít films-sjangruíkon fyri filmar og sjónvarpsrøðir."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Legg inn landasúmbol fyri landsknútpunkt hjá filmum."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Set seinkingina millum fanart-skifti yvir alt skinið."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Fallandi bakgrundsárin. Snjór, Bløð osfr."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Vís tónleikafanart fyri verandi spælandi lut yvir alt skinið. Setur seg yvir savns-fanart."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Kveikir tónleikasjóngerð í bakgrundini, tá ið tónleikur spælir. Krevur, at sjóngerð er virkt í Player-stillingum/Tónleiki."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Vís video, ið spælir nú, í bakgrundini, meðan tú fartar í savninum. Setur seg yvir savns-fanart."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Henta myndir og eyka upplýsingar frá fanart.tv og theaudiodb.com fyri listamannin, ið spælir nú. Fyri fullskíggjatónleik, alnótarløkir og útvarp."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Stillingar fyri skript til tónleika-ljósmyndasýning."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "Ein snarvegur til videospælilistan, um hann ikki er tómur."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "Ein snarvegur til tónleikaspælilistan, um hann ikki er tómur."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Snarvegur til fullan skíggja, tá ið miðil spælir."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Trýst fyri at lata snarvegamenuna upp."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Spælarastýring, tá ið miðil spælir."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Spæl næsta part av sjónvarpsrøðini sjálvvirkandi."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Spæl evnisløg, tá ið tú rættar í sjónvarpsrøðum, filmum og tónleikavideoum."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "Savnsknútpunkts-skiftarin loyvir tær at búa til og sérgera egin videoknútpunkt og tónleikaknútpunkt í Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Vís yvirleggsmerki-kunning fyri sæðar, ósæðar og í-gongd miðlalutir."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Eitt skript til at rætta í innbygda RSS-rullaranum hjá Kodi."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Skin-útgáva og endurstovnunarmøguleikar. Endurstovnar øll standardvirði til fyrsta dags keyrslu."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Ískoyti"