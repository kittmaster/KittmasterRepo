# --- Body texts: top row category selectors (controls 901–904, 905) ---

#: /16x9/includes.xml
msgctxt "#31567"
msgid "Highlight a logo from the palette below and click to assign it to 4K / UHD video files."
msgstr "Истакните логотип из палете испод и кликните да бисте га доделили 4K / UHD видео датотекама."

#: /16x9/includes.xml
msgctxt "#31568"
msgid "Highlight a logo from the palette below and click to assign it to WebDL and streaming video sources."
msgstr "Истакните логотип из палете испод и кликните да бисте га доделили WebDL и стриминг видео изворима."

#: /16x9/includes.xml
msgctxt "#31569"
msgid "Highlight a logo from the palette below and click to assign it to 1080p Full HD video files."
msgstr "Истакните логотип из палете испод и кликните да бисте га доделили 1080p Full HD видео датотекама."

#: /16x9/includes.xml
msgctxt "#31570"
msgid "Highlight a logo from the palette below and click to assign it to 720p HD video files."
msgstr "Истакните логотип из палете испод и кликните да бисте га доделили 720p HD видео датотекама."

#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "Истакните логотип из палете испод и кликните да бисте га доделили DVD и видео датотекама стандардне резолуције."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "Прикажи само логотипе ултра високе резолуције и 4K у мрежи палете."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "Прикажи само логотипе HEVC и H.265 кодека у мрежи палете."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Прикажи само логотипе AVC и H.264 кодека у мрежи палете."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Прикажи само логотипе за DivX, XviD и застареле MPEG-4 формате у мрежи палете."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Прикажи класичне MPEG, DVD и логотипе стандардног ТВ емитовања у мрежи палете."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Прикажи логотипе за Windows Media Video и VC-1 кодеке у мрежи палете."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Прикажи омоте контејнера, формате дискова и друге разне логотипе у мрежи палете."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Затвори овај дијалог за прилагођавање заставица и врати се у подешавања."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Истакните било који логотип у средишњој мрежи и кликните да бисте га сачували као своју прилагођену заставицу за активну категорију."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Очистите свој избор прилагођене заставице и вратите ову категорију на аутоматску подразумевану логику заставица маске."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Пребаците глобални изглед заставица између обојених дизајна и једнобојне подразумеване беле боје."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Користите тастере са стрелицама за навигацију кроз опције. Притисните Назад или изаберите Излаз у било ком тренутку да бисте затворили без измена."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Изабери за измену"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Прилагођавање почетног екрана, виџета и менија са пречицама."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Скрипта за креаторе маски која омогућава корисницима да изаберу додатак за ресурсе слика."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Аутоматски додаје додатне уметничке слике за медије у вашим библиотекама медија."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Текстови за музику. Потребно за омогућавање анимираних текстова."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Синхронизујте своју колекцију и статус одгледаности са trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Креирајте прилагођену омиљену ставку од изабраних Коди омиљених ставки."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Уредите мени почетног екрана, виџете, позадине и информативне линије."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Ресетујте мени почетног екрана, виџете, позадине и информативне линије на подразумеване вредности."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Креирајте прилагођену омиљену ставку од изабраних Коди омиљених ставки. За употребу у виџетима главног менија. Захтева да скрипта за омиљене ставке буде инсталирана."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Креирајте прилагођени омиљени додатак од инсталираних додатака. За употребу у виџетима главног менија."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Ресетујте тему и боје маске на подразумеване вредности."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Изаберите са листе предефинисаних тема."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Закључајте подешавања да бисте онемогућили режим приказа, опције приказа, информативни дијалог и подешавања целог екрана."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Прилагодите почетни екран, омиљене ставке, предефинисане теме и киоск режим."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Промените текстуре теме маске."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Прилагодите боје текстуре маске."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Прилагодите позадину и резервна решења за одређене области маске."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Омогућите или онемогућите разне функције маске."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Прилагодите уметничке слике и инсталирајте подржане пакете уметничких слика."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Инсталирајте и конфигуришите подржане додатке."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Омогућите и онемогућите приказе библиотеке. Онемогућавање приказа библиотеке на слабијим системима може побољшати перформансе."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Приказује почетно слово при брзом клизању кроз приказе библиотеке."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Приказује абецеду за скок на позицију у контејнеру. Радиће само за подразумеване методе сортирања (А-Ш)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Приказује кратак садржај (plot outline) за ТВ серије и филмове ако је доступан, у супротном ће приказати подразумевани дужи садржај."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Аутоматски клизи кроз садржај ако не стаје у димензије контроле."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Омогућите мени са пречицама за тренутни приступ одређеним областима маске. У медијском менију кликните лево да бисте га отворили или кликните на икону пречице."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Уредите мени са пречицама."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Омогућите и онемогућите елементе горње траке."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Промените подешавања видео информација."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Промените подешавања музичких информација."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Промените подешавања видео репродукције преко целог екрана."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Промените подешавања аудио репродукције преко целог екрана."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Смањите величину искачућих обавештења."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Затамњује екран иза искачућих дијалога. Није применљиво за видео или аудио преко целог екрана."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Омогућите иконе у боји за горњу траку, медијске информације и приказе библиотеке."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Омогућите обојене, HDR, дубину бита и језичке медијске заставице."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Резервни изглед аудио CD-а на нивоу целе маске."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Резервни изглед видео диска на нивоу целог система маске."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Изаберите и инсталирајте пакет икона за време за горњу траку, виџете и временску прогнозу."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Изаберите и инсталирајте пакет фан-арта за време за позадине, виџете и временску прогнозу."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Инсталирајте беле иконе студија за употребу у целој масци."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Инсталирајте обојене иконе студија за употребу у целој масци."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Инсталирајте иконе издавачких кућа за употребу у целој масци."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Инсталирајте заставице језика за приказе библиотеке и избор титлова."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Инсталирајте иконе музичких жанрова за музику и музичке спотове."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Инсталирајте обојене иконе филмских жанрова за филмове и ТВ серије."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Инсталирајте црно-беле иконе филмских жанрова за филмове и ТВ серије."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Инсталирајте иконе држава за чвор држава у филмовима."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Подесите време одлагања између прелаза фан-арта на нивоу целе маске."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Падајући позадински ефекти. Снег, лишће итд."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Прикажи музички фан-арт тренутно пуштене ставке у целој масци. Наткрива фан-арт библиотеке."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Омогућава музичку визуелизацију у позадини током репродукције музике. Захтева да визуелизација буде омогућена у подешавањима - Подешавања плејера/Музика."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Прикажи тренутно пуштени видео у позадини током прегледања библиотеке. Наткрива фан-арт библиотеке."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Преузми слике и додатне информације са fanart.tv и theaudiodb.com за тренутно пуштеног извођача. За музику преко целог екрана, интернет стримове и радио."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Подешавања скрипте за слајдшоу извођача."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "Пречица до видео плејлисте ако није празна."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "Пречица до музичке плејлисте ако није празна."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Пречица до целог екрана када се медиј репродукује."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Кликните да бисте отворили мени са пречицама."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Контроле плејера када се медиј репродукује."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Аутоматски пусти следећу епизоду ТВ серије."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Пуштај тематске мелодије током навигације кроз ТВ серије, филмове и музичке спотове."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "Уређивач чворова библиотеке вам омогућава да креирате и прилагођавате сопствене видео и музичке чворове унутар Кодија."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Прикажи информације о ознакама преко омота за одгледане, неодгледане и ставке у току репродукције."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Скрипта за уређивање уграђене Кодијеве RSS траке."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Верзија маске и опције опоравка. Враћа све подразумеване вредности на почетно стање од првог дана."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Додаци"