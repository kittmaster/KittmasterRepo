#: /16x9/includes.xml
msgctxt "#31568"
msgid "Highlight a logo from the palette below and click to assign it to WebDL and streaming video sources."
msgstr "Ressalteu un logotip de la paleta següent i feu-hi clic per assignar-lo a les fonts de vídeo WebDL i d'emissió."

#: /16x9/includes.xml
msgctxt "#31569"
msgid "Highlight a logo from the palette below and click to assign it to 1080p Full HD video files."
msgstr "Ressalteu un logotip de la paleta següent i feu-hi clic per assignar-lo als fitxers de vídeo Full HD 1080p."

#: /16x9/includes.xml
msgctxt "#31570"
msgid "Highlight a logo from the palette below and click to assign it to 720p HD video files."
msgstr "Ressalteu un logotip de la paleta següent i feu-hi clic per assignar-lo als fitxers de vídeo HD 720p."

#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "Ressalteu un logotip de la paleta següent i feu-hi clic per assignar-lo als fitxers de vídeo de definició estàndard i DVD."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "Mostra només els dissenys de logotip d'ultra alta definició i 4K a la quadrícula de la paleta."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "Mostra només els dissenys de logotip del còdec HEVC i H.265 a la quadrícula de la paleta."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Mostra només els dissenys de logotip del còdec AVC i H.264 a la quadrícula de la paleta."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Mostra només els dissenys de logotip de format DivX, XviD i format heretat MPEG-4 a la quadrícula de la paleta."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Mostra els dissenys de logotip clàssics de MPEG, DVD i transmissions de televisió estàndard a la quadrícula de la paleta."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Mostra els dissenys de logotip del còdec Windows Media Video i VC-1 a la quadrícula de la paleta."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Mostra embolcalls de contenidors, formats de disc i altres dissenys de logotip diversos a la quadrícula de la paleta."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Tanca aquest diàleg de personalització dels indicadors i torna als paràmetres."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Ressalteu qualsevol disseny de logotip a la quadrícula central i feu-hi clic per desar-lo com a indicador personalitzat per a la categoria activa."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Esborra la selecció d'indicador personalitzat i restaura aquesta categoria a la lògica d'indicadors automàtica per defecte de la pell."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Alterna les imatges dels indicadors de mitjans globals entre els dissenys de colors i el blanc monocromàtic per defecte."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Utilitzeu les tecles de direcció per navegar per les opcions. Premeu Enrere o seleccioneu Surt en qualsevol moment per tancar sense desar els canvis."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Selecciona per modificar"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Personalització de la pantalla d'inici, els ginys i el menú de dreceres."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Script perquè els creadors de pells permetin als usuaris seleccionar un add-on de recursos d'imatge."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Afegeix automàticament imatges addicionals per als continguts de les vostres biblioteques multimèdia."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Lletres per a la música. Requerit per activar les lletres animades."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Sincronitza la vostra col·lecció i l'estat de vist amb trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Crea un preferit personalitzat a partir dels preferits de Kodi seleccionats."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Edita el menú de la pantalla d'inici, els ginys, els fons i les línies d'informació."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Restaura el menú de la pantalla d'inici, els ginys, els fons i les línies d'informació als valors per defecte."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Crea un preferit personalitzat a partir dels preferits de Kodi seleccionats. Per utilitzar en els ginys del menú principal. Cal que l'script de preferits estigui instal·lat."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Crea un add-on preferit personalitzat a partir dels add-ons instal·lats. Per utilitzar en els ginys del menú principal."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Restaura el tema i els colors de la pell als valors per defecte."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Selecciona d'una llista de temes predefinits."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Bloqueja les preferències per desactivar el mode de visualització, les opcions de visualització, el diàleg d'informació i els paràmetres de pantalla completa."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Personalitza la pantalla d'inici, els preferits, els temes predefinits i el mode quiosc."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Canvia les textures del tema de la pell."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Personalitza els colors de la textura de la pell."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Personalitza el fons i les imatges de reserva per a àrees específiques de la pell."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Activa o desactiva diverses característiques de la pell."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Personalitza l'art i instal·la paquets d'art compatibles."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Instal·la i configura els add-ons compatibles."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Activa i desactiva les visualitzacions de la biblioteca. Desactivar les visualitzacions en sistemes de baixes especificacions pot millorar el rendiment."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Mostra la lletra de desplaçament en desplaçar-se per les visualitzacions de la biblioteca."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Mostra l'abecedari per saltar a una posició del contenidor. Només funcionarà per als mètodes d'ordenació per defecte (A-Z)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Mostra el resum de l'argument per a sèries i pel·lícules si està disponible; si no, es mostrarà l'argument per defecte."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Desplaça automàticament l'argument si no s'ajusta a les dimensions del control."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Activa el menú de dreceres per accedir a l'instant a àrees específiques de la pell. Al menú multimèdia, feu clic a l'esquerra per obrir-lo o feu clic a la icona de drecera."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Edita el menú de dreceres."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Activa i desactiva els elements de la barra superior."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Canvia la configuració de la informació del vídeo."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Canvia la configuració de la informació de la música."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Canvia la configuració de vídeo a pantalla completa."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Canvia la configuració d'àudio a pantalla completa."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Redueix la mida de les notificacions emergents."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Fosqueix la pantalla darrere dels diàlegs emergents. No s'aplica al vídeo o àudio a pantalla completa."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Activa les icones de colors per a la barra superior, la informació dels mitjans i les visualitzacions de la biblioteca."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Activa els indicadors de mitjans a color, HDR, profunditat de bits i idioma."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Imatge de disc alternatòria per a CD d'àudio a tota la pell."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Imatge de disc alternatòria per a vídeo a tota la pell."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Selecciona i instal·la un paquet d'icones del temps per a la barra superior, els ginys i el temps."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Selecciona i instal·la un paquet de fanart del temps per als fons, els ginys i el temps."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Instal·la icones d'estudis blanques per utilitzar-les a tota la pell."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Instal·la icones d'estudis a color per utilitzar-les a tota la pell."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Instal·la icones de discogràfiques per utilitzar-les a tota la pell."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Instal·la banderes d'idiomes per a les visualitzacions de la biblioteca i la selecció de subtítols."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Instal·la icones de gènere de música per a música i videoclips."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Instal·la icones de gènere de pel·lícules a color per a pel·lícules i sèries."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Instal·la icones de gènere de pel·lícules en blanc i negre per a pel·lícules i sèries."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Instal·la icones de països per al node de països de les pel·lícules."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Defineix el retard entre les transicions de fanarts a tota la pell."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Efectes de fons de caiguda: neu, fulles, etc."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Mostra el fanart musical del contingut que s'està reproduint a tota la pell. Prevaleix sobre el fanart de la biblioteca."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Activa la visualització de música de fons mentre es reprodueix àudio. Requereix activar la visualització a Paràmetres - Paràmetres del reproductor/Música."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Mostra el vídeo que s'està reproduint en fons mentre es navega per la biblioteca. Prevaleix sobre el fanart de la biblioteca."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Descarrega imatges i informació addicional de fanart.tv i theaudiodb.com de l'artista que s'està reproduint actualment. Per a música a pantalla completa, emissions d'Internet i ràdio."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Configuració de l'script de presentació de l'artista."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "Una drecera a la llista de reproducció de vídeos si no és buida."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "Una drecera a la llista de reproducció de música si no és buida."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Drecera a pantalla completa quan s'estan reproduint mitjans."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Feu clic per obrir el menú de dreceres."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Controls de reproducció quan s'estan reproduint mitjans."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Reprodueix automàticament el proper episodi de la sèrie."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Reprodueix sintonies mentre es navega per sèries, pel·lícules i videoclips."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "L'editor de nodes de la biblioteca us permet crear i configurar nodes de vídeo i música personalitzats dins de Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Mostra marcadors sobreposats d'informació per a elements de mitjans vists, no vists i en curs."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Un script per editar el teletip d'RSS integrat de Kodi."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Versió de la pell i opcions de recuperació. Restaura tots els valors per defecte a l'estat inicial de funcionament."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Add-ons"