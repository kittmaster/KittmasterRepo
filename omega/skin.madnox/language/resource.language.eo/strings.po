#: /16x9/includes.xml
msgctxt "#31565"
msgid "Restore default:"
msgstr "Restaŭri defaŭlton:"

#: /16x9/includes.xml
msgctxt "#31566"
msgid "Toggle Color Scheme:"
msgstr "Baskuligi kolorskemon:"

# --- Body texts: top row category selectors (controls 901–904, 905) ---

#: /16x9/includes.xml
msgctxt "#31567"
msgid "Highlight a logo from the palette below and click to assign it to 4K / UHD video files."
msgstr "Emfazu emblemon el la suba paletro kaj klaku por atribui ĝin al 4K / UHD videodosieroj."

#: /16x9/includes.xml
msgctxt "#31568"
msgid "Highlight a logo from the palette below and click to assign it to WebDL and streaming video sources."
msgstr "Emfazu emblemon el la suba paletro kaj klaku por atribui ĝin al WebDL kaj fluaj videofontoj."

#: /16x9/includes.xml
msgctxt "#31569"
msgid "Highlight a logo from the palette below and click to assign it to 1080p Full HD video files."
msgstr "Emfazu emblemon el la suba paletro kaj klaku por atribui ĝin al 1080p Full HD videodosieroj."

#: /16x9/includes.xml
msgctxt "#31570"
msgid "Highlight a logo from the palette below and click to assign it to 720p HD video files."
msgstr "Emfazu emblemon el la suba paletro kaj klaku por atribui ĝin al 720p HD videodosieroj."

#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "Emfazu emblemon el la suba paletro kaj klaku por atribui ĝin al DVD kaj normaj videodosieroj."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "Montri nur ultra-distingivajn kaj 4K emblemojn en la paletra krado."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "Montri nur HEVC kaj H.265 kodekajn emblemojn en la paletra krado."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Montri nur AVC kaj H.264 kodekajn emblemojn en la paletra krado."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Montri nur DivX, XviD kaj heredaĵajn MPEG-4 emblemojn en la paletra krado."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Montri klasikajn MPEG, DVD kaj normajn televidajn elsendajn emblemojn en la paletra krado."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Montri Windows Media Video kaj VC-1 kodekajn emblemojn en la paletra krado."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Montri ujo-enpakilojn, diskformatojn kaj aliajn diversajn emblemojn en la paletra krado."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Fermi ĉi tiun dialogon de flaga personigo kaj reveni al agordoj."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Emfazu iun emblemon en la centra krado kaj klaku por konservi ĝin kiel vian propran flagon por la aktuala kategorio."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Forigi vian propran flagelekton kaj restaŭri ĉi tiun kategorion al la aŭtomata defaŭlta flago de la haŭto."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Baskuligi la tutmondajn flagojn inter koloraj desegnoj kaj unukolora defaŭlta blanko."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Uzu viajn direktajn klavojn por navigi opciojn. Premu Retroiron aŭ elektu Eliri iam ajn por fermi sen konservi ŝanĝojn."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Elekti por modifi"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Personigo de la hejma ekrano, fenestraĵoj kaj fulmvoja menuo."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Skripto por haŭto-kreantoj, kiu ebligas al uzantoj elekti bildrimedan aldonprogramon."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Aŭtomate aldonas kromajn artaĵojn por aŭdvidaĵoj en vias plurmediaj bibliotekoj."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Kantsignoj por muziko. Bezoniĝas por aktivigi vigligitajn kantsignojn."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Sinkronigi vian kolekton kaj rigarditan statuson kun trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Krei propran preferataĵon el elektitaj preferataĵoj de Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Redakti la hejman ekranan menuon, fenestraĵojn, fonojn kaj informliniojn."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Restaŭri la hejman ekranan menuon, fenestraĵojn, fonojn kaj informliniojn al la defaŭlto."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Krei propran preferataĵon el elektitaj preferataĵoj de Kodi. Por uzo en ĉefmenuaj fenestraĵoj. Postulas instaladon de la preferataĵa skripto."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Krei propran preferatan aldonprogramon el instalitaj aldonprogramoj. Por uzo en ĉefmenuaj fenestraĵoj."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Restaŭri la etoson kaj kolorojn de la haŭto al defaŭlto."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Elekti el listo de antaŭdifinitaj etosoj."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Ŝlosi agordojn por malaktivigi vidreĝimon, vidopciojn, informdialogon kaj plenekranajn agordojn."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Personecigi la hejman ekranon, preferataĵojn, antaŭdifinitajn etosojn kaj kioskan reĝimon."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Ŝanĝi teksturojn de la haŭta etoso."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Personecigi la kolorojn de la haŭtaj teksturoj."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Personecigi la fonojn kaj rezervajn agordojn por specifaj haŭtaj areoj."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Aktivigi aŭ malaktivigi diversajn trajtojn de la haŭto."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Personecigi artaĵojn kaj instali subtenatajn artaĵpakojn."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Instali kaj agordi subtenatajn aldonprogramojn."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Aktivigi kaj malaktivigi bibliotekajn vidojn. Malaktivigo de bibliotekaj vidojn sur malfortaj sistemoj povas plibonigi rendimenton."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Montras rulan literon dum rulumado en bibliotekaj vidoj."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Montras la alfabeton por salti al specifa pozicio de la ujo. Nur funkcias por defaŭltaj ordigaj metodoj (A-Z)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Montras skizan scenaron por televidserioj kaj filmoj se disponeble, alie montras la defaŭltan scenaron."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Aŭtomate rulumas la scenaron se ĝi ne sidas en la dimensioj de la fenestro."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Aktivigi la fulmvojan menuon por tuja aliro al specifaj haŭtaj areoj. En la plurmedia menuo, klaku maldekstren por malfermi aŭ klaku sur la fulmvojan piktogramon."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Redakti la fulmvojan menuon."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Aktivigi kaj malaktivigi la elementojn de la supra breto."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Ŝanĝi agordojn pri videaj informoj."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Ŝanĝi agordojn pri muzikaj informoj."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Ŝanĝi agordojn de plenekrana video."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Ŝanĝi agordojn de plenekrana audio."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Malpliigi la grandecon de ŝprucsicigoj."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Malklarigas la ekranon malantaŭ dialogaj ŝprucoj. Ne aplikeblas al plenekrana video aŭ audio."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Aktivigi kolorajn piktogramojn por la supra breto, plurmediaj informoj kaj bibliotekaj vidoj."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Aktivigi kolorajn, HDR, bitprofundajn kaj lingvajn plurmediajn flagojn."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Rezerva KD-arto por audio tra la tuta haŭto."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Rezerva KD-arto por video tra la tuta haŭto."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Elekti kaj instali veter-piktograman pakon por la supra breto, fenestraĵoj kaj vetero."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Elekti kaj instali fankartan veterpakon por la fonoj, fenestraĵoj kaj vetero."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Instali blankajn studio-emblemojn por uzo tra la haŭto."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Instali kolorajn studio-emblemojn por uzo tra la haŭto."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Instali muzikeldonejajn emblemojn por uzo tra la haŭto."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Instali lingvajn flagojn por bibliotekaj vidojn kaj elekto de subtekstoj."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Instali muzikĝenrajn piktogramojn por muziko kaj muzikfilmetoj."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Instali kolorajn filmoĝenrajn piktogramojn por filmoj kaj televidserioj."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Instali nigrablankajn filmoĝenrajn piktogramojn por filmoj kaj televidserioj."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Instali landajn piktogramojn por la landnoda sekcio de filmoj."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Agordi la prokraston inter alternado de fankartoj tra la tuta haŭto."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Falantaj fonaj efektoj (neĝo, folioj ktp)."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Montri muzikan fankarton de nuntempe ludata ero tra la tuta haŭto. Preterpasas bibliotekan fankarton."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Aktivigas muzikan vidigon en fono dum ludado de muziko. Postulas ke vidigo estu aktivigita en agordoj - Ludilaj agordoj/Muziko."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Montri nuntempe ludatan videon en fono dum foliumado de la biblioteko. Preterpasas bibliotekan fankarton."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Elŝuti bildojn kaj kromajn informojn de fanart.tv kaj theaudiodb.com de la nuntempe ludata artisto. Por plenekrana muziko, interretaj fluoj kaj radio."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Agordoj pri la skripto por artista lumbildoprezento."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "Fulmvojo al la videa ludlisto se ĝi ne estas malplena."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "Fulmvojo al la muzika ludlisto se ĝi ne estas malplena."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Fulmvojo al plenekrano kiam plurmedio ludas."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Klaki por malfermi la fulmvojan menuon."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Ludilaj regiloj kiam plurmedio ludas."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Aŭtomate ludi la sekvan epizodon de televidserio."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Ludi etosajn melodiojn dum foliumado de televidserioj, filmoj kaj muzikfilmetoj."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "La Biblioteka Nod-Redaktilo ebligas krei kaj personecigi proprajn videajn nodojn kaj muzikajn nodojn en Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Montri surmetajn markilajn informojn pri rigarditaj, nerigarditaj kaj progresantaj plurmediaj eroj."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Skripto por redakti la enkonstruitan RSS-teleksilon de Kodi."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Haŭtversio kaj reakiraj opcioj. Restaŭras ĉiujn defaŭltojn al la funkcio de la unua tago."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Aldonprogramoj"