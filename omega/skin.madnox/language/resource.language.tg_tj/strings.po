# --- Body texts: top row category selectors (controls 901–904, 905) ---

#: /16x9/includes.xml
msgctxt "#31567"
msgid "Highlight a logo from the palette below and click to assign it to 4K / UHD video files."
msgstr "Логотипро аз палитраи зер равшан кунед ва клик кунед, то онро ба файлҳои видеоии 4K / UHD таъйин кунед."

#: /16x9/includes.xml
msgctxt "#31568"
msgid "Highlight a logo from the palette below and click to assign it to WebDL and streaming video sources."
msgstr "Логотипро аз палитраи зер равшан кунед ва клик кунед, то онро ба WebDL ва манбаъҳои видеоии ҷараёнӣ таъйин кунед."

#: /16x9/includes.xml
msgctxt "#31569"
msgid "Highlight a logo from the palette below and click to assign it to 1080p Full HD video files."
msgstr "Логотипро аз палитраи зер равшан кунед ва клик кунед, то онро ба файлҳои видеоии 1080p Full HD таъйин кунед."

#: /16x9/includes.xml
msgctxt "#31570"
msgid "Highlight a logo from the palette below and click to assign it to 720p HD video files."
msgstr "Логотипро аз палитраи зер равшан кунед ва клик кунед, то онро ба файлҳои видеоии 720p HD таъйин кунед."

#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "Логотипро аз палитраи зер равшан кунед ва клик кунед, то онро ба файлҳои видеоии DVD ва сифати стандартии SD таъйин кунед."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "Танҳо тарҳҳои логотипи ултра-баланд ва 4K-ро дар шабакаи палитра намоиш диҳед."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "Танҳо тарҳҳои логотипи кодекҳои HEVC ва H.265-ро дар шабакаи палитра намоиш диҳед."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Танҳо тарҳҳои логотипи кодекҳои AVC ва H.264-ро дар шабакаи палитра намоиш диҳед."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Танҳо тарҳҳои логотипи форматҳои DivX, XviD ва MPEG-4-и кӯҳнаро дар шабакаи палитра намоиш диҳед."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Тарҳҳои классикии логотипи MPEG, DVD ва пахши телевизиони стандартиро дар шабакаи палитра намоиш диҳед."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Тарҳҳои логотипи кодекҳои Windows Media Video ва VC-1-ро дар шабакаи палитра намоиш диҳед."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Контейнерҳо, форматҳои диск ва дигар тарҳҳои гуногуни логотипро дар шабакаи палитра намоиш диҳед."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Ин равзанаи шахсисозии парчамро пӯшед ва ба танзимотҳо баргардед."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Ҳар як тарҳи логотипро дар шабакаи марказӣ равшан кунед ва клик кунед, то онро ҳамчун парчами фармоишии худ барои категорияи фаъол захира кунед."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Интихоби парчами фармоишии худро нест кунед ва ин категорияро ба мантиқи автоматии парчами пешфарзи пӯст барқарор кунед."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Гузариши тарҳҳои парчамҳои глобалӣ байни тарҳҳои ранга ва ранги сафеди пешфарзи монохромӣ."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Барои паймоиши имконот тугмаҳои самтро истифода баред. Барои пӯшидан бидуни тағирот, дар вақти дилхоҳ тугмаи 'Бозгашт'-ро пахш кунед ё 'Хуруҷ'-ро интихоб кунед."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Интихоб барои тағир додан"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Шахсисозии экрани асосӣ, виҷетҳо ва менюи миёнабурҳо."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Скрипт барои тарроҳони пӯст, ки ба корбарон имкон медиҳад иловаи манбаи тасвирро интихоб кунанд."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Ба таври худкор тасвирҳои иловагиро барои медиа дар китобхонаҳои медиавии шумо илова мекунад."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Матни суруд барои мусиқӣ. Барои фаъол кардани матни аниматсионии суруд лозим аст."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Ҳамоҳангсозии маҷмӯа ва ҳолати тамошои шумо бо trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Эҷоди дӯстдоштаи фармоишӣ аз дӯстдоштаҳои интихобшудаи Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Таҳрири менюи экрани асосӣ, виҷетҳо, заминаҳо ва сатрҳои иттилоотӣ."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Бозсозии менюи экрани асосӣ, виҷетҳо, заминаҳо ва сатрҳои иттилоотӣ ба ҳолати пешфарз."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Эҷоди дӯстдоштаи фармоишӣ аз дӯстдоштаҳои интихобшудаи Kodi. Барои истифода дар виҷетҳои менюи асосӣ. Насб кардани скрипти дӯстдоштаҳоро талаб мекунад."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Эҷоди иловаи дӯстдоштаи фармоишӣ аз иловаҳои насбшуда. Барои истифода дар виҷетҳои менюи асосӣ."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Бозсозии мавзӯи пӯст ва рангҳо ба ҳолати пешфарз."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Интихоб аз рӯйхати мавзӯъҳои қаблан муайяншуда."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Қулф кардани танзимот барои ғайрифаъол кардани режими намоиш, имконоти намоиш, муколамаи иттилоотӣ ва танзимоти пурраэкранӣ."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Шахсисозии экрани асосӣ, дӯстдоштаҳо, мавзӯъҳои қаблан муайяншуда ва режими киоск."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Тағир додани текстураҳои мавзӯи пӯст."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Шахсисозии рангҳои текстураи пӯст."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Шахсисозии замина ва захираҳо барои минтақаҳои муайяни пӯст."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Фаъол ё ғайрифаъол кардани хусусиятҳои гуногуни пӯст."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Шахсисозии артворк ва насб кардани бастаҳои дастгиришавандаи расмҳо."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Насб ва танзим кардани иловаҳои дастгиришаванда."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Фаъол ва ғайрифаъол кардани намудҳои китобхона. Ғайрифаъол кардани намудҳои китобхона дар системаҳои суст метавонад маҳсулнокиро беҳтар кунад."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Ҳангоми ҳаракат дар намудҳои китобхона ҳарфи ҳаракаткунандаро нишон медиҳад."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Алифбоеро барои гузариш ба мавқеи контейнер нишон медиҳад. Танҳо барои усулҳои батартибдарории пешфарз (А-Я) кор мекунад."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Хулосаи сужаро барои намоишҳои ТВ ва филмҳо, агар мавҷуд бошад, нишон медиҳад, вагарна сужаи пешфарз намоиш дода мешавад."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Агар сужа ба андозаҳои унсури назоратӣ мувофиқ наояд, онро ба таври худкор мечархонад."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Фаъол кардани менюи миёнабурҳо барои дастрасии фаврӣ ба минтақаҳои муайяни пӯст. Дар менюи медиа ба чап клик кунед, то кушоед, ё нишонаи миёнабурро клик кунед."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Таҳрири менюи миёнабурҳо."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Фаъол ва ғайрифаъол кардани унсурҳои навори болоӣ."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Тағир додани танзимоти иттилооти видеоӣ."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Тағир додани танзимоти иттилооти мусиқӣ."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Тағир додани танзимоти видеои пурраэкранӣ."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Тағир додани танзимоти аудиои пурраэкранӣ."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Кам кардани андозаи огоҳиномаҳои пайдошаванда."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Экранро дар паси муколамаҳои пайдошаванда торик мекунад. Барои видео ё аудиои пурраэкранӣ татбиқ намегардад."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Фаъол кардани нишонаҳои ранга барои навори болоӣ, иттилооти медиа ва намудҳои китобхона."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Фаъол кардани парчамҳои медиавии ранга, HDR, умқи бит ва забонӣ."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Захираи расми диски аудиоӣ дар тамоми система."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Захираи расми диски видеоӣ дар тамоми система."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Интихоб ва насб кардани бастаи нишонаҳои обу ҳаво барои навори болоӣ, виҷетҳо ва обу ҳаво."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Интихоб ва насб кардани бастаи фанарти обу ҳаво барои заминаҳо, виҷетҳо ва обу ҳаво."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Насб кардани нишонаҳои сафеди студияҳо барои истифода дар тамоми пӯст."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Насб кардани нишонаҳои рангаи студияҳо барои истифода дар тамоми пӯст."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Насб кардани нишонаҳои лейблҳои сабт барои истифода дар тамоми пӯст."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Насб кардани парчамҳои забонҳо барои намудҳои китобхона ва интихоби субтитрҳо."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Насб кардани нишонаҳои жанри мусиқӣ барои мусиқӣ ва клипҳои мусиқӣ."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Насб кардани нишонаҳои рангаи жанри филм барои филмҳо ва намоишҳои ТВ."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Насб кардани нишонаҳои сиёҳу сафеди жанри филм барои филмҳо ва намоишҳои ТВ."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Насб кардани нишонаҳои кишварҳо барои гиреҳи кишварҳои филм."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Танзими таъхир байни гузаришҳои фанарт дар тамоми пӯст."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Эффектҳои заминаи резанда. Барф, баргҳо ва ғайра."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Намоиши фанарти мусиқии унсури ҷории пахшшаванда дар тамоми пӯст. Фанарти китобхонаро бекор мекунад."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Визуализатсияи мусиқиро дар замина ҳангоми пахши мусиқӣ фаъол мекунад. Фаъол будани визуализатсияро дар танзимотҳо - Танзимоти плеер/Мусиқӣ талаб мекунад."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Намоиши видеои ҷорӣ дар замина ҳангоми дидани китобхона. Фанарти китобхонаро бекор мекунад."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Зеркашии тасвирҳо ва иттилооти иловагӣ аз fanart.tv ва theaudiodb.com барои ҳунарпешаи ҷорӣ. Барои мусиқии пурраэкранӣ, ҷараёнҳои интернетӣ ва радио."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Танзимоти скрипти слайдшоуи ҳунарманд."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "Миёнабур ба рӯйхати пахши видео, агар холӣ набошад."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "Миёнабур ба рӯйхати пахши мусиқӣ, агар холӣ набошад."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Миёнабур ба ҳолати пурраэкранӣ ҳангоми пахши медиа."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Барои кушодани менюи миёнабурҳо клик кунед."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Идоракунии плеер ҳангоми пахши медиа."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Пахши худкори қисми навбатии намоиши ТВ."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Пахш кардани мавзӯъҳои мусиқӣ ҳангоми дидани намоишҳои ТВ, филмҳо ва клипҳои мусиқӣ."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "Муҳаррири гиреҳҳои китобхона ба шумо имкон медиҳад, ки гиреҳҳои видеоӣ ва мусиқии фармоиширо дар Kodi эҷод ва шахсисозӣ кунед."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Намоиши иттилооти нишонгузор барои унсурҳои медиавии тамошошуда, тамошонашуда ва дар ҳоли иҷро."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Скрипт барои таҳрири RSS Ticker-и дохилии Kodi."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Версияи пӯст ва имконоти барқароркунӣ. Ҳама танзимоти пешфарзро ба ҳолати рӯзи аввал бармегардонад."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Иловаҳо"