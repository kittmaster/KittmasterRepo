# --- Body texts: top row category selectors (controls 901–904, 905) ---

#: /16x9/includes.xml
msgctxt "#31567"
msgid "Highlight a logo from the palette below and click to assign it to 4K / UHD video files."
msgstr "Quyidagi palitradan logotipni belgilang va uni 4K / UHD video fayllariga biriktirish uchun bosing."

#: /16x9/includes.xml
msgctxt "#31568"
msgid "Highlight a logo from the palette below and click to assign it to WebDL and streaming video sources."
msgstr "Quyidagi palitradan logotipni belgilang va uni WebDL hamda oqimli video manbalariga biriktirish uchun bosing."

#: /16x9/includes.xml
msgctxt "#31569"
msgid "Highlight a logo from the palette below and click to assign it to 1080p Full HD video files."
msgstr "Quyidagi palitradan logotipni belgilang va uni 1080p Full HD video fayllariga biriktirish uchun bosing."

#: /16x9/includes.xml
msgctxt "#31570"
msgid "Highlight a logo from the palette below and click to assign it to 720p HD video files."
msgstr "Quyidagi palitradan logotipni belgilang va uni 720p HD video fayllariga biriktirish uchun bosing."

#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "Quyidagi palitradan logotipni belgilang va uni DVD hamda standart aniqlikdagi video fayllariga biriktirish uchun bosing."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "Palitra panjarasida faqat o'ta yuqori aniqlikdagi va 4K logotip namunalarini ko'rish."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "Palitra panjarasida faqat HEVC va H.265 kodekli logotip namunalarini ko'rish."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Palitra panjarasida faqat AVC va H.264 kodekli logotip namunalarini ko'rish."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Palitra panjarasida faqat DivX, XviD va eski MPEG-4 formatidagi logotip namunalarini ko'rish."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Palitra panjarasida klassik MPEG, DVD va standart TV efiri logotip namunalarini ko'rish."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Palitra panjarasida Windows Media Video va VC-1 kodekli logotip namunalarini ko'rish."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Palitra panjarasida konteyner qobiqlari, disk formatlari va boshqa turli xil logotip namunalarini ko'rish."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Ushbu bayroqchalarni moslashtirish muloqot oynasini yopish va sozlamalarga qaytish."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Markaziy panjaradagi istalgan logotip namunasini belgilang va uni faol kategoriya uchun maxsus bayroqcha sifatida saqlash uchun bosing."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Maxsus tanlangan bayroqchangizni o'chirish va ushbu kategoriyani interfeysning avtomatik standart mantiqiga qaytarish."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Global bayroqcha san'atini rangli va oq-qora standart dizaynlar orasida almashtirish."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Variantlar bo'ylab harakatlanish uchun yo'nalish tugmalaridan foydalaning. O'zgarishlarsiz yopish uchun istalgan vaqtda 'Orqaga' tugmasini bosing yoki 'Chiqish'ni tanlang."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "O'zgartirish uchun tanlang"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Bosh ekran, vidjetlar va tezkor tugmalar menyusini moslashtirish."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Foydalanuvchilarga tasvirlar manbai plaginini tanlash imkonini beruvchi interfeys yaratuvchilari uchun skript."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Media kutubxonalaringizdagi media obyektlari uchun avtomatik ravishda qo'shimcha rasmlarni qo'shadi."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Musiqa matnlari. Animatsiyali matnlarni yoqish uchun zarur."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "To'plamingiz va ko'rilganlik holatini trakt.tv bilan sinxronlashtiring."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Tanlangan kodi saralanganlaridan maxsus saralangan obyekt yarating."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Bosh ekran menyusi, vidjetlar, fonlar va ma'lumotlar satrlarini tahrirlang."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Bosh ekran menyusi, vidjetlar, fonlar va ma'lumotlar satrlarini standart holatiga qaytaring."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Tanlangan kodi saralanganlaridan maxsus saralangan obyekt yarating. Asosiy menyu vidjetlarida foydalanish uchun. Saralanganlar skripti o'rnatilgan bo'lishi talab etiladi."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "O'rnatilgan plaginlardan maxsus saralangan plagin yarating. Asosiy menyu vidjetlarida foydalanish uchun."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Interfeys mavzusi va ranglarini standart holatiga qaytaring."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Oldindan belgilangan mavzular ro'yxatidan tanlang."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Ko'rish rejimi, ko'rish parametrlari, ma'lumot muloqot oynasi va butun ekran sozlamalarini o'chirib qo'yish uchun sozlamalarni qulflang."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Bosh ekran, saralanganlar, oldindan belgilangan mavzular va kiosk rejimini moslashtiring."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Interfeys mavzusi teksturalarini o'zgartiring."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Interfeys tekstura ranglarini moslashtiring."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Muayyan interfeys sohalari uchun fon va zaxiralarni moslashtiring."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Turli interfeys funksiyalarini yoqing yoki o'chiring."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Rassomlik ishlarini moslashtiring va qo'llab-quvvatlanadigan rasm paketlarini o'rnating."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Qo'llab-quvvatlanadigan plaginlarni o'rnating va sozlang."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Kutubxona ko'rinishlarini yoqing va o'chiring. Kuchsiz tizimlarda kutubxona ko'rinishlarini o'chirish unumdorlikni oshirishi mumkin."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Kutubxona ko'rinishlarida aylantirilganda aylantirish harfini ko'rsatadi."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Konteyner holatiga o'tish uchun alifboni ko'rsatadi. Faqat standart saralash usullarida ishlaydi (A-Z)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Mavjud bo'lsa, seriallar va filmlar uchun syujet qisqacha mazmunini ko'rsatadi, aks holda standart syujetni ko'rsatadi."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Agar syujet matni boshqaruv o'lchamlariga sig'masa, uni avtomatik aylantiradi."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Muayyan interfeys sohalariga tezkor kirish uchun tezkor menyuni yoqing. Media menyusida ochish uchun chapga bosing yoki tezkor tugma belgisini bosing."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Tezkor menyuni tahrirlash."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Yuqori panel elementlarini yoqing va o'chiring."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Video ma'lumotlari sozlamalarini o'zgartiring."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Musiqa ma'lumotlari sozlamalarini o'zgartiring."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Butun ekranli video sozlamalarini o'zgartiring."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Butun ekranli audio sozlamalarini o'zgartiring."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Qalqib chiquvchi bildirishnomalar hajmini kichraytiring."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Muloqot oynalari ortidagi ekranni qoraytiradi. Butun ekranli video yoki audioga nisbatan qo'llanilmaydi."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Yuqori panel, media ma'lumotlari va kutubxona ko'rinishlari uchun rangli piktogrammalarni yoqing."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Rangli, HDR, bit chuqurligi va tilga oid media bayroqchalarini yoqing."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Butun tizim bo'ylab audio CD diski rasmining zaxira foni."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Butun tizim bo'ylab video CD diski rasmining zaxira foni."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Yuqori panel, vidjetlar va ob-havo uchun ob-havo piktogrammalari paketini tanlang va o'rnating."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Fon rasmlari, vidjetlar va ob-havo uchun ob-havo fan-art paketini tanlang va o'rnating."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Butun interfeys bo'ylab foydalanish uchun oq rangli studiya piktogrammalarini o'rnating."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Butun interfeys bo'ylab foydalanish uchun rangli studiya piktogrammalarini o'rnating."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Butun interfeys bo'ylab foydalanish uchun ovoz yozish studiyasi piktogrammalarini o'rnating."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Kutubxona ko'rinishlari va subtitrlarni tanlash uchun til bayroqlarini o'rnating."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Musiqa va kliplar uchun musiqa janri piktogrammalarini o'rnating."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Filmlar va seriallar uchun rangli kino janri piktogrammalarini o'rnating."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Filmlar va seriallar uchun oq-qora kino janri piktogrammalarini o'rnating."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Filmlar mamlakatlari tuguni uchun mamlakat piktogrammalarini o'rnating."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Butun tizim bo'ylab fan-art almashinuvi orasidagi kechikishni belgilang."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Tushayotgan ob-havo fon effektlari (Qor, Barglar va hokazo)."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Butun tizim bo'ylab hozir ijro etilayotgan obyektning musiqa fan-artini ko'rsatish. Kutubxona fan-artidan ustun turadi."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Musiqa ijro etilayotganda fonda musiqa vizualizatsiyasini yoqadi. Vizualizatsiya o'yinchi sozlamalari/Musiqa bo'limida yoqilgan bo'lishi kerak."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Kutubxonani ko'rib chiqayotganda hozir ijro etilayotgan videoni fonda ko'rsatish. Kutubxona fan-artidan ustun turadi."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Hozir ijro etayotgan ijrochining rasmlari va qo'shimcha ma'lumotlarini fanart.tv va theaudiodb.com saytlaridan yuklab oling. Butun ekranli musiqa, internet oqimlari va radio uchun."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Ijrochi slayd-shousi skripti sozlamalari."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "Bo'sh bo'lmasa, video pleylistiga tezkor yo'l."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "Bo'sh bo'lmasa, musiqa pleylistiga tezkor yo'l."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Media ijro etilayotganda butun ekranga o'tish tezkor tugmasi."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Tezkor menyuni ochish uchun bosing."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Media ijro etilayotganda o'yinchi boshqaruvlari."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Serialning keyingi qismini avtomatik ravishda ijro etish."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Seriallar, Filmlar va Kliplar bo'ylab harakatlanayotganda musiqiy mavzularni ijro etish."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "Kutubxona tugunlari tahrirlovchisi Kodi ichida maxsus video va musiqa tugunlarini yaratish hamda sozlash imkonini beradi."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Ko'rilgan, ko'rilmagan va jarayondagi media elementlari uchun ustki belgilar ma'lumotlarini ko'rsatish."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Kodi-ning o'rnatilgan RSS satrini tahrirlash uchun skript."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Interfeys versiyasi va tiklash parametrlari. Barcha standart sozlamalarni dastlabki holatiga qaytaradi."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Plaginlar"