msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "Visualizar apenas designs de logótipo de codec HEVC e H.265 na grelha da paleta."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Visualizar apenas designs de logótipo de codec AVC e H.264 na grelha da paleta."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Visualizar apenas designs de logótipo de formato DivX, XviD e MPEG-4 antigo na grelha da paleta."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Visualizar apenas designs de logótipo clássicos MPEG, DVD e de transmissão de TV padrão na grelha da paleta."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Visualizar apenas designs de logótipo de codec Windows Media Video e VC-1 na grelha da paleta."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Visualizar formatos de contentor, formatos de disco e outros designs de logótipos diversos na grelha da paleta."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Fechar esta janela de personalização de sinalizadores e voltar às definições."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Realce qualquer design de logótipo na grelha central e prima para o guardar como o seu sinalizador personalizado para a categoria ativa."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Limpar a sua escolha de sinalizador personalizado e restaurar esta categoria para a lógica automática de sinalizadores do skin."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Alternar a arte dos sinalizadores globais entre designs coloridos e o branco padrão monocromático."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Utilize as suas teclas direcionais para navegar pelas opções. Prima Retroceder ou selecione Sair a qualquer momento para fechar sem guardar as alterações."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Selecionar para modificar"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Personalização do ecrã inicial, widgets e menu de atalhos."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Script para criadores de skins que permite aos utilizadores selecionar um add-on de recursos de imagem."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Adiciona automaticamente arte extra para os ficheiros de média nas suas bibliotecas."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Letras para música. Necessário para ativar letras animadas."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Sincronize a sua coleção e o estado de visualização com o trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Crie um favorito personalizado a partir dos favoritos selecionados do Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Edite o menu do ecrã inicial, widgets, fundos e linhas de informação."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Reponha o menu do ecrã inicial, widgets, fundos e linhas de informação para os valores predefinidos."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Crie um favorito personalizado a partir dos favoritos selecionados do Kodi. Para uso em widgets do menu principal. Requer que o script de favoritos esteja instalado."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Crie um favorito de add-on personalizado a partir dos add-ons instalados. Para uso em widgets do menu principal."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Reponha o tema e as cores do skin para os valores predefinidos."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Selecione a partir de uma lista de temas predefinidos."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Bloqueie as preferências para desativar o modo de visualização, opções de visualização, janela de informação e definições de ecrã inteiro."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Personalize o ecrã inicial, favoritos, temas predefinidos e o modo quiosque."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Altere as texturas do tema do skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Personalize as cores das texturas do skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Personalize o fundo e as alternativas para áreas específicas do skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Ative ou desative várias funcionalidades do skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Personalize a arte e instale pacotes de arte suportados."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Instale e configure os add-ons suportados."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Ative e desative as visualizações da biblioteca. Desativar as visualizações da biblioteca em sistemas de baixo desempenho pode melhorar a fluidez."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Mostra a letra de deslocamento ao navegar pelas visualizações da biblioteca."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Mostra o alfabeto para saltar para uma posição do contentor. Apenas funciona nos métodos de ordenação padrão (A-Z)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Mostra o resumo do enredo para séries de TV e filmes, se disponível; caso contrário, mostra o enredo padrão."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Desloca automaticamente o texto do enredo se este não couber nas dimensões do controlo."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Ative o menu de atalhos para acesso instantâneo a áreas específicas do skin. No menu de média, clique para a esquerda para abrir ou clique no ícone do atalho."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Edite o menu de atalhos."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Ative e desative os elementos da barra superior."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Altere as definições de informação de vídeo."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Altere as definições de informação de música."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Altere as definições de ecrã inteiro para vídeo."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Altere as definições de ecrã inteiro para áudio."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Reduza o tamanho das notificações pop-up."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Escurece o ecrã por trás das janelas de diálogo pop-up. Não aplicável a vídeo ou áudio em ecrã inteiro."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Ative ícones coloridos para a barra superior, informação de média e visualizações da biblioteca."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Ative os sinalizadores de média coloridos, de HDR, profundidade de bits e idioma."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Alternativa global da arte de CD de áudio no skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Alternativa global da arte de disco de vídeo no skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Selecione e instale um pacote de ícones meteorológicos para a barra superior, widgets e meteorologia."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Selecione e instale um pacote de fanart meteorológica para fundos, widgets e meteorologia."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Instale ícones brancos de estúdios para usar em todo o skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Instale ícones coloridos de estúdios para usar em todo o skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Instale ícones de editoras discográficas para usar em todo o skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Instale bandeiras de idiomas para as visualizações da biblioteca e seleção de legendas."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Instale ícones de géneros musicais para música e videoclipes."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Instale ícones coloridos de géneros cinematográficos para filmes e séries de TV."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Instale ícones a preto e branco de géneros cinematográficos para filmes e séries de TV."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Instale ícones de países para o nó de países dos filmes."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Defina o atraso global das transições de fanart no skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Efeitos de fundo de queda livre. Neve, folhas, etc."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Mostra a fanart de música do item em reprodução em todo o skin. Sobrepõe-se à fanart da biblioteca."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Ativa a visualização de música em segundo plano enquanto a música é reproduzida. Requer que a visualização esteja ativada nas definições do leitor > Música."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Mostra o vídeo em reprodução em segundo plano enquanto navega pela biblioteca. Sobrepõe-se à fanart da biblioteca."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Transfere imagens e informações adicionais do fanart.tv e do theaudiodb.com para o artista atualmente em reprodução. Para música em ecrã inteiro, transmissões de internet e rádio."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Definições do script da apresentação de diapositivos do artista."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "Um atalho para a lista de reprodução de vídeo, se não estiver vazia."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "Um atalho para a lista de reprodução de música, se não estiver vazia."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Atalho para ecrã inteiro quando há ficheiros de média em reprodução."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Prima para abrir o menu de atalhos."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Controlos do leitor quando há ficheiros de média em reprodução."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Reproduz o episódio seguinte da série de TV de forma automática."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Reproduz os temas musicais enquanto navega por séries de TV, filmes e videoclipes."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "O Editor de Nós de Biblioteca permite-lhe criar e personalizar nós de vídeo e nós de música dentro do Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Mostra informações de marcação de sobreposição para itens de média vistos, não vistos e em progresso."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Um script para editar a barra de RSS integrada do Kodi."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Versão do skin e opções de recuperação. Restaura todos os valores predefinidos para o estado original de instalação."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Add-ons"