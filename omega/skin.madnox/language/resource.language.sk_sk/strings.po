msgid "Restore default:"
msgstr "Obnoviť predvolené:"

#: /16x9/includes.xml
msgctxt "#31566"
msgid "Toggle Color Scheme:"
msgstr "Prepnúť farebnú schému:"

# --- Body texts: top row category selectors (controls 901–904, 905) ---

#: /16x9/includes.xml
msgctxt "#31567"
msgid "Highlight a logo from the palette below and click to assign it to 4K / UHD video files."
msgstr "Zvýraznite logo z palety nižšie a kliknutím ho priraďte k videosúborom 4K / UHD."

#: /16x9/includes.xml
msgctxt "#31568"
msgid "Highlight a logo from the palette below and click to assign it to WebDL and streaming video sources."
msgstr "Zvýraznite logo z palety nižšie a kliknutím ho priraďte k zdrojom videa WebDL a streamom."

#: /16x9/includes.xml
msgctxt "#31569"
msgid "Highlight a logo from the palette below and click to assign it to 1080p Full HD video files."
msgstr "Zvýraznite logo z palety nižšie a kliknutím ho priraďte k videosúborom 1080p Full HD."

#: /16x9/includes.xml
msgctxt "#31570"
msgid "Highlight a logo from the palette below and click to assign it to 720p HD video files."
msgstr "Zvýraznite logo z palety nižšie a kliknutím ho priraďte k videosúborom 720p HD."

#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "Zvýraznite logo z palety nižšie a kliknutím ho priraďte k videosúborom DVD a s bežným rozlíšením (SD)."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "Zobraziť v mriežke palety iba dizajny loga s ultra vysokým rozlíšením a 4K."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "Zobraziť v mriežke palety iba dizajny loga kodekov HEVC a H.265."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Zobraziť v mriežke palety iba dizajny loga kodekov AVC a H.264."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Zobraziť v mriežke palety iba dizajny loga formátov DivX, XviD a starších MPEG-4."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Zobraziť v mriežke palety dizajny loga klasického MPEG, DVD a štandardného televízneho vysielania."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Zobraziť v mriežke palety dizajny loga Windows Media Video a kodeku VC-1."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Zobraziť v mriežke palety dizajny loga formátov kontajnerov, diskových formátov a iné rôzne dizajny."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Zatvoriť tento dialóg prispôsobenia značiek a vrátiť sa do nastavení."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Zvýraznite ľubovoľný dizajn loga v stredovej mriežke a kliknutím ho uložte ako vlastnú značku pre aktívnu kategóriu."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Vymazať výber vlastnej značky a obnoviť pre túto kategóriu automatickú logiku predvolených značiek skinu."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Prepnúť globálnu grafiku značiek medzi farebnými dizajnmi a predvolenou čiernobielou (bielou)."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Pomocou smerových klávesov navigujte v možnostiach. Stlačením tlačidla Späť alebo výberom položky Ukončiť môžete kedykoľvek zavrieť dialóg bez zmien."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Vyberte pre úpravu"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Prispôsobenie domovskej obrazovky, widgetov a ponuky skratiek."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Skript pre tvorcov skinov, ktorý umožňuje používateľom vybrať doplnok so zdrojmi obrázkov."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Automaticky pridáva dodatočnú grafiku pre médiá vo vašich knižniciach médií."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Texty piesní k hudbe. Vyžadované pre povolenie animovaných textov."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Synchronizujte svoju zbierku a stav videného so službou trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Vytvoriť vlastnú obľúbenú položku z vybraných obľúbených v Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Upraviť ponuku domovskej obrazovky, widgety, pozadia a informačné riadky."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Obnoviť ponuku domovskej obrazovky, widgety, pozadia a informačné riadky na predvolené hodnoty."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Vytvoriť vlastnú obľúbenú položku z vybraných obľúbených položiek Kodi. Na použitie vo widgetoch hlavného menu. Vyžaduje nainštalovaný skript Favourites."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Vytvoriť vlastný obľúbený doplnok z nainštalovaných doplnkov. Na použitie vo widgetoch hlavného menu."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Obnoviť tému skinu a farby na predvolené hodnoty."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Vybrať zo zoznamu vopred definovaných tém."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Uzamknúť predvoľby na zakázanie režimu zobrazenia, možností zobrazenia, informačného dialógu a nastavení celej obrazovky."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Prispôsobiť domovskú obrazovku, obľúbené položky, preddefinované témy a režim Kiosk."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Zmeniť textúry témy skinu."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Prispôsobiť farby textúry skinu."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Prispôsobiť pozadie a náhradné obrázky pre konkrétne oblasti skinu."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Povoliť alebo zakázať rôzne funkcie skinu."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Prispôsobiť grafiku a nainštalovať podporované balíky grafiky."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Nainštalovať a nakonfigurovať podporované doplnky."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Povoliť a zakázať zobrazenia knižnice. Zakázanie zobrazení knižnice na menej výkonných systémoch môže zlepšiť výkon."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Zobrazuje písmeno pri rýchlom posúvaní v zobrazeniach knižnice."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Zobrazuje abecedu na rýchly skok na požadovanú pozíciu v zozname. Funguje iba pri predvolených metódach triedenia (A-Z)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Zobrazuje stručný popis deja pre filmy a seriály, ak je k dispozícii, inak sa zobrazí predvolený popis."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Automaticky posúvať text popisu deja, ak sa nezmestí do vyhradeného priestoru."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Povoliť ponuku skratiek pre okamžitý prístup ku konkrétnym oblastiam skinu. V ponuke médií otvorte kliknutím vľavo alebo kliknutím na ikonu skratky."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Upraviť ponuku skratiek."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Povoliť a zakázať prvky hornej lišty."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Zmeniť nastavenia informácií o videu."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Zmeniť nastavenia informácií o hudbe."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Zmeniť nastavenia videa na celú obrazovku."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Zmeniť nastavenia zvuku na celú obrazovku."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Zmenšiť veľkosť vyskakovacích oznámení."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Stmaví obrazovku za vyskakovacími dialógmi. Neplatí pre video alebo hudbu na celú obrazovku."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Povoliť farebné ikony pre hornú lištu, informácie o médiách a zobrazenia knižnice."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Povoliť farebné značky, HDR, bitovú hĺbku a jazykové mediálne značky."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Predvolený obrázok CD disku v celom skine."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Predvolený obrázok DVD/BD disku v celom skine."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Vybrať a nainštalovať balík ikon počasia pre hornú lištu, widgety a počasie."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Vybrať a nainštalovať balík fanartov počasia pre pozadia, widgety a počasie."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Nainštalovať biele ikony štúdií na použitie v celom skine."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Nainštalovať farebné ikony štúdií na použitie v celom skine."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Nainštalovať ikony hudobných vydavateľstiev na použitie v celom skine."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Nainštalovať vlajky jazykov pre zobrazenia knižnice a výber titulkov."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Nainštalovať ikony hudobných žánrov pre hudbu a hudobné videá."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Nainštalovať farebné ikony filmových žánrov pre filmy a seriály."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Nainštalovať čiernobiele ikony filmových žánrov pre filmy a seriály."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Nainštalovať ikony krajín pre zoznamy podľa krajiny pôvodu."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Nastaviť oneskorenie medzi prechodmi fanartov v celom skine."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Efekty padania na pozadí. Sneh, listy atď."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Zobraziť fanart práve prehrávanej skladby v celom skine. Prepíše predvolený knižničný fanart."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Povolí vizualizáciu hudby na pozadí počas prehrávania hudby. Vyžaduje povolenú vizualizáciu v menu Nastavenia - Nastavenia prehrávača/Hudba."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Zobraziť práve prehrávané video na pozadí pri prehliadaní knižnice. Prepíše predvolený knižničný fanart."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Sťahovať obrázky a dodatočné informácie o práve prehrávanom interpretovi zo služieb fanart.tv a theaudiodb.com. Pre hudbu na celú obrazovku, internetové streamy a rádio."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Nastavenia skriptu Prezentácia interpreta."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "Skratka k zoznamu videí, ak nie je prázdny."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "Skratka k zoznamu hudby, ak nie je prázdny."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Skratka na celú obrazovku počas prehrávania médií."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Kliknutím otvoríte ponuku skratiek."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Ovládacie prvky prehrávača počas prehrávania médií."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Automaticky prehrať nasledujúcu epizódu seriálu."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Prehrávať znelky/témy pri prehliadaní seriálov, filmov a hudobných videí."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "Editor knižničných uzlov umožňuje vytvárať a prispôsobovať vlastné video a hudobné uzly v Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Zobraziť prekryvné indikátory pre videné, nevidené a rozpozerané položky médií."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Skript na úpravu vstavaného RSS pásu v Kodi."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Verzia skinu a možnosti obnovenia. Obnoví všetky predvolené hodnoty do pôvodného stavu pri inštalácii."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Doplnky"