msgid "Madnox image resource addon"
msgstr "Doplnok obrázkových zdrojov pre Madnox"

#: /16x9/SkinSettings.xml
msgctxt "#31522"
msgid "Images"
msgstr "Obrázky"

#: /16x9/SkinSettings.xml
msgctxt "#31523"
msgid "Display ratings as 10-point numbers"
msgstr "Zobraziť hodnotenie ako 10-bodové čísla"

#: /16x9/SkinSettings.xml
msgctxt "#31524"
msgid "Allows changes to the ratings to convert between floating numbers or as a percentage. Affects TMDb & IMDb, all others remain as their default display."
msgstr "Umožňuje zmenu zobrazenia hodnotenia na desatinné čísla alebo na percentá. Ovplyvňuje TMDb a IMDb, ostatné zostávajú vo svojom predvolenom formáte."

#: /16x9/SkinSettings.xml
msgctxt "#31525"
msgid "Re-run skin shortcuts migrator"
msgstr "Znovu spustiť migráciu skratiek skinu"

#: /16x9/SkinSettings.xml
msgctxt "#31526"
msgid "This will rewrite the skin shortcuts .properties file to the current 3 module addon structure. Only run if there are issues with background images or playlists are not working."
msgstr "Týmto sa prepíše súbor .properties pre skratky skinu na aktuálnu štruktúru 3-modulového doplnku. Spúšťajte len vtedy, ak máte problémy s obrázkami na pozadí alebo nefungujú zoznamy skladieb."

#: /16x9/SkinSettings.xml
msgctxt "#31527"
msgid "This will reactivate the addons installer. Only run if addons were not installed when skin was first installed."
msgstr "Týmto sa znovu aktivuje inštalátor doplnkov. Spustite ho iba vtedy, ak doplnky neboli nainštalované pri prvej inštalácii skinu."

#: /16x9/Includes_Settings.xml
msgctxt "#31528"
