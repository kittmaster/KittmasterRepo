# --- Body texts: top row category selectors (controls 901–904, 905) ---

#: /16x9/includes.xml
msgctxt "#31567"
msgid "Highlight a logo from the palette below and click to assign it to 4K / UHD video files."
msgstr "Iezīmējiet logotipu zemāk esošajā paletē un noklikšķiniet, lai to piesaistītu 4K / UHD video failiem."

#: /16x9/includes.xml
msgctxt "#31568"
msgid "Highlight a logo from the palette below and click to assign it to WebDL and streaming video sources."
msgstr "Iezīmējiet logotipu zemāk esošajā paletē un noklikšķiniet, lai to piesaistītu WebDL un straumēšanas video avotiem."

#: /16x9/includes.xml
msgctxt "#31569"
msgid "Highlight a logo from the palette below and click to assign it to 1080p Full HD video files."
msgstr "Iezīmējiet logotipu zemāk esošajā paletē un noklikšķiniet, lai to piesaistītu 1080p Full HD video failiem."

#: /16x9/includes.xml
msgctxt "#31570"
msgid "Highlight a logo from the palette below and click to assign it to 720p HD video files."
msgstr "Iezīmējiet logotipu zemāk esošajā paletē un noklikšķiniet, lai to piesaistītu 720p HD video failiem."

#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "Iezīmējiet logotipu zemāk esošajā paletē un noklikšķiniet, lai to piesaistītu DVD un standarta izšķirtspējas video failiem."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "Rādīt paletes režģī tikai ultra-augstas izšķirtspējas un 4K logotipu dizainus."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "Rādīt paletes režģī tikai HEVC un H.265 kodeku logotipu dizainus."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Rādīt paletes režģī tikai AVC un H.264 kodeku logotipu dizainus."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Rādīt paletes režģī tikai DivX, XviD un mantoto MPEG-4 formātu logotipu dizainus."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Rādīt paletes režģī klasiskos MPEG, DVD un standarta TV apraides logotipu dizainus."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Rādīt paletes režģī Windows Media Video un VC-1 kodeka logotipu dizainus."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Rādīt paletes režģī konteineru formātu, disku formātu un citus dažādus logotipu dizainus."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Aizvērt šo karodziņu pielāgošanas dialoglodziņu un atgriezties iestatījumos."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Iezīmējiet jebkuru logotipa dizainu centrālajā režģī un noklikšķiniet, lai saglabātu to kā savu pielāgoto karodziņu aktīvajai kategorijai."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Notīrīt jūsu pielāgoto karodziņu izvēli un atjaunot šo kategoriju uz ādiņas automātisko noklusējuma karodziņu loģiku."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Pārslēgt globālo karodziņu noformējumu starp krāsainiem dizainiem un monohromo noklusējuma balto krāsu."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Izmantojiet virzienpogas, lai pārvietotos pa opcijām. Nospiediet 'Atpakaļ' vai izvēlieties 'Iziet' jebkurā laikā, lai aizvērtu bez izmaiņām."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Izvēlēties, lai mainītu"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Sākuma ekrāna, logrīku un īsceļu izvēlnes pielāgošana."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Skripts ādiņu izstrādātājiem, kas ļauj lietotājiem izvēlēties attēlu resursu papildinājumu."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Automātiski pievieno papildu noformējumus multividei jūsu bibliotēkās."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Mūzikas dziesmu teksti. Nepieciešams, lai iespējotu animētus dziesmu tekstus."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Sinhronizējiet savu kolekciju un skatīšanās statusu ar trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Izveidot pielāgotu izlasi no atlasītajām Kodi izlasēm."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Rediģēt sākuma ekrāna izvēlni, logrīkus, fonus un informācijas joslas."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Atiestatīt sākuma ekrāna izvēlni, logrīkus, fonus un informācijas joslas uz noklusējumu."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Izveidot pielāgotu izlasi no atlasītajām Kodi izlasēm izmantošanai galvenās izvēlnes logrīkos. Nepieciešams, lai būtu instalēts izlases skripts."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Izveidot pielāgotu papildinājumu izlasi no instalētajām papildprogrammām izmantošanai galvenās izvēlnes logrīkos."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Atiestatīt ādiņas motīvu un krāsas uz noklusējumu."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Izvēlēties no iepriekš definētu motīvu saraksta."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Bloķēt preferences, lai atspējotu skata režīmu, skata opcijas, informācijas dialoglodziņu un pilnekrāna iestatījumus."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Pielāgot sākuma ekrānu, izlasi, iepriekš definētos motīvus un kioska režīmu."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Mainīt ādiņas motīva tekstūras."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Pielāgot ādiņas tekstūras krāsas."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Pielāgot fonu un rezerves variantus noteiktiem ādiņas apgabaliem."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Iespējot vai atspējot dažādas ādiņas funkcijas."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Pielāgot noformējumus un instalēt atbalstītās noformējumu pakotnes."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Instalēt un konfigurēt atbalstītās papildprogrammas."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Iespējot un atspējot bibliotēkas skatus. Atspējojot bibliotēkas skatus sistēmās ar zemiem parametriem, var uzlaboties veiktspēja."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Rāda ritināšanas burtu, kad ritina bibliotēkas skatus."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Parāda alfabētu, lai pārietu uz konteinera pozīciju. Darbosies tikai ar noklusējuma kārtošanas metodēm (A-Z)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Rāda seriālu un filmu sižeta kopsavilkumu, ja tas ir pieejams, pretējā gadījumā parādīs noklusējuma sižetu."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Automātiski ritināt sižetu, ja tas neietilpst vadīklas izmēros."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Iespējot īsceļu izvēlni tūlītējai piekļuvei noteiktiem ādiņas apgabaliem. Multivides izvēlnē noklikšķiniet pa kreisi, lai atvērtu, vai noklikšķiniet uz īsceļa ikonas."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Rediģēt īsceļu izvēlni."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Iespējot un atspējot augšējās joslas elementus."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Mainīt video informācijas iestatījumus."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Mainīt mūzikas informācijas iestatījumus."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Mainīt pilnekrāna video iestatījumus."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Mainīt pilnekrāna audio iestatījumus."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Samazināt uznirstošo paziņojumu izmēru."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Aptumšo ekrānu aiz dialoglodziņu uznirstošajiem logiem. Nav piemērojams pilnekrāna video vai audio režīmā."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Iespējot krāsainas ikonas augšējai joslai, multivides informācijai un bibliotēkas skatiem."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Iespējot krāsainus, HDR, bitu dziļuma un valodas multivides karodziņus."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Audio kompaktdiska noformējuma rezerves variants visā ādiņā."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Video kompaktdiska noformējuma rezerves variants visā ādiņā."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Izvēlēties un instalēt laikapstākļu ikonu pakotni augšējai joslai, logrīkiem un laikapstākļiem."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Izvēlēties un instalēt laikapstākļu fanu noformējuma pakotni foniem, logrīkiem un laikapstākļiem."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Instalēt baltas studiju ikonas lietošanai visā ādiņā."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Instalēt krāsainas studiju ikonas lietošanai visā ādiņā."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Instalēt ierakstu kompāniju logotipus lietošanai visā ādiņā."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Instalēt valodu karogus bibliotēkas skatiem un subtitru izvēlei."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Instalēt mūzikas žanru ikonas mūzikai un mūzikas video."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Instalēt krāsainas filmu žanru ikonas filmām un seriāliem."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Instalēt melnbaltas filmu žanru ikonas filmām un seriāliem."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Instalēt valstu ikonas filmu valstu mezglam."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Iestatīt aizturi starp fanu noformējumu pārejām visā ādiņā."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Krītošu fonu efekti. Sniegs, lapas utt."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Rādīt pašlaik atskaņojamā vienuma mūzikas fanu noformējumu visā ādiņā. Ignorē bibliotēkas fanu noformējumu."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Iespējo mūzikas vizualizāciju fonā mūzikas atskaņošanas laikā. Nepieciešams, lai vizualizācija būtu iespējota iestatījumos - Atskaņotāja iestatījumi/Mūzika."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Rādīt pašlaik atskaņojamo video fonā, kamēr tiek pārlūkota bibliotēka. Ignorē bibliotēkas fanu noformējumu."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Lejupielādēt attēlus un papildu informāciju no fanart.tv un theaudiodb.com par pašreiz atskaņoto izpildītāju. Paredzēts pilnekrāna mūzikai, interneta straumēm un radio."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Izpildītāja slīdrādes skripta iestatījumi."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "Īsceļš uz video atskaņošanas sarakstu, ja tas nav tukšs."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "Īsceļš uz mūzikas atskaņošanas sarakstu, ja tas nav tukšs."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Īsceļš uz pilnekrāna režīmu, kad tiek atskaņota vide."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Noklikšķiniet, lai atvērtu īsceļu izvēlni."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Atskaņotāja vadīklas, kad tiek atskaņota vide."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Automātiski atskaņot nākamo seriāla sēriju."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Atskaņot motīvu mūziku, pārvietojoties pa seriāliem, filmām un mūzikas video."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "Bibliotēkas mezglu redaktors allows you to create and customise custom video nodes and music nodes within Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Rādīt pārklājuma marķiera informāciju skatītajiem, neskatītajiem un nepabeigtajiem multivides vienumiem."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Skripts Kodi iebūvētās RSS ziņu joslas rediģēšanai."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Ādiņas versija un atkopšanas opcijas. Atjauno visus noklusējumus uz pirmās dienas iestatījumiem."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Papildprogrammas"