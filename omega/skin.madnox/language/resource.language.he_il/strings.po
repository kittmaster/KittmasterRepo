#: /16x9/Includes_Settings.xml
msgctxt "#31511"
msgid "Dedicated addon for Madnox required for Piers+. Moves all free running scripts to a dedicated addon for security purposes."
msgstr "הרחבה ייעודית עבור Madnox הנדרשת עבור Piers+. מעבירה את כל התסריטים שרצים ברקע להרחבה ייעודית לצורכי אבטחה."

#: /16x9/Includes_Settings.xml
msgctxt "#31512"
msgid "TMDbHelper provides several tools to assist skinners with retrieving information from TMDb, OMDb and Trakt APIs."
msgstr "TMDbHelper מספק מספר כלים כדי לסייע למעצבי ערכות עיצוב באחזור מידע ממשקי ה-API של TMDb, OMDb ו-Trakt."

#: /16x9/Includes_Settings.xml
msgctxt "#31513"
msgid "Wikipedia addon for Kodi."
msgstr "הרחבת ויקיפדיה עבור Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31514"
msgid "Advanced CinemaVision replacement that can be enabled to replace Madnox's built in simpler CinemaMode. Allows the ultimate CinemaMode experience and customisation."
msgstr "תחליף CinemaVision מתקדם שניתן להפעיל כדי להחליף את מצב הקולנוע המובנה והפשוט יותר של Madnox. מאפשר את חוויית מצב הקולנוע וההתאמה האישית האולטימטיביים."

#: /16x9/Includes_CustomSelect.xml
msgctxt "#31515"
msgid "Blur with color"
msgstr "טשטוש עם צבע"

#: /16x9/Includes_CustomSelect.xml
msgctxt "#31516"
msgid "Displays or hides the menu item in the main context menu (S on the keyboard)."
msgstr "מציג או מסתיר את פריט התפריט בתפריט ההקשר הראשי (מקש S במקלדת)."

#: /16x9/Includes_CustomSelect.xml
msgctxt "#31517"
msgid "Displays or hides the menu item in the main context menu (S on the keyboard). NOTE: This menu item is visible ONLY on the home screen only regardless of this setting."
msgstr "מציג או מסתיר את פריט התפריט בתפריט ההקשר הראשי (S במקלדת). הערה: פריט תפריט זה גלוי אך ורק במסך הבית, ללא קשר להגדרה זו."

#: SkinSettings.xml
msgctxt "#31518"
msgid "Re-run optional extras installer"
msgstr "הפעלה מחדש של מתקין התוספות האופציונליות"

#: Custom_1109_DialogConfirmExtrasInstall.xml
msgctxt "#31519"
msgid "Optional extras installer"
msgstr "מתקין תוספות אופציונליות"

#: Custom_1109_DialogConfirmExtrasInstall.xml
msgctxt "#31520"
msgid "This will re-run the optional extras installer. All extras will be downloaded and installed in a disabled state. Enable only what you need in Settings > Skin Settings > Addons."
msgstr "פעולה זו תפעיל מחדש את מתקין התוספות האופציונליות. כל התוספות יורדו ויותקנו במצב מושבת. הפעל רק את מה שאתה צריך תחת הגדרות > הגדרות ערכת עיצוב > הרחבות."

#: /16x9/SkinSettings.xml
msgctxt "#31521"
msgid "Madnox image resource addon"
msgstr "הרחבת משאבי תמונות של Madnox"

#: /16x9/SkinSettings.xml
msgctxt "#31522"
msgid "Images"
msgstr "תמונות"

#: /16x9/SkinSettings.xml
msgctxt "#31523"
msgid "Display ratings as 10-point numbers"
msgstr "הצגת דירוגים כמספרים בטווח של 10"

#: /16x9/SkinSettings.xml
msgctxt "#31524"
msgid "Allows changes to the ratings to convert between floating numbers or as a percentage. Affects TMDb & IMDb, all others remain as their default display."
msgstr "מאפשר שינויים בדירוגים כדי להמיר בין מספרים עשרוניים או כאחוזים. משפיע על TMDb ו-IMDb, כל השאר נשארים בתצוגת ברירת המחדל שלהם."

#: /16x9/SkinSettings.xml
msgctxt "#31525"
msgid "Re-run skin shortcuts migrator"
msgstr "הפעלה מחדש של מעביר קיצורי הדרך של ערכת העיצוב"

#: /16x9/SkinSettings.xml
msgctxt "#31526"
msgid "This will rewrite the skin shortcuts .properties file to the current 3 module addon structure. Only run if there are issues with background images or playlists are not working."
msgstr "פעולה זו תכתוב מחדש את קובץ ה-.properties של קיצורי הדרך למבנה הנוכחי של הרחבה בעלת 3 מודולים. יש להריץ זאת רק אם קיימות בעיות עם תמונות רקע או שרשימות השמעה אינן עובדות."

#: /16x9/SkinSettings.xml
msgctxt "#31527"
msgid "This will reactivate the addons installer. Only run if addons were not installed when skin was first installed."
msgstr "פעולה זו תפעיל מחדש את מתקין ההרחבות. יש להריץ זאת רק אם ההרחבות לא הותקנו כאשר ערכת העיצוב הותקנה לראשונה."

#: /16x9/Includes_Settings.xml
msgctxt "#31528"
msgid "Dedicated addon for Madnox required for Piers+. Moves skin images into a dedicated addon for security purposes."
msgstr "הרחבה ייעודית עבור Madnox הנדרשת עבור Piers+. מעבירה את תמונות ערכת העיצוב להרחבה ייעודית לצורכי אבטחה."

