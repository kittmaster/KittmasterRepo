# --- Body texts: top row category selectors (controls 901–904, 905) ---

#: /16x9/includes.xml
msgctxt "#31567"
msgid "Highlight a logo from the palette below and click to assign it to 4K / UHD video files."
msgstr "סמן לוגו פלטת הצבעים למטה ולחץ כדי לשייך אותו לקובצי וידאו של 4K / UHD."

#: /16x9/includes.xml
msgctxt "#31568"
msgid "Highlight a logo from the palette below and click to assign it to WebDL and streaming video sources."
msgstr "סמן לוגו פלטת הצבעים למטה ולחץ כדי לשייך אותו למקורות וידאו של WebDL והזרמת מדיה."

#: /16x9/includes.xml
msgctxt "#31569"
msgid "Highlight a logo from the palette below and click to assign it to 1080p Full HD video files."
msgstr "סמן לוגו פלטת הצבעים למטה ולחץ כדי לשייך אותו לקובצי וידאו של 1080p Full HD."

#: /16x9/includes.xml
msgctxt "#31570"
msgid "Highlight a logo from the palette below and click to assign it to 720p HD video files."
msgstr "סמן לוגו פלטת הצבעים למטה ולחץ כדי לשייך אותו לקובצי וידאו של 720p HD."

#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "סמן לוגו פלטת הצבעים למטה ולחץ כדי לשייך אותו לקובצי וידאו של DVD ורזולוציה סטנדרטית (SD)."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "הצג עיצובי לוגו של רזולוציה אולטרה-גבוהה ו-4K בלבד ברשת פלטת הצבעים."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "הצג עיצובי לוגו של מקודדי HEVC ו-H.265 בלבד ברשת פלטת הצבעים."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "הצג עיצובי לוגו של מקודדי AVC ו-H.264 בלבד ברשת פלטת הצבעים."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "הצג עיצובי לוגו של פורמטי DivX, XviD ומקודדי MPEG-4 ישנים בלבד ברשת פלטת הצבעים."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "הצג עיצובי לוגו של MPEG קלאסי, DVD ושידורי טלוויזיה סטנדרטיים בלבד ברשת פלטת הצבעים."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "הצג עיצובי לוגו של מקודדי Windows Media Video ו-VC-1 בלבד ברשת פלטת הצבעים."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "הצג עיצובי לוגו של פורמטי קובץ (Containers), פורמטי דיסקים ועיצובים שונים אחרים ברשת פלטת הצבעים."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "סגור חלון התאמת דגלים זה וחזור להגדרות."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "סמן עיצוב לוגו כלשהו ברשת המרכזית ולחץ כדי לשמור אותו כדגל המותאם אישית שלך עבור הקטגוריה הפעילה."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "נקה את בחירת הדגל המותאם אישית שלך ושחזר קטגוריה זו ללוגיקת ברירת המחדל האוטומטית של דגלי ערכת העיצוב."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "החלף את אמנות הדגלים הגלובלית בין עיצובים צבעוניים לבין לבן מונוכרומטי כברירת מחדל."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "השתמש במקשי הכיוון שלך כדי לנווט בין האפשרויות. לחץ על 'חזור' או בחר 'יציאה' בכל עת כדי לסגור מבלי לשמור שינויים."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "בחר כדי לשנות"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "התאמה אישית של מסך הבית, הווידג'טים ותפריט קיצורי הדרך."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "תסריט עבור מעצבי ערכות עיצוב המאפשר למשתמשים לבחור הרחבת משאבי תמונות."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "מוסיף באופן אוטומטית אמנות נוספת עבור מדיה בספריות המדיה שלך."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "מילות שיר עבור מוזיקה. נדרש להפעלת מילים מונפשות."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "סנכרן את האוסף שלך ומצב הצפייה שלך עם trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "צור מועדף מותאם אישית ממועדפי Kodi שנבחרו."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "ערוך את תפריט מסך הבית, הווידג'טים, הרקעים ושורות המידע."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "אפס את תפריט מסך הבית, הווידג'טים, הרקעים ושורות המידע לברירת המחדל."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "צור מועדף מותאם אישית ממועדפי Kodi שנבחרו. לשימוש בווידג'טים של התפריט הראשי. דורש התקנה של תסריט המועדפים."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "צור הרחבה מועדפת מותאמת אישית מהרחבות מותקנות. לשימוש בווידג'טים של התפריט הראשי."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "אפס את ערכת הנושא והצבעים של ערכת העיצוב לברירת המחדל."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "בחר מתוך רשימה של ערכות נושא מוגדרות מראש."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "נעל העדפות כדי להשבית את מצב התצוגה, אפשרויות התצוגה, דו-שיח המידע והגדרות מסך מלא."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "התאם אישית את מסך הבית, המועדפים, ערכות הנושא המוגדרות מראש ומצב הקיוסק."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "שנה את הטקסטורות של ערכת הנושא."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "התאם אישית את צבעי הטקסטורה של ערכת העיצוב."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "התאם אישית את הרקע וגיבויי ברירת המחדל עבור אזורים ספציפיים בערכת העיצוב."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "הפעל או השבת תכונות שונות של ערכת העיצוב."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "התאם אישית אמנות והתקן חבילות אמנות נתמכות."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "התקן והגדר הרחבות נתמכות."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "הפעל והשבת תצוגות ספרייה. השבתת תצוגות ספרייה במערכות בעלות מפרט נמוך עשויה לשפר את הביצועים."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "מציג את אות הגלילה בעת גלילה בתצוגות ספרייה."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "מציג את האלפבית כדי לעבור למיקום במכולה. יעבוד רק בשיטות מיון ברירת מחדל (א'-ת')."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "מציג את תקציר העלילה עבור סדרות וסרטים אם הוא זמין, אחרת יציג את העלילה כברירת מחדל."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "גלילה אוטומטית של העלילה אם היא אינה מתאימה לממדי הפקד."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "הפעל את תפריט קיצורי הדרך לגישה מיידית לאזורים ספציפיים בערכת העיצוב. בתפריט המדיה לחץ שמאלה כדי לפתוח או לחץ על סמל קיצור הדרך."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "ערוך את תפריט קיצורי הדרך."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "הפעל והשבת את אלמנטים של הסרגל העליון."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "שנה את הגדרות מידע הווידאו."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "שנה את הגדרות מידע המוזיקה."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "שנה את הגדרות הווידאו במסך מלא."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "שנה את הגדרות השמע במסך מלא."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "צמצם את גודל ההתראות הקופצות."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "מעמעם את המסך מאחורי חלונות דו-שיח קופצים. לא חל על וידאו או שמע במסך מלא."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "הפעל סמלים צבעוניים עבור הסרגל העליון, מידע המדיה ותצוגות הספרייה."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "הפעל דגלי מדיה צבעוניים, דגלי HDR, עומק סיביות ושפות."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "גיבוי עבור אמנות תקליטור שמע בכל ערכת העיצוב."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "גיבוי עבור אמנות תקליטור וידאו בכל ערכת העיצוב."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "בחר והתקן חבילת סמלי מזג אוויר עבור הסרגל העליון, הווידג'טים ומזג האוויר."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "בחר והתקן חבילת פאנארט מזג אוויר עבור הרקעים, הווידג'טים ומזג האוויר."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "התקן סמלי אולפן לבנים לשימוש ברחבי ערכת העיצוב."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "התקן סמלי אולפן צבעוניים לשימוש ברחבי ערכת העיצוב."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "התקן סמלי חברות תקליטים לשימוש ברחבי ערכת העיצוב."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "התקן דגלי שפות עבור תצוגות הספרייה ובחירת כתוביות."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "התקן סמלי ז'אנר מוזיקה עבור מוזיקה ווידאו קליפים."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "התקן סמלי ז'אנר סרטים צבעוניים עבור סרטים וסדרות טלוויזיה."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "התקן סמלי ז'אנר סרטים בשחור-לבן עבור סרטים וסדרות טלוויזיה."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "התקן סמלי מדינות עבור צומת מדינת סרטים."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "קבע את ההשהיה בין מעברי פאנארט ברחבי ערכת העיצוב."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "אפקטים של רקע נופל. שלג, עלים וכו'."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "הצג פאנארט מוזיקה של הפריט המתנגן כעת ברחבי ערכת העיצוב. עוקף את פאנארט הספרייה."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "מפעיל ויזואליזציה של מוזיקה ברקע בזמן ניגון מוזיקה. דורש הפעלת ויזואליזציה בהגדרות - הגדרות נגן/מוזיקה."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "הצג וידאו מתנגן כעת ברקע בזמן דפדוף בספרייה. עוקף את פאנארט הספרייה."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "הורד תמונות ומידע נוסף מ-fanart.tv ומ-theaudiodb.com של האמן המתנגן כעת. עבור מוזיקה במסך מלא, שידורי אינטרנט ורדיו."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "הגדרות תסריט של מצגת אמנים."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "קיצור דרך לרשימת השמעת הווידאו אם אינה ריקה."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "קיצור דרך לרשימת השמעת המוזיקה אם אינה ריקה."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "קיצור דרך למסך מלא כאשר מדיה מתנגנת."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "לחץ כדי לפתוח את תפריט קיצורי הדרך."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "פקדי נגן כאשר מדיה מתנגנת."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "נגן את הפרק הבא של סדרת הטלוויזיה באופן אוטומטית."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "נגן נעימות נושא בעת ניווט בסדרות טלוויזיה, סרטים ווידאו קליפים."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "עורך צמתי הספרייה מאפשר לך ליצור ולהתאים אישית צמתי וידאו וצמתי מוזיקה מותאמים אישית בתוך Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "הצג מידע על סמני שכבת-על עבור פריטי מדיה שנצפו, שלא נצפו ובתהליך צפייה."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "תסריט לעריכת מבזק ה-RSS המובנה של Kodi."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "גרסת ערכת עיצוב ואפשרויות שחזור. משחזר את כל ברירות המחדל לפעולה של היום הראשון."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "הרחבות"