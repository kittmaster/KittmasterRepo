# --- Body texts: top row category selectors (controls 901–904, 905) ---

#: /16x9/includes.xml
msgctxt "#31567"
msgid "Highlight a logo from the palette below and click to assign it to 4K / UHD video files."
msgstr "Uwcholeuwch logo o'r palet isod a chliciwch i'w neilltuo i ffeiliau fideo 4K / UHD."

#: /16x9/includes.xml
msgctxt "#31568"
msgid "Highlight a logo from the palette below and click to assign it to WebDL and streaming video sources."
msgstr "Uwcholeuwch logo o'r palet isod a chliciwch i'w neilltuo i WebDL a ffynonellau fideo ffrydio."

#: /16x9/includes.xml
msgctxt "#31569"
msgid "Highlight a logo from the palette below and click to assign it to 1080p Full HD video files."
msgstr "Uwcholeuwch logo o'r palet isod a chliciwch i'w neilltuo i ffeiliau fideo HD Llawn 1080p."

#: /16x9/includes.xml
msgctxt "#31570"
msgid "Highlight a logo from the palette below and click to assign it to 720p HD video files."
msgstr "Uwcholeuwch logo o'r palet isod a chliciwch i'w neilltuo i ffeiliau fideo HD 720p."

#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "Uwcholeuwch logo o'r palet isod a chliciwch i'w neilltuo i ffeiliau fideo DVD a diffiniad safonol."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "Gweld dyluniadau logo ultra-uchel-ddiffiniad a 4K yn unig yn y grid palet."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "Gweld dyluniadau logo codec HEVC a H.265 yn unig yn y grid palet."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Gweld dyluniadau logo codec AVC a H.264 yn unig yn y grid palet."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Gweld dyluniadau logo DivX, XviD, a fformatau etifeddol MPEG-4 yn unig yn y grid palet."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Gweld dyluniadau logo clasurol MPEG, DVD, a darllediadau teledu safonol yn y grid palet."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Gweld dyluniadau logo codec Windows Media Video a VC-1 yn unig yn y grid palet."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Gweld pecynnau cynhwysydd, fformatau disg, a dyluniadau logo amrywiol eraill yn y grid palet."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Cau'r ddialog personoli baneri hon a dychwelyd i'm gosodiadau."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Uwcholeuwch unrhyw ddyluniad logo yn y grid canolog a chliciwch i'w gadw fel eich baner bersonol ar gyfer y categori gweithredol."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Clirio'ch dewis baner bersonol ac adfer y categori hwn i resymeg baneri diofyn awtomatig y croen."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Togl celf baneri byd-eang rhwng dyluniadau lliw a gwyn diofyn monocromatig."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Defnyddiwch eich bysellau cyfeiriadol i lywio opsiynau. Gwasgwch Back neu dewiswch Exit unrhyw bryd i gau heb newidiadau."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Dewis i addasu"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Personoli'r sgrîn gartref, teclynnau a'r ddewislen llwybrau byr."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Sgript i ddylunwyr crwyn i adael i ddefnyddwyr ddewis ychwanegyn adnodd delwedd."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Yn ychwanegu celf ychwanegol yn awtomatig ar gyfer cyfryngau yn eich llyfrgelloedd cyfryngau."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Geiriau ar gyfer cerddoriaeth. Angenrheidiol i alluogi geiriau caneuon animeiddiedig."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Cydweddu'ch casgliad a'ch statws gwylio gyda trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Creu ffefryn personol o ffefrynnau dewisol Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Golygu dewislen y sgrîn gartref, teclynnau, cefndiroedd a llinellau gwybodaeth."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Ailosod dewislen y sgrîn gartref, teclynnau, cefndiroedd a llinellau gwybodaeth i'r diofyn."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Creu ffefryn personol o ffefrynnau dewisol Kodi. Ar gyfer ei ddefnyddio mewn teclynnau prif ddewislen. Angen gosod script favourites."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Creu ychwanegyn ffefryn personol o ychwanegion gosodedig. Ar gyfer ei ddefnyddio mewn teclynnau prif ddewislen."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Ailosod thema'r croen a'r lliwiau i'r diofyn."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Dewis o restr o themâu a ddiffiniwyd ymlaen llaw."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Cloi dewisiadau i analluogi modd gweld, opsiynau gweld, deialog gwybodaeth a gosodiadau sgrîn lawn."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Personoli'r sgrîn gartref, ffefrynnau, themâu rhagosodedig a modd ciosg."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Newid gweadau thema'r croen."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Personoli lliwiau gwead y croen."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Personoli'r cefndir a'r pethau wrth gefn ar gyfer ardaloedd croen penodol."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Galluogi neu analluogi amrywiol nodweddion y croen."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Personoli celf a gosod pecynnau celf a gefnogir."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Gosod a ffurfweddu ychwanegion a gefnogir."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Galluogi ac analluogi golygon llyfrgell. Gall analluogi golygon llyfrgell ar systemau specs isel wella perfformiad."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Yn dangos llythyren sgrolio wrth sgrolio mewn golygon llyfrgell."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Yn dangos yr wyddor i neidio i safle yn y cynhwysydd. Dim ond ar gyfer dulliau didoli diofyn y bydd yn gweithio (A-Z)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Yn dangos amlinelliad plot ar gyfer sioeau teledu a ffilmiau os ydynt ar gael, fel arall bydd yn arddangos y plot diofyn."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Sgrolio'r plot yn awtomatig os nad yw'n ffitio dimensiynau'r rheolydd."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Galluogi'r ddewislen llwybrau byr ar gyfer mynediad sydyn i ardaloedd croen penodol. Yn y ddewislen cyfryngau cliciwch i'r chwith i agor neu cliciwch ar eicon y llwybr byr."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Golygu'r ddewislen llwybrau byr."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Galluogi ac analluogi elfennau'r bar uchaf."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Newid gosodiadau gwybodaeth fideo."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Newid gosodiadau gwybodaeth cerddoriaeth."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Newid gosodiadau fideo sgrîn lawn."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Newid gosodiadau sain sgrîn lawn."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Lleihau maint hysbysiadau pop-up."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Yn tywyllu'r sgrîn y tu ôl i bop-ypiau deialog. Nid yw'n berthnasol i fideo neu sain sgrîn lawn."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Galluogi eiconau lliw ar gyfer y bar uchaf, gwybodaeth cyfryngau a golygon llyfrgell."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Galluogi baneri cyfryngau lliw, HDR, dyfnder did ac iaith."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Celf cd sain wrth gefn ar draws y croen."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Celf cd fideo wrth gefn ar draws y croen."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Dewis a gosod pecyn eiconau tywydd ar gyfer y bar uchaf, teclynnau a'r tywydd."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Dewis a gosod pecyn fanart tywydd ar gyfer y cefndiroedd, teclynnau a'r tywydd."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Gosod eiconau stiwdio gwyn i'w defnyddio ledled y croen."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Gosod eiconau stiwdio lliw i'w defnyddio ledled y croen."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Gosod eiconau label recordiau i'w defnyddio ledled y croen."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Gosod baneri ieithoedd ar gyfer golygon llyfrgell a dewis is-deitlau."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Gosod eiconau genre cerddoriaeth ar gyfer cerddoriaeth a fideos cerddoriaeth."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Gosod eiconau genre ffilm lliw ar gyfer ffilmiau a sioeau teledu."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Gosod eiconau genre ffilm du a gwyn ar gyfer ffilmiau a sioeau teledu."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Gosod eiconau gwledydd ar gyfer nod gwlad ffilmiau."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Gosod yr oedi rhwng trawsnewidiadau fanart ar draws y croen."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Effeithiau cefndir sy'n cwympo. Eira, Dail ac ati."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Dangos fanart cerddoriaeth o'r eitem sy'n chwarae ar draws y croen. Yn gwrthwneud fanart y llyfrgell."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Yn galluogi gweledigaeth cerddoriaeth yn y cefndir wrth chwarae cerddoriaeth. Angen galluogi gweledigaeth mewn gosodiadau - Gosodiadau Chwaraewr/Cerddoriaeth."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Dangos fideo sy'n chwarae nawr yn y cefndir wrth bori'r llyfrgell. Yn gwrthwneud fanart y llyfrgell."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Lawrlwytho delweddau a gwybodaeth ychwanegol o fanart.tv a theaudiodb.com o'r artist sy'n chwarae ar hyn o bryd. Ar gyfer sain sgrîn lawn, ffrydiau rhyngrwyd a radio."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Gosodiadau sgript sioe sleidiau artist."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "Llwybr byr i'r rhestr chwarae fideo os nad yw'n wag."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "Llwybr byr i'r rhestr chwarae cerddoriaeth os nad yw'n wag."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Llwybr byr i sgrîn lawn pan fydd cyfryngau yn chwarae."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Cliciwch i agor y ddewislen llwybrau byr."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Rheolyddion chwaraewr pan fydd cyfryngau yn chwarae."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Chwarae pennod nesaf y sioe deledu yn awtomatig."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Chwarae themâu wrth bori Sioeau Teledu, Ffilmiau a Fideos Cerddoriaeth."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "Mae Golygydd Nod y Llyfrgell yn caniatáu i chi greu a phersonoli nodau fideo a nodau cerddoriaeth o fewn Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Dangos gwybodaeth marciwr troslun ar gyfer eitemau cyfryngau a wyliwyd, sydd heb eu gwylio, ac sydd ar y gweill."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Sgript ar gyfer golygu RSS Ticker adeiledig Kodi."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Fersiwn y croen ac opsiynau adfer. Yn adfer pob un diofyn i weithrediad diwrnod un."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Ychwanegion"