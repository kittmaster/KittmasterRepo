#: /16x9/includes.xml
msgctxt "#31567"
msgid "Highlight a logo from the palette below and click to assign it to 4K / UHD video files."
msgstr "താഴെയുള്ള പാലറ്റിൽ നിന്ന് ഒരു ലോഗോ തിരഞ്ഞെടുത്ത് 4K / UHD വീഡിയോ ഫയലുകൾക്കായി നൽകുന്നതിന് ക്ലിക്ക് ചെയ്യുക."

#: /16x9/includes.xml
msgctxt "#31568"
msgid "Highlight a logo from the palette below and click to assign it to WebDL and streaming video sources."
msgstr "താഴെയുള്ള പാലറ്റിൽ നിന്ന് ഒരു ലോഗോ തിരഞ്ഞെടുത്ത് WebDL, സ്ട്രീമിംഗ് വീഡിയോകൾക്കായി നൽകുന്നതിന് ക്ലിക്ക് ചെയ്യുക."

#: /16x9/includes.xml
msgctxt "#31569"
msgid "Highlight a logo from the palette below and click to assign it to 1080p Full HD video files."
msgstr "താഴെയുള്ള പാലറ്റിൽ നിന്ന് ഒരു ലോഗോ തിരഞ്ഞെടുത്ത് 1080p ഫുൾ എച്ച്ഡി വീഡിയോ ഫയലുകൾക്കായി നൽകുന്നതിന് ക്ലിക്ക് ചെയ്യുക."

#: /16x9/includes.xml
msgctxt "#31570"
msgid "Highlight a logo from the palette below and click to assign it to 720p HD video files."
msgstr "താഴെയുള്ള പാലറ്റിൽ നിന്ന് ഒരു ലോഗോ തിരഞ്ഞെടുത്ത് 720p എച്ച്ഡി വീഡിയോ ഫയലുകൾക്കായി നൽകുന്നതിന് ക്ലിക്ക് ചെയ്യുക."

#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "താഴെയുള്ള പാലറ്റിൽ നിന്ന് ഒരു ലോഗോ തിരഞ്ഞെടുത്ത് ഡിവിഡി, സ്റ്റാൻഡേർഡ് ഡെഫനിഷൻ വീഡിയോ ഫയലുകൾക്കായി നൽകുന്നതിന് ക്ലിക്ക് ചെയ്യുക."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "പാലറ്റ് ഗ്രിഡിൽ അൾട്രാ-ഹൈ-ഡെഫനിഷൻ, 4K ലോഗോ ഡിസൈനുകൾ മാത്രം കാണുക."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "പാലറ്റ് ഗ്രിഡിൽ HEVC, H.265 കോഡെക് ലോഗോ ഡിസൈനുകൾ മാത്രം കാണുക."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "പാലറ്റ് ഗ്രിഡിൽ AVC, H.264 കോഡെക് ലോഗോ ഡിസൈനുകൾ മാത്രം കാണുക."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "പാലറ്റ് ഗ്രിഡിൽ DivX, XviD, പഴയ MPEG-4 ഫോർമാറ്റ് ലോഗോ ഡിസൈനുകൾ മാത്രം കാണുക."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "പാലറ്റ് ഗ്രിഡിൽ ക്ലാസിക് MPEG, ഡിവിഡി, സ്റ്റാൻഡേർഡ് ടിവി ബ്രോഡ്കാസ്റ്റ് ലോഗോ ഡിസൈനുകൾ കാണുക."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "പാലറ്റ് ഗ്രിഡിൽ വിൻഡോസ് മീഡിയ വീഡിയോ, VC-1 കോഡെക് ലോഗോ ഡിസൈനുകൾ കാണുക."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "പാലറ്റ് ഗ്രിഡിൽ കണ്ടെയ്നർ റാപ്പറുകൾ, ഡിസ്ക് ഫോർമാറ്റുകൾ, മറ്റ് അനുബന്ധ ലോഗോ ഡിസൈനുകൾ എന്നിവ കാണുക."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "ഈ ഫ്ലാഗ് ഇഷ്‌ടാനുസൃതമാക്കൽ ഡയലോഗ് അടച്ച് ക്രമീകരണങ്ങളിലേക്ക് മടങ്ങുക."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "കേന്ദ്ര ഗ്രിഡിലെ ഏതെങ്കിലും ലോഗോ ഡിസൈൻ തിരഞ്ഞെടുത്ത് സജീവ വിഭാഗത്തിനായുള്ള നിങ്ങളുടെ ഇഷ്‌ടാനുസൃത ഫ്ലാഗ് ആയി സംരക്ഷിക്കാൻ ക്ലിക്ക് ചെയ്യുക."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "നിങ്ങളുടെ ഇഷ്‌ടാനുസൃത ഫ്ലാഗ് മായ്‌ച്ച് ഈ വിഭാഗത്തെ സ്കിന്നിന്റെ സ്വയമേവയുള്ള ഡിഫോൾട്ട് ഫ്ലാഗ് ലോജിക്കിലേക്ക് പുനഃസ്ഥാപിക്കുക."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "ആഗോള ഫ്ലാഗ് ആർട്ട്‌വർക്ക് വർണ്ണാഭമായ ഡിസൈനുകൾക്കും മോണോക്രോമാറ്റിക് ഡിഫോൾട്ട് വൈറ്റിനും ഇടയിൽ മാറ്റുക."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "ഓപ്ഷനുകൾ നാവിഗേറ്റ് ചെയ്യാൻ നിങ്ങളുടെ ഡയറക്ഷണൽ কീകൾ ഉപയോഗിക്കുക. മാറ്റങ്ങളില്ലാതെ അടയ്ക്കാൻ എപ്പോൾ വേണമെങ്കിലും ബാക്ക് പ്രസ്സ് ചെയ്യുക അല്ലെങ്കിൽ എക്സിറ്റ് തിരഞ്ഞെടുക്കുക."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "മാറ്റം വരുത്താൻ തിരഞ്ഞെടുക്കുക"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "ഹോം സ്ക്രീൻ, വിഡ്ജറ്റുകൾ, ഷോർട്ട്കട്ട് മെനു എന്നിവയുടെ ഇഷ്‌ടാനുസൃതമാക്കൽ."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "ഒരു ഇമേജ് റിസോഴ്സ് ആഡ്ഓൺ തിരഞ്ഞെടുക്കാൻ ഉപയോക്താക്കളെ അനുവദിക്കുന്നതിന് സ്കിന്നർമാർക്കുള്ള സ്ക്രിപ്റ്റ്."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "നിങ്ങളുടെ മീഡിയ ലൈബ്രറികളിലെ മീഡിയകൾക്കായി അധിക ആർട്ട്‌വർക്ക് സ്വയമേവ ചേർക്കുന്നു."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "സംഗീതത്തിനായുള്ള വരികൾ. ആനിമേറ്റഡ് വരികൾ പ്രവർത്തനക്ഷമമാക്കാൻ ഇത് ആവശ്യമാണ്."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "നിങ്ങളുടെ ശേഖരവും കണ്ട വിവരങ്ങളും trakt.tv യുമായി സമന്വയിപ്പിക്കുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "തിരഞ്ഞെടുത്ത കോഡി പ്രിയപ്പെട്ടവയിൽ നിന്ന് ഒരു ഇഷ്‌ടാനുസൃത പ്രിയപ്പെട്ടവ സൃഷ്‌ടിക്കുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "ഹോം സ്ക്രീൻ മെനു, വിഡ്ജറ്റുകൾ, പശ്ചാത്തലങ്ങൾ, വിവര വരികൾ എന്നിവ എഡിറ്റ് ചെയ്യുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "ഹോം സ്ക്രീൻ മെനു, വിഡ്ജറ്റുകൾ, പശ്ചാത്തലങ്ങൾ, വിവര വരികൾ എന്നിവ സ്ഥിരസ്ഥിതിയിലേക്ക് റീസെറ്റ് ചെയ്യുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "തിരഞ്ഞെടുത്ത കോഡി പ്രിയപ്പെട്ടവയിൽ നിന്ന് ഒരു ഇഷ്‌ടാനുസൃത പ്രിയപ്പെട്ടവ സൃഷ്‌ടിക്കുക. പ്രധാന മെനു വിഡ്ജറ്റുകളിൽ ഉപയോഗിക്കുന്നതിന്. സ്ക്രിപ്റ്റ് ഫേവറിറ്റ്സ് ഇൻസ്റ്റാൾ ചെയ്തിരിക്കണം."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "ഇൻസ്റ്റാൾ ചെയ്ത ആഡ്ഓണുകളിൽ നിന്ന് ഒരു ഇഷ്‌ടാനുസൃത ആഡ്ഓൺ പ്രിയപ്പെട്ടവ സൃഷ്‌ടിക്കുക. പ്രധാന മെനു വിഡ്ജറ്റുകളിൽ ഉപയോഗിക്കാൻ."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "സ്കിൻ തീമും നിറങ്ങളും സ്ഥിരസ്ഥിതിയിലേക്ക് റീസെറ്റ് ചെയ്യുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "മുൻകൂട്ടി നിർവചിച്ച തീമുകളുടെ പട്ടികയിൽ നിന്ന് തിരഞ്ഞെടുക്കുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "കാഴ്ച രീതി, കാഴ്ച ഓപ്ഷനുകൾ, വിവര ഡയലോഗ്, ഫുൾസ്ക്രീൻ ക്രമീകരണങ്ങൾ എന്നിവ പ്രവർത്തനരഹിതമാക്കാൻ മുൻഗണനകൾ ലോക്ക് ചെയ്യുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "ഹോം സ്ക്രീൻ, പ്രിയപ്പെട്ടവ, മുൻകൂട്ടി നിർവചിച്ച തീമുകൾ, കിയോസ്‌ക് മോഡ് എന്നിവ ഇഷ്‌ടാനുസൃതമാക്കുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "സ്കിൻ തീം ടെക്സ്ചറുകൾ മാറ്റുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "സ്കിൻ ടെക്സ്ചർ നിറങ്ങൾ ഇഷ്‌ടാനുസൃതമാക്കുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "നിർദ്ദിഷ്ട സ്കിൻ മേഖലകൾക്കായി പശ്ചാത്തലവും ഫോൾബാക്കുകളും ഇഷ്‌ടാനുസൃതമാക്കുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "വിവിധ സ്കിൻ ഫീച്ചറുകൾ പ്രവർത്തനക്ഷമമാക്കുകയോ പ്രവർത്തനരഹിതമാക്കുകയോ ചെയ്യുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "ആർട്ട്‌വർക്ക് ഇഷ്‌ടാനുസൃതമാക്കുകയും പിന്തുണയ്ക്കുന്ന ആർട്ട്‌വർക്ക് പാക്കുകൾ ഇൻസ്റ്റാൾ ചെയ്യുകയും ചെയ്യുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "പിന്തുണയ്ക്കുന്ന ആഡ്ഓണുകൾ ഇൻസ്റ്റാൾ ചെയ്യുകയും കോൺഫിഗർ ചെയ്യുകയും ചെയ്യുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "ലൈബ്രറി കാഴ്ചകൾ പ്രവർത്തനക്ഷമമാക്കുകയോ പ്രവർത്തനരഹിതമാക്കുകയോ ചെയ്യുക. കുറഞ്ഞ ശേഷിയുള്ള സിസ്റ്റങ്ങളിൽ ലൈബ്രറി കാഴ്ചകൾ പ്രവർത്തനരഹിതമാക്കുന്നത് പ്രകടനം മെച്ചപ്പെടുത്തിയേക്കാം."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "ലൈബ്രറി കാഴ്ചകളിൽ സ്ക്രോൾ ചെയ്യുമ്പോൾ സ്ക്രോൾ ലെറ്റർ കാണിക്കുന്നു."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "കണ്ടെയ്നറിന്റെ ഒരു സ്ഥാനത്തേക്ക് ചാടുന്നതിന് അക്ഷരമാല കാണിക്കുന്നു. സ്ഥിരസ്ഥിതി ക്രമീകരണ രീതികൾക്ക് (A-Z) മാത്രമേ ഇത് പ്രവർത്തിക്കൂ."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "ലഭ്യമാണെങ്കിൽ ടിവി ഷോകൾക്കും സിനിമകൾക്കുമായി പ്ലോട്ട് ഔട്ട്ലൈൻ കാണിക്കുന്നു, അല്ലാത്തപക്ഷം സ്ഥിരസ്ഥിതി പ്ലോട്ട് കാണിക്കും."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "കൺട്രോൾ അളവുകൾക്ക് അനുയോജ്യമല്ലെങ്കിൽ പ്ലോട്ട് സ്വയമേവ സ്ക്രോൾ ചെയ്യുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "നിർദ്ദിഷ്ട സ്കിൻ ഏരിയകളിലേക്ക് തൽക്ഷണ ആക്സസ് ലഭിക്കുന്നതിന് ഷോർട്ട്കട്ട് മെനു പ്രവർത്തനക്ഷമമാക്കുക. മീഡിയ മെനുവിൽ തുറക്കാൻ ഇടത്തേക്ക് ക്ലിക്ക് ചെയ്യുക അല്ലെങ്കിൽ ഷോർട്ട്കട്ട് ഐക്കണിൽ ക്ലിക്ക് ചെയ്യുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "ഷോർട്ട്കട്ട് മെനു എഡിറ്റ് ചെയ്യുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "ടോപ്പ്ബാർ ഘടകങ്ങൾ പ്രവർത്തനക്ഷമമാക്കുകയോ പ്രവർത്തനരഹിതമാക്കുകയോ ചെയ്യുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "വീഡിയോ വിവര ക്രമീകരണങ്ങൾ മാറ്റുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "മ്യൂസിക് വിവര ക്രമീകരണങ്ങൾ മാറ്റുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "ഫുൾസ്ക്രീൻ видео ക്രമീകരണങ്ങൾ മാറ്റുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "ഫുൾസ്ക്രീൻ ഓഡിയോ ക്രമീകരണങ്ങൾ മാറ്റുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "പോപ്പ് അപ്പ് അറിയിപ്പുകളുടെ വലുപ്പം കുറയ്ക്കുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "ഡയലോഗ് പോപ്പ്അപ്പുകൾക്ക് പിന്നിലെ സ്ക്രീൻ ഇരുണ്ടതാക്കുന്നു. ഫുൾസ്ക്രീൻ വീഡിയോയ്ക്കോ ഓഡിയോയ്ക്കോ ബാധകമല്ല."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "ടോപ്പ്ബാർ, മീഡിയ വിവരങ്ങൾ, ലൈബ്രറി കാഴ്ചകൾ എന്നിവയ്ക്കായി വർണ്ണാഭമായ ഐക്കണുകൾ പ്രവർത്തനക്ഷമമാക്കുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "വർണ്ണാഭമായ, HDR, ബിറ്റ് ഡെപ്ത്, ഭാഷാ മീഡിയ ഫ്ലാഗുകൾ എന്നിവ പ്രവർത്തനക്ഷമമാക്കുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "സ്കിന്നിൽ ഉടനീളമുള്ള ഓഡിയോ സിഡി ആർട്ട് ഫോൾബാക്ക്."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "സ്കിന്നിൽ ഉടനീളമുള്ള വീഡിയോ സിഡി ആർട്ട് ഫോൾബാക്ക്."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "ടോപ്പ്ബാർ, വിഡ്ജറ്റുകൾ, കാലാവസ്ഥ എന്നിവയ്ക്കായി ഒരു കാലാവസ്ഥാ ഐക്കൺ പാക്ക് തിരഞ്ഞെടുത്ത് ഇൻസ്റ്റാൾ ചെയ്യുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "പശ്ചാത്തലങ്ങൾ, വിഡ്ജറ്റുകൾ, കാലാവസ്ഥ എന്നിവയ്ക്കായി ഒരു കാലാവസ്ഥാ ഫാൻആർട്ട് പാക്ക് തിരഞ്ഞെടുത്ത് ഇൻസ്റ്റാൾ ചെയ്യുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "സ്കിന്നിൽ ഉടനീളം ഉപയോഗിക്കുന്നതിന് വൈറ്റ് സ്റ്റുഡിയോ ഐക്കണുകൾ ഇൻസ്റ്റാൾ ചെയ്യുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "സ്കിന്നിൽ ഉടനീളം ഉപയോഗിക്കുന്നതിന് കളർ സ്റ്റുഡിയോ ഐക്കണുകൾ ഇൻസ്റ്റാൾ ചെയ്യുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "സ്കിന്നിൽ ഉടനീളം ഉപയോഗിക്കുന്നതിന് റെക്കോർഡ് ലേബൽ ഐക്കണുകൾ ഇൻസ്റ്റാൾ ചെയ്യുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "ലൈബ്രറി കാഴ്ചകൾക്കും സബ്‌ടൈറ്റിൽ തിരഞ്ഞെടുക്കലിനും ഭാഷാ പതാകകൾ ഇൻസ്റ്റാൾ ചെയ്യുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "സംഗീതത്തിനും മ്യൂസിക് വീഡിയോകൾക്കുമായി മ്യൂസിക് തരം ഐക്കണുകൾ ഇൻസ്റ്റാൾ ചെയ്യുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "സിനിമകൾക്കും ടിവി ഷോകൾക്കുമായി വർണ്ണാഭമായ മൂവി തരം ഐക്കണുകൾ ഇൻസ്റ്റാൾ ചെയ്യുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "സിനിമകൾക്കും ടിവി ഷോകൾക്കുമായി ബ്ലാക്ക് ആൻഡ് വൈറ്റ് മൂവി തരം ഐക്കണുകൾ ഇൻസ്റ്റാൾ ചെയ്യുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "സിനിമകളുടെ രാജ്യ നോഡിനായി രാജ്യ ഐക്കണുകൾ ഇൻസ്റ്റാൾ ചെയ്യുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "സ്കിന്നിൽ ഉടനീളമുള്ള ഫാൻആർട്ട് മാറ്റങ്ങൾ തമ്മിലുള്ള കാലതാമസം സജ്ജമാക്കുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "വീഴുന്ന പശ്ചാത്തല ഇഫക്റ്റുകൾ. മഞ്ഞ്, ഇലകൾ തുടങ്ങിയവ."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "നിലവിൽ പ്ലേ ചെയ്യുന്ന ഇനത്തിന്റെ മ്യൂസിക് ഫാൻആർട്ട് സ്കിന്നിൽ ഉടനീളം കാണിക്കുക. ലൈബ്രറി ഫാൻആർട്ടിനെ മറികടക്കുന്നു."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "സംഗീതം പ്ലേ ചെയ്യുമ്പോൾ പശ്ചാത്തലത്തിൽ മ്യൂസിക് വിഷ്വലൈസേഷൻ പ്രാപ്തമാക്കുന്നു. ക്രമീകരണങ്ങൾ - പ്ലെയർ ക്രമീകരണങ്ങൾ/സംഗീതം എന്നിവയിൽ വിഷ്വലൈസേഷൻ പ്രവർത്തനക്ഷമമാക്കിയിരിക്കണം."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "ലൈബ്രറി ബ്രൗസ് ചെയ്യുമ്പോൾ ഇപ്പോൾ പ്ലേ ചെയ്യുന്ന വീഡിയോ പശ്ചാത്തലത്തിൽ കാണിക്കുക. ലൈബ്രറി ഫാൻആർട്ടിനെ മറികടക്കുന്നു."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "നിലവിൽ പ്ലേ ചെയ്യുന്ന കലാകാരന്റെ ചിത്രങ്ങളും അധിക വിവരങ്ങളും fanart.tv, theaudiodb.com എന്നിവയിൽ നിന്ന് ഡൗൺലോഡ് ചെയ്യുക. ഫുൾസ്ക്രീൻ സംഗീതം, ഇന്റർനെറ്റ് സ്ട്രീമുകൾ, റേഡിയോ എന്നിവയ്ക്കായി."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "ആർട്ടിസ്റ്റ് സ്ലൈഡ്ഷോ സ്ക്രിപ്റ്റ് ക്രമീകരണങ്ങൾ."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "ശൂന്യമല്ലെങ്കിൽ വീഡിയോ പ്ലേലിസ്റ്റിലേക്കുള്ള ഒരു ഷോർട്ട്കട്ട്."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "ശൂന്യമല്ലെങ്കിൽ മ്യൂസിക് പ്ലേലിസ്റ്റിലേക്കുള്ള ഒരു ഷോർട്ട്കട്ട്."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "മീഡിയ പ്ലേ ചെയ്യുമ്പോൾ ഫുൾസ്ക്രീനിലേക്കുള്ള ഷോർട്ട്കട്ട്."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "ഷോർട്ട്കട്ട് മെനു തുറക്കാൻ ക്ലിക്ക് ചെയ്യുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "മീഡിയ പ്ലേ ചെയ്യുമ്പോൾ പ്ലെയർ നിയന്ത്രണങ്ങൾ."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "അടുത്ത ടിവി ഷോ എപ്പിസോഡ് സ്വയമേവ പ്ലേ ചെയ്യുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "ടിവി ഷോകൾ, സിനിമകൾ, മ്യൂസിക് വീഡിയോകൾ എന്നിവയിലൂടെ നാവിഗേറ്റ് ചെയ്യുമ്പോൾ തീമുകൾ പ്ലേ ചെയ്യുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "ലൈബ്രറി നോഡ് എഡിറ്റർ കോഡിയിൽ ഇഷ്ടാനുസൃത വീഡിയോ നോഡുകളും മ്യൂസിക് നോഡുകളും സൃഷ്ടിക്കാനും ഇഷ്ടാനുസൃതമാക്കാനും നിങ്ങളെ അനുവദിക്കുന്നു."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "കണ്ടവ, കാണാത്തവ, പുരോഗതിയിലുള്ളവ എന്നിവയ്ക്കായി ഓവർലേ മാർക്കർ വിവരങ്ങൾ കാണിക്കുക."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "കോഡിയുടെ ബിൽറ്റ്-ഇൻ RSS ടിക്കർ എഡിറ്റ് ചെയ്യുന്നതിനുള്ള ഒരു സ്ക്രിപ്റ്റ്."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "സ്കിൻ പതിപ്പും റിക്കവറി ഓപ്ഷനുകളും. എല്ലാ സ്ഥിരസ്ഥിതികളും ആദ്യ ദിവസത്തെ പ്രവർത്തനത്തിലേക്ക് പുനഃസ്ഥാപിക്കുന്നു."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "ആഡ്ഓണുകൾ"