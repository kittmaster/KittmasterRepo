msgstr "\"ഇൻ-പ്രോഗ്രസ്\" ബാർ ഫീച്ചറിന്റെ നിറം ക്രമീകരിക്കാൻ പ്രാപ്തമാക്കുന്നു."

#: /16x9/Includes_Settings.xml
msgctxt "#31473"
msgid "Sets of the color of \"In-Progress\" bar feature globally when enabled."
msgstr "പ്രവർത്തനക്ഷമമാക്കുമ്പോൾ ആഗോളതലത്തിൽ \"ഇൻ-പ്രോഗ്രസ്\" ബാർ ഫീച്ചറിന്റെ നിറം സജ്ജമാക്കുന്നു."

