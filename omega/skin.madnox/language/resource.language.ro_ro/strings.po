#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "Evidențiați un logo din paleta de mai jos și faceți clic pe el pentru a-l atribui fișierelor video DVD și de definiție standard."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "Vizualizați doar designurile de logo ultra-înaltă definiție și 4K din grila paletei."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "Vizualizați doar designurile de logo pentru codecurile HEVC și H.265 din grila paletei."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Vizualizați doar designurile de logo pentru codecurile AVC și H.264 din grila paletei."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Vizualizați doar designurile de logo pentru formatele DivX, XviD și MPEG-4 moștenite din grila paletei."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Vizualizați designurile de logo pentru difuzările clasice MPEG, DVD și TV standard din grila paletei."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Vizualizați designurile de logo pentru codecurile Windows Media Video și VC-1 din grila paletei."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Vizualizați designurile de logo pentru containere media, formate de disc și alte tipuri diverse din grila paletei."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Închideți acest dialog de personalizare a etichetelor și reveniți la setări."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Evidențiați orice design de logo din grila centrală și faceți clic pentru a-l salva ca etichetă personalizată pentru categoria activă."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Ștergeți opțiunea de etichetă personalizată și restaurați această categorie la logica automată a etichetelor implicite din skin."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Comutați grafica globală a etichetelor între designuri colorate și albul monocromatic implicit."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Utilizați tastele direcționale pentru a naviga printre opțiuni. Apăsați Înapoi sau selectați Ieșire în orice moment pentru a închide fără a salva modificările."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Selectați pentru a modifica"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Personalizarea ecranului de pornire, a widgeturilor și a meniului de scurtături."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Script pentru creatori de skinuri pentru a le permite utilizatorilor să selecteze un supliment de resurse de imagini."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Adaugă automat artă grafică suplimentară pentru elementele media din bibliotecile dvs."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Versuri pentru muzică. Necesar pentru a activa versurile animate."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Sincronizați-vă colecția și starea de vizionare cu trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Creați un favorit personalizat din favoritele Kodi selectate."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Editați meniul ecranului de pornire, widgeturile, fundalurile și liniile de informații."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Resetați meniul ecranului de pornire, widgeturile, fundalurile și liniile de informații la valorile implicite."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Creați un favorit personalizat din favoritele Kodi selectate. Pentru utilizare în widgeturile meniului principal. Necesită instalarea scriptului pentru favorite."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Creați un favorit supliment personalizat din suplimentele instalate. Pentru utilizare în widgeturile meniului principal."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Resetați tema și culorile skinului la valorile implicite."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Selectați dintr-o listă de teme predefinite."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Blocați preferințele pentru a dezactiva modul de vizualizare, opțiunile de vizualizare, dialogul de informații și setările pe tot ecranul."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Personalizați ecranul de pornire, favoritele, temele predefinite și modul chioșc."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Schimbați texturile temei skinului."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Personalizați culorile texturii skinului."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Personalizați fundalul și rezervele pentru anumite zone ale skinului."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Activați sau dezactivați diverse caracteristici ale skinului."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Personalizați arta grafică și instalați pachete de artă acceptate."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Instalați și configurați suplimentele acceptate."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Activați și dezactivați vizualizările de bibliotecă. Dezactivarea vizualizărilor de bibliotecă pe sistemele cu specificații reduse poate îmbunătăți performanța."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Afișează litera de derulare când se derulează în vizualizările bibliotecii."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Afișează alfabetul pentru a sări la o poziție din container. Funcționează numai pentru metodele de sortare implicite (A-Z)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Afișează rezumatul scurt al serialelor și filmelor dacă este disponibil, în caz contrar va afișa rezumatul complet implicit."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Defilare automată a rezumatului dacă acesta nu se încadrează în dimensiunile controlului."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Activați meniul de scurtături pentru acces instantaneu la anumite zone ale skinului. În meniul media, faceți clic la stânga pentru a deschide sau faceți clic pe pictograma scurtăturii."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Editați meniul de scurtături."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Activați și dezactivați elementele barei de sus."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Schimbați setările de informații video."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Schimbați setările de informații muzică."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Schimbați setările video pe tot ecranul."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Schimbați setările audio pe tot ecranul."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Reduceți dimensiunea notificărilor de tip pop-up."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Întunecă ecranul din spatele ferestrelor de dialog. Nu se aplică pentru video sau audio pe tot ecranul."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Activați pictogramele colorate pentru bara de sus, informațiile media și vizualizările bibliotecii."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Activați etichetele media colorate, HDR, adâncime de biți și limbă."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Imagine CD audio de rezervă la nivel de skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Imagine CD video de rezervă la nivel de skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Selectați și instalați un pachet de pictograme meteo pentru bara de sus, widgeturi și vreme."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Selectați și instalați un pachet de fanart meteo pentru fundaluri, widgeturi și vreme."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Instalați pictograme albe de studio pentru utilizare în întregul skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Instalați pictograme colorate de studio pentru utilizare în întregul skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Instalați pictograme de case de discuri pentru utilizare în întregul skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Instalați steaguri de limbă pentru vizualizările bibliotecii și selectarea subtitrărilor."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Instalați pictograme pentru genul muzical pentru muzică și videoclipuri muzicale."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Instalați pictograme colorate de gen de film pentru filme și seriale."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Instalați pictograme alb-negru de gen de film pentru filme și seriale."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Instalați pictogramele țărilor pentru nodul țară al filmelor."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Setați întârzierea dintre tranzițiile fanart la nivel de skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Efecte de fundal în cădere. Zăpadă, frunze etc."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Afișează fanart-ul muzical al elementului redat în prezent la nivel de skin. Suprascrie fanart-ul bibliotecii."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Activează vizualizarea muzicală în fundal în timpul redării muzicii. Necesită ca vizualizarea să fie activată în Setări - Setări player/Muzică."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Afișează videoclipul redat în prezent în fundal în timp ce navigați prin bibliotecă. Suprascrie fanart-ul bibliotecii."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Descărcați imagini și informații suplimentare de pe fanart.tv și theaudiodb.com pentru artistul care rulează în prezent. Pentru muzică pe tot ecranul, fluxuri internet și radio."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Setări script prezentare diapozitive artist."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "O scurtătură către lista de redare video dacă nu este goală."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "O scurtătură către lista de redare muzică dacă nu este goală."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Scurtătură către ecran complet când rulează fișiere media."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Faceți clic pentru a deschide meniul de scurtături."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Controale player când rulează fișiere media."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Redă automat următorul episod al serialului."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Redă teme muzicale în timp ce navigați prin seriale, filme și videoclipuri muzicale."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "Editorul de noduri de bibliotecă vă permite să creați și să personalizați noduri video și muzicale personalizate în Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Afișează informații despre marcatorii suprapuși pentru elementele media vizionate, nevizionate și în curs de desfășurare."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Un script pentru editarea benzii RSS integrate din Kodi."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Versiunea skinului și opțiunile de recuperare. Restaurează toate valorile implicite la starea inițială."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Suplimente"