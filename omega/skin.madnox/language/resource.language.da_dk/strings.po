msgstr "Vis kun AVC- og H.264-codec-logodesign i paletgitteret."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Vis kun DivX-, XviD- og ældre MPEG-4-format-logodesign i paletgitteret."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Vis klassiske MPEG-, DVD- og standard TV-udsendelses-logodesign i paletgitteret."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Vis Windows Media Video- og VC-1-codec-logodesign i paletgitteret."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Vis container-wrappers, diskformater og andre diverse logodesign i paletgitteret."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Luk denne dialogboks til flagtilpasning og vend tilbage til indstillinger."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Fremhæv et vilkårligt logodesign i midtergitteret, og klik for at gemme det som dit brugerdefinerede flag for den aktive kategori."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Ryd dit brugerdefinerede flagvalg, og gendan denne kategori til skinnets automatiske standard-flaglogik."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Skift global flag-grafik mellem farvede design og monokrom standard hvid."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Brug dine piletaster til at navigere i mulighederne. Tryk på Tilbage eller vælg Afslut når som helst for at lukke uden ændringer."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Vælg for at redigere"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Tilpasning af startskærmen, widgets og genvejsmenuen."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Script til skin-udviklere, der lader brugere vælge en billedressource-tilføjelse."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Tilføjer automatisk ekstra grafik til medier i dine mediebiblioteker."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Sangtekster til musik. Påkrævet for at aktivere animerede sangtekster."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Synkroniser din samling og set-status med trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Opret en brugerdefineret favorit ud fra valgte Kodi-favoritter."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Rediger startskærmmenuen, widgets, baggrunde og infolinjer."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Nulstil startskærmmenuen, widgets, baggrunde og infolinjer til standard."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Opret en brugerdefineret favorit ud fra valgte Kodi-favoritter. Til brug i hovedmenu-widgets. Kræver, at favoritter-scriptet er installeret."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Opret en brugerdefineret favorit-tilføjelse ud fra installerede tilføjelser. Til brug i hovedmenu-widgets."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Nulstil skin-temaet og farverne til standard."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Vælg fra en liste over foruddefinerede temaer."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Lås indstillinger for at deaktivere visningstilstand, visningsmuligheder, infodialog og fuldskærmsindstillinger."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Tilpas startskærmen, favoritter, foruddefinerede temaer og kiosk-tilstand."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Skift teksturer for skin-temaet."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Tilpas farverne på skin-teksturen."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Tilpas baggrunden og fallback-billeder til specifikke skin-områder."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Aktiver eller deaktiver forskellige skin-funktioner."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Tilpas grafik og installer understøttede grafikpakker."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Installer og konfigurer understøttede tilføjelser."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Aktiver og deaktiver biblioteksvisninger. Deaktivering af biblioteksvisninger på systemer med lave specifikationer kan forbedre ydeevnen."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Viser rullebogstav, når der rulles i biblioteksvisninger."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Viser alfabetet for at hoppe til en position i containeren. Fungerer kun for standardsorteringsmetoder (A-Z)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Viser kort handlingsreferat for TV-serier og film, hvis det er tilgængeligt, ellers vises standardreferatet."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Rul automatisk handlingsteksten, hvis den ikke passer til kontrolelementets dimensioner."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Aktiver genvejsmenuen for hurtig adgang til specifikke skin-områder. I mediemenuen skal du klikke til venstre for at åbne eller klikke på genvejsikonet."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Rediger genvejsmenuen."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Aktiver og deaktiver elementer i topbjælken."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Skift indstillinger for videoinfo."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Skift indstillinger for musikinfo."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Skift indstillinger for video i fuldskærm."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Skift indstillinger for lyd i fuldskærm."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Reducer størrelsen på pop-up-notifikationer."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Mørkner skærmen bag dialog-pop-ups. Gælder ikke for video eller lyd i fuldskærm."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Aktiver farvede ikoner til topbjælken, medieinformationer og biblioteksvisninger."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Aktiver farvede-, HDR-, bitdybde- og sprogmedieflag."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Fallback for lyd-cd-art i hele skinnet."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Fallback for video-cd-art i hele skinnet."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Vælg og installer en vejrikonpakke til topbjælken, widgets og vejr."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Vælg og installer en vejr-fanartpakke til baggrunde, widgets og vejr."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Installer hvide studieikoner til brug i hele skinnet."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Installer farvede studieikoner til brug i hele skinnet."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Installer pladeselskabsikoner til brug i hele skinnet."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Installer sprogflag til biblioteksvisninger og valg af undertekster."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Installer musikgenreikoner til musik og musikvideoer."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Installer farvede filmgenreikoner til film og TV-serier."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Installer sort/hvide filmgenreikoner til film og TV-serier."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Installer landeikoner til filmens landeknude."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Indstil forsinkelsen mellem fanart-overgange i hele skinnet."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Faldende baggrundseffekter. Sne, blade osv."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Vis musik-fanart for det element, der afspilles nu, i hele skinnet. Tilsidesætter biblieteks-fanart."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Aktiverer musikvisualisering i baggrunden, mens der afspilles musik. Kræver, at visualisering er aktiveret i Indstillinger - Afspillerindstillinger/Musik."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Vis den video, der afspilles nu, i baggrunden, mens du gennemser biblioteket. Tilsidesætter biblieteks-fanart."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Download billeder og yderligere information fra fanart.tv og theaudiodb.com for den kunstner, der afspilles nu. Til musik i fuldskærm, internet-streams og radio."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Indstillinger for script til kunstner-diasshow."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "En genvej til videoplaylisten, hvis den ikke er tom."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "En genvej til musikplaylisten, hvis den ikke er tom."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Genvej til fuldskærm, når der afspilles medier."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Klik for at åbne genvejsmenuen."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Afspillerstyring, når medier afspilles."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Afspil automatisk næste episode af en TV-serie."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Afspil temamusik, mens du navigerer i TV-serier, film og musikvideoer."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "Biblioteksknude-editoren lader dig oprette og tilpasse brugerdefinerede videoknuder og musikknuder i Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Vis overlay-markeringsinformation for sete, usete og igangværende medieelementer."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Et script til redigering af Kodis indbyggede RSS-ticker."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Skin-version og gendannelsesmuligheder. Gendanner alle standardindstillinger til de oprindelige standardværdier."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Tilføjelser"