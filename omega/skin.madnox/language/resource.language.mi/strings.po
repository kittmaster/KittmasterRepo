# --- Body texts: top row category selectors (controls 901–904, 905) ---

#: /16x9/includes.xml
msgctxt "#31567"
msgid "Highlight a logo from the palette below and click to assign it to 4K / UHD video files."
msgstr "Miramirahia tētahi tohu mai i te pae tae i raro iho nei, ā, pēhi ki te toha ki ngā kōnae ataata 4K / UHD."

#: /16x9/includes.xml
msgctxt "#31568"
msgid "Highlight a logo from the palette below and click to assign it to WebDL and streaming video sources."
msgstr "Miramirahia tētahi tohu mai i te pae tae i raro iho nei, ā, pēhi ki te toha ki ngā mātāpuna ataata WebDL me te pāho."

#: /16x9/includes.xml
msgctxt "#31569"
msgid "Highlight a logo from the palette below and click to assign it to 1080p Full HD video files."
msgstr "Miramirahia tētahi tohu mai i te pae tae i raro iho nei, ā, pēhi ki te toha ki ngā kōnae ataata 1080p Full HD."

#: /16x9/includes.xml
msgctxt "#31570"
msgid "Highlight a logo from the palette below and click to assign it to 720p HD video files."
msgstr "Miramirahia tētahi tohu mai i te pae tae i raro iho nei, ā, pēhi ki te toha ki ngā kōnae ataata 720p HD."

#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "Miramirahia tētahi tohu mai i te pae tae i raro iho nei, ā, pēhi ki te toha ki ngā kōnae ataata DVD me te whakataunga paerewa."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "Tirohia ngā hoahoa tohu whakataunga tino nui me te 4K anake i te pae tae."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "Tirohia ngā hoahoa tohu codec HEVC me te H.265 anake i te pae tae."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Tirohia ngā hoahoa tohu codec AVC me te H.264 anake i te pae tae."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Tirohia ngā hoahoa tohu hōputu DivX, XviD, me te MPEG-4 tuku iho anake i te pae tae."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Tirohia ngā hoahoa tohu pāhotanga MPEG, DVD, me te pouaka whakaata paerewa anake i te pae tae."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Tirohia ngā hoahoa tohu codec Windows Media Video me te VC-1 anake i te pae tae."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Tirohia ngā hoahoa tohu kōpaki kōnae, hōputu kōpae, me ētahi atu hoahoa rerekē i te pae tae."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Katia tēnei pouaka whakaritenga haki, ā, whakahoki ki ngā tautuhinga."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Miramirahia tētahi hoahoa tohu i te pae kei waenga, ā, pēhi ki te tiaki hei haki whakarite ake māu mō te kāwai kaha."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Mukua tō kōwhiringa haki whakarite ake, ā, whakahokia tēnei kāwai ki te arorau haki taunoa aunoa a te kiri."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Whakahurihia te toi haki puta noa i waenga i ngā hoahoa whai tae me te mangu/mā taunoa."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Whakamahia ō patene ahunga hei whakatere i ngā kōwhiringa. Pēhi i te Patene Hoki, kōwhiria rānei te Puta i ngā wā katoa hei kati me te kore e whakarerekē."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Kōwhiri hei whakarerekē"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Whakaritenga o te mata kāinga, ngā atanga iti me te rārangi pokatata."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "He tuhituhinga mō ngā kaihoahoa kiri kia taea ai e ngā kaiwhakamahi te kōwhiri i tētahi tāpirihanga rauemi atahanga."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Ka tāpiri aunoa i te toi tāpiri mō ngā pāpāho i roto i ō puna pāpāho."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Kupu waiata mō te puoro. E hiahiatia ana hei whakahohe i ngā kupu waiata hākoritanga."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Te tukutahi i tō kohinga me te tūnga mātakitaki ki trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Hangaia he tino pai ake mai i ngā tino pai a kodi kua kōwhiria."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Whakatika i te rārangi mata kāinga, ngā atanga iti, ngā tuarongo me ngā rārangi mōhiohio."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Tautuhia anō te rārangi mata kāinga, ngā atanga iti, ngā tuarongo me ngā rārangi mōhiohio ki te taunoa."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Hangaia he tino pai ake mai i ngā tino pai a kodi kua kōwhiria. Hei whakamahi i ngā atanga iti o te rārangi matua. Me whakauru te tuhituhinga tino pai."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Hangaia he tāpirihanga tino pai ake mai i ngā tāpirihanga kua whakauruhia. Hei whakamahi i ngā atanga iti o te rārangi matua."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Tautuhia anō te kaupapa kiri me ngā tae ki te taunoa."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Kōwhiria mai i tētahi rārangi kaupapa kua oti te whakarite."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Maukati ngā kōwhiringa matua hei whakakore i te aratau tirohanga, ngā kōwhiringa tirohanga, te pouaka kōrero mōhiohio me ngā tautuhinga mata-whānui."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Whakaritea te mata kāinga, ngā tino pai, ngā kaupapa kua oti te whakarite me te aratau kiosk."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Huria ngā kākano kaupapa kiri."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Whakaritea ngā tae kākano kiri."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Whakaritea te tuarongo me ngā kōwhiringa tuarua mō ngā wāhanga kiri motuhake."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Whakahohea, whakakorea rānei ētahi āhuatanga kiri rerekē."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Whakaritea te toi me te whakauru i ngā kete toi e tautokona ana."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Whakauruhia me te whirihora i ngā tāpirihanga e tautokona ana."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Whakahohea, whakakorea rānei ngā tirohanga puna mōhio. Ka rorohiko ake te mahi a ngā pūnaha ngoikore ki te whakakorea ngā tirohanga puna mōhio."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Whakaatuhia te reta kōpiko ina huri haere i ngā tirohanga puna mōhio."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Whakaatuhia te tāpiritanga tātai reta hei peke ki tētahi tūranga o te ipu. Ka mahi noa mō ngā tikanga whakaraupapa taunoa (A-Z)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Whakaatuhia te whakarāpopototanga kōrero mō ngā whakaaturanga TV me ngā whitiāhua ki te wātea, ki te kore ka whakaatuhia te kōrero taunoa."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Kōpeke aunoatia te kōrero ki te kore e uru ki ngā rahi whakahaere."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Whakahohea te rārangi pokatata mō te urunga tere ki ngā wāhanga kiri motuhake. I te rārangi pāpāho, pēhi ki te taha mauī hei whakatuwhera, pēhi rānei i te tohu pokatata."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Whakatika i te rārangi pokatata."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Whakahohea, whakakorea rānei ngā tūemi o te pae runga."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Huria ngā tautuhinga mōhiohio ataata."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Huria ngā tautuhinga mōhiohio puoro."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Huria ngā tautuhinga ataata mata-whānui."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Huria ngā tautuhinga oro mata-whānui."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Whakaitihia te rahi o ngā pānuitanga pakū-ake."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Whakapōuri i te mata i muri i ngā pouaka pānuitanga. Kāore e pā ki te ataata, oro rānei i te mata-whānui."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Whakahohea ngā tohu whai tae mō te pae runga, mōhiohio pāpāho me ngā tirohanga puna mōhio."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Whakahohea ngā haki pāpāho whai tae, HDR, hohonu paraire me te reo."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Toi kōpae oro tuarua puta noa i te kiri."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Toi kōpae ataata tuarua puta noa i te kiri."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Kōwhiria me te whakauru i tētahi kete tohu huarere mō te pae runga, ngā atanga iti me te huarere."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Kōwhiria me te whakauru i tētahi kete toi kaiwhaiwhai huarere mō ngā tuarongo, ngā atanga iti me te huarere."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Whakauruhia ngā tohu Whare Hopu mangu/mā hei whakamahi puta noa i te kiri."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Whakauruhia ngā tohu Whare Hopu whai tae hei whakamahi puta noa i te kiri."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Whakauruhia ngā tohu tohu hopu mō te whakamahi puta noa i te kiri."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Whakauruhia ngā haki reo mō ngā tirohanga puna mōhio me te kōwhiringa taitara-ā-raro."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Whakauruhia ngā tohu momo puoro mō te puoro me ngā ataata puoro."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Whakauruhia ngā tohu momo whitiāhua whai tae mō ngā whitiāhua me ngā whakaaturanga pouaka whakaata."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Whakauruhia ngā tohu momo whitiāhua mangu/mā mō ngā whitiāhua me ngā whakaaturanga pouaka whakaata."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Whakauruhia ngā tohu whenua mō te kōpuku whenua o ngā whitiāhua."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Tautuhia te tōmuri i waenga i ngā huringa toi kaiwhaiwhai puta noa i te kiri."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Ngā paheko tuarongo taka iho. Huka rororori, Rau, me ētahi atu."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Whakaatuhia te toi kaiwhaiwhai puoro o te tūemi e whakatangi ana i nāianei puta noa i te kiri. Ka whakakapi tēnei i te toi kaiwhaiwhai puna mōhio."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Whakahohea te whakaataata puoro i te tuarongo i te wā e whakatangi ana te puoro. Me whakahohe te whakaataata i ngā tautuhinga - Tautuhinga Kaiwhakatangi/Puoro."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Whakaatuhia te ataata e whakatangi ana i nāianei i te tuarongo i te wā e tirotiro ana i te puna mōhio. Ka whakakapi tēnei i te toi kaiwhaiwhai puna mōhio."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Tikiake i ngā atahanga me ngā mōhiohio tāpiri mai i fanart.tv me theaudiodb.com mō te kaiwaiata e whakatangi ana i nāianei. Mō te puoro mata-whānui, ngā pāhotanga tuihono me te irirangi."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Ngā tautuhinga tuhituhinga whakaaturanga kiriata kaiwaiata."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "He pokatata ki te rārangi pānuitanga ataata mēnā kāore i te kaupapa."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "He pokatata ki te rārangi pānuitanga puoro mēnā kāore i te kaupapa."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "He pokatata ki te mata-whānui ina whakatangi ana te pāpāho."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Pēhi hei whakatuwhera i te rārangi pokatata."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Ngā whakahaere kaiwhakatangi ina whakatangi ana te pāpāho."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Whakatangihia te pāhotanga whakaaturanga TV whai ake aunoa."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Whakatangihia ngā kaupapa puoro i te wā e whakatere ana i ngā Whakaaturanga TV, ngā Whitiāhua me ngā Ataata Puoro."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "Ma te Kaiwhakatika Kōpuku Puna Mōhio e whakaae ki a koe te hanga me te whakarite i ngā kōpuku ataata me ngā kōpuku puoro i roto i a Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Whakaatuhia te mōhiohio tohu taupoki mō ngā tūemi pāpāho kua mātakitakitia, kāore anō kia mātakitakitia, me ngā mea kei te haere tonu."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "He tuhituhinga mō te whakatika i te Tika RSS taketake a Kodi."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Ko te putanga kiri me ngā kōwhiringa whakahoki. Ka whakahoki i ngā taunoa katoa ki te mahi o te rā tuatahi."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Ngā Tāpirihanga"