<?xml version="1.0" encoding="utf-8" ?>
<includes>
	<include name="View541SquareWall">
		<!-- Background fade -->
		<control type="group">
			<visible>Control.IsVisible(541)</visible>
			<include>AnimationVisibleFade</include>
			<include>AnimationWindowFade</include>
			<control type="image">
				<include>FullScreenDimensions</include>
				<texture>colors/black50.png</texture>
			</control>
		</control>
		<!-- Panel -->
		<control type="group">
			<visible>Control.IsVisible(541)</visible>
			<animation effect="slide" end="0,-40" time="240" condition="Skin.HasSetting(VideosHideTopBar) + [$EXP[AreaVisibleVideos]]">Conditional</animation>
			<animation effect="slide" end="0,-40" time="240" condition="Skin.HasSetting(VideosHideTopBar) + [$EXP[AreaVisibleMusic]]">Conditional</animation>
			<animation effect="slide" end="0,-40" time="240" condition="Skin.HasSetting(AddonsHideTopBar) + [$EXP[AreaVisibleAddons]]">Conditional</animation>
			<include>AnimationZoomWindow</include>
			<include>AnimationZoomVisible</include>
			<control type="panel" id="541">
				<top>80</top>
				<left>40</left>
				<width>1840</width>
				<height>1040</height>
				<onleft>9050</onleft>
				<onright>60541</onright>
				<pagecontrol>60541</pagecontrol>
				<include>ContainerScrollTime</include>
				<viewtype label="$LOCALIZE[31255]">bigicon</viewtype>

				<!-- ── LARGE layouts ───────────────────────────────────────────
				     Non-Favourites: gated by !SmallIcons setting as original.
				     Favourites: always active (541 = large only here).        -->
				<itemlayout height="368" width="368" condition="[!Skin.HasSetting(View541SmallIcons) + !Container.Content(albums)] | [!Skin.HasSetting(View541SmallIcons) + !Skin.HasSetting(View541AlbumCase) + Container.Content(albums)] | [Window.IsVisible(MyFavourites.xml) + !Container.Content(albums)] | [Window.IsVisible(MyFavourites.xml) + !Skin.HasSetting(View541AlbumCase) + Container.Content(albums)]">
					<include content="ViewArtwork">
						<param name="aspect">keep</param>
						<param name="texturefadetime">0</param>
						<param name="diffuse">diffuse/rounded5-348x348.png</param>
						<param name="labelvisible">Container.Content(artists) + !Skin.HasSetting(View541DisableArtistLabel)</param>
					</include>
				</itemlayout>
				<focusedlayout height="368" width="368" condition="[!Skin.HasSetting(View541SmallIcons) + !Container.Content(albums)] | [!Skin.HasSetting(View541SmallIcons) + !Skin.HasSetting(View541AlbumCase) + Container.Content(albums)] | [Window.IsVisible(MyFavourites.xml) + !Container.Content(albums)] | [Window.IsVisible(MyFavourites.xml) + !Skin.HasSetting(View541AlbumCase) + Container.Content(albums)]">
					<control type="group">
						<animation effect="zoom" start="100" end="115" center="auto" time="240">focus</animation>
						<animation effect="zoom" start="115" end="100" center="auto" time="240">unfocus</animation>
						<control type="image">
							<texture colordiffuse="$VAR[PanelHighlightColorVar]" border="10">buttons/thumb-select-focus.png</texture>
						</control>
						<include content="ViewArtwork">
							<param name="aspect">keep</param>
							<param name="texturefadetime">0</param>
							<param name="diffuse">diffuse/rounded5-348x348.png</param>
							<param name="labeltextcolor">$VAR[PanelTextColorVar]</param>
							<param name="labelvisible">Container.Content(artists) + !Skin.HasSetting(View541DisableArtistLabel)</param>
						</include>
					</control>
				</focusedlayout>
				<!-- Album case large: non-Favourites only (Favourites uses 5411 for small) -->
				<itemlayout height="343" width="368" condition="!Skin.HasSetting(View541SmallIcons) + Skin.HasSetting(View541AlbumCase) + Container.Content(albums)">
					<include content="ViewArtworkAudioCase">
						<param name="texturefadetime">0</param>
						<param name="bordersize">39,14,14,14</param>
					</include>
				</itemlayout>
				<focusedlayout height="343" width="368" condition="!Skin.HasSetting(View541SmallIcons) + Skin.HasSetting(View541AlbumCase) + Container.Content(albums)">
					<control type="group">
						<animation effect="zoom" start="100" end="115" center="auto" time="240">focus</animation>
						<animation effect="zoom" start="115" end="100" center="auto" time="240">unfocus</animation>
						<control type="image">
							<texture colordiffuse="$VAR[PanelHighlightColorVar]" border="10">buttons/thumb-select-focus.png</texture>
						</control>
						<include content="ViewArtworkAudioCase">
							<param name="texturefadetime">0</param>
							<param name="bordersize">39,14,14,14</param>
						</include>
					</control>
				</focusedlayout>

				<!-- ── SMALL layouts: only active in non-Favourites ───────── -->
				<itemlayout height="306.65" width="306.65" condition="[Skin.HasSetting(View541SmallIcons) + !Container.Content(albums) + !Window.IsVisible(MyFavourites.xml)] | [Skin.HasSetting(View541SmallIcons) + !Skin.HasSetting(View541AlbumCase) + Container.Content(albums) + !Window.IsVisible(MyFavourites.xml)]">
					<include content="ViewArtwork">
						<param name="aspect">keep</param>
						<param name="texturefadetime">0</param>
						<param name="diffuse">diffuse/rounded5-287x287.png</param>
						<param name="labelvisible">Container.Content(artists) + !Skin.HasSetting(View541DisableArtistLabel)</param>
						<param name="labelfont">Font26_Cond_07</param>
					</include>
				</itemlayout>
				<focusedlayout height="306.65" width="306.65" condition="[Skin.HasSetting(View541SmallIcons) + !Container.Content(albums) + !Window.IsVisible(MyFavourites.xml)] | [Skin.HasSetting(View541SmallIcons) + !Skin.HasSetting(View541AlbumCase) + Container.Content(albums) + !Window.IsVisible(MyFavourites.xml)]">
					<control type="group">
						<animation effect="zoom" start="100" end="115" center="auto" time="240">focus</animation>
						<animation effect="zoom" start="115" end="100" center="auto" time="240">unfocus</animation>
						<control type="image">
							<texture colordiffuse="$VAR[PanelHighlightColorVar]" border="10">buttons/thumb-select-focus.png</texture>
						</control>
						<include content="ViewArtwork">
							<param name="aspect">keep</param>
							<param name="texturefadetime">0</param>
							<param name="diffuse">diffuse/rounded5-287x287.png</param>
							<param name="labeltextcolor">$VAR[PanelTextColorVar]</param>
							<param name="labelvisible">Container.Content(artists) + !Skin.HasSetting(View541DisableArtistLabel)</param>
							<param name="labelfont">Font26_Cond_07</param>
						</include>
					</control>
				</focusedlayout>
				<itemlayout height="285" width="306.65" condition="Skin.HasSetting(View541SmallIcons) + Skin.HasSetting(View541AlbumCase) + Container.Content(albums) + !Window.IsVisible(MyFavourites.xml)">
					<include content="ViewArtworkAudioCase">
						<param name="texturefadetime">0</param>
						<param name="bordersize">34,14,14,14</param>
					</include>
				</itemlayout>
				<focusedlayout height="285" width="306.65" condition="Skin.HasSetting(View541SmallIcons) + Skin.HasSetting(View541AlbumCase) + Container.Content(albums) + !Window.IsVisible(MyFavourites.xml)">
					<control type="group">
						<animation effect="zoom" start="100" end="115" center="auto" time="240">focus</animation>
						<animation effect="zoom" start="115" end="100" center="auto" time="240">unfocus</animation>
						<control type="image">
							<texture colordiffuse="$VAR[PanelHighlightColorVar]" border="10">buttons/thumb-select-focus.png</texture>
						</control>
						<include content="ViewArtworkAudioCase">
							<param name="texturefadetime">0</param>
							<param name="bordersize">34,14,14,14</param>
						</include>
					</control>
				</focusedlayout>
			</control>
			<control type="group">
				<visible>!Window.IsVisible(MyFavourites.xml)</visible>
				<include content="ViewWallScrollBar">
					<param name="id">541</param>
				</include>
			</control>
		</control>
		<!-- Bottom info/Media flags: suppressed in Favourites (has its own HUD) -->
		<control type="group">
			<visible>Control.IsVisible(541) + !Window.IsVisible(MyFavourites.xml)</visible>
			<include content="AnimationSlideBottomWindow">
				<param name="slide">220</param>
			</include>
			<include>FloorShadowWall</include>
			<include content="ViewCoverFlowBottomInfo">
				<param name="logovisible">View541Logo</param>
			</include>
			<include content="MediaFlagsPanelVideos" condition="Window.IsVisible(MyVideoNav.xml)">
				<param name="left">50</param>
				<param name="right">50</param>
				<param name="bottom">28</param>
			</include>
			<include content="MediaFlagsPanelAudio" condition="Window.IsVisible(MyMusicNav.xml)">
				<param name="left">50</param>
				<param name="right">50</param>
				<param name="bottom">28</param>
			</include>
		</control>

		<!-- ═══════════════════════════════════════════════════════════════ -->
		<!-- FAVOURITES SMALL VIEW (5411)                                   -->
		<!-- Panel 541 is locked to large in Favourites. This panel handles -->
		<!-- small exclusively via Container.SetViewMode(5411).             -->
		<!-- ═══════════════════════════════════════════════════════════════ -->
		<control type="group">
			<visible>Window.IsVisible(MyFavourites.xml)</visible>
			<!-- Background fade for small view -->
			<control type="group">
				<visible>Control.IsVisible(5411)</visible>
				<include>AnimationVisibleFade</include>
				<include>AnimationWindowFade</include>
				<control type="image">
					<include>FullScreenDimensions</include>
					<texture>colors/black50.png</texture>
				</control>
			</control>
			<!-- Small panel -->
			<control type="panel" id="5411">
				<top>80</top>
				<left>40</left>
				<width>1840</width>
				<height>1040</height>
				<onleft>9050</onleft>
				<onright>605411</onright>
				<pagecontrol>605411</pagecontrol>
				<include>ContainerScrollTime</include>
				<viewtype label="$LOCALIZE[31255]">bigicon</viewtype>
				<itemlayout height="306.65" width="306.65" condition="!Container.Content(albums) | [Container.Content(albums) + !Skin.HasSetting(View541AlbumCase)]">
					<include content="ViewArtwork">
						<param name="aspect">keep</param>
						<param name="texturefadetime">0</param>
						<param name="diffuse">diffuse/rounded5-287x287.png</param>
						<param name="labelvisible">Container.Content(artists) + !Skin.HasSetting(View541DisableArtistLabel)</param>
						<param name="labelfont">Font26_Cond_07</param>
					</include>
				</itemlayout>
				<focusedlayout height="306.65" width="306.65" condition="!Container.Content(albums) | [Container.Content(albums) + !Skin.HasSetting(View541AlbumCase)]">
					<control type="group">
						<animation effect="zoom" start="100" end="115" center="auto" time="240">focus</animation>
						<animation effect="zoom" start="115" end="100" center="auto" time="240">unfocus</animation>
						<control type="image">
							<texture colordiffuse="$VAR[PanelHighlightColorVar]" border="10">buttons/thumb-select-focus.png</texture>
						</control>
						<include content="ViewArtwork">
							<param name="aspect">keep</param>
							<param name="texturefadetime">0</param>
							<param name="diffuse">diffuse/rounded5-287x287.png</param>
							<param name="labeltextcolor">$VAR[PanelTextColorVar]</param>
							<param name="labelvisible">Container.Content(artists) + !Skin.HasSetting(View541DisableArtistLabel)</param>
							<param name="labelfont">Font26_Cond_07</param>
						</include>
					</control>
				</focusedlayout>
				<itemlayout height="285" width="306.65" condition="Skin.HasSetting(View541AlbumCase) + Container.Content(albums)">
					<include content="ViewArtworkAudioCase">
						<param name="texturefadetime">0</param>
						<param name="bordersize">34,14,14,14</param>
					</include>
				</itemlayout>
				<focusedlayout height="285" width="306.65" condition="Skin.HasSetting(View541AlbumCase) + Container.Content(albums)">
					<control type="group">
						<animation effect="zoom" start="100" end="115" center="auto" time="240">focus</animation>
						<animation effect="zoom" start="115" end="100" center="auto" time="240">unfocus</animation>
						<control type="image">
							<texture colordiffuse="$VAR[PanelHighlightColorVar]" border="10">buttons/thumb-select-focus.png</texture>
						</control>
						<include content="ViewArtworkAudioCase">
							<param name="texturefadetime">0</param>
							<param name="bordersize">34,14,14,14</param>
						</include>
					</control>
				</focusedlayout>
			</control>
			<!-- Small scrollbar: ViewWallScrollBar with id=5411 generates id="605411" -->
			<control type="group">
				<visible>Control.IsVisible(5411)</visible>
				<include content="ViewWallScrollBar">
					<param name="id">5411</param>
				</include>
			</control>
		</control>
	</include>
</includes>
