<?xml version="1.0" encoding="utf-8" ?>
<includes>
	<include name="View542BannerWall">
		<!-- Background fade -->
		<control type="group">
			<visible>Control.IsVisible(542)</visible>
			<include>AnimationVisibleFade</include>
			<include>AnimationWindowFade</include>
			<control type="image">
				<include>FullScreenDimensions</include>
				<texture>colors/black80.png</texture>
			</control>
		</control>

		<!-- Main Panel Group (Animates) -->
		<control type="group">
			<visible>Control.IsVisible(542)</visible>
			<!-- Animation To Slide Wall Left When Trailer Plays -->
			<animation type="Conditional" condition="!String.IsEmpty(Window(Home).Property(IsPlayingTrailer))" reversible="true">
				<effect type="slide" end="-800,0" time="400" tween="cubic" easing="out" />
			</animation>
			<animation effect="slide" end="0,-40" time="240" condition="Skin.HasSetting(VideosHideTopBar) + [$EXP[AreaVisibleVideos]]">Conditional</animation>
			<animation effect="slide" end="0,-40" time="240" condition="Skin.HasSetting(MusicHideTopBar) + [$EXP[AreaVisibleMusic]]">Conditional</animation>
			<include>AnimationZoomWindow</include>
			<include>AnimationZoomVisible</include>
			<control type="panel" id="542">
				<top>80</top>
				<left>40</left>
				<width>1840</width>
				<height>999</height>
				<!-- Script Trigger and Navigation Cleanup -->
				<onfocus>RunScript(script.skin.madnox, action=trailer_rolling)</onfocus>
				<!-- Global Collection View Sync: backup enforcer fires when list gains focus -->
				<onfocus>RunScript(script.skin.madnox, action=collection_view_sync, mode=focus)</onfocus>
				<onunfocus>RunScript(script.skin.madnox, action=trailer_cleanup)</onunfocus>
				<onleft>9050</onleft>
				<onright>60542</onright>
				<pagecontrol>60542</pagecontrol>
				<include>ContainerScrollTime</include>
				<viewtype label="$LOCALIZE[31256]">bigicon</viewtype>
				<itemlayout height="130" width="613.3" condition="!Skin.HasSetting(View542SmallIcons)">
					<control type="group">
						<visible>!String.IsEmpty(ListItem.Art(banner)) | !String.IsEmpty(ListItem.Art(tvshow.banner))</visible>
						<include content="ViewArtwork">
							<param name="texturefadetime">0</param>
							<param name="watchedstatusvisible">!Skin.HasSetting(View542DisableWatchedStatus)</param>
							<param name="art">$VAR[BannerVar]</param>
							<param name="diffuse">diffuse/rounded5-593x110.png</param>
						</include>
					</control>
					<control type="group">
						<visible>String.IsEmpty(ListItem.Art(banner)) + String.IsEmpty(ListItem.Art(tvshow.banner))</visible>
						<include content="ViewBannerFallback">
							<param name="watchedstatusvisible">!Skin.HasSetting(View542DisableWatchedStatus)</param>
							<param name="diffuse">diffuse/rounded5-593x110.png</param>
						</include>
					</control>
					<include content="Object_ProgressBar">
						<param name="left" value="25" />
						<param name="right" value="25" />
						<param name="bottom" value="12" />
						<param name="height" value="8" />
					</include>
				</itemlayout>
				<focusedlayout height="130" width="613.3" condition="!Skin.HasSetting(View542SmallIcons)">
					<control type="group">
						<animation effect="zoom" start="100" end="110" center="auto" time="240">focus</animation>
						<animation effect="zoom" start="110" end="100" center="auto" time="240">unfocus</animation>
						<control type="image">
							<texture colordiffuse="$VAR[PanelHighlightColorVar]" border="10">buttons/thumb-select-focus.png</texture>
						</control>
						<control type="group">
							<visible>!String.IsEmpty(ListItem.Art(banner)) | !String.IsEmpty(ListItem.Art(tvshow.banner))</visible>
							<include content="ViewArtwork">
								<param name="texturefadetime">0</param>
								<param name="watchedstatusvisible">!Skin.HasSetting(View542DisableWatchedStatus)</param>
								<param name="art">$VAR[BannerVar]</param>
								<param name="diffuse">diffuse/rounded5-593x110.png</param>
							</include>
						</control>
						<control type="group">
							<visible>String.IsEmpty(ListItem.Art(banner)) + String.IsEmpty(ListItem.Art(tvshow.banner))</visible>
							<include content="ViewBannerFallback">
								<param name="watchedstatusvisible">!Skin.HasSetting(View542DisableWatchedStatus)</param>
								<param name="diffuse">diffuse/rounded5-593x110.png</param>
							</include>
						</control>
						<include content="Object_ProgressBar">
							<param name="left" value="25" />
							<param name="right" value="25" />
							<param name="bottom" value="12" />
							<param name="height" value="8" />
						</include>
					</control>
				</focusedlayout>
				<itemlayout height="100" width="460" condition="Skin.HasSetting(View542SmallIcons)">
					<control type="group">
						<visible>!String.IsEmpty(ListItem.Art(banner)) | !String.IsEmpty(ListItem.Art(tvshow.banner))</visible>
						<include content="ViewArtwork">
							<param name="texturefadetime">0</param>
							<param name="watchedstatusvisible">!Skin.HasSetting(View542DisableWatchedStatus)</param>
							<param name="art">$VAR[BannerVar]</param>
							<param name="diffuse">diffuse/rounded5-440x81.png</param>
						</include>
					</control>
					<control type="group">
						<visible>String.IsEmpty(ListItem.Art(banner)) + String.IsEmpty(ListItem.Art(tvshow.banner))</visible>
						<include content="ViewBannerFallback">
							<param name="font">Font28_Bold</param>
							<param name="watchedstatusvisible">!Skin.HasSetting(View542DisableWatchedStatus)</param>
							<param name="diffuse">diffuse/rounded5-440x81.png</param>
						</include>
					</control>
					<include content="Object_ProgressBar">
						<param name="left" value="25" />
						<param name="right" value="25" />
						<param name="bottom" value="12" />
						<param name="height" value="8" />
					</include>
				</itemlayout>
				<focusedlayout height="100" width="460" condition="Skin.HasSetting(View542SmallIcons)">
					<control type="group">
						<animation effect="zoom" start="100" end="115" center="auto" time="240">focus</animation>
						<animation effect="zoom" start="115" end="100" center="auto" time="240">unfocus</animation>
						<control type="image">
							<texture colordiffuse="$VAR[PanelHighlightColorVar]" border="10">buttons/thumb-select-focus.png</texture>
						</control>
						<control type="group">
							<visible>!String.IsEmpty(ListItem.Art(banner)) | !String.IsEmpty(ListItem.Art(tvshow.banner))</visible>
							<include content="ViewArtwork">
								<param name="texturefadetime">0</param>
								<param name="watchedstatusvisible">!Skin.HasSetting(View542DisableWatchedStatus)</param>
								<param name="art">$VAR[BannerVar]</param>
								<param name="diffuse">diffuse/rounded5-440x81.png</param>
							</include>
						</control>
						<control type="group">
							<visible>String.IsEmpty(ListItem.Art(banner)) + String.IsEmpty(ListItem.Art(tvshow.banner))</visible>
							<include content="ViewBannerFallback">
								<param name="font">Font28_Bold</param>
								<param name="watchedstatusvisible">!Skin.HasSetting(View542DisableWatchedStatus)</param>
								<param name="diffuse">diffuse/rounded5-440x81.png</param>
							</include>
						</control>
						<include content="Object_ProgressBar">
							<param name="left" value="25" />
							<param name="right" value="25" />
							<param name="bottom" value="12" />
							<param name="height" value="8" />
						</include>
					</control>
				</focusedlayout>
			</control>
			<include content="ViewWallScrollBar">
				<param name="id">542</param>
			</include>
		</control>
		<!-- Bottom Info/Media Flags -->
		<control type="group">
			<visible>Control.IsVisible(542)</visible>
			<include content="AnimationSlideBottomWindow">
				<param name="slide">220</param>
			</include>
			<include>FloorShadowWall</include>
			<include content="ViewCoverFlowBottomInfo">
				<param name="logovisible">View542Logo</param>
			</include>
			<include content="MediaFlagsPanelVideos" condition="Window.IsVisible(MyVideoNav.xml)">
				<param name="left">50</param>
				<param name="right">50</param>
				<param name="bottom">28</param>
			</include>
			<include content="MediaFlagsPanelAudio" condition="Window.IsVisible(MyMusicNav.xml)">
				<param name="left">50</param>
				<param name="right">50</param>
				<param name="bottom">28</param>
			</include>
		</control>

		<!-- Pop-Up Video Player Group (Copied from View 540) -->
		<control type="group">
			<visible>Control.IsVisible(542) + !String.IsEmpty(Window(Home).Property(IsPlayingTrailer))</visible>
			<include>AnimationVideoPreviewPopup400</include>
			<right>50</right>
			<top>120</top>
			<width>700</width>
			<height>800</height>
			<!-- Video Player -->
			<control type="group">
				<width>700</width>
				<height>394</height>
				<control type="image">
					<texture>colors/black.png</texture>
				</control>
				<control type="videowindow">
					<colordiffuse>FFA0A0A0</colordiffuse>
				</control>
				<control type="image">
					<bordersize>-15</bordersize>
					<texture border="20" colordiffuse="$VAR[PanelHighlightColorVar]">thumbs/overlay.png</texture>
				</control>
			</control>
			<!-- Info Panel for Video -->
			<control type="group">
				<top>410</top>
				<!-- Title -->
				<control type="label">
					<width>700</width>
					<height>90</height>
					<font>Font28_Bold</font>
					<textcolor>ff00aaff</textcolor>
					<shadowcolor>ff000000</shadowcolor>
					<align>left</align>
					<aligny>top</aligny>
					<label>$INFO[ListItem.Title]</label>
					<scroll>true</scroll>
				</control>
				<!-- Top Separator -->
				<control type="image">
					<top>90</top>
					<height>4</height>
					<texture colordiffuse="$VAR[PanelListSeparatorColorVar]">panels/separator.png</texture>
				</control>
				<!-- Plot Textbox -->
				<control type="textbox">
					<top>100</top>
					<width>700</width>
					<height>280</height>
					<font>Font28_Reg</font>
					<textcolor>ffcccccc</textcolor>
					<shadowcolor>ff000000</shadowcolor>
					<align>justify</align>
					<label>$INFO[ListItem.Plot]</label>
					<animation effect="scroll" time="20000" delay="5000" end="100%" condition="true" loop="true" reversible="false">Conditional</animation>
				</control>
				<!-- Bottom Separator -->
				<control type="image">
					<top>390</top>
					<height>4</height>
					<texture colordiffuse="$VAR[PanelListSeparatorColorVar]">panels/separator.png</texture>
				</control>
			</control>
		</control>
	</include>
</includes>
