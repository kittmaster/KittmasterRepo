<?xml version="1.0" encoding="utf-8" ?>
<window>
	<!-- HANDSHAKE: Tell 1108 that the video successfully started -->
	<onload condition="Skin.HasSetting(Madnox.IntroActive)">SetProperty(IntroStarted,1,Home)</onload>

	<!-- Clean up boolean, then let Kodi natively close this window and drop back to 1108 -->
	<onplaybackended condition="Skin.HasSetting(Madnox.IntroActive)">Skin.Reset(Madnox.IntroActive)</onplaybackended>
	<onplaybackstopped condition="Skin.HasSetting(Madnox.IntroActive)">Skin.Reset(Madnox.IntroActive)</onplaybackstopped>

	<defaultcontrol />
	<controls>
		<control type="group" id="0">
			<!-- Hides UI during intro -->
			<visible>Control.IsVisible(10) + !Window.IsVisible(seekbar) + !Skin.HasSetting(Madnox.IntroActive)</visible>
			<width>1920</width>
			<height>162</height>
			<include content="AnimationSlideTopVisible">
				<param name="slide">162</param>
			</include>
			<include content="PanelWide">
				<param name="top">0</param>
				<param name="toptexture">0</param>
				<param name="topshadow">149</param>
				<param name="height">169</param>
				<param name="heighttexture">149</param>
				<param name="flipy">true</param>
			</include>
			<control type="grouplist">
				<top>14</top>
				<left>25</left>
				<width>1920</width>
				<height>600</height>
				<control type="label" id="10">
					<font>Font26_Bold_Caps</font>
					<textcolor>$VAR[PanelHighlightColorVar]</textcolor>
					<include>VideoOSDProcessInfo</include>
				</control>
				<control type="label" id="11">
					<include>VideoOSDProcessInfo</include>
				</control>
				<control type="label" id="12">
					<include>VideoOSDProcessInfo</include>
				</control>
			</control>
		</control>
		<control type="label" id="1">
			<right>20</right>
			<top>33</top>
			<width>915</width>
			<height>60</height>
			<align>right</align>
			<label>$INFO[Player.SeekNumeric(hh:mm:ss)]</label>
			<font>Font_MainMenu</font>
			<shadowcolor>black</shadowcolor>
			<include>AnimationVisibleFade</include>
			<!-- Hides seek time during intro -->
			<visible>!String.IsEmpty(Player.SeekNumeric) + !Skin.HasSetting(Madnox.IntroActive)</visible>
		</control>
	</controls>
</window>
