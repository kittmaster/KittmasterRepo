<?xml version="1.0" encoding="utf-8" ?>
<includes>
	<include name="View500Portrait">
		<!-- Info Panel -->
		<control type="group">
			<visible>Control.IsVisible(500)</visible>
			<include content="ViewCoverFlowInfoPanel">
				<param name="id">500</param>
			</include>
		</control>
		<!-- Floor -->
		<include content="Floor">
			<param name="visible">Skin.HasSetting(View500HideFloor) + Control.IsVisible(500)</param>
			<param name="highlight">FloorHighlightMiddle</param>
		</include>
		<!-- Panel -->
		<include content="View500Panel" condition="!Skin.HasSetting(View500FixedList)">
			<param name="listtype">wraplist</param>
		</include>
		<include content="View500Panel" condition="Skin.HasSetting(View500FixedList)">
			<param name="listtype">fixedlist</param>
		</include>
		<!-- Bottom Info/Media Flags -->
		<control type="group">
			<visible>Control.IsVisible(500)</visible>
			<include content="AnimationSlideBottomWindow">
				<param name="slide">220</param>
			</include>
			<include content="ViewCoverFlowBottomInfo">
				<param name="logovisible">View500Logo</param>
				<param name="logowidth">840</param>
			</include>
			<include condition="Window.IsVisible(MyVideoNav.xml)">MediaFlagsPanelVideos</include>
		</control>
	</include>
	<!-- Includes Panel -->
	<include name="View500Panel">
		<param name="listtype">wraplist</param>
		<definition>
			<control type="group">
				<visible>Control.IsVisible(500)</visible>
				<animation effect="slide" end="0,30" condition="Container.Content(genres) + [System.HasAddon(resource.images.moviegenreicons.filmstrip-hd.colour) | System.HasAddon(resource.images.moviegenreicons.filmstrip-hd.colour)]">conditional</animation>
				<include content="AnimationSlideBottomWindow">
					<param name="slide">525</param>
				</include>
				<include content="AnimationSlideBottomVisible">
					<param name="slide">525</param>
				</include>
				<control type="$PARAM[listtype]" id="500">
					<top>595</top>
					<left>-70.50</left>
					<width>1991</width>
					<height>469</height>
					<onup condition="!Skin.String(View500InfoDelay,manual) | ListItem.IsParentFolder">9050</onup>
					<onup condition="Skin.String(View500InfoDelay,manual) + !ListItem.IsParentFolder">9999</onup>
					<ondown>60500</ondown>
					<onfocus>RunScript(script.skin.madnox, action=trailer_rolling)</onfocus>
					<!-- Global Collection View Sync: backup enforcer fires when list gains focus -->
					<onfocus>RunScript(script.skin.madnox, action=collection_view_sync, mode=focus)</onfocus>
					<onunfocus>RunScript(script.skin.madnox, action=trailer_cleanup)</onunfocus>
					<onleft>500</onleft>
					<onright>500</onright>
					<pagecontrol>60500</pagecontrol>
					<focusposition>4</focusposition>
					<orientation>horizontal</orientation>
					<include>ContainerScrollTime</include>
					<viewtype label="$LOCALIZE[31239]">icon</viewtype>
					<itemlayout width="229" height="334">
						<control type="group">
							<visible>!Skin.HasSetting(View500VideoCase) | Container.Content(genres)</visible>
							<control type="group">
								<visible>!Skin.HasSetting(View500HideReflect)</visible>
								<top>319</top>
								<height>334</height>
								<include content="ViewArtworkReflect">
									<param name="texturefadetime">0</param>
								</include>
							</control>
							<include content="ViewArtwork">
								<param name="texturefadetime">0</param>
								<param name="watchedstatusvisible">!Skin.HasSetting(View500DisableWatchedStatus)</param>
								<param name="diffuse">diffuse/rounded5-209x314.png</param>
							</include>
						</control>
						<control type="group">
							<visible>Skin.HasSetting(View500VideoCase) + !Container.Content(genres)</visible>
							<control type="group">
								<visible>!Skin.HasSetting(View500HideReflect)</visible>
								<top>319</top>
								<height>334</height>
								<include content="ViewArtworkVideoCaseReflect">
									<param name="texturefadetime">0</param>
									<param name="bordersize">15,17,15,33</param>
								</include>
							</control>
							<include content="ViewArtworkVideoCase">
								<param name="logoheight">27</param>
								<param name="texturefadetime">0</param>
								<param name="bordersize">15,33,15,17</param>
								<param name="watchedstatustop">35</param>
								<param name="watchedstatusvisible">!Skin.HasSetting(View500DisableWatchedStatus)</param>
							</include>
						</control>
					</itemlayout>
					<focusedlayout width="229" height="334">
						<control type="group">
							<camera x="114" y="167" />
							<animation effect="zoom" start="100" end="120" center="auto" time="240">focus</animation>
							<animation effect="zoom" start="120" end="100" center="auto" time="240">unfocus</animation>

							<!-- LAYER 1: BACK TRAY & DISC -->
							<control type="group">
								<visible>Skin.HasSetting(View500VideoCase) + Skin.HasSetting(View500OpenCase) + [!String.IsEmpty(ListItem.Art(discart)) | !String.IsEqual(Skin.String(LibraryVideoDiscArtFallback),none)] + !Container.Content(genres)</visible>
								<animation effect="fade" start="0" end="100" time="300" delay="1000">focus</animation>
								<animation effect="fade" start="100" end="0" time="150">unfocus</animation>
								<control type="image">
									<left>15</left>
									<top>33</top>
									<width>199</width>
									<height>284</height>
									<texture border="20">$VAR[ShowCaseBackVar]</texture>
								</control>
								<control type="image">
									<left>38</left>
									<top>102</top>
									<width>150</width>
									<height>150</height>
									<texture background="true">$VAR[LibraryVideoDiscArtVar]</texture>
									<aspectratio align="center" aligny="center">keep</aspectratio>
								</control>
							</control>

							<!-- LAYER 2: FRONT COVER HINGE -->
							<control type="group">
								<animation effect="rotatey" center="15,0" start="0" end="100" time="400" delay="1000" tween="quadratic" easing="out" condition="Skin.HasSetting(View500VideoCase) + Skin.HasSetting(View500OpenCase) + [!String.IsEmpty(ListItem.Art(discart)) | !String.IsEqual(Skin.String(LibraryVideoDiscArtFallback),none)] + !Container.Content(genres)">focus</animation>
								<animation effect="rotatey" center="15,0" start="100" end="0" time="250" tween="quadratic" easing="in" condition="Skin.HasSetting(View500VideoCase) + Skin.HasSetting(View500OpenCase) + [!String.IsEmpty(ListItem.Art(discart)) | !String.IsEqual(Skin.String(LibraryVideoDiscArtFallback),none)] + !Container.Content(genres)">unfocus</animation>

								<control type="group">
									<visible>!Skin.HasSetting(View500VideoCase) | Container.Content(genres)</visible>
									<control type="group">
										<visible>!Skin.HasSetting(View500HideReflect)</visible>
										<top>319</top>
										<height>334</height>
										<include content="ViewArtworkReflect">
											<param name="texturefadetime">0</param>
										</include>
									</control>
									<include content="ViewArtwork">
										<param name="texturefadetime">0</param>
										<param name="watchedstatusvisible">!Skin.HasSetting(View500DisableWatchedStatus)</param>
										<param name="diffuse">diffuse/rounded5-209x314.png</param>
									</include>
								</control>
								<control type="group">
									<visible>Skin.HasSetting(View500VideoCase) + !Container.Content(genres)</visible>
									<control type="group">
										<visible>!Skin.HasSetting(View500HideReflect)</visible>
										<top>319</top>
										<height>334</height>
										<include content="ViewArtworkVideoCaseReflect">
											<param name="texturefadetime">0</param>
											<param name="bordersize">15,17,15,33</param>
										</include>
									</control>
									<include content="ViewArtworkVideoCase">
										<param name="logoheight">27</param>
										<param name="texturefadetime">0</param>
										<param name="bordersize">15,33,15,17</param>
										<param name="watchedstatustop">35</param>
										<param name="watchedstatusvisible">!Skin.HasSetting(View500DisableWatchedStatus)</param>
									</include>
								</control>
							</control>
						</control>
					</focusedlayout>
				</control>
				<include content="ViewCoverFlowScrollBar">
					<param name="id">500</param>
				</include>
			</control>
		</definition>
	</include>
</includes>
