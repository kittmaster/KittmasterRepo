<?xml version="1.0" encoding="utf-8" ?>
<window type="dialog" id="1122">
	<defaultcontrol always="true">9009</defaultcontrol>
	<controls>
		<control type="image">
			<texture colordiffuse="A0000000">colors/black.png</texture>
			<animation effect="fade" time="400">WindowOpen</animation>
		</control>
		<control type="group">
			<animation type="WindowOpen" reversible="false">
				<effect type="fade" start="0" end="100" time="400" />
				<effect type="slide" start="0,200" end="0,0" time="500" tween="cubic" />
			</animation>
			<animation type="WindowClose" reversible="false">
				<effect type="fade" start="100" end="0" time="300" />
			</animation>
			<centerleft>50%</centerleft>
			<centertop>50%</centertop>
			<width>1400</width>
			<height>800</height>
			<include content="DialogBackground">
				<param name="width" value="1400" />
				<param name="height" value="800" />
			</include>
			<control type="image">
				<right>40</right>
				<top>30</top>
				<width>120</width>
				<height>60</height>
				<aspectratio>keep</aspectratio>
				<texture>icons/logo.png</texture>
			</control>

			<control type="label">
				<top>40</top>
				<left>40</left>
				<right>40</right>
				<height>50</height>
				<textcolor>$VAR[PanelHighlightColorVar]</textcolor>
				<label>$LOCALIZE[31497] $LOCALIZE[14116]...</label>
				<align>left</align>
				<include>SettingsLeftLabelWidgetsShortcut</include>
			</control>

			<control type="image">
				<left>40</left>
				<top>120</top>
				<width>600</width>
				<height>540</height>
				<aspectratio>scale</aspectratio>
				<texture border="5">icons/systeminfo/fanart/memory.jpg</texture>
				<bordertexture colordiffuse="22FFFFFF" border="5">colors/white.png</bordertexture>
				<bordersize>5</bordersize>
			</control>

			<control type="grouplist" id="9001">
				<left>680</left>
				<top>120</top>
				<width>680</width>
				<height>540</height>
				<itemgap>15</itemgap>
				<orientation>vertical</orientation>
				<!-- Header -->
				<control type="label">
					<height>40</height>
					<font>Font30_Reg</font>
					<label>[COLOR FF6db9e5][B]$LOCALIZE[31497] [LOWERCASE]$LOCALIZE[126][/LOWERCASE]:[/B][/COLOR]</label>
					<include>SettingsLabelNoOffset</include>
				</control>
				<control type="label">
					<height>40</height>
					<font>Font30_Reg</font>
					<label>[COLOR FF6db9e5]$LOCALIZE[31497] [LOWERCASE]$LOCALIZE[565][/LOWERCASE]:[/COLOR] [B]$INFO[System.Memory(used.percent)][/B]</label>
				</control>
				<control type="label">
					<height>40</height>
					<font>Font30_Reg</font>
					<label>[COLOR FF6db9e5]$LOCALIZE[20162] [LOWERCASE]$LOCALIZE[31497][/LOWERCASE]:[/COLOR] [B]$INFO[System.Memory(used)][/B]</label>
				</control>
				<control type="label">
					<height>40</height>
					<font>Font30_Reg</font>
					<label>[COLOR FF6db9e5]$LOCALIZE[22012]:[/COLOR] [B]$INFO[System.Memory(total)][/B]</label>
				</control>
				<control type="label">
					<height>40</height>
					<font>Font30_Reg</font>
					<label>[COLOR FF6db9e5]$LOCALIZE[158]:[/COLOR] [B]$INFO[System.Memory(free)][/B]</label>
				</control>
				<control type="label">
					<height>40</height>
					<font>Font30_Reg</font>
					<label>[COLOR FF6db9e5]$LOCALIZE[31498] [LOWERCASE]$LOCALIZE[31497][/LOWERCASE]:[/COLOR] [B]$INFO[System.FreeMemory][/B]</label>
				</control>
			</control>

			<control type="button" id="9009">
				<width>200</width>
				<height>60</height>
				<centerleft>50%</centerleft>
				<bottom>40</bottom>
				<label>$LOCALIZE[186]</label>
				<font>Font30_Bold</font>
				<align>center</align>
				<onclick>Action(Close)</onclick>
				<include>DialogButtonAlwaysFocused</include>
			</control>
		</control>
	</controls>
</window>
