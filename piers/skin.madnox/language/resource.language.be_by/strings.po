msgid "Save Madnox current settings to the preset folder."
msgstr "Захаваць бягучыя налады Madnox у папку профіляў."

#: /16x9/SkinSettings.xml
msgctxt "#31541"
msgid "Load Madnox previously saved settings from the preset folder."
msgstr "Загрузіць раней захаваныя налады Madnox з папкі профіляў."

#: /16x9/SkinSettings.xml
msgctxt "#31542"
msgid "Export current settings to an external file (Used for sharing or collaboration)."
msgstr "Экспартаваць бягучыя налады ў вонкавы файл (выкарыстоўваецца для абмену або сумеснай працы)."

#: /16x9/SkinSettings.xml
msgctxt "#31543"
msgid "Import settings from an external file (Used for sharing or collaboration). Invalid files/format will not be loaded."
msgstr "Імпартаваць налады з вонкавага файла. Несапраўдныя файлы або фарматы не будуць загружаны."

#: /16x9/Includes_MediaMenu.xml
