msgstr "Ver solo diseños de logotipos de ultra alta definición y 4K en la cuadrícula de la paleta."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "Ver solo diseños de logotipos de códecs HEVC y H.265 en la cuadrícula de la paleta."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Ver solo diseños de logotipos de códecs AVC y H.264 en la cuadrícula de la paleta."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Ver solo diseños de logotipos de formatos DivX, XviD y MPEG-4 heredados en la cuadrícula de la paleta."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Ver diseños de logotipos clásicos de MPEG, DVD y transmisiones de TV estándar en la cuadrícula de la paleta."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Ver diseños de logotipos de códecs Windows Media Video y VC-1 en la cuadrícula de la paleta."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Ver empaquetadores de contenedores, formatos de disco y otros diseños de logotipos diversos en la cuadrícula de la paleta."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Cierra este cuadro de diálogo de personalización de indicadores y regresa a la configuración."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Resalta cualquier diseño de logotipo en la cuadrícula central y haz clic para guardarlo como tu indicador personalizado para la categoría activa."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Borra tu elección de indicador personalizado y restaura esta categoría a la lógica de indicadores automáticos predeterminados de la skin."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Alterna el arte de los indicadores globales entre diseños a color y blanco predeterminado monocromático."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Usa tus teclas de dirección para navegar por las opciones. Presiona Atrás o selecciona Salir en cualquier momento para cerrar sin guardar los cambios."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Seleccionar para modificar"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Personalización de la pantalla de inicio, widgets y menú de accesos directos."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Script para creadores de skins que permite a los usuarios seleccionar un complemento de recurso de imagen."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Agrega automáticamente arte adicional para los medios en tus bibliotecas de medios."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Letras para música. Requerido para activar letras animadas."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Sincroniza tu colección y el estado de visto con trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Crea un favorito personalizado a partir de los favoritos de Kodi seleccionados."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Edita el menú de la pantalla de inicio, widgets, fondos y líneas de información."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Restablece el menú de la pantalla de inicio, widgets, fondos y líneas de información a sus valores predeterminados."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Crea un favorito personalizado a partir de los favoritos de Kodi seleccionados. Para usar en widgets del menú principal. Requiere que el script de favoritos esté instalado."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Crea un favorito de complemento personalizado a partir de los complementos instalados. Para usar en widgets del menú principal."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Restablece el tema y los colores de la skin a sus valores predeterminados."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Selecciona de una lista de temas predefinidos."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Bloquea las preferencias para desactivar el modo de vista, las opciones de vista, el cuadro de diálogo de información y los ajustes de pantalla completa."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Personaliza la pantalla de inicio, favoritos, temas predefinidos y el modo quiosco."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Cambia las texturas del tema de la skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Personaliza los colores de textura de la skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Personaliza el fondo y los alternativos para áreas específicas de la skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Activa o desactiva varias características de la skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Personaliza el arte e instala paquetes de arte compatibles."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Instala y configura complementos compatibles."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Activa y desactiva las vistas de la biblioteca. Desactivar las vistas de la biblioteca en sistemas de bajas especificaciones puede mejorar el rendimiento."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Muestra la letra de de desplazamiento al desplazarse en las vistas de la biblioteca."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Muestra el alfabeto para saltar a una posición del contenedor. Solo funcionará para los métodos de ordenación predeterminados (A-Z)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Muestra una sinopsis corta para series y películas si está disponible; de lo contrario, mostrará la sinopsis predeterminada."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Desplaza automáticamente la sinopsis si no cabe en las dimensiones del control."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Activa el menú de accesos directos para un acceso instantáneo a áreas específicas de la skin. En el menú de medios, haz clic a la izquierda para abrir o haz clic en el icono de acceso directo."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Edita el menú de accesos directos."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Activa y desactiva los elementos de la barra superior."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Cambia la configuración de información del video."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Cambia la configuración de información de la música."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Cambia la configuración de video en pantalla completa."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Cambia la configuración de audio en pantalla completa."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Reduce el tamaño de las notificaciones emergentes."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Oscurece la pantalla detrás de los cuadros de diálogo emergentes. No es aplicable para video o audio en pantalla completa."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Activa los iconos a color para la barra superior, la información de medios y las vistas de la biblioteca."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Activa los indicadores de medios a color, de HDR, de profundidad de bits y de idioma."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Arte de CD de audio alternativo para toda la skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Arte de CD de video alternativo para toda la skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Selecciona e instala un paquete de iconos del clima para la barra superior, los widgets y el clima."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Selecciona e instala un paquete de fanart del clima para los fondos, los widgets y el clima."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Instala iconos de estudio blancos para usarlos en toda la skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Instala iconos de estudio a color para usarlos en toda la skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Instala iconos de sellos discográficos para usarlos en toda la skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Instala banderas de idiomas para las vistas de la biblioteca y la selección de subtítulos."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Instala iconos de género musical para música y videos musicales."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Instala iconos de género cinematográfico a color para películas y series."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Instala iconos de género cinematográfico en blanco y negro para películas y series."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Instala iconos de países para el nodo de países de películas."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Establece el retraso entre las transiciones de fanart para toda la skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Efectos de fondo que caen. Nieve, hojas, etc."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Muestra el fanart de música del elemento en reproducción actual en toda la skin. Invalida el fanart de la biblioteca."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Activa la visualización de música en segundo plano mientras se reproduce música. Requiere que la visualización esté activada en Ajustes - Ajustes del reproductor/Música."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Muestra el video en reproducción actual en segundo plano mientras exploras la biblioteca. Invalida el fanart de la biblioteca."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Descarga imágenes e información adicional desde fanart.tv y theaudiodb.com de los artistas en reproducción actual. Para música en pantalla completa, transmisiones de Internet y radio."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Configuración del script de presentación de diapositivas de artistas."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "Un acceso directo a la lista de reproducción de video si no está vacía."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "Un acceso directo a la lista de reproducción de música si no está vacía."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Acceso directo a pantalla completa cuando se reproducen medios."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Haz clic para abrir el menú de accesos directos."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Controles del reproductor cuando se reproducen medios."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Reproduce el siguiente episodio de la serie automáticamente."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Reproduce temas mientras navegas por series, películas y videos musicales."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "El editor de nodos de la biblioteca te permite crear y personalizar nodos de video y de música personalizados dentro de Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Muestra información de marcadores superpuestos para elementos de medios vistos, no vistos y en progreso."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Un script para editar el teletipo RSS integrado de Kodi."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Versión de la skin y opciones de recuperación. Restaura todos los valores predeterminados al estado inicial."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Complementos"