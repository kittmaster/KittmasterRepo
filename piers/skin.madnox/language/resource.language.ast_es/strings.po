msgstr "Instalar banderes de llingues pa les vistes de la biblioteca y la selección de sustítulos."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Instalar iconos de xéneros musicales pa la música y los videoclips."

