msgstr "Camudar los axustes de videu a pantalla completa."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Camudar los axustes d'audiu a pantalla completa."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Amenorgar el tamañu de les notificaciones emerxentes."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Escurez la pantalla tres de los diálogos emerxentes. Esto nun s'aplica al videu o audiu a pantalla completa."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Activar iconos de colores pa la barra superior, la información multimedia y les vistes de la biblioteca."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Activar los indicadores multimedia de color, HDR, fondura de bits y llingua."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Alternativa d'arte de CD d'audiu en tol skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Alternativa d'arte de CD de videu en tol skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Escoyer ya instalar un paquete d'iconos del tiempu pa la barra superior, los widgets y el tiempu."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Escoyer ya instalar un paquete de fanart del tiempu pa los fondos, los widgets y el tiempu."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Instalar iconos de los estudios en color blancu pa usalos en tol skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Instalar iconos de los estudios de color pa usalos en tol skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
