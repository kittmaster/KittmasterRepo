msgstr "Escueye un logotipu de la paleta d'abaxo pa asignalu a los ficheros de videu en DVD o resolución estándar."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "Amuesa namás diseños de logos de 4K y resolución ultra alta na paleta."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "Amuesa namás diseños de logos de los códecs HEVC y H.265 na paleta."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Amuesa namás diseños de logos de los códecs AVC y H.264 na paleta."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Amuesa namás diseños de logos de formatos DivX, XviD y MPEG-4 antigua na paleta."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Amuesa namás diseños de logos de emisiones de TV estándar, MPEG clásica y DVD na paleta."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Amuesa namás diseños de logos del códec Windows Media Video y VC-1 na paleta."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Amuesa namás contenedores, formatos de discu y otros logos de miscelánea na paleta."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Zarrar esti diálogu de personalización d'indicadores y volver a los axustes."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Escueye cualesquier d'esti diseñu de logo de la cuadrícula del centru y fai clic pa guardalu como'l to indicador personalizáu pa la categoría activa."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Llimpiar l'indicador personalizáu escoyíu y volver al estilu automáticu predetermináu del skin pa esta categoría."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Alternar los diseños de los indicadores ente un estilu coloriao y el blancu monocromáticu por defectu."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Usa les tecles de dirección pa movete poles opciones. Primi 'atrás' o escueye 'colar' en cualquier momentu pa zarrar ensin guardar cambeos."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Facer clic pa modificar"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Personalización de la pantalla d'entamu, los widgets y el menú d'atayos."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Script pa creadores de skins que dexa a los usuarios escoyer un complementu de recursos d'imaxe."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Amiesta diseños artísticos estra automáticamente a los elementos multimedia de les tos biblioteques."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Lletres pa la música. Requeríu pa activar les lletres animaes."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Sincroniza la to colección y l'estáu de visto con trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Crear un favoritu personalizáu dende los favoritos escoyíos de Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Editar el menú de la pantalla d'entamu, los widgets, los fondos y les llinies d'información."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Restablecer el menú de la pantalla d'entamu, los widgets, los fondos y les llinies d'información a los valores por defectu."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Crear un favoritu personalizáu dende los favoritos de Kodi escoyíos. Pa usar nos widgets del menú principal. Precisa de la instalación del script de favoritos."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Crear un complementu favoritu personalizáu dende los complementos instalaos. Pa usar nos widgets del menú principal."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Restablecer el tema y los colores del skin a los valores por defectu."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Escoyer d'ente una llista de temes yá definíos."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Bloquiar les preferencies pa desactivar el mou de vista, les opciones de vista, los diálogos d'información y los axustes de pantalla completa."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Personalizar la pantalla d'entamu, los favoritos, los temes yá definíos y el mou quioscu."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Camudar les testures del tema del skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Personalizar los colores de la testura del skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Personalizar el fondu y les alternatives pa zones del skin específicas."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Activar o desactivar delles carauterístiques del skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Personalizar los diseños artísticos ya instalar paquetes de diseños artísticos compatibles."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Instalar y configurar complementos compatibles."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Activar y desactivar vistes de la biblioteca. Desactivar les vistes de la biblioteca en preseos de baxes prestaciones puede ameyorar el rindimientu."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Amuesa la lletra de desplazamientu al movese poles vistes de la biblioteca."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Amuesa l'abecedariu pa saltar a una posición del contenedor. Solo va funcionar colos métodos d'ordenación por defectu (A-Z)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Amuesa la sinopsis de series y películes si ta disponible, si non va amosar l'argumentu por defectu."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Desplazar el testu de la sinopsis automáticamente si nun cabe nes dimensiones del control."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Activar el menú d'atayos pa un accesu inmediatu a zones del skin específiques. Nel menú multimedia, primi a la izquierda pa abrilo o fai clic nel iconu d'atayu."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Editar el menú d'atayos."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Activar y desactivar los elementos de la barra superior."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Camudar los axustes d'info de videu."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Camudar los axustes d'info de música."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
