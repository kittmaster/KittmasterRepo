msgstr "Instalar iconos de xéneru de película en blancu y prietu pa películes y series."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Instalar iconos de países pal nodu de países de les películes."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Establecer el retardu ente les transiciones de fanart en tol skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Efeutos de fondu de cayida (ñeve, fueyes, etc.)."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
