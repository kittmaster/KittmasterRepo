msgstr "Primi pa abrir el menú d'atayos."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Controles del reproductor mientres se reproduz conteníu multimedia."

#: /16x9/Includes_Settings.xml
