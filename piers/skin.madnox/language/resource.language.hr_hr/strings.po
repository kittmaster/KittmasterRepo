msgctxt "#31561"
msgid "Customise 1080p flag:"
msgstr "Prilagodi oznaku za 1080p:"

#: /16x9/includes.xml
msgctxt "#31562"
msgid "Customise 720p flag:"
msgstr "Prilagodi oznaku za 720p:"

#: /16x9/includes.xml
msgctxt "#31563"
msgid "Customise DVD / SD flag:"
msgstr "Prilagodi oznaku za DVD / SD:"

#: /16x9/includes.xml
msgctxt "#31564"
msgid "Category filter:"
msgstr "Filtar kategorije:"

#: /16x9/includes.xml
msgctxt "#31565"
msgid "Restore default:"
msgstr "Vrati zadano:"

#: /16x9/includes.xml
msgctxt "#31566"
msgid "Toggle Color Scheme:"
msgstr "Promijeni shemu boja:"

# --- Body texts: top row category selectors (controls 901–904, 905) ---

#: /16x9/includes.xml
msgctxt "#31567"
msgid "Highlight a logo from the palette below and click to assign it to 4K / UHD video files."
msgstr "Istaknite logotip s palete u nastavku i kliknite da biste ga dodijelili 4K / UHD video datotekama."

#: /16x9/includes.xml
msgctxt "#31568"
msgid "Highlight a logo from the palette below and click to assign it to WebDL and streaming video sources."
msgstr "Istaknite logotip s palete u nastavku i kliknite da biste ga dodijelili WebDL i strujećim video izvorima."

#: /16x9/includes.xml
msgctxt "#31569"
msgid "Highlight a logo from the palette below and click to assign it to 1080p Full HD video files."
msgstr "Istaknite logotip s palete u nastavku i kliknite da biste ga dodijelili 1080p Full HD video datotekama."

#: /16x9/includes.xml
msgctxt "#31570"
msgid "Highlight a logo from the palette below and click to assign it to 720p HD video files."
msgstr "Istaknite logotip s palete u nastavku i kliknite da biste ga dodijelili 720p HD video datotekama."

#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "Istaknite logotip s palete u nastavku i kliknite da biste ga dodijelili DVD i video datotekama standardne rezolucije."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "Prikažite samo ultra-visoku rezoluciju i 4K dizajne logotipa u mreži palete."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "Prikažite samo HEVC i H.265 dizajne logotipa kodeka u mreži palete."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Prikažite samo AVC i H.264 dizajne logotipa kodeka u mreži palete."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Prikažite samo DivX, XviD i zastarjele MPEG-4 formate dizajna logotipa u mreži palete."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Prikažite klasične MPEG, DVD i standardne dizajne logotipa TV prijenosa u mreži palete."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Prikažite Windows Media Video i VC-1 dizajne logotipa kodeka u mreži palete."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Prikažite pakete spremnika, formate diskova i ostale razne dizajne logotipa u mreži palete."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Zatvorite ovaj dijaloški okvir za prilagodbu oznaka i vratite se u postavke."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Istaknite bilo koji dizajn logotipa u središnjoj mreži i kliknite da biste ga spremili kao prilagođenu oznaku za aktivnu kategoriju."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Uklonite svoj prilagođeni odabir oznake i vratite ovu kategoriju na automatsku zadanu logiku oznaka teme."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Promijenite globalne ilustracije oznaka između dizajna u boji i jednobojne zadane bijele."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Koristite tipke za smjer za kretanje kroz opcije. Pritisnite natrag ili odaberite Izlaz u bilo kojem trenutku za zatvaranje bez promjena."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Odaberite za izmjenu"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Prilagodba početnog zaslona, widgeta i izbornika prečaca."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Skripta za autore tema koja korisnicima omogućuje odabir dodatka s resursima slika."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Automatski dodaje dodatne ilustracije za medije u vašim medijatekama."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Tekstovi za glazbu. Potrebno za omogućavanje animiranih tekstova."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Sinkronizirajte svoju kolekciju i status gledanja s trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Stvorite prilagođeni favorit od odabranih Kodi favorita."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Uredite izbornik početnog zaslona, widgete, pozadine i informativne retke."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Vratite izbornik početnog zaslona, widgete, pozadine i informativne retke na zadano."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Stvorite prilagođeni favorit od odabranih Kodi favorita. Za upotrebu u widgetima glavnog izbornika. Zahtijeva instaliranu skriptu za favorite."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Stvorite prilagođeni omiljeni dodatak od instaliranih dodataka. Za upotrebu u widgetima glavnog izbornika."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Vratite temu i boje na zadane vrijednosti."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Odaberite s popisa unaprijed definiranih tema."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Zaključajte postavke kako biste onemogućili način prikaza, opcije prikaza, dijaloški okvir s informacijama i postavke cijelog zaslona."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Prilagodite početni zaslon, favorite, unaprijed definirane teme i kiosk način rada."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Promijenite teksture teme."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Prilagodite boje teksture teme."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Prilagodite pozadinu i rezervne opcije za određena područja teme."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Omogućite ili onemogućite razne značajke teme."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Prilagodite ilustracije i instalirajte podržane pakete ilustracija."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Instalirajte i konfigurirajte podržane dodatke."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Omogućite i onemogućite prikaze medijateke. Onemogućavanje prikaza medijateke na manje snažnim sustavima može poboljšati performanse."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Prikazuje slovo pri pomicanju u prikazima medijateke."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Prikazuje abecedu za brzi skok na određenu poziciju u spremniku. Radit će samo za zadane načine razvrstavanja (A-Z)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Prikazuje kratak sažetak radnje za TV serije i filmove ako je dostupan, inače će se prikazati zadana radnja."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Automatski pomiči opis radnje ako ne stane u dimenzije kontrole."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Omogućite izbornik prečaca za trenutačni pristup određenim područjima teme. U medijskom izborniku kliknite lijevo za otvaranje ili kliknite na ikonu prečaca."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Uredite izbornik prečaca."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Omogućite i onemogućite elemente gornje trake."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Promijenite postavke informacija o videu."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Promijenite postavke informacija o glazbi."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Promijenite postavke videa na cijelom zaslonu."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Promijenite postavke zvuka na cijelom zaslonu."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Smanjite veličinu skočnih obavijesti."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Zatamnjuje zaslon iza skočnih dijaloških okvira. Nije primjenjivo na videozapise ili zvuk preko cijelog zaslona."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Omogućite ikone u boji za gornju traku, informacije o mediju i prikaze medijateke."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Omogućite medijske oznake u boji, za HDR, dubinu bitova i jezik."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Rezervni slikovni prikaz audio CD-a na razini cijele teme."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Rezervni slikovni prikaz video CD-a na razini cijele teme."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Odaberite i instalirajte paket ikona vremena za gornju traku, widgete i vrijeme."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Odaberite i instalirajte paket vremenskih pozadina (fanarta) za pozadine, widgete i vrijeme."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Instalirajte bijele ikone filmskih studija za upotrebu u cijeloj temi."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Instalirajte obojene ikone filmskih studija za upotrebu u cijeloj temi."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Instalirajte ikone diskografskih kuća za upotrebu u cijeloj temi."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Instalirajte zastave jezika za prikaze medijateke i odabir titlova."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Instalirajte ikone glazbenih žanrova za glazbu i glazbene videozapise."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Instalirajte obojene ikone filmskih žanrova za filmove i TV serije."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Instalirajte crno-bijele ikone filmskih žanrova za filmove i TV serije."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Instalirajte ikone država za čvor država u filmovima."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Postavite odgodu između prijelaza fanarta na razini cijele teme."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Pozadinski efekti padanja. Snijeg, lišće itd."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Prikaži fanart trenutno reproducirane glazbe u cijeloj temi. Nadjačava fanart medijateke."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Omogućuje glazbenu vizualizaciju u pozadini tijekom reprodukcije glazbe. Zahtijeva da vizualizacija bude omogućena u postavkama - Postavke reproduktora/Glazba."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Prikaži videozapis koji se trenutno reproducira u pozadini dok pregledavate medijateku. Nadjačava fanart medijateke."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Preuzmite slike i dodatne informacije s fanart.tv i theaudiodb.com za trenutno reproduciranog izvođača. Za glazbu preko cijelog zaslona, internetske streamove i radio."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Postavke skripte za slideshow izvođača."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "Prečac do popisa izvođenja videozapisa ako nije prazan."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "Prečac do popisa izvođenja glazbe ako nije prazan."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Prečac za prikaz preko cijelog zaslona kada se reproducira medij."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Kliknite za otvaranje izbornika prečaca."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Kontrole reproduktora kada se reproducira medij."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Automatski reproduciraj sljedeću epizodu TV serije."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Reproduciraj tematsku glazbu tijekom pregledavanja TV serija, filmova i glazbenih videozapisa."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "Uređivač čvorova medijateke omogućuje vam stvaranje i prilagodbu prilagođenih video i glazbenih čvorova unutar Kodija."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Prikaži prekrivajuće oznake informacija za gledane, negledane i stavke medija u tijeku."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Skripta za uređivanje Kodijevog ugrađenog RSS pokretnog teksta."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Inačica teme i opcije oporavka. Vraća sve zadane vrijednosti na početno stanje."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Dodaci"