# --- Body texts: top row category selectors (controls 901–904, 905) ---

#: /16x9/includes.xml
msgctxt "#31567"
msgid "Highlight a logo from the palette below and click to assign it to 4K / UHD video files."
msgstr "Aşağıdakı palitradan loqonu seçin və onu 4K / UHD video fayllarına təyin etmək üçün klikləyin."

#: /16x9/includes.xml
msgctxt "#31568"
msgid "Highlight a logo from the palette below and click to assign it to WebDL and streaming video sources."
msgstr "Aşağıdakı palitradan loqonu seçin və onu WebDL və canlı yayım video mənbələrinə təyin etmək üçün klikləyin."

#: /16x9/includes.xml
msgctxt "#31569"
msgid "Highlight a logo from the palette below and click to assign it to 1080p Full HD video files."
msgstr "Aşağıdakı palitradan loqonu seçin və onu 1080p Full HD video fayllarına təyin etmək üçün klikləyin."

#: /16x9/includes.xml
msgctxt "#31570"
msgid "Highlight a logo from the palette below and click to assign it to 720p HD video files."
msgstr "Aşağıdakı palitradan loqonu seçin və onu 720p HD video fayllarına təyin etmək üçün klikləyin."

#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "Aşağıdakı palitradan loqonu seçin və onu DVD və standart keyfiyyətli video fayllarına təyin etmək üçün klikləyin."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "Palitrada yalnız ultra-yüksək keyfiyyətli və 4K loqo dizaynlarını göstər."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "Palitrada yalnız HEVC və H.265 kodek loqo dizaynlarını göstər."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Palitrada yalnız AVC və H.264 kodek loqo dizaynlarını göstər."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Palitrada yalnız DivX, XviD və köhnə MPEG-4 formatlı loqo dizaynlarını göstər."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Palitrada yalnız klassik MPEG, DVD və standart televiziya yayımı loqo dizaynlarını göstər."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Palitrada yalnız Windows Media Video və VC-1 kodekli loqo dizaynlarını göstər."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Palitrada yalnız müxtəlif konteyner növlərini, disk formatlarını və digər loqo dizaynlarını göstər."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Bu nişan fərdiləşdirmə pəncərəsini bağla və ayarlara qayıt."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Mərkəzi şəbəkədəki hər hansı bir loqo dizaynını seçin və onu aktiv kateqoriya üçün xüsusi nişanınız kimi saxlamaq üçün klikləyin."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Xüsusi nişan seçiminizi təmizləyin və bu kateqoriyanı interfeysin standart nişan məntiqinə qaytarın."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Ümumi nişan tərtibatını rəngli və standart ağ-qara dizaynlar arasında dəyişin."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Seçimlər arasında hərəkət etmək üçün istiqamət düymələrindən istifadə edin. Dəyişiklik etmədən bağlamaq üçün istənilən vaxt Geri düyməsini basın və ya Çıxış-ı seçin."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Dəyişdirmək üçün seçin"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Ana ekranın, vidjetlərin və kəsə yollar menyusunun fərdiləşdirilməsi."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "İstifadəçilərin şəkil resursu əlavəsini seçməsinə imkan verən interfeys köməkçi skripti."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Kitabxananızdakı fayllar üçün avtomatik olaraq əlavə dizayn işləri yükləyir."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Musiqi üçün mahnı sözləri. Animasiyalı sözləri aktivləşdirmək üçün tələb olunur."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Kolleksiyanızı və baxış statusunuzu trakt.tv ilə sinxronlaşdırır."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Seçilmiş Kodi favoritlərindən xüsusi favorit siyahısı yaradın."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Ana ekran menyusunu, vidjetləri, fonları və məlumat sətirlərini redaktə edin."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Ana ekran menyusunu, vidjetləri, fonları və məlumat sətirlərini standart vəziyyətinə qaytarın."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Seçilmiş Kodi favoritlərindən fərdi favorit yaradın. Baş menyu vidjetlərində istifadə üçün nəzərdə tutulub. Fərdi favoritlər skriptinin quraşdırılması tələb olunur."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Quraşdırılmış əlavələrdən fərdi favorit siyahısı yaradın. Baş menyu vidjetlərində istifadə üçün nəzərdə tutulub."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "İnterfeys mövzusunu və rənglərini standart vəziyyətinə qaytarın."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Əvvəlcədən təyin olunmuş mövzulardan ibarət siyahıdan seçin."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Görünüş rejimini, görünüş seçimlərini, məlumat dialoqunu və tam ekran parametrlərini söndürmək üçün seçimləri kilidləyin."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Ana ekranı, favoritləri, əvvəlcədən təyin olunmuş mövzuları və köşk rejimini fərdiləşdirin."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "İnterfeys mövzusunun teksturalarını dəyişin."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "İnterfeys teksturasının rənglərini fərdiləşdirin."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Müəyyən interfeys sahələri üçün fonu və alternativləri fərdiləşdirin."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Müxtəlif interfeys xüsusiyyətlərini aktivləşdirin və ya söndürün."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Dizayn işlərini fərdiləşdirin və dəstəklənən dizayn paketlərini quraşdırın."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Dəstəklənən əlavələri quraşdırın və konfiqurasiya edin."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Kitabxana görünüşlərini aktivləşdirin və söndürün. Aşağı göstəricili cihazlarda kitabxana görünüşlərini söndürmək sürəti artıra bilər."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Kitabxana görünüşlərində sürüşdürərkən sürüşdürmə hərfini göstərir."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "İstədiyiniz mövqeyə sürətlə keçmək üçün əlifbanı göstərir. Yalnız standart sıralama üsulları (A-Z) üçün işləyir."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Mövcud olduqda seriallar və filmlər üçün qısa məzmunu göstərir, əks halda standart məzmunu göstərir."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Mətn ölçüsü ekrana sığmadıqda məzmunun avtomatik sürüşməsini təmin edir."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Müəyyən interfeys sahələrinə dərhal daxil olmaq üçün kəsə yol menyusunu aktivləşdirin. Media menyusunda açmaq üçün sola klikləyin və ya kəsə yol nişanına klikləyin."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Kəsə yol menyusunu redaktə edin."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Üst panel elementlərini aktivləşdirin və söndürün."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Video məlumat ayarlarını dəyişin."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Musiqi məlumat ayarlarını dəyişin."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Tam ekran video ayarlarını dəyişin."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Tam ekran audio ayarlarını dəyişin."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Açılan pəncərə bildirişlərinin ölçüsünü azaldın."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Dialoq pəncərələri açıldıqda arxa planı qaraldır. Tam ekran video və ya audio üçün tətbiq olunmur."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Üst panel, media məlumatları və kitabxana görünüşləri üçün rəngli nişanları aktivləşdirin."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Rəngli, HDR, bit dərinliyi və dil media nişanlarını aktivləşdirin."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Bütün interfeysdə audio CD diski rəsmi alternativi tətbiq edilir."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Bütün interfeysdə video CD diski rəsmi alternativi tətbiq edilir."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Üst panel, vidjetlər və hava üçün hava nişanları paketi seçin və quraşdırın."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Fonlar, vidjetlər və hava üçün hava fan-art paketi seçin və quraşdırın."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Bütün interfeysdə istifadə üçün ağ studiya nişanlarını quraşdırın."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Bütün interfeysdə istifadə üçün rəngli studiya nişanlarını quraşdırın."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Bütün interfeysdə istifadə üçün səs yazma studiyası nişanlarını quraşdırın."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Kitabxana görünüşləri və altyazı seçimi üçün dil bayraqlarını quraşdırın."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Musiqi və musiqi videoları üçün musiqi janrı nişanlarını quraşdırın."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Filmlər və seriallar üçün rəngli film janrı nişanlarını quraşdırın."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Filmlər və seriallar üçün ağ-qara film janrı nişanlarını quraşdırın."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Filmlərin ölkə qovşağı üçün ölkə nişanlarını quraşdırın."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Bütün interfeysdə fon şəkillərinin keçid gecikməsini təyin edin."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Düşən fon effektləri (qar, yarpaqlar və s.)."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Hal-hazırda oynayan musiqinin fon rəsmini bütün interfeysdə göstərir. Kitabxana fon rəsmini əvəzləyir."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Musiqi oxudularkən arxa planda vizuallaşdırmanı aktivləşdirir. Bunun üçün pleyer ayarlarında vizuallaşdırma aktiv olmalıdır."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Kitabxanada gəzişərkən indi oynadılan videonu arxa planda göstərir. Kitabxana fon rəsmini əvəzləyir."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "İndi oxudulan sənətçinin şəkillərini və əlavə məlumatlarını fanart.tv və theaudiodb.com saytlarından yükləyir. Tam ekran musiqi, internet yayımları və radio üçün nəzərdə tutulub."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Sənətçi slayd nümayişi skript ayarları."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "Boş olmadıqda video pleylistə aparan kəsə yol."

#: /16x9/Includes_Settings.xml
