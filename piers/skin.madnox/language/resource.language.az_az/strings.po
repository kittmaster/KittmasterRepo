msgstr "Əlavə xüsusiyyətlər quraşdırıcısını yenidən işə sal"

#: Custom_1109_DialogConfirmExtrasInstall.xml
msgctxt "#31519"
msgid "Optional extras installer"
msgstr "Əlavə xüsusiyyətlər quraşdırıcısı"

#: Custom_1109_DialogConfirmExtrasInstall.xml
msgctxt "#31520"
msgid "This will re-run the optional extras installer. All extras will be downloaded and installed in a disabled state. Enable only what you need in Settings > Skin Settings > Addons."
msgstr "Bu, əlavə xüsusiyyətlər quraşdırıcısını yenidən işə salacaq. Bütün əlavələr yüklənəcək, lakin qeyri-aktiv vəziyyətdə quraşdırılacaq. Yalnız sizə lazım olanları Ayarlar > İnterfeys Ayarları > Əlavələr bölməsindən aktivləşdirin."

#: /16x9/SkinSettings.xml
msgctxt "#31521"
