msgid "Images"
msgstr "Immaġnijiet"

#: /16x9/SkinSettings.xml
msgctxt "#31523"
msgid "Display ratings as 10-point numbers"
msgstr "Uri l-klassifikazzjonijiet bħala numri b'10 punti"

#: /16x9/SkinSettings.xml
msgctxt "#31524"
msgid "Allows changes to the ratings to convert between floating numbers or as a percentage. Affects TMDb & IMDb, all others remain as their default display."
msgstr "Jippermetti bidliet fil-klassifikazzjonijiet biex jikkonvertu bejn numri deċimali jew bħala persentaġġ. Jaffettwa lil TMDb u IMDb, l-oħrajn kollha jibqgħu bil-wiri default tagħhom."

#: /16x9/SkinSettings.xml
msgctxt "#31525"
msgid "Re-run skin shortcuts migrator"
msgstr "Erġa' ħaddem il-migratur tas-shortcuts tal-ġilda"

#: /16x9/SkinSettings.xml
msgctxt "#31526"
msgid "This will rewrite the skin shortcuts .properties file to the current 3 module addon structure. Only run if there are issues with background images or playlists are not working."
msgstr "Dan se jerġa' jikteb il-fajl .properties tas-shortcuts tal-ġilda għall-istruttura tal-addon attwali ta' 3 moduli. Ħaddem biss jekk ikun hemm problemi bl-immaġnijiet tal-isfond jew jekk il-playlists ma jkunux qed jaħdmu."

#: /16x9/SkinSettings.xml
msgctxt "#31527"
msgid "This will reactivate the addons installer. Only run if addons were not installed when skin was first installed."
msgstr "Dan se jerġa' jattiva l-installatur tal-addons. Ħaddem biss jekk l-addons ma ġewx installati meta l-ġilda ġiet installata għall-ewwel darba."

#: /16x9/Includes_Settings.xml
