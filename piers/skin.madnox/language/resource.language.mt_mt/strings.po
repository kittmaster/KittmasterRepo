msgstr "Aqleb l-iskema tal-kuluri:"

# --- Body texts: top row category selectors (controls 901–904, 905) ---

#: /16x9/includes.xml
msgctxt "#31567"
msgid "Highlight a logo from the palette below and click to assign it to 4K / UHD video files."
msgstr "Evidenzja logo mill-paletta t'hawn taħt u kklikkja biex tassenjah lil fajls tal-vidjo 4K / UHD."

#: /16x9/includes.xml
msgctxt "#31568"
msgid "Highlight a logo from the palette below and click to assign it to WebDL and streaming video sources."
msgstr "Evidenzja logo mill-paletta t'hawn taħt u kklikkja biex tassenjah lil sorsi tal-vidjo WebDL u streaming."

#: /16x9/includes.xml
msgctxt "#31569"
msgid "Highlight a logo from the palette below and click to assign it to 1080p Full HD video files."
msgstr "Evidenzja logo mill-paletta t'hawn taħt u kklikkja biex tassenjah lil fajls tal-vidjo 1080p Full HD."

#: /16x9/includes.xml
msgctxt "#31570"
msgid "Highlight a logo from the palette below and click to assign it to 720p HD video files."
msgstr "Evidenzja logo mill-paletta t'hawn taħt u kklikkja biex tassenjah lil fajls tal-vidjo 720p HD."

#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "Evidenzja logo mill-paletta t'hawn taħt u kklikkja biex tassenjah lil fajls tal-vidjo DVD u standard-definition."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "Uri biss disinji tal-logo b'definizzjoni ultra-għolja u 4K fil-grid tal-paletta."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "Uri biss disinji tal-logo tal-codec HEVC u H.265 fil-grid tal-paletta."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Uri biss disinji tal-logo tal-codec AVC u H.264 fil-grid tal-paletta."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Uri biss disinji tal-logo tal-format DivX, XviD, u legacy MPEG-4 fil-grid tal-paletta."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Uri disinji tal-logo tal-MPEG klassiku, DVD, u xandir tat-TV standard fil-grid tal-paletta."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Uri disinji tal-logo tal-codec Windows Media Video u VC-1 fil-grid tal-paletta."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Uri wraps tal-kontenituri, formati tad-diski, u disinji tal-logo varji oħra fil-grid tal-paletta."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Agħlaq dan id-djalogu tal-personalizzazzjoni tal-bandiera u rritorna għas-settings."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Evidenzja kwalunkwe disinn tal-logo fil-grid taċ-ċentru u kklikkja biex issalvah bħala l-bandiera personalizzata tiegħek għall-kategorija attiva."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Ikklerja l-għażla tal-bandiera personalizzata tiegħek u rrestawra din il-kategorija għal-loġika awtomatika tal-bandiera default tal-ġilda."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Aqleb l-arti tal-bandiera globali bejn disinji kkuluriti u abjad default monokromatiku."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Uża t-tasti tad-direzzjoni tiegħek biex tinnaviga l-għażliet. Agħfas Lura jew agħżel Ħruġ fi kwalunkwe ħin biex tagħlaq mingħajr ma tagħmel bidliet."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Agħzel biex timmodifika"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Personalizzazzjoni tal-iskrin ewlieni, tal-widgets u tal-menu tas-shortcuts."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Script għall-iżviluppaturi tal-ġilda biex jippermettu lill-utenti jagħżlu addon tar-riżorsi tal-immaġni."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Iżid awtomatikament arti addizzjonali għall-midja fil-libreriji tal-midja tiegħek."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Lirika għall-mużika. Meħtieġa biex tiġi attivata lirika animata."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Sinkronizza l-kollezzjoni u l-istatus ta' wiri tiegħek ma' trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Oħloq favorit personalizzat minn favoriti magħżula ta' kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Editja l-menu tal-iskrin ewlieni, widgets, sfondi u infolines."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Irrisettja l-menu tal-iskrin ewlieni, widgets, sfondi u infolines għal dawk default."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Oħloq favorit personalizzat minn favoriti magħżula ta' kodi. Għall-użu fil-widgets tal-menu prinċipali. Jirrikjedi li l-iscript tal-favoriti jkun installat."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Oħloq favorit ta' addon personalizzat minn addons installati. Għall-użu fil-widgets tal-menu prinċipali."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Irrisettja t-tema u l-kuluri tal-ġilda għal dawk default."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Agħżel minn lista ta' temi definiti minn qabel."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Isakkar il-preferenzi biex tiddiżattiva l-mod tal-vista, l-għażliet tal-vista, id-djalogu tal-informazzjoni u s-settings tal-iskrin sħiħ."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Ippersonalizza l-iskrin ewlieni, il-favoriti, it-temi definiti minn qabel u l-modalità kiosk."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Ibdel in-nisġiet tat-tema tal-ġilda."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Ippersonalizza l-kuluri tan-nisġiet tal-ġilda."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Ippersonalizza l-isfond u l-fallbacks għal żoni speċifiċi tal-ġilda."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Attiva jew iddiżattiva diversi karatteristiċi tal-ġilda."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Ippersonalizza l-arti u nstalla pakketti tal-arti appoġġjati."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Installa u kkonfigura addons appoġġjati."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Attiva u ddiżattiva l-fehmiet tal-librerija. Id-diżattivazzjoni tal-fehmiet tal-librerija fuq sistemi bi speċifikazzjonijiet baxxi tista' ttejjeb il-prestazzjoni."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Juri l-ittra tal-iscrolling meta tiskrollja fil-fehmiet tal-librerija."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Juri l-alfabett biex taqbeż għal pożizzjoni tal-kontenitur. Jaħdem biss għal metodi ta' rranġar default (A-Z)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Juri l-linja tal-istorja għal serje tat-TV u films jekk tkun disponibbli, inkella juri l-plot default."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Skrollja l-plot awtomatikament jekk ma joqgħodx fid-dimensjonijiet tal-kontroll."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Attiva l-menu tas-shortcuts għal aċċess immedjat għal żoni speċifiċi tal-ġilda. Fil-menu tal-midja kklikkja fuq ix-xellug biex tiftaħ jew ikklikkja fuq l-ikona tas-shortcut."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Editja l-menu tas-shortcuts."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Attiva u ddiżattiva l-elementi tal-bar ta' fuq."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Ibdel is-settings tal-informazzjoni tal-vidjo."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Ibdel is-settings tal-informazzjoni tal-mużika."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Ibdel is-settings tal-vidjo bi skrin sħiħ."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Ibdel is-settings tal-awdjo bi skrin sħiħ."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Naqqas id-daqs tan-notifiki pop-up."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Idallam l-iskrin wara l-popups tad-djalogu. Mhux applikabbli għal vidjo jew awdjo bi skrin sħiħ."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Attiva ikoni kkuluriti għall-bar ta' fuq, informazzjoni tal-midja u fehmiet tal-librerija."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Attiva bnadar tal-midja kkuluriti, tal-HDR, tal-profondità tal-bit u tal-lingwa."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Fallback tal-arti tas-CD tal-awdjo fil-ġilda kollha."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Fallback tal-arti tas-CD tal-vidjo fil-ġilda kollha."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Agħżel u nstalla pakkett ta' ikoni tat-temp għall-bar ta' fuq, widgets u temp."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Agħżel u nstalla pakkett ta' fanart tat-temp għall-isfondi, widgets u temp."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Installa ikoni tal-istudjo bojod biex jintużaw fil-ġilda kollha."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Installa ikoni tal-istudjo kkuluriti biex jintużaw fil-ġilda kollha."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Installa ikoni tat-tikketti tad-diski biex jintużaw fil-ġilda kollha."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Installa bnadar tal-lingwa għall-fehmiet tal-librerija u l-għażla tas-sottotitoli."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Installa ikoni tal-ġeneru tal-mużika għall-mużika u vidjos mużikali."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Installa ikoni kkuluriti tal-ġeneru tal-films għal films u serje tat-TV."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Installa ikoni bl-iswed u abjad tal-ġeneru tal-films għal films u serje tat-TV."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Installa ikoni tal-pajjiżi għan-nodu tal-pajjiżi tal-films."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Issettja d-dewmien bejn it-tranżizzjonijiet tal-fanart fil-ġilda kollha."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Effetti ta' sfond li jaqa'. Silġ, Weraq eċċ."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Uri fanart tal-mużika tal-oġġett li qed jindaqq bħalissa fil-ġilda kollha. Jissostitwixxi l-fanart tal-librerija."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Jattiva l-viżwalizzazzjoni tal-mużika fl-isfond waqt li tkun qed tindaqq il-mużika. Jeħtieġ li l-viżwalizzazzjoni tkun attivata fis-settings - Settings tal-Plejer/Mużika."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Uri l-vidjo li qed jindaqq bħalissa fl-isfond waqt li qed tibbrawżja l-librerija. Jissostitwixxi l-fanart tal-librerija."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Niżżel immaġnijiet u informazzjoni addizzjonali minn fanart.tv u theaudiodb.com tal-artist li qed jindaqq bħalissa. Għal mużika bi skrin sħiħ, streams tal-internet u radju."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Settings tal-iscript tas-slideshow tal-artist."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "Shortcut għall-playlist tal-vidjo jekk ma tkunx vojta."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "Shortcut għall-playlist tal-mużika jekk ma tkunx vojta."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Shortcut għal skrin sħiħ meta tkun qed tindaqq il-midja."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Ikklikkja biex tiftaħ il-menu tas-shortcuts."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Kontrolli tal-plejer meta tkun qed tindaqq il-midja."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Daqq l-episodju li jmiss tas-serje tat-TV awtomatikament."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Daqq temi waqt li tkun qed tibbrawżja serje tat-TV, films u vidjos mużikali."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "Il-Library Node Editor jippermettilek toħloq u tippersonalizza nodi tal-vidjo u tal-mużika personalizzati fi ħdan Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Uri informazzjoni dwar l-overlay tal-markaturi għal oġġetti tal-midja li ntwerew, dawk li ma ntwerewx, u dawk li qed jindaqq bħalissa."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Script għall-editjar tal-RSS Ticker integrat ta' Kodi."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Verżjoni tal-ġilda u għażliet ta' rkupru. Jirrestawra d-defaults kollha għall-operat tal-ewwel jum."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Addons"