msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Visa endast logotyper för DivX, XviD och äldre MPEG-4-format i palettrutnätet."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Se klassiska MPEG-, DVD- och standardlogotyper för TV-sändningar i palettrutnätet."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Se Windows Media Video och VC-1 codec-logotypdesigner i palettrutnätet."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Visa behållaromslag, diskformat och andra olika logotyper i palettrutnätet."

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Stäng den här dialogrutan för flagganpassning och återgå till inställningarna."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Markera valfri logotypdesign i mittrutnätet och klicka för att spara den som din anpassade flagga för den aktiva kategorin."

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Rensa ditt val av anpassad flagga och återställ denna kategori till skalets automatiska standardflagglogik."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Växla global flaggkonst mellan färgad design och monokromatisk standardvit."

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Använd dina riktningsknappar för att navigera i alternativen. Tryck på Tillbaka eller välj Avsluta när som helst för att stänga utan ändringar."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Välj för att ändra"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Anpassning av startskärmen, widgetar och genvägsmenyn."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Skript för skinnare för att låta användare välja en bildresurstillägg."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Lägger automatiskt till extra konstverk för media i dina mediebibliotek."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Texter för musik. Krävs för att aktivera animerade texter."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Synkronisera din samling och tittade status med trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Skapa en anpassad favorit från valda kodi-favoriter."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Redigera startskärmsmenyn, widgetar, bakgrunder och informationsrader."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Återställ startskärmens meny, widgets, bakgrunder och infolinjer till standardinställningarna."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Skapa en anpassad favorit från utvalda Kodi-favoriter. För användning i widgetar på huvudmenyn. Kräver att skriptfavoriter är installerade."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Skapa en anpassad addon-favorit från installerade addons. För användning i widgetar på huvudmenyn."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Återställ hudens tema och färger till standardinställningarna."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Välj från en lista med fördefinierade teman."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Lås inställningar för att inaktivera visningsläge, visningsalternativ, informationsdialog och helskärmsinställningar."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Anpassa startskärmen, favoriterna, fördefinierade teman och kioskläget."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Ändra texturer för hudtema."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Anpassa färgerna på hudstrukturen."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Anpassa bakgrund och fallbacks för specifika hudområden."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Aktivera eller inaktivera olika funktioner i skinnet."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Anpassa illustrationer och installera illustrationspaket som stöds."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Installera och konfigurera tillägg som stöds."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Aktivera och inaktivera biblioteksvyer. Om du avaktiverar biblioteksvyer på system med låg specifikation kan det förbättra prestandan."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Visar rullningsbokstaven när du rullar i biblioteksvyer."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods."
msgstr "Visar alfabetet för att hoppa till en position i behållaren. Fungerar endast för standardsorteringsmetoder."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Visar intrigskisser för tv-serier och filmer om sådana finns tillgängliga, annars visas standardintrigen."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Automatisk rullning av diagrammet om det inte passar in i kontrolldimensionerna."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Aktivera genvägsmenyn för omedelbar åtkomst till specifika hudområden. Klicka på vänster i mediamenyn för att öppna eller klicka på genvägsikonen."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Redigera genvägsmenyn."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Aktivera och inaktivera elementen i toppfältet."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Ändra inställningar för videoinfo."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Ändra inställningar för musikinfo."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Ändra inställningar för helskärmsvideo."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Ändra ljudinställningar för helskärm."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Minska storleken på popup-meddelanden."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Mörkar skärmen bakom popup-fönster för dialogrutor. Gäller inte för video eller ljud i helskärm."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Aktivera färgade ikoner för toppfältet, medieinformation och biblioteksvyer."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Aktivera mediaflaggor för färg, HDR, bitdjup och språk."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Ljud-CD-omslagsbild fallback över hela temat"

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Video cd art fallback skin wide."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Välj och installera ett ikonpaket för väder för toppfältet, widgetar och väder."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Välj och installera ett fanartpaket för väder för bakgrunder, widgets och väder."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Installera vita studioikoner för användning i hela höljet."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Installera färgade studioikoner för användning i hela höljet."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Installera ikoner för skivmärkning för användning i hela huden."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Installera språkflaggor för biblioteksvisning och val av undertexter."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Installera ikoner för musikgenrer för musik och musikvideor."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Installera färgade filmgenreikoner för filmer och tv-program."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Installera svartvita filmgenreikoner för filmer och tv-program."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Installera landsikoner för landsnoder för filmer."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Ställ in fördröjningen mellan fanart-övergångar och hudbredd."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Fallande bakgrundseffekter. Snö, löv etc."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Visa musikfanart för det objekt som spelas för tillfället på hela ytan. Åsidosätter biblioteket fanart."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Möjliggör musikvisualisering i bakgrunden när du spelar musik. Kräver att visualisering är aktiverad i inställningar - Spelarinställningar/Musik."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Visa video som spelas nu i bakgrunden när du bläddrar i biblioteket. Åsidosätter bibliotekets fanart."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Hämta ner bilder och ytterligare information från fanart.tv och theaudiodb.com om artisten som spelas för tillfället. För musik i helskärm, internetströmmar och radio."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Inställningar för skript för bildspel för artister."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "En genväg till videospelningslistan om den inte är tom."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "En genväg till musikspellistan om den inte är tom."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Genväg till helskärm när media spelas upp."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Klicka för att öppna genvägsmenyn."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Spelaren styr när media spelas upp."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Spela upp nästa avsnitt av tv-serien automatiskt."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Spela teman när du navigerar i TV-serier, filmer och musikvideor."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "Biblioteksnodredigeraren låter dig skapa och anpassa egna videonoder och musiknoder i Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Visa överläggsmarkeringsinformation för tittade, otittade och pågående medieobjekt."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Ett skript för att redigera Kodis inbyggda RSS-ticker."
#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Hudversion och återställningsalternativ. Återställer alla standardinställningar till dag ett operation."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Tillägg"

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Hudversion och återställningsalternativ. Återställer alla standardinställningar till dag ett operation."

