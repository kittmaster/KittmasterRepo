msgstr "類別"

# --- Colored prefix labels ---

#: /16x9/includes.xml
msgctxt "#31559"
msgid "Customise 4K / UHD flag:"
msgstr "自訂 4K / UHD 標籤："

#: /16x9/includes.xml
msgctxt "#31560"
msgid "Customise WebDL flag:"
msgstr "自訂 WebDL 標籤："

#: /16x9/includes.xml
msgctxt "#31561"
msgid "Customise 1080p flag:"
msgstr "自訂 1080p 標籤："

#: /16x9/includes.xml
msgctxt "#31562"
msgid "Customise 720p flag:"
msgstr "自訂 720p 標籤："

#: /16x9/includes.xml
msgctxt "#31563"
msgid "Customise DVD / SD flag:"
msgstr "自訂 DVD / SD 標籤："

#: /16x9/includes.xml
msgctxt "#31564"
msgid "Category filter:"
msgstr "類別篩選器："

#: /16x9/includes.xml
