# --- Body texts: top row category selectors (controls 901–904, 905) ---

#: /16x9/includes.xml
msgctxt "#31567"
msgid "Highlight a logo from the palette below and click to assign it to 4K / UHD video files."
msgstr "یک لوگو را از پالت زیر برجسته کرده و برای اختصاص آن به فایل‌های ویدیویی 4K / UHD کلیک کنید."

#: /16x9/includes.xml
msgctxt "#31568"
msgid "Highlight a logo from the palette below and click to assign it to WebDL and streaming video sources."
msgstr "یک لوگو را از پالت زیر برجسته کرده و برای اختصاص آن به منابع ویدیویی جریانی و WebDL کلیک کنید."

#: /16x9/includes.xml
msgctxt "#31569"
msgid "Highlight a logo from the palette below and click to assign it to 1080p Full HD video files."
msgstr "یک لوگو را از پالت زیر برجسته کرده و برای اختصاص آن به فایل‌های ویدیویی Full HD 1080p کلیک کنید."

#: /16x9/includes.xml
msgctxt "#31570"
msgid "Highlight a logo from the palette below and click to assign it to 720p HD video files."
msgstr "یک لوگو را از پالت زیر برجسته کرده و برای اختصاص آن به فایل‌های ویدیویی HD 720p کلیک کنید."

#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "یک لوگو را از پالت زیر برجسته کرده و برای اختصاص آن به فایل‌های ویدیویی DVD و کیفیت استاندارد کلیک کنید."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "مشاهده فقط طرح‌های لوگوی Ultra HD و 4K در شبکه پالت."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "مشاهده فقط طرح‌های لوگوی کدک HEVC و H.265 در شبکه پالت."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "مشاهده فقط طرح‌های لوگوی کدک AVC و H.264 در شبکه پالت."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "مشاهده فقط طرح‌های لوگوی فرمت‌های قدیمی MPEG-4، DivX و XviD در شبکه پالت."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "مشاهده طرح‌های لوگوی پخش تلویزیونی استاندارد، DVD و MPEG کلاسیک در شبکه پالت."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "مشاهده طرح‌های لوگوی کدک VC-1 و Windows Media Video در شبکه پالت."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "مشاهده ظرف‌های قالب رسانه (کانتینرها)، فرمت‌های دیسک و سایر طرح‌های لوگوی متفرقه در شبکه پالت."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "بستن این کادر گفتگوی سفارشی‌سازی پرچم و بازگشت به تنظیمات."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "هر طرح لوگو را در شبکه مرکزی برجسته کرده و کلیک کنید تا به عنوان پرچم سفارشی شما برای دسته فعال ذخیره شود."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "پاک کردن انتخاب پرچم سفارشی شما و بازیابی این دسته به منطق پرچم پیش‌فرض و خودکار پوسته."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "تغییر جلوه گرافیکی پرچم سراسری بین طرح‌های رنگی و سفید پیش‌فرض تک‌رنگ."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "از کلیدهای جهت‌نما برای پیمایش گزینه‌ها استفاده کنید. برای خروج بدون تغییر، در هر زمان کلید بازگشت (Back) را فشار داده یا خروج را انتخاب کنید."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "انتخاب برای اصلاح"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "سفارشی‌سازی صفحه اصلی، ویجت‌ها و منوی میانبرها."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "اسکریپتی برای پوسته‌سازان جهت اجازه دادن به کاربران برای انتخاب یک افزونه منبع تصویر."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "افزودن خودکار آرت‌ورک اضافی برای رسانه‌ها در کتابخانه‌های رسانه‌ای شما."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "متن شعر برای موسیقی. برای فعال کردن متن شعر متحرک مورد نیاز است."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "همگام‌سازی مجموعه و وضعیت تماشای شما با trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "ایجاد یک علاقه‌مندی سفارشی از علاقه‌مندی‌های انتخاب شده کدی."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "ویرایش منوی صفحه اصلی، ویجت‌ها، پس‌زمینه‌ها و خطوط اطلاعات."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "بازنشانی منوی صفحه اصلی، ویجت‌ها، پس‌زمینه‌ها و خطوط اطلاعات به پیش‌فرض."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "ایجاد یک علاقه‌مندی سفارشی از علاقه‌مندی‌های انتخاب شده کدی. جهت استفاده در ویجت‌های منوی اصلی. به نصب بودن اسکریپت علاقه‌مندی‌ها نیاز دارد."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "ایجاد یک افزونه علاقه‌مندی سفارشی از افزونه‌های نصب شده. جهت استفاده در ویجت‌های منوی اصلی."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "بازنشانی پوسته و رنگ‌های پوسته به پیش‌فرض."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "انتخاب از لیستی از پوسته‌های از پیش تعریف شده."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "قفل کردن تنظیمات برای غیرفعال کردن حالت نمایش، گزینه‌های نمایش، کادر گفتگوی اطلاعات و تنظیمات تمام‌صفحه."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "سفارشی‌سازی صفحه اصلی، علاقه‌مندی‌ها، پوسته‌های از پیش تعریف شده و حالت کیوسک."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "تغییر بافت‌های پوسته."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "سفارشی‌سازی رنگ‌های بافت پوسته."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "سفارشی‌سازی پس‌زمینه و جایگزین‌ها برای بخش‌های خاص پوسته."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "فعال یا غیرفعال کردن ویژگی‌های مختلف پوسته."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "سفارشی‌سازی تصاویر هنری (آرت‌ورک) و نصب بسته‌های آرت‌ورک پشتیبانی شده."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "نصب و پیکربندی افزونه‌های پشتیبانی شده."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "فعال و غیرفعال کردن نماهای کتابخانه. غیرفعال کردن نماهای کتابخانه در سیستم‌های ضعیف ممکن است عملکرد را بهبود بخشد."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "هنگام پیمایش در نماهای کتابخانه، حرف اسکرول را نشان می‌دهد."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "نمایش حروف الفبا برای پرش به یک موقعیت در کانتینر. فقط برای روش‌های مرتب‌سازی پیش‌فرض (A-Z) کار خواهد کرد."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "خلاصه داستان را برای سریال‌ها و فیلم‌ها در صورت موجود بودن نشان می‌دهد، در غیر این صورت طرح پیش‌فرض را نمایش می‌دهد."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "اگر متن داستان در ابعاد کنترل جا نشود، آن را به طور خودکار اسکرول می‌کند."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "منوی میانبر را برای دسترسی فوری به بخش‌های خاص پوسته فعال کنید. در منوی رسانه به چپ کلیک کنید تا باز شود یا روی آیکون میانبر کلیک کنید."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "ویرایش منوی میانبر."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "فعال و غیرفعال کردن عناصر نوار بالایی."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "تغییر تنظیمات اطلاعات ویدیو."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "تغییر تنظیمات اطلاعات موسیقی."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "تغییر تنظیمات ویدیوی تمام‌صفحه."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "تغییر تنظیمات صوتی تمام‌صفحه."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "کاهش اندازه اعلان‌های پاپ‌آپ."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "صفحه نمایش را پشت پنجره‌های بازشوی گفتگو تاریک می‌کند. برای ویدیو یا صدای تمام‌صفحه اعمال نمی‌شود."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "فعال کردن آیکون‌های رنگی برای نوار بالایی، اطلاعات رسانه و نماهای کتابخانه."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "فعال کردن پرچم‌های رسانه‌ای رنگی، HDR، عمق بیت و زبان."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "پیش‌فرض جایگزین هنر سی‌دی صوتی در سراسر پوسته."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "پیش‌فرض جایگزین هنر سی‌دی ویدیویی در سراسر پوسته."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "انتخاب و نصب یک بسته آیکون آب و هوا برای نوار بالایی، ویجت‌ها و آب و هوا."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "انتخاب و نصب یک بسته فن‌آرت آب و هوا برای پس‌زمینه‌ها، ویجت‌ها و آب و هوا."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "نصب آیکون‌های استودیویی سفید برای استفاده در سراسر پوسته."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "نصب آیکون‌های استودیویی رنگی برای استفاده در سراسر پوسته."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "نصب آیکون‌های برچسب ضبط (Record Label) برای استفاده در سراسر پوسته."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "نصب پرچم‌های زبان برای نماهای کتابخانه و انتخاب زیرنویس."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "نصب آیکون‌های ژانر موسیقی برای موسیقی و موزیک ویدیوها."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "نصب آیکون‌های رنگی ژانر فیلم برای فیلم‌ها و سریال‌ها."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "نصب آیکون‌های سیاه و سفید ژانر فیلم برای فیلم‌ها و سریال‌ها."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "نصب آیکون‌های کشور برای گره کشور فیلم‌ها."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "تنظیم مدت زمان تأخیر بین انتقال‌های فن‌آرت در سراسر پوسته."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "جلوه‌های پس‌زمینه بارشی مانند برف، برگ‌ها و غیره."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "نمایش فن‌آرت موسیقی مورد در حال پخش در سراسر پوسته. بر فن‌آرت کتابخانه اولویت دارد."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "جلوه‌های بصری موسیقی را هنگام پخش موسیقی در پس‌زمینه فعال می‌کند. به فعال بودن بصری‌سازی در مسیر تنظیمات - تنظیمات پخش‌کننده/موسیقی نیاز دارد."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "نمایش ویدیوی در حال پخش در پس‌زمینه هنگام مرور کتابخانه. بر فن‌آرت کتابخانه اولویت دارد."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "دانلود تصاویر و اطلاعات اضافی از fanart.tv و theaudiodb.com برای هنرمند در حال پخش. برای موسیقی تمام‌صفحه، پخش‌های اینترنتی و رادیو."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "تنظیمات اسکریپت اسلایدشوی هنرمند."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "یک میانبر به لیست پخش ویدیو در صورت خالی نبودن."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "یک میانبر به لیست پخش موسیقی در صورت خالی نبودن."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "میانبر به حالت تمام‌صفحه هنگام پخش رسانه."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "برای باز کردن منوی میانبر کلیک کنید."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "کنترل‌های پخش‌کننده هنگام پخش رسانه."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "پخش خودکار قسمت بعدی سریال تلویزیونی."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "پخش موسیقی متن تم هنگام ناوبری در سریال‌ها، فیلم‌ها و موزیک ویدیوها."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "ویرایشگر گره کتابخانه به شما امکان می‌دهد گره‌های ویدیویی و موسیقی سفارشی را در داخل کدی ایجاد و شخصی‌سازی کنید."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "نمایش اطلاعات علامت‌گذاری لایه‌ای برای موارد رسانه‌ای تماشا شده، تماشا نشده و در حال انجام."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "اسکریپتی برای ویرایش بخش خبرخوان (RSS Ticker) داخلی کدی."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "نسخه پوسته و گزینه‌های بازیابی. تمام تنظیمات پیش‌فرض را به عملکرد روز اول بازمی‌گرداند."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "افزونه‌ها"