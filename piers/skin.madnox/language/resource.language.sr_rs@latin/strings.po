#: /16x9/includes.xml
msgctxt "#31562"
msgid "Customise 720p flag:"
msgstr "Prilagodi 720p oznaku:"

#: /16x9/includes.xml
msgctxt "#31563"
msgid "Customise DVD / SD flag:"
msgstr "Prilagodi DVD / SD oznaku:"

#: /16x9/includes.xml
msgctxt "#31564"
msgid "Category filter:"
msgstr "Filter kategorije:"

#: /16x9/includes.xml
msgctxt "#31565"
msgid "Restore default:"
msgstr "Vrati podrazumevano:"

#: /16x9/includes.xml
msgctxt "#31566"
msgid "Toggle Color Scheme:"
msgstr "Promeni šemu boja:"

# --- Body texts: top row category selectors (controls 901–904, 905) ---

#: /16x9/includes.xml
msgctxt "#31567"
msgid "Highlight a logo from the palette below and click to assign it to 4K / UHD video files."
msgstr "Istaknite logotip sa palete ispod i kliknite da biste ga dodelili 4K / UHD video datotekama."

#: /16x9/includes.xml
msgctxt "#31568"
msgid "Highlight a logo from the palette below and click to assign it to WebDL and streaming video sources."
msgstr "Istaknite logotip sa palete ispod i kliknite da biste ga dodelili WebDL i striming izvorima videa."

#: /16x9/includes.xml
msgctxt "#31569"
msgid "Highlight a logo from the palette below and click to assign it to 1080p Full HD video files."
msgstr "Istaknite logotip sa palete ispod i kliknite da biste ga dodelili 1080p Full HD video datotekama."

#: /16x9/includes.xml
msgctxt "#31570"
msgid "Highlight a logo from the palette below and click to assign it to 720p HD video files."
msgstr "Istaknite logotip sa palete ispod i kliknite da biste ga dodelili 720p HD video datotekama."

#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "Istaknite logotip sa palete ispod i kliknite da biste ga dodelili DVD i video datotekama standardne rezolucije."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "Prikaži samo logotipe ultra visoke definicije i 4K u mreži palete."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "Prikaži samo logotipe HEVC i H.265 kodeka u mreži palete."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Prikaži samo logotipe AVC i H.264 kodeka u mreži palete."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Prikaži samo logotipe DivX, XviD i starijih MPEG-4 formata u mreži palete."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Prikaži samo logotipe klasičnog MPEG-a, DVD-a i standardnog TV emitovanja u mreži palete."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Prikaži samo logotipe Windows Media Video i VC-1 kodeka u mreži palete."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Prikaži samo formate kontejnera, formate diskova i druge mešovite logotipe u mreži palete."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Zatvorite ovaj prozor za prilagođavanje oznaka i vratite se u podešavanja."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Istaknite bilo koji dizajn logotipa u središnjoj mreži i kliknite da biste ga sačuvali kao svoju prilagođenu oznaku za aktivnu kategoriju."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Obrišite svoj izbor prilagođene oznake i vratite ovu kategoriju na automatsku podrazumevanu logiku oznaka maske."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Promenite globalni izgled oznaka između dizajna u boji i jednobojne podrazumevane bele."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Koristite tastere sa strelicama za kretanje kroz opcije. Pritisnite taster Nazad ili izaberite Izlaz u bilo kom trenutku da biste zatvorili bez promena."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Izaberi za izmenu"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Prilagođavanje početnog ekrana, vidžeta i menija sa prečicama."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Skripta za kreatore maski koja omogućava korisnicima da izaberu dodatak za resurse slika."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Automatski dodaje dodatne slike za medije u vašim bibliotekama medija."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Tekstovi za muziku. Potrebno za omogućavanje animiranih tekstova pesama."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Sinhronizujte svoju kolekciju i status odgledanosti sa trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Kreirajte prilagođenu omiljenu stavku od izabranih Kodi omiljenih stavki."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Uredite meni početnog ekrana, vidžete, pozadine i info linije."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Resetujte meni početnog ekrana, vidžete, pozadine i info linije na podrazumevane vrednosti."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Kreirajte prilagođenu omiljenu stavku od izabranih Kodi omiljenih stavki. Za upotrebu u vidžetima glavnog menija. Zahteva instaliranu skriptu za omiljene stavke."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Kreirajte prilagođeni omiljeni dodatak od instaliranih dodataka. Za upotrebu u vidžetima glavnog menija."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Resetujte temu i boje maske na podrazumevane vrednosti."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Izaberite sa liste unapred definisanih tema."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Zaključajte podešavanja da biste onemogućili režim prikaza, opcije prikaza, info prozor i podešavanja preko celog ekrana."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Prilagodite početni ekran, omiljene stavke, unapred definisane teme i kiosk režim."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Promenite teksture teme maske."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Prilagodite boje teksture maske."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Prilagodite pozadinu i rezervne opcije za određene oblasti maske."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Omogućite ili onemogućite različite funkcije maske."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Prilagodite izgled i instalirajte podržane pakete grafike."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Instalirajte i konfigurišite podržane dodatke."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Omogućite i onemogućite prikaze biblioteke. Onemogućavanje prikaza biblioteke na sistemima slabijih specifikacija može poboljšati performanse."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Prikazuje slovo pri brzom kretanju kroz prikaze biblioteke."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Prikazuje abecedu za skok na poziciju kontejnera. Radiće samo za podrazumevane metode sortiranja (A-Z)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Prikazuje kratak sadržaj za TV serije i filmove ako je dostupan, u suprotnom prikazuje podrazumevani sadržaj."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Automatski skroluje sadržaj (plot) ako ne staje u dimenzije kontrole."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Omogućite meni sa prečicama za trenutni pristup određenim oblastima maske. U meniju medija kliknite levo da biste otvorili ili kliknite na ikonu prečice."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Uredite meni sa prečicama."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Omogućite i onemogućite elemente gornje trake."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Promenite podešavanja informacija o videu."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Promenite podešavanja informacija o muzici."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Promenite podešavanja videa preko celog ekrana."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Promenite podešavanja zvuka preko celog ekrana."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Smanjite veličinu iskačućih obaveštenja."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Zatamnjuje ekran iza iskačućih prozora. Nije primenljivo za video ili audio preko celog ekrana."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Omogućite obojene ikone za gornju traku, informacije o medijima i prikaze biblioteke."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Omogućite obojene, HDR, dubinu bita i jezičke oznake medija."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Rezervni izgled audio CD-a na nivou cele maske."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Rezervni izgled video CD-a na nivou cele maske."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Izaberite i instalirajte paket vremenskih ikona za gornju traku, vidžete i vreme."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Izaberite i instalirajte paket vremenskog fanarta za pozadine, vidžete i vreme."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Instalirajte bele ikone filmskih studija za upotrebu u celoj maski."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Instalirajte obojene ikone filmskih studija za upotrebu u celoj maski."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Instalirajte ikone izdavačkih kuća za upotrebu u celoj maski."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Instalirajte zastave jezika za prikaze biblioteke i izbor titlova."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Instalirajte ikone muzičkih žanrova za muziku i muzičke spotove."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Instalirajte obojene ikone filmskih žanrova za filmove i TV serije."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Instalirajte crno-bele ikone filmskih žanrova za filmove i TV serije."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Instalirajte ikone država za čvor država u filmovima."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Podesite kašnjenje između prelaza fanarta na nivou cele maske."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Efekti padanja u pozadini. Sneg, lišće itd."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Prikaži muzički fanart stavke koja se trenutno reprodukuje na nivou cele maske. Prepisuje bibliotečki fanart."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Omogućava vizuelizaciju muzike u pozadini dok se muzika reprodukuje. Zahteva da vizuelizacija bude omogućena u podešavanjima - Podešavanja plejera/Muzika."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Prikaži video koji se trenutno reprodukuje u pozadini tokom pretraživanja biblioteke. Prepisuje bibliotečki fanart."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Preuzmite slike i dodatne informacije sa fanart.tv i theaudiodb.com za izvođača koji se trenutno reprodukuje. Za muziku preko celog ekrana, internet strimove i radio."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Podešavanja skripte za slajdšou izvođača."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "Prečica do video plejliste ako nije prazna."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "Prečica do muzičke plejliste ako nije prazna."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Prečica za prikaz preko celog ekrana kada se medij reprodukuje."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Kliknite da biste otvorili meni sa prečicama."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Kontrole plejera kada se medij reprodukuje."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Automatski pusti sledeću epizodu TV serije."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Puštaj tematsku muziku tokom kretanja kroz TV serije, filmove i muzičke spotove."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "Library Node Editor vam omogućava da kreirate i prilagodite sopstvene video i muzičke čvorove unutar Kodija."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Prikaži prekrivne informacije o oznakama za odgledane, neodgledane i započete stavke medija."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Skripta za uređivanje ugrađene Kodi RSS trake."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Verzija maske i opcije oporavka. Vraća sve podrazumevane vrednosti na početne."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Dodaci"