# --- Body texts: top row category selectors (controls 901–904, 905) ---

#: /16x9/includes.xml
msgctxt "#31567"
msgid "Highlight a logo from the palette below and click to assign it to 4K / UHD video files."
msgstr "Jelöljön ki egy logót az alábbi palettáról, majd kattintással rendelje hozzá a 4K / UHD videofájlokhoz."

#: /16x9/includes.xml
msgctxt "#31568"
msgid "Highlight a logo from the palette below and click to assign it to WebDL and streaming video sources."
msgstr "Jelöljön ki egy logót az alábbi palettáról, majd kattintással rendelje hozzá a WebDL és streaming videoforrásokhoz."

#: /16x9/includes.xml
msgctxt "#31569"
msgid "Highlight a logo from the palette below and click to assign it to 1080p Full HD video files."
msgstr "Jelöljön ki egy logót az alábbi palettáról, majd kattintással rendelje hozzá az 1080p Full HD videofájlokhoz."

#: /16x9/includes.xml
msgctxt "#31570"
msgid "Highlight a logo from the palette below and click to assign it to 720p HD video files."
msgstr "Jelöljön ki egy logót az alábbi palettáról, majd kattintással rendelje hozzá a 720p HD videofájlokhoz."

#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "Jelöljön ki egy logót az alábbi palettáról, majd kattintással rendelje hozzá a DVD és normál felbontású videofájlokhoz."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "Csak az ultra-nagy felbontású és 4K logótervek megjelenítése a paletta rácsban."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "Csak a HEVC és H.265 kodek logótervek megjelenítése a paletta rácsban."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Csak az AVC és H.264 kodek logótervek megjelenítése a paletta rácsban."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Csak a DivX, XviD és korábbi MPEG-4 formátumú logótervek megjelenítése a paletta rácsban."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Klasszikus MPEG, DVD és szabványos TV-közvetítési logótervek megjelenítése a paletta rácsban."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Windows Media Video és VC-1 kodek logótervek megjelenítése a paletta rácsban."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Konténerek, lemezformátumok és egyéb vegyes logótervek megjelenítése a paletta rácsban."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "A jelölő-testreszabási párbeszédpanel bezárása és visszatérés a beállításokhoz."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Jelöljön ki egy tetszőleges logótervet a középső rácsban, majd kattintással mentse el egyéni jelölőként az aktív kategóriához."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Az egyéni jelölőválasztás törlése, és a kategória visszaállítása a téma automatikus alapértelmezett jelölési logikájára."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Globális jelölőgrafika átváltása a színes dizájn és a monokróm alapértelmezett fehér között."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Használja az iránygombokat a navigációhoz. Nyomja meg a Vissza gombot, vagy válassza a Kilépés lehetőséget a módosítások nélküli bezáráshoz."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Válassza ki a módosításhoz"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "A kezdőképernyő, a widgetek és a gyorsgombok menüjének testreszabása."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Szkript témaszerkesztőknek, amellyel a felhasználók kiválaszthatnak egy képforrás-kiegészítőt."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Automatikusan extra borítóképeket és grafikákat ad hozzá a médiakönyvtárában található elemekhez."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Dalszövegek zenéhez. Szükséges az animált dalszövegek engedélyezéséhez."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Szinkronizálja gyűjteményét és megtekintési állapotát a trakt.tv szolgáltatással."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Egyéni kedvenc létrehozása a kiválasztott Kodi kedvencekből."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "A kezdőképernyő menüjének, widgetjeinek, háttereinek és infósorainak szerkesztése."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "A kezdőképernyő menüjének, widgetjeinek, háttereinek és infósorainak alaphelyzetbe állítása."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Egyéni kedvenc létrehozása a kiválasztott Kodi kedvencekből, főmenü widgetekben való használatra. A Favourites szkript telepítése szükséges hozzá."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Egyéni kiegészítő-kedvenc létrehozása a telepített kiegészítőkből, főmenü widgetekben való használatra."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "A téma és a színek alaphelyzetbe állítása."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Válasszon az előre meghatározott témák listájából."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Beállítások zárolása a nézeti mód, a nézeti opciók, az információs ablakok és a teljes képernyős beállítások letiltásához."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "A kezdőképernyő, a kedvencek, az előre meghatározott témák és a kioszk mód testreszabása."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Téma textúráinak módosítása."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "A téma textúraszíneinek testreszabása."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "A hátterek és tartalékok testreszabása az egyes tématerületekhez."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Különböző témafunkciók engedélyezése vagy letiltása."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Grafikák testreszabása és támogatott borítócsomagok telepítése."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Támogatott kiegészítők telepítése és konfigurálása."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Könyvtári nézetek engedélyezése és letiltása. A könyvtári nézetek letiltása alacsony teljesítményű rendszereken javíthatja a sebességet."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Gördítési betű megjelenítése a könyvtári nézetekben való böngészéskor."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Megjeleníti az ábécét a tároló egy adott pozíciójára való ugráshoz. Csak az alapértelmezett rendezési módoknál működik (A-Z)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Megjeleníti a sorozatok és filmek rövid történetét, ha elérhető, egyébként az alapértelmezett leírást mutatja."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "A leírás automatikus gördítése, ha nem fér el a megadott méretben."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Gyorsmenü engedélyezése az egyes tématerületek azonnali eléréséhez. A médiamenüben kattintson balra a megnyitáshoz, vagy kattintson a gyorsgomb ikonra."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "A gyorsmenü szerkesztése."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "A felső sáv elemeinek engedélyezése és letiltása."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Videó infó beállítások módosítása."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Zene infó beállítások módosítása."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Teljes képernyős videóbeállítások módosítása."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Teljes képernyős hangbeállítások módosítása."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Felugró értesítések méretének csökkentése."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Elsötétíti a képernyőt a felugró párbeszédpanelek mögött. Nem vonatkozik teljes képernyős videóra vagy hangra."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Színes ikonok engedélyezése a felső sávhoz, a médiainformációkhoz és a könyvtárnézetekhez."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Színes, HDR, színmélység és nyelvi médiajelölők engedélyezése."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Zenei CD-kép tartalék az egész témában."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Videó lemezkép tartalék az egész témában."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Időjárás ikoncsomag kiválasztása és telepítése a felső sávhoz, a widgetekhez és az időjáráshoz."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Időjárás háttérkép-csomag kiválasztása és telepítése a hátterekhez, a widgetekhez és az időjáráshoz."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Fehér stúdiólogók telepítése a témában való használatra."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Színes stúdiólogók telepítése a témában való használatra."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Kiadói logók telepítése a témában való használatra."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Nyelvi zászlók telepítése a könyvtári nézetekhez és a feliratválasztáshoz."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Zenei műfajikonok telepítése zenékhez és zenei videókhoz."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Színes filmműfaj-ikonok telepítése filmekhez és sorozatokhoz."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Fekete-fehér filmműfaj-ikonok telepítése filmekhez és sorozatokhoz."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Országikonok telepítése a filmek országcsomópontjához."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "A háttérképek közötti áttűnés késleltetésének beállítása a témában."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Hulló háttéreffektusok (hó, levelek stb.)."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "A most játszott elem zenei fanartjának megjelenítése a témában. Felülbírálja a könyvtár fanartját."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Engedélyezi a zenei vizualizációt a háttérben zenelejátszás közben. Ehhez engedélyezni kell a vizualizációt a Lejátszó / Zene beállításokban."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "A most játszott videó megjelenítése a háttérben a könyvtár böngészése közben. Felülbírálja a könyvtár fanartját."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Képek és további információk letöltése a fanart.tv és theaudiodb.com oldalakról a most játszott előadóhoz. Teljes képernyős zenéhez, internetes adatfolyamokhoz és rádióhoz."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Artist Slideshow szkript beállításai."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "Gyorsgomb a videó lejátszási listához, ha az nem üres."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "Gyorsgomb a zene lejátszási listához, ha az nem üres."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Gyorsgomb a teljes képernyős módhoz médialejátszás közben."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Kattintson a gyorsmenü megnyitásához."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Lejátszásvezérlők, amikor a média lejátszása folyamatban van."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "A sorozat következő epizódjának automatikus lejátszása."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Témazenék lejátszása a sorozatok, filmek és zenei videók böngészése közben."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "A Könyvtár csomópont-szerkesztő lehetővé teszi egyéni videó- és zenei csomópontok létrehozását és testreszabását a Kodiban."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Átfedő jelölések megjelenítése a megtekintett, nem megtekintett és folyamatban lévő médiaelemekhez."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Szkript a Kodi beépített RSS-hírcsatornájának szerkesztéséhez."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Témaverzió és visszaállítási opciók. Visszaállít minden alapértelmezett értéket a kezdeti állapotra."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Kiegészítők"