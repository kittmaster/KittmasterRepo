msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Ջնջել ձեր ընտրած անհատական դրոշակը և վերականգնել այս կատեգորիայի համար կազմի լռելյայն ավտոմատ տրամաբանությունը:"

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Փոխարկել համընդհանուր դրոշակների ձևավորումը գունավորի և լռելյայն միագույն սպիտակի միջև:"

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Օգտագործեք սլաքները՝ տարբերակների միջև նավարկելու համար: Սեղմեք Back (Հետ) կամ ընտրեք Exit (Ելք) ցանկացած պահի՝ առանց փոփոխությունների փակելու համար:"

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Ընտրեք՝ փոփոխելու համար"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Գլխավոր էկրանի, վիդջեթների և արագ հասանելիության մենյուի անհատականացում:"

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Սկրիպտ կազմերի մշակողների համար, որը թույլ է տալիս օգտատերերին ընտրել պատկերների ռեսուրսի հավելված:"

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Ավտոմատ կերպով ավելացնում է լրացուցիչ ձևավորումներ ձեր մեդիա գրադարանների մեդիա ֆայլերի համար:"

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Երգերի տեքստեր երաժշտության համար: Պահանջվում է անիմացիոն տեքստերը միացնելու համար:"

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Համաժամեցնել ձեր հավաքածուն և դիտված լինելու կարգավիճակը trakt.tv-ի հետ:"

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Ստեղծել անհատական էջանշան ընտրված kodi էջանշաններից:"

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Խմբագրել գլխավոր էկրանի մենյուն, վիդջեթները, ֆոները և տեղեկատվական տողերը:"

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Վերակայել գլխավոր էկրանի մենյուն, վիդջեթները, ֆոները և տեղեկատվական տողերը լռելյայն արժեքներին:"

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Ստեղծել անհատական էջանշան ընտրված kodi էջանշաններից՝ գլխավոր մենյուի վիդջեթներում օգտագործելու համար: Պահանջում է տեղադրված script favourites:"

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Ստեղծել անհատական հավելվածի էջանշան տեղադրված հավելվածներից՝ գլխավոր մենյուի վիդջեթներում օգտագործելու համար:"

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Վերակայել կազմի թեման և գույները լռելյայն արժեքներին:"

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Ընտրել նախապես սահմանված թեմաների ցուցակից:"

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Արգելափակել նախապատվությունները՝ տեսքի ռեժիմը, տեսքի տարբերակները, տեղեկատվական պատուհանը և լիաէկրան կարգավորումներն անջատելու համար:"

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Անհատականացնել գլխավոր էկրանը, էջանշանները, նախապես սահմանված թեմաները և կրպակի ռեժիմը:"

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Փոխել կազմի թեմայի տեքստուրաները:"

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Անհատականացնել կազմի տեքստուրայի գույները:"

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Անհատականացնել ֆոնը և պահուստային տարբերակները կազմի կոնկրետ տարածքների համար:"

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Միացնել կամ անջատել կազմի տարբեր գործառույթներ:"

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Անհատականացնել ձևավորումը և տեղադրել աջակցվող ձևավորման փաթեթներ:"

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Տեղադրել և կարգավորել աջակցվող հավելվածները:"

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Միացնել և անջատել գրադարանի տեսքերը: Թույլ բնութագրերով համակարգերում գրադարանի տեսքերն անջատելը կարող է բարելավել արտադրողականությունը:"

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Ցուցադրում է թերթման տառը գրադարանի տեսքերում թերթելիս:"

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Ցուցադրում է այբուբենը՝ կոնտեյների դիրքին անցնելու համար: Կաշխատի միայն լռելյայն տեսակավորման եղանակների դեպքում (A-Z):"

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Ցուցադրում է հեռուստաշոուների և ֆիլմերի սյուժեի համառոտագիրը, եթե այն հասանելի է, հակառակ դեպքում կցուցադրվի լռելյայն սյուժեն:"

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Ավտոմատ կերպով թերթել սյուժեն, եթե այն չի տեղավորվում կառավարման տարրի չափսերում:"

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Միացնել արագ հասանելիության մենյուն կազմի կոնկրետ տարածքներ անմիջապես անցնելու համար: Մեդիա մենյուում սեղմեք ձախ՝ բացելու համար, կամ սեղմեք արագ հասանելիության պատկերակի վրա:"

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Խմբագրել արագ հասանելիության մենյուն:"

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Միացնել և անջատել վերին վահանակի տարրերը:"

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Փոխել տեսանյութի տեղեկությունների կարգավորումները:"

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Փոխել երաժշտության տեղեկությունների կարգավորումները:"

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Փոխել լիաէկրան տեսանյութի կարգավորումները:"

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Փոխել լիաէկրան աուդիոյի կարգավորումները:"

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Փոքրացնել ծագող ծանուցումների չափսը:"

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Մթնեցնում է էկրանը երկխոսության պատուհանների հետևում: Չի կիրառվում լիաէկրան տեսանյութի կամ աուդիոյի դեպքում:"

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Միացնել գունավոր պատկերակները վերին վահանակի, մեդիա տեղեկությունների և գրադարանի տեսքերի համար:"

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Միացնել գունավոր, HDR, գույնի խորության (bit depth) և լեզվի մեդիա դրոշները:"

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Աուդիո CD սկավառակի ձևավորման պահուստային տարբերակ ամբողջ կազմի համար:"

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Տեսանյութի CD սկավառակի ձևավորման պահուստային տարբերակ ամբողջ կազմի համար:"

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Ընտրել և տեղադրել եղանակի պատկերակների փաթեթ վերին վահանակի, վիդջեթների և եղանակի համար:"

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Ընտրել և տեղադրել եղանակի ֆան-արտի փաթեթ ֆոների, վիդջեթների և եղանակի համար:"

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Տեղադրել ստուդիաների սպիտակ պատկերակներ ամբողջ կազմում օգտագործելու համար:"

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Տեղադրել ստուդիաների գունավոր պատկերակներ ամբողջ կազմում օգտագործելու համար:"

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Տեղադրել ձայնագրման լեյբլների պատկերակներ ամբողջ կազմում օգտագործելու համար:"

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Տեղադրել լեզուների դրոշներ գրադարանի տեսքերի և ենթագրերի ընտրության համար:"

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Տեղադրել երաժշտության ժանրերի պատկերակներ երաժշտության և երաժշտական տեսահոլովակների համար:"

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Տեղադրել ֆիլմերի գունավոր ժանրերի պատկերակներ ֆիլմերի և հեռուստաշոուների համար:"

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Տեղադրել ֆիլմերի սև-սպիտակ ժանրերի պատկերակներ ֆիլմերի և հեռուստաշոուների համար:"

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Տեղադրել երկրների պատկերակներ ֆիլմերի երկրների հանգույցի համար:"

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Սահմանել ֆան-արտերի անցումների միջև ուշացումը ամբողջ կազմում:"

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Թափվող ֆոնային էֆեկտներ՝ ձյուն, տերևներ և այլն:"

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Ցուցադրել այժմ նվագարկվող երաժշտության ֆան-արտը ամբողջ կազմում: Գերակայում է գրադարանի ֆան-արտին:"

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Միացնում է երաժշտության վիզուալիզացիան ֆոնին՝ երաժշտություն նվագարկելիս: Պահաննջվում է, որ վիզուալիզացիան միացված լինի Կարգավորումներ - Նվագարկչի կարգավորումներ/Երաժշտություն բաժնում:"

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Ցուցադրել այժմ նվագարկվող տեսանյութը ֆոնին գրադարանը թերթելիս: Գերակայում է գրադարանի ֆան-արտին:"

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Ներբեռնել պատկերներ և լրացուցիչ տեղեկություններ fanart.tv-ից և theaudiodb.com-ից այժմ նվագարկվող կատարողի համար: Լիաէկրան երաժշտության, ինտերնետային հոսքերի և ռադիոյի համար:"

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Կատարողի սլայդշոուի սկրիպտի կարգավորումներ:"

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "Արագ անցում դեպի տեսանյութերի նվագացանկ, եթե այն դատարկ չէ:"

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "Արագ անցում դեպի երաժշտության նվագացանկ, եթե այն դատարկ չէ:"

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Արագ անցում դեպի լիաէկրան ռեժիմ, երբ մեդիան նվագարկվում է:"

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Սեղմեք՝ արագ հասանելիության մենյուն բացելու համար:"

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Նվագարկչի կառավարում, երբ մեդիան նվագարկվում է:"

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Ավտոմատ կերպով նվագարկել հեռուստաշոուի հաջորդ էպիզոդը:"

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Նվագարկել թեմատիկ երաժշտությունը հեռուստաշոուներով, ֆիլմերով և երաժշտական տեսահոլովակներով նավարկելիս:"

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "Գրադարանի հանգույցների խմբագրիչը թույլ է տալիս ստեղծել և անհատականացնել անհատական տեսահանգույցներ և երաժշտական հանգույցներ Kodi-ում:"

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Ցուցադրել վրադիր նշիչի տեղեկությունները դիտված, չդիտված և ընթացքի մեջ գտնվող մեդիա տարրերի համար:"

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Սկրիպտ Kodi-ի ներկառուցված RSS տողը խմբագրելու համար:"

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Կազմի տարբերակը և վերականգնման տարբերակները: Վերականգնում է բոլոր լռելյայնները առաջին օրվա աշխատանքային վիճակին:"

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Հավելվածներ"