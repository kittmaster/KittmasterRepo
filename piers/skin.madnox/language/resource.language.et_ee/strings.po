msgctxt "#31567"
msgid "Highlight a logo from the palette below and click to assign it to 4K / UHD video files."
msgstr "Märgi allolevast paletist logo ja klõpsa selle määramiseks 4K / UHD videofailidele."

#: /16x9/includes.xml
msgctxt "#31568"
msgid "Highlight a logo from the palette below and click to assign it to WebDL and streaming video sources."
msgstr "Märgi allolevast paletist logo ja klõpsa selle määramiseks WebDL ja voogedastuse videoallikatele."

#: /16x9/includes.xml
msgctxt "#31569"
msgid "Highlight a logo from the palette below and click to assign it to 1080p Full HD video files."
msgstr "Märgi allolevast paletist logo ja klõpsa selle määramiseks 1080p Full HD videofailidele."

#: /16x9/includes.xml
msgctxt "#31570"
msgid "Highlight a logo from the palette below and click to assign it to 720p HD video files."
msgstr "Märgi allolevast paletist logo ja klõpsa selle määramiseks 720p HD videofailidele."

#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "Märgi allolevast paletist logo ja klõpsa selle määramiseks DVD ja standardlahutusega videofailidele."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "Kuva paletivõrgus ainult ultra-kõrglahutusega ja 4K logo kujundusi."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "Kuva paletivõrgus ainult HEVC ja H.265 koodeki logo kujundusi."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Kuva paletivõrgus ainult AVC ja H.264 koodeki logo kujundusi."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Kuva paletivõrgus ainult DivX, XviD ja vanemate MPEG-4 vormingute logo kujundusi."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Kuva paletivõrgus klassikalisi MPEG, DVD ja tavaliste telesaadete logo kujundusi."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Kuva paletivõrgus Windows Media Video ja VC-1 koodeki logo kujundusi."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Kuva paletivõrgus konteinereid, kettaformaate ja muid mitmesuguseid logokujundusi."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Sule see lipu kohandamise dialoog ja naase seadetesse."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Märgi keskmises võrgus suvaline logokujundus ja klõpsa selle salvestamiseks aktiivse kategooria kohandatud lipuna."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Eemalda oma kohandatud lipu valik ja taasta sellele kategooriale kujunduse automaatne vaikimisi loogika."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Lülita globaalse lipu kujundust värvilise ja monokroomse vaikimisi valge vahel."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Kasuta valikute navigeerimiseks nooleklahve. Vajuta tagasi-nuppu või vali väljumine igal ajal, et sulgeda ilma muudatusteta."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Vali muutmiseks"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Avakuva, vidinate ja otseteede menüü kohandamine."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Skript kujundajatele, mis võimaldab kasutajatel valida pildiressursside lisa."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Lisab automaatselt täiendavat pildimaterjali sinu meediateekides olevatele failidele."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Muusika laulusõnad. Vajalik animeeritud laulusõnade lubamiseks."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Sünkrooni oma kogu ja vaatamisolek veebilehega trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Loo kohandatud lemmik valitud Kodi lemmikutest."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Muuda avakuva menüüd, vidinaid, taustapilte ja inforidu."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Lähtesta avakuva menüü, vidinad, taustad ja inforoad vaikeseadetele."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Loo valitud Kodi lemmikutest kohandatud lemmik. Kasutamiseks peamenüü vidinates. Nõuab lemmikute skripti installimist."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Loo paigaldatud lisadest kohandatud lisalemmik. Kasutamiseks peamenüü vidinates."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Lähtesta kujunduse teema ja värvid vaikeseadetele."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Vali eelnevalt määratletud teemade loendist."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Lukusta eelistused, et keelata vaaterežiim, vaatevalikud, infodialoog ja täisekraani seaded."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Kohanda avakuva, lemmikuid, eelmääratletud teemasid ja kioski režiimi."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Muuda kujunduse teema tekstuure."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Kohanda kujunduse tekstuuride värve."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Kohanda taustasid ja asendusvariante konkreetsetes kujunduse piirkondades."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Luba või keela erinevad kujunduse funktsioonid."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Kohanda pildimaterjali ja installi toetatud kunstipakid."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Paigalda ja konfigureeri toetatud lisad."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Luba ja keela andmekogu vaated. Andmekogu vaadete keelamine nõrgema jõudlusega süsteemides võib parandada toimimist."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Näitab andmekogu vaadete kerimisel kerimistähte."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Näitab tähestikku, et hüpata konteineri soovitud positsiooni. Toimib ainult vaikimisi sorteerimismeetodite puhul (A-Z)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Kuvab sarjade ja filmide sisututvustuse lühikokkuvõtte (kui on saadaval), vastasel juhul kuvatakse vaikimisi sisututvustus."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Keri sisututvustust automaatselt, kui see ei mahu akna mõõtmetesse."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Luba otseteede menüü vahetuks juurdepääsuks konkreetsetele kujunduse osadele. Meediamenüüs klõpsa avamiseks vasakule või otsetee ikoonile."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Muuda otseteede menüüd."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Luba ja keela ülariba elemendid."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Muuda videoteabe seadeid."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Muuda muusikateabe seadeid."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Muuda täisekraanil video seadeid."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Muuda täisekraanil heli seadeid."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Vähenda hüpikteavituste suurust."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Tumendab ekraani dialoogakende taga. Ei kehti täisekraanil video või heli puhul."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Luba värvilised ikoonid ülaribal, meediateabes ja andmekogu vaadetes."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Luba värvilised, HDR, bittide sügavuse ja keele meedialipud."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Audio-CD plaadipildi asendusvariant kogu kujunduse ulatuses."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Video-CD plaadipildi asendusvariant kogu kujunduse ulatuses."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Vali ja installi ilmaikoonide pakk ülariba, vidinate ja ilma jaoks."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Vali ja installi ilmataustade pakk taustade, vidinate ja ilma jaoks."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Paigalda valged stuudioikoonid kogu kujunduses kasutamiseks."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Paigalda värvilised stuudioikoonid kogu kujunduses kasutamiseks."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Paigalda plaadifirmade ikoonid kogu kujunduses kasutamiseks."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Paigalda keelelipud andmekogu vaadete ja subtiitrite valiku jaoks."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Paigalda muusikažanrite ikoonid muusika ja muusikavideote jaoks."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Paigalda värvilised filmižanrite ikoonid filmide ja sarjade jaoks."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Paigalda mustvalged filmižanrite ikoonid filmide ja sarjade jaoks."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Paigalda riikide ikoonid filmide riigi sõlme jaoks."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Määra fännipiltide vaheldumise viivitus kogu kujunduse ulatuses."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Langevad taustajõud/efektid. Lumi, lehed jne."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Näita parajasti esitatava üksuse muusika fännipilti kogu kujunduse ulatuses. Kirjutab üle andmekogu fännipildi."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Lubab muusika esitamise ajal taustal muusika visualiseerimise. Nõuab visualiseerimise lubamist seadetes: Mängija seaded -> Muusika."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Näita parajasti esitatavat videot taustal andmekogu sirvimise ajal. Kirjutab üle andmekogu fännipildi."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Laadi alla parajasti esitatava esitaja pildid ja täiendav teave saitidelt fanart.tv ja theaudiodb.com. Täisekraanil muusika, internetivoogude ja raadio jaoks."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Esitaja slaidiseansi skripti seaded."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "Otsetee video esitusloendisse, kui see pole tühi."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "Otsetee muusika esitusloendisse, kui see pole tühi."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Otsetee täisekraanile, kui meediat esitatakse."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Klõpsa otseteede menüü avamiseks."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Mängija juhtnupud meedia esitamise ajal."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Esita järgmine sarja episood automaatselt."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Esita tunnusmuusikat sarjade, filmide ja muusikavideote sirvimise ajal."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "Andmekogu sõlmede redaktor võimaldab luua ja kohandada kohandatud video- ja muusikasõlmi Kodis."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Näita kattemärgise teavet vaadatud, vaatamata ja pooleli olevate meediaüksuste kohta."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Skript Kodi sisseehitatud RSS-uudisteriba muutmiseks."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Kujunduse versioon ja taastevalikud. Taastab kõik algseaded esimese päeva olekusse."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Lisad"