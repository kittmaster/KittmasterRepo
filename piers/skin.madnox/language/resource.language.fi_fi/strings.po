msgstr "Mukauta 720p-lippu:"

#: /16x9/includes.xml
msgctxt "#31563"
msgid "Customise DVD / SD flag:"
msgstr "Mukauta DVD / SD -lippu:"

#: /16x9/includes.xml
msgctxt "#31564"
msgid "Category filter:"
msgstr "Kategoriasuodatin:"

#: /16x9/includes.xml
msgctxt "#31565"
msgid "Restore default:"
msgstr "Palauta oletus:"

#: /16x9/includes.xml
msgctxt "#31566"
msgid "Toggle Color Scheme:"
msgstr "Vaihda väriteemaa:"

# --- Body texts: top row category selectors (controls 901–904, 905) ---

#: /16x9/includes.xml
msgctxt "#31567"
msgid "Highlight a logo from the palette below and click to assign it to 4K / UHD video files."
msgstr "Korosta logo alla olevasta paletista ja napsauta määrittääksesi sen 4K / UHD -videotiedostoille."

#: /16x9/includes.xml
msgctxt "#31568"
msgid "Highlight a logo from the palette below and click to assign it to WebDL and streaming video sources."
msgstr "Korosta logo alla olevasta paletista ja napsauta määrittääksesi sen WebDL- ja suoratoistovideolähteille."

#: /16x9/includes.xml
msgctxt "#31569"
msgid "Highlight a logo from the palette below and click to assign it to 1080p Full HD video files."
msgstr "Korosta logo alla olevasta paletista ja napsauta määrittääksesi sen 1080p Full HD -videotiedostoille."

#: /16x9/includes.xml
msgctxt "#31570"
msgid "Highlight a logo from the palette below and click to assign it to 720p HD video files."
msgstr "Korosta logo alla olevasta paletista ja napsauta määrittääksesi sen 720p HD -videotiedostoille."

#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "Korosta logo alla olevasta paletista ja napsauta määrittääksesi sen DVD- ja standardipiirron videotiedostoille."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "Näytä vain ultra-high-definition- ja 4K-logomallit palettiruudukossa."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "Näytä vain HEVC- ja H.265-koodekkien logomallit palettiruudukossa."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Näytä vain AVC- ja H.264-koodekkien logomallit palettiruudukossa."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Näytä vain DivX-, XviD- ja vanhojen MPEG-4-formaattien logomallit palettiruudukossa."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Näytä perinteiset MPEG-, DVD- ja tavallisten TV-lähetysten logomallit palettiruudukossa."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Näytä Windows Media Video- ja VC-1-koodekkien logomallit palettiruudukossa."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Näytä säiliömuotojen, levymuotojen ja muiden erilaisten logomallien kuvakkeet palettiruudukossa."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Sulje tämä lippujen mukautusikkuna ja palaa asetuksiin."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Korosta mikä tahansa logomalli keskimmäisessä ruudukossa ja napsauta tallentaaksesi sen mukautetuksi lipuksesi aktiivisessa kategoriassa."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Tyhjennä mukautettu lippuvalintasi ja palauta tämä kategoria ulkoasun automaattiseen oletuslippulogiikkaan."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Vaihda yleinen lippukuvitus värillisten mallien ja yksivärisen oletusvalkoisen välillä."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Käytä suuntapainikkeita asetuksissa liikkumiseen. Paina Takaisin tai valitse Poistu milloin tahansa sulkeaksesi ilman muutoksia."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Valitse muokataksesi"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Aloitusnäytön, widgetien ja pikavalikon mukauttaminen."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Skripti ulkoasun tekijöille, jotta käyttäjät voivat valita kuvaresurssien lisäosan."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Lisää automaattisesti ylimääräistä kuvitusta mediakirjastojesi mediatiedostoille."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Musiikin sanoitukset. Vaaditaan animoitujen sanoitusten käyttöönottoon."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Synkronoi kokoelmasi ja katselutilasi trakt.tv-palvelun kanssa."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Luo mukautettu suosikki valituista Kodin suosikeista."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Muokkaa aloitusnäytön valikkoa, widgetejä, taustoja ja inforivejä."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Palauta aloitusnäytön valikko, widgetit, taustat ja inforivit oletusasetuksiin."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Luo mukautettu suosikki valituista Kodin suosikeista päävalikon widgeteissä käytettäväksi. Vaatii suosikit-skriptin asennuksen."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Luo mukautettu suosikkilisäosa asennetuista lisäosista päävalikon widgeteissä käytettäväksi."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Palauta ulkoasun teema ja värit oletusarvoisiksi."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Valitse ennalta määritettyjen teemojen luettelosta."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Lukitse mieltymykset poistaaksesi näkymätilan, näkymäasetukset, tietoikkunan ja koko näytön asetukset käytöstä."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Mukauta aloitusnäyttöä, suosikkeja, ennalta määritettyjä teemoja ja kioskitiilaa."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Muuta ulkoasun teeman tekstuureja."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Mukauta ulkoasun tekstuurivärejä."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Mukauta taustaa ja korvaavia taustoja tietyille ulkoasun alueille."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Ota käyttöön tai poista käytöstä useita ulkoasun toimintoja."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Mukauta kuvitusta ja asenna tuettuja kuvituspaketteja."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Asenna ja määritä tuettuja lisäosia."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Ota käyttöön ja poista käytöstä kirjastonäkymiä. Kirjastonäkymien poistaminen käytöstä vähätehoisissa järjestelmissä saattaa parantaa suorituskykyä."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Näyttää selauskirjaimen kirjastonäkymiä selattaessa."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Näyttää aakkoset siirtyäksesi tiettyyn kohtaan säiliössä. Toimii vain oletusarvoisilla lajittelumenetelmillä (A-Ö)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Näyttää sarjojen ja elokuvien juonen lyhennelmän, jos se on saatavilla, muussa tapauksessa näytetään oletusjuoni."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Selaa juonikuvausta automaattisesti, jos se ei mahdu sille varattuun tilaan."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Ota käyttöön pikavalikko nopeaa pääsyä varten tietyille ulkoasun alueille. Paina vasemmalle mediavalikossa avataksesi sen tai napsauta pikavalikkokuvaketta."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Muokkaa pikavalikkoa."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Ota käyttöön ja poista käytöstä yläpalkin elementtejä."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Muuta videon tietojen asetuksia."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Muuta musiikin tietojen asetuksia."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Muuta koko näytön videon asetuksia."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Muuta koko näytön äänen asetuksia."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Pienennä ponnahdusikkunailmoitusten kokoa."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Himmennä näytön valintaikkunoiden takana. Ei koske koko näytön videota tai ääntä."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Ota käyttöön värilliset kuvakkeet yläpalkissa, mediatiedoissa ja kirjastonäkymissä."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Ota käyttöön värilliset, HDR-, bittisyvyys- ja kielimedialiput."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Äänen CD-levykuvan korvike koko ulkoasussa."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Videon CD-levykuvan korvike koko ulkoasussa."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Valitse ja asenna sääkuvakepaketti yläpalkille, widgeteille ja säälle."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Valitse ja asenna sääfanitaidepaketti taustoille, widgeteille ja säälle."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Asenna valkoiset studiokuvakkeet käytettäväksi koko ulkoasussa."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Asenna värilliset studiokuvakkeet käytettäväksi koko ulkoasussa."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Asenna levy-yhtiökuvakkeet käytettäväksi koko ulkoasussa."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Asenna kieliliput kirjastonäkymiä ja tekstityksen valintaa varten."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Asenna musiikin tyylilajikuvakkeet musiikille ja musiikkivideoille."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Asenna värilliset elokuvien tyylilajikuvakkeet elokuville ja sarjoille."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Asenna mustavalkoiset elokuvien tyylilajikuvakkeet elokuville ja sarjoille."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Asenna maakuvakkeet elokuvien maasolmua varten."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Määritä viive fanitaiteen vaihtumiselle koko ulkoasussa."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Putoavat taustatehosteet. Lumi, lehdet jne."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Näytä parhaillaan toistettavan kohteen musiikkifanitaide koko ulkoasussa. Ohittaa kirjaston fanitaiteen."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Ottaa käyttöön musiikin visualisoinnin taustalla musiikkia toistettaessa. Vaatii visualisoinnin olevan käytössä kohdassa Asetukset - Soittimen asetukset/Musiikki."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Näytä parhaillaan toistettava video taustalla kirjastoa selattaessa. Ohittaa kirjaston fanitaiteen."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Lataa kuvia ja lisätietoja fanart.tv- ja theaudiodb.com-palveluista parhaillaan toistettavalta artistilta. Koko näytön musiikille, internet-striimeille ja radiolle."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Artistin diaesityksen skriptiasetukset."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "Pikakuvake videosoittolistaan, jos se ei ole tyhjä."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "Pikakuvake musiikkisoittolistaan, jos se ei ole tyhjä."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Pikakuvake koko näyttöön median toiston aikana."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Napsauta avataksesi pikavalikon."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Soittimen ohjaimet median toiston aikana."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Toista sarjan seuraava jakso automaattisesti."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Toista teemamusiikkia selattaessa sarjoja, elokuvia ja musiikkivideoita."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "Kirjastosolmujen muokkain (Library Node Editor) sallii mukautettujen videosolmujen ja musiikkisolmujen luomisen ja muokkaamisen Kodissa."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Näytä katselutilan merkit katsotuille, katsomattomille ja käynnissä oleville mediakohteille."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Skripti Kodin sisäänrakennetun RSS-uutisnauhan muokkaamiseen."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Ulkoasun versio ja palautusasetukset. Palauttaa kaikki oletukset alkuperäiseen tilaan."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Lisäosat"