# --- Body texts: top row category selectors (controls 901–904, 905) ---

#: /16x9/includes.xml
msgctxt "#31567"
msgid "Highlight a logo from the palette below and click to assign it to 4K / UHD video files."
msgstr "Επισημάνετε ένα λογότυπο από την παρακάτω παλέτα και κάντε κλικ για να το αντιστοιχίσετε σε αρχεία βίντεο 4K / UHD."

#: /16x9/includes.xml
msgctxt "#31568"
msgid "Highlight a logo from the palette below and click to assign it to WebDL and streaming video sources."
msgstr "Επισημάνετε ένα λογότυπο από την παρακάτω παλέτα και κάντε κλικ για να το αντιστοιχίσετε σε πηγές βίντεο WebDL και ροής."

#: /16x9/includes.xml
msgctxt "#31569"
msgid "Highlight a logo from the palette below and click to assign it to 1080p Full HD video files."
msgstr "Επισημάνετε ένα λογότυπο από την παρακάτω παλέτα και κάντε κλικ για να το αντιστοιχίσετε σε αρχεία βίντεο Full HD 1080p."

#: /16x9/includes.xml
msgctxt "#31570"
msgid "Highlight a logo from the palette below and click to assign it to 720p HD video files."
msgstr "Επισημάνετε ένα λογότυπο από την παρακάτω παλέτα και κάντε κλικ για να το αντιστοιχίσετε σε αρχεία βίντεο HD 720p."

#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "Επισημάνετε ένα λογότυπο από την παρακάτω παλέτα και κάντε κλικ για να το αντιστοιχίσετε σε αρχεία βίντεο DVD και τυπικής ευκρίνειας (SD)."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "Εμφάνιση μόνο σχεδίων λογότυπων εξαιρετικά υψηλής ευκρίνειας και 4K στο πλέγμα της παλέτας."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "Εμφάνιση μόνο σχεδίων λογότυπων κωδικοποιητή HEVC και H.265 στο πλέγμα της παλέτας."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Εμφάνιση μόνο σχεδίων λογότυπων κωδικοποιητή AVC και H.264 στο πλέγμα της παλέτας."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Εμφάνιση μόνο σχεδίων λογότυπων μορφής DivX, XviD και παλαιού τύπου MPEG-4 στο πλέγμα της παλέτας."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Εμφάνιση κλασικών σχεδίων λογότυπων MPEG, DVD και τηλεοπτικής μετάδοσης στο πλέγμα της παλέτας."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Εμφάνιση σχεδίων λογότυπων κωδικοποιητή Windows Media Video και VC-1 στο πλέγμα της παλέτας."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Εμφάνιση περιεκτών, μορφών δίσκων και άλλων σχεδίων λογότυπων στο πλέγμα της παλέτας."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Κλείσιμο αυτού του παραθύρου διαλόγου προσαρμογής σημάτων και επιστροφή στις ρυθμίσεις."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Επισημάνετε οποιοδήποτε σχέδιο λογότυπου στο κεντρικό πλέγμα και κάντε κλικ για να το αποθηκεύσετε ως προσαρμοσμένο σήμα για την ενεργή κατηγορία."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Καθαρισμός της επιλογής προσαρμοσμένου σήματος και επαναφορά αυτής της κατηγορίας στην αυτόματη προεπιλεγμένη λογική σημάτων του skin."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Εναλλαγή των καθολικών γραφικών σημάτων μεταξύ έγχρωμων σχεδίων και μονόχρωμου προεπιλεγμένου λευκού."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Χρησιμοποιήστε τα πλήκτρα κατεύθυνσης για να πλοηγηθείτε στις επιλογές. Πατήστε Πίσω ή επιλέξτε Έξοδος ανά πάσα στιγμή για να κλείσετε χωρίς αλλαγές."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Επιλέξτε για τροποποίηση"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Προσαρμογή της αρχικής οθόνης, των γραφικών στοιχείων και του μενού συντομεύσεων."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Σενάριο για σχεδιαστές skin που επιτρέπει στους χρήστες να επιλέξουν ένα πρόσθετο πόρων εικόνας."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Προσθέτει αυτόματα επιπλέον γραφικά για πολυμέσα στις βιβλιοθήκες πολυμέσων σας."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Στίχοι για μουσική. Απαιτείται για την ενεργοποίηση κινουμένων στίχων."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Συγχρονισμός της συλλογής σας και της κατάστασης παρακολούθησης με το trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Δημιουργία προσαρμοσμένου αγαπημένου από επιλεγμένα αγαπημένα του kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Επεξεργασία του μενού της αρχικής οθόνης, των γραφικών στοιχείων, των φόντων και των γραμμών πληροφοριών."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Επαναφορά του μενού της αρχικής οθόνης, των γραφικών στοιχείων, των φόντων και των γραμμών πληροφοριών στις προεπιλογές."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Δημιουργία προσαρμοσμένου αγαπημένου από επιλεγμένα αγαπημένα του kodi. Για χρήση στα γραφικά στοιχεία του κύριου μενού. Απαιτείται η εγκατάσταση του σεναρίου αγαπημένων."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Δημιουργία προσαρμοσμένου αγαπημένου πρόσθετου από εγκατεστημένα πρόσθετα. Για χρήση στα γραφικά στοιχεία του κύριου μενού."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Επαναφορά του θέματος και των χρωμάτων του skin στις προεπιλογές."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Επιλογή από μια λίστα προκαθορισμένων θεμάτων."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Κλείδωμα προτιμήσεων για απενεργοποίηση της λειτουργίας προβολής, των επιλογών προβολής, του διαλόγου πληροφοριών και των ρυθμίσεων πλήρους οθόνης."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Προσαρμογή της αρχικής οθόνης, των αγαπημένων, των προκαθορισμένων θεμάτων και της λειτουργίας περιπτέρου."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Αλλαγή υφών θέματος του skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Προσαρμογή των χρωμάτων υφής του skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Προσαρμογή του φόντου και των εναλλακτικών για συγκεκριμένες περιοχές του skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Ενεργοποίηση ή απενεργοποίηση διαφόρων λειτουργιών του skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Προσαρμογή γραφικών και εγκατάσταση υποστηριζόμενων πακέτων γραφικών."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Εγκατάσταση και διαμόρφωση υποστηριζόμενων πρόσθετων."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Ενεργοποίηση και απενεργοποίηση προβολών βιβλιοθήκης. Η απενεργοποίηση των προβολών βιβλιοθήκης σε συστήματα χαμηλών προδιαγραφών μπορεί να βελτιώσει την απόδοση."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Εμφανίζει το γράμμα κύλισης κατά την κύλιση σε προβολές βιβλιοθήκης."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Εμφανίζει το αλφάβητο για μετάβαση σε μια θέση του περιέκτη. Λειτουργεί μόνο για τις προεπιλεγμένες μεθόδους ταξινόμησης (Α-Ω)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Εμφανίζει το περίγραμμα της υπόθεσης για τηλεοπτικές εκπομπές και ταινίες εάν είναι διαθέσιμο, διαφορετικά θα εμφανίζει την προεπιλεγμένη υπόθεση."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Αυτόματη κύλιση της υπόθεσης εάν δεν χωράει στις διαστάσεις του στοιχείου ελέγχου."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Ενεργοποιήστε το μενού συντομεύσεων για άμεση πρόσβαση σε συγκεκριμένες περιοχές του skin. Στο μενού πολυμέσων κάντε κλικ αριστερά για να ανοίξει ή κάντε κλικ στο εικονίδιο συντόμευσης."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Επεξεργασία του μενού συντομεύσεων."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Ενεργοποίηση και απενεργοποίηση των στοιχείων της επάνω γραμμής."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Αλλαγή ρυθμίσεων πληροφοριών βίντεο."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Αλλαγή ρυθμίσεων πληροφοριών μουσικής."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Αλλαγή ρυθμίσεων βίντεο πλήρους οθόνης."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Αλλαγή ρυθμίσεων ήχου πλήρους οθόνης."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Μείωση του μεγέθους των αναδυόμενων ειδοποιήσεων."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Σκουραίνει την οθόνη πίσω από τα αναδυόμενα παράθυρα διαλόγου. Δεν ισχύει για βίντεο ή ήχο πλήρους οθόνης."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Ενεργοποίηση έγχρωμων εικονιδίων για την επάνω γραμμή, τις πληροφορίες πολυμέσων και τις προβολές βιβλιοθήκης."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Ενεργοποίηση έγχρωμων σημάτων πολυμέσων, HDR, βάθους bit και γλώσσας."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Εναλλακτικό cd art ήχου σε όλο το skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Εναλλακτικό cd art βίντεο σε όλο το skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Επιλογή και εγκατάσταση πακέτου εικονιδίων καιρού για την επάνω γραμμή, τα γραφικά στοιχεία και τον καιρό."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Επιλογή και εγκατάσταση πακέτου fanart καιρού για τα φόντα, τα γραφικά στοιχεία και τον καιρό."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Εγκατάσταση λευκών εικονιδίων στούντιο για χρήση σε όλο το skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Εγκατάσταση έγχρωμων εικονιδίων στούντιο για χρήση σε όλο το skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Εγκατάσταση εικονιδίων δισκογραφικών εταιρειών για χρήση σε όλο το skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Εγκατάσταση σημαιών γλωσσών για προβολές βιβλιοθήκης και επιλογή υποτίτλων."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Εγκατάσταση εικονιδίων ειδών μουσικής για μουσική και μουσικά βίντεο."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Εγκατάσταση έγχρωμων εικονιδίων ειδών ταινιών για ταινίες και τηλεοπτικές εκπομπές."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Εγκατάσταση ασπρόμαυρων εικονιδίων ειδών ταινιών για ταινίες και τηλεοπτικές εκπομπές."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Εγκατάσταση εικονιδίων χωρών για τον κόμβο χωρών ταινιών."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Ορισμός της καθυστέρησης μεταξύ των μεταβάσεων fanart σε όλο το skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Εφέ φόντου που πέφτει. Χιόνι, Φύλλα κ.λπ."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Εμφάνιση fanart μουσικής του τρέχοντος αναπαραγόμενου στοιχείου σε όλο το skin. Υπερισχύει του fanart βιβλιοθήκης."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Ενεργοποιεί την οπτικοποίηση μουσικής στο φόντο κατά την αναπαραγωγής μουσικής. Απαιτείται η ενεργοποίηση της οπτικοποίησης στις ρυθμίσεις - Ρυθμίσεις αναπαραγωγέα/Μουσική."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Εμφάνιση του τρέχοντος αναπαραγόμενου βίντεο στο φόντο κατά την περιήγηση στη βιβλιοθήκη. Υπερισχύει του fanart βιβλιοθήκης."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Λήψη εικόνων και πρόσθετων πληροφοριών από το fanart.tv και το theaudiodb.com για τον τρέχοντα αναπαραγόμενο καλλιτέχνη. Για μουσική πλήρους οθόνης, ροές διαδικτύου και ραδιόφωνο."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Ρυθμίσεις σεναρίου παρουσίασης καλλιτέχνη."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "Μια συντόμευση για τη λίστα αναπαραγωγής βίντεο εάν δεν είναι κενή."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "Μια συντόμευση για τη λίστα αναπαραγωγής μουσικής εάν δεν είναι κενή."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Συντόμευση για πλήρη οθόνη κατά την αναπαραγωγή πολυμέσων."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Κάντε κλικ για να ανοίξετε το μενού συντομεύσεων."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Στοιχεία ελέγχου αναπαραγωγέα κατά την αναπαραγωγή πολυμέσων."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Αυτόματη αναπαραγωγή του επόμενου επεισοδίου τηλεοπτικής εκπομπής."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Αναπαραγωγή θεμάτων (soundtracks) κατά την πλοήγηση σε Τηλεοπτικές Εκπομπές, Ταινίες και Μουσικά Βίντεο."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "Ο Επεξεργαστής Κόμβων Βιβλιοθήκης σάς επιτρέπει να δημιουργείτε και να προσαρμόζετε προσαρμοσμένους κόμβους βίντεο και μουσικής στο Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Εμφάνιση πληροφοριών δείκτη επικάλυψης για παρακολουθημένα, μη παρακολουθημένα και σε εξέλιξη στοιχεία πολυμέσων."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Ένα σενάριο για την επεξεργασία του ενσωματωμένου RSS Ticker του Kodi."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Έκδοση skin και επιλογές ανάκτησης. Επαναφέρει όλες τις προεπιλογές στην κατάσταση της πρώτης ημέρας λειτουργίας."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Πρόσθετα"