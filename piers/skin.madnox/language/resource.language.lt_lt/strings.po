# --- Body texts: top row category selectors (controls 901–904, 905) ---

#: /16x9/includes.xml
msgctxt "#31567"
msgid "Highlight a logo from the palette below and click to assign it to 4K / UHD video files."
msgstr "Pažymėkite logotipą iš žemiau esančios paletės ir spustelėkite, kad priskirtumėte jį 4K / UHD vaizdo failams."

#: /16x9/includes.xml
msgctxt "#31568"
msgid "Highlight a logo from the palette below and click to assign it to WebDL and streaming video sources."
msgstr "Pažymėkite logotipą iš žemiau esančios paletės ir spustelėkite, kad priskirtumėte jį WebDL ir transliacijų vaizdo šaltiniams."

#: /16x9/includes.xml
msgctxt "#31569"
msgid "Highlight a logo from the palette below and click to assign it to 1080p Full HD video files."
msgstr "Pažymėkite logotipą iš žemiau esančios paletės ir spustelėkite, kad priskirtumėte jį 1080p Full HD vaizdo failams."

#: /16x9/includes.xml
msgctxt "#31570"
msgid "Highlight a logo from the palette below and click to assign it to 720p HD video files."
msgstr "Pažymėkite logotipą iš žemiau esančios paletės ir spustelėkite, kad priskirtumėte jį 720p HD vaizdo failams."

#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "Pažymėkite logotipą iš žemiau esančios paletės ir spustelėkite, kad priskirtumėte jį DVD ir standartinės raiškos vaizdo failams."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "Rodyti tik itin didelės raiškos ir 4K logotipų dizainus paletės tinklelyje."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "Rodyti tik HEVC ir H.265 kodekų logotipų dizainus paletės tinklelyje."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Rodyti tik AVC ir H.264 kodekų logotipų dizainus paletės tinklelyje."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Rodyti tik DivX, XviD ir senesnių MPEG-4 formatų logotipų dizainus paletės tinklelyje."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Rodyti klasikinio MPEG, DVD ir standartinių TV transliacijų logotipų dizainus paletės tinklelyje."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Rodyti „Windows Media Video“ ir VC-1 kodekų logotipų dizainus paletės tinklelyje."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Rodyti talpyklų pakuotes, diskų formatus ir kitus įvairius logotipų dizainus paletės tinklelyje."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Uždaryti šį žymų pritaikymo dialogą ir grįžti į nustatymus."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Pažymėkite bet kurį logotipo dizainą centriniame tinklelyje ir spustelėkite, kad išsaugotumėte jį kaip pasirinktinę žymą aktyviai kategorijai."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Išvalyti pasirinktinės žymos pasirinkimą ir atkurti šią kategoriją pagal temos numatytąją automatinę žymų logiką."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Perjungti visuotinių žymų išvaizdą tarp spalvotų dizainų ir vienspalvės baltos spalvos."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Naudokite krypties klavišus parinkčių navigacijai. Bet kada paspauskite „Atgal“ arba pasirinkite „Išeiti“, kad uždarytumėte be pakeitimų."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Pasirinkite, kad pakeistumėte"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Pagrindinio ekrano, valdiklių ir nuorodų meniu pritaikymas."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Scenarijus temos kūrėjams, leidžiantis vartotojams pasirinkti vaizdų išteklių priedą."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Automatiškai prideda papildomus meno kūrinius jūsų medijos bibliotekose esančiai medijai."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Muzikos dainų tekstai. Reikalinga, kad būtų galima įjungti animuotus dainų tekstus."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Sinchronizuokite savo kolekciją ir peržiūrėjimo būseną su trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Sukurti pasirinktinį mėgstamiausią iš pasirinktų „Kodi“ mėgstamiausių."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Redaguoti pagrindinio ekrano meniu, valdiklius, fonus ir informacines eilutes."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Atkurti pagrindinio ekrano meniu, valdiklius, fonus ir informacines eilutes į numatytuosius nustatymus."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Sukurti pasirinktinį mėgstamiausią iš pasirinktų „Kodi“ mėgstamiausių, skirtą naudoti pagrindinio meniu valdikliuose. Reikia, kad būtų įdiegtas „Favourites“ skriptas."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Sukurti pasirinktinį mėgstamiausią priedą iš įdiegtų priedų, skirtą naudoti pagrindinio meniu valdikliuose."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Atkurti temos dizainą ir spalvas į numatytąsias."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Pasirinkti iš iš anksto nustatytų temų sąrašo."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Užrakinti nuostatas, kad būtų išjungtas rodinio režimas, rodymo parinktys, informacijos langas ir viso ekrano nustatymai."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Pritaikyti pagrindinį ekraną, mėgstamiausius, iš anksto nustatytas temas ir kiosko režimą."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Keisti temos tekstūras."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Pritaikyti temos tekstūrų spalvas."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Pritaikyti konkrečių temos sričių foną ir atsarginius variantus."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Įjungti arba išjungti įvairias temos funkcijas."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Pritaikyti apipavidalinimą ir įdiegti palaikomus meno kūrinių paketus."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Įdiegti ir sukonfigūruoti palaikomus priedus."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Įjungti ir išjungti bibliotekos rodinius. Bibliotekos rodinių išjungimas mažos specifikacijos sistemose gali pagerinti našumą."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Rodo slinkties raidę, kai slenkama bibliotekos rodiniuose."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Rodo abėcėlę, leidžiančią greitai pereiti į atitinkamą sąrašo vietą. Veiks tik su numatytaisiais rikiavimo metodais (A-Z)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Rodo trumpą siužeto aprašymą televizijos laidoms ir filmams, jei jis prieinamas; kitu atveju bus rodomas numatytasis siužetas."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Automatiškai slinkti siužetą, jei jis netelpa į valdymo elemento matmenis."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Įjungti nuorodų meniu, kad galėtumėte greitai pasiekti tam tikras temos sritis. Medijos meniu spustelėkite kairėn, kad atidarytumėte, arba spustelėkite nuorodos piktogramą."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Redaguoti nuorodų meniu."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Įjungti ir išjungti viršutinės juostos elementus."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Keisti vaizdo įrašų informacijos nustatymus."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Keisti muzikos informacijos nustatymus."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Keisti viso ekrano vaizdo įrašų nustatymus."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Keisti viso ekrano garso nustatymus."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Sumažinti iškylančiųjų pranešimų dydį."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Pritemdo ekraną už iškylančiųjų dialogų langų. Netaikoma viso ekrano vaizdo ar garso atkūrimo metu."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Įjungti spalvotas piktogramas viršutinėje juostoje, medijos informacijoje ir bibliotekos rodiniuose."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Įjungti spalvotas, HDR, bitų gylio ir kalbos medijos žymas."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Atsarginis muzikos CD apipavidalinimas visoje temoje."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Atsarginis vaizdo įrašo disko apipavidalinimas visoje temoje."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Pasirinkti ir įdiegti orų piktogramų paketą, skirtą viršutinei juostai, valdikliams ir orų skelbimui."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Pasirinkti ir įdiegti orų fono paveikslėlių paketą, skirtą fonams, valdikliams ir orų skelbimui."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Įdiegti baltas studijų piktogramas, kurios bus naudojamos visoje temoje."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Įdiegti spalvotas studijų piktogramas, kurios bus naudojamos visoje temoje."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Įdiegti įrašų kompanijų (etiketės) piktogramas, kurios bus naudojamos visoje temoje."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Įdiegti kalbų vėliavas, skirtas bibliotekos rodiniams ir subtitrų pasirinkimui."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Įdiegti muzikos žanrų piktogramas muzikai ir muzikiniams klipams."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Įdiegti spalvotas filmų žanrų piktogramas filmams ir TV laidoms."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Įdiegti juodai baltas filmų žanrų piktogramas filmams ir TV laidoms."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Įdiegti šalių piktogramas filmų šalių mazgui."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Nustatyti delsą tarp fono paveikslėlių keitimo visoje temoje."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Krentančių fono efektų pasirinkimas. Sniegas, lapai ir kt."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Rodyti šiuo metu grojamo muzikos kūrinio atlikėjo fono paveikslėlius visoje temoje. Pakeičia bibliotekos foninius paveikslėlius."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Muzikos atkūrimo metu fone įjungia muzikos vizualizaciją. Reikia, kad vizualizacija būtų įjungta nustatymuose - Grotuvo nustatymai / Muzika."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Rodyti šiuo metu grojamą vaizdo įrašą fone naršant bibliotekoje. Pakeičia bibliotekos foninius paveikslėlius."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Atsisiųsti šiuo metu grojamo atlikėjo vaizdus bei papildomą informaciją iš fanart.tv ir theaudiodb.com. Skirta viso ekrano muzikai, interneto srautams ir radijui."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Atlikėjo skaidrių demonstracijos skripto nustatymai."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "Nuoroda į vaizdo įrašų grojaraštį, jei jis nėra tuščias."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "Nuoroda į muzikos grojaraštį, jei jis nėra tuščias."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Nuoroda į viso ekrano režimą, kai atkuriama medija."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Spustelėkite, kad atidarytumėte nuorodų meniu."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Grotuvo valdikliai, kai atkuriama medija."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Automatiškai paleisti kitą TV laidos epizodą."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Atkurti temines dainas naršant po TV laidas, filmus ir muzikinius klipus."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "Bibliotekos mazgų redaktorius leidžia kurti ir pritaikyti pasirinktinius vaizdo įrašų ir muzikos mazgus „Kodi“ programoje."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Rodyti perdangos žymeklių informaciją peržiūrėtiems, neperžiūrėtiems ir nebaigtiems žiūrėti medijos elementams."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Kodi integruoto RSS naujienų bėgantčios eilutės redagavimo skriptas."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Temos versija ir atkūrimo parinktys. Atkuria visus numatytuosius nustatymus į pradines reikšmes."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Priedai"