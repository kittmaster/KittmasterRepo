# --- Body texts: top row category selectors (controls 901–904, 905) ---

#: /16x9/includes.xml
msgctxt "#31567"
msgid "Highlight a logo from the palette below and click to assign it to 4K / UHD video files."
msgstr "Изберете лого от палитрата по-долу и щракнете, за да го зададете за видеофайлове 4K / UHD."

#: /16x9/includes.xml
msgctxt "#31568"
msgid "Highlight a logo from the palette below and click to assign it to WebDL and streaming video sources."
msgstr "Изберете лого от палитрата по-долу и щракнете, за да го зададете за източници WebDL и видео потоци."

#: /16x9/includes.xml
msgctxt "#31569"
msgid "Highlight a logo from the palette below and click to assign it to 1080p Full HD video files."
msgstr "Изберете лого от палитрата по-долу и щракнете, за да го зададете за видеофайлове 1080p Full HD."

#: /16x9/includes.xml
msgctxt "#31570"
msgid "Highlight a logo from the palette below and click to assign it to 720p HD video files."
msgstr "Изберете logo от палитрата по-долу и щракнете, за да го зададете за видеофайлове 720p HD."

#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "Изберете лого от палитрата по-долу и щракнете, за да го зададете за видеофайлове DVD и стандартна резолюция."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "Показване само на лога с ултрависока резолюция и 4K в палитрата."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "Показване само на лога на кодеците HEVC и H.265 в палитрата."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Показване само на лога на кодеците AVC и H.264 в палитрата."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Показване само на лога на форматите DivX, XviD и стари MPEG-4 в палитрата."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Показване само на лога на класически емисии на ТВ, MPEG и DVD в палитрата."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Показване само на лога на кодека Windows Media Video и VC-1 в палитрата."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Показване само на контейнери, дискови формати и други разнообразни лога в палитрата."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Затваряне на прозореца за настройка на флагове и връщане към настройките."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Изберете лого от централната палитра и щракнете, за да го запишете като вашия персонален флаг за активната категория."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Изчистване на вашия избор за персонален флаг и връщане на тази категория към стандартната логика на темата."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Превключване на оформлението на флаговете между цветни дизайни и манахромно бяло по подразбиране."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Използвайте клавишите за посока за навигация в опциите. Натиснете 'Назад' или изберете 'Изход' по всяко време за затваряне без промени."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Избор за промяна"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Персонализиране на началния екран, уиджетите и менюто за бърз достъп."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Скрипт за създатели на теми, позволяващ на потребителите да изберат добавка за графични ресурси."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Автоматично добавя допълнително оформление за файловете във вашите библиотеки."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Текстове на песни. Изисква се за активиране на анимирани текстове."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Синхронизиране на вашата колекция и статус на гледане с trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Създаване на персонализирани любими от избрани любими елементи на Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Редактиране на менюто на началния екран, уиджетите, фоновете и информационните редове."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Нулиране на менюто на началния екран, уиджетите, фоновете и информационните редове до стандартните им стойности."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Създаване на персонализирани любими от избрани любими на Kodi. За използване в уиджети на главното меню. Изисква инсталиране на скрипта за любими."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Създаване на персонализирана любима добавка от инсталираните добавки. За използване в уиджети на главното меню."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Нулиране на темата и цветовете до стандартните им стойности."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Избор от списък с предварително дефинирани теми."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Заключване на предпочитанията за деактивиране на режима на изглед, опциите за изглед, информационния диалог и настройките за цял екран."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Персонализиране на началния екран, любимите, предварително дефинираните теми и режима на павилион."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Промяна на текстурите на темата."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Персонализиране на цветовете на текстурата."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Персонализиране на фона и резервните опции за специфични зони."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Активиране или деактивиране на различни функции на темата."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Персонализиране на оформлението и инсталиране на поддържани пакети."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Инсталиране и конфигуриране на поддържани добавки."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Активиране и деактивиране на изгледи на библиотеката. Деактивирането на изгледи на библиотеката на системи с ниски характеристики може да подобри производителността."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Показва буква при превъртане в изгледите на библиотеката."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Показва азбуката за преход към позиция в контейнера. Работи само при сортиране по подразбиране (А-Я / A-Z)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Показва кратко резюме на сюжета за сериали и филми, ако е налично, в противен случай показва стандартното резюме."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Автоматично превъртане на сюжета, ако не се събира в размерите на полето."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Активиране на менюто за бърз достъп за незабавен достъп до специфични зони. В медийното меню натиснете наляво за отваряне или щракнете върху иконата за бърз достъп."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Редактиране на менюто за бърз достъп."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Активиране и деактивиране на елементите на горната лента."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Промяна на настройките за видео информацията."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Промяна на настройките за музикална информация."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Промяна на настройките за видео на цял екран."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Промяна на настройките за аудио на цял екран."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Намаляване на размера на изскачащите известия."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Затъмнява екрана зад изскачащите диалози. Не се прилага за видео или аудио на цял екран."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Активиране на цветни икони за горната лента, медийната информация и изгледите на библиотеката."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Активиране на цветни, HDR, битова дълбочина и езикови медийни флагове."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Резервно изображение за аудио CD в мащаба на цялата тема."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Резервно изображение за видео CD в мащаба на цялата тема."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Избор и инсталиране на пакет с икони за времето за горната лента, уиджетите и времето."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Избор и инсталиране на пакет с фен-арт за времето за фоновете, уиджетите и времето."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Инсталиране на бели икони на филмови студия за използване навсякъде в темата."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Инсталиране на цветни икони на филмови студия за използване навсякъде в темата."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Инсталиране на икони за музикални издатели за използване навсякъде в темата."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Инсталиране на езикови флагове за изгледите на библиотеката и избора на субтитри."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Инсталиране на икони за музикални жанрове за музика и музикални видеоклипове."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Инсталиране на цветни икони за жанрове на филми и сериали."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Инсталиране на черно-бели икони за жанрове на филми и сериали."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Инсталиране на държавни икони за държавния възел на филмите."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Задаване на забавянето между преходите на фен-арта навсякъде в темата."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Падащи фонови ефекти (сняг, листа и др.)."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Показване на музикалния фен-арт на текущо възпроизвеждания елемент навсякъде в темата. Заменя фен-арта на библиотеката."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Активира визуализация на музиката на заден план по време на възпроизвеждане. Изисква визуализацията да е активирана в настройките на плейъра."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Показване на текущо възпроизвежданото видео на заден план при разглеждане на библиотеката. Заменя фен-арта на библиотеката."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Изтегляне на изображения и допълнителна информация от fanart.tv и theaudiodb.com за текущо възпроизвеждания изпълнител. За музика на цял екран, интернет потоци и радио."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Настройки на скрипта за слайдшоу на изпълнителя."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "Път за бърз достъп до видео плейлиста, ако не е празен."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "Път за бърз достъп до музикалния плейлист, ако не е празен."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Бърз преход към цял екран при възпроизвеждане."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Щракнете, за да отворите менюто за бърз достъп."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Контроли на плейъра при възпроизвеждане."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Автоматично възпроизвеждане на следващия епизод на сериала."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Възпроизвеждане на темтична музика при разглеждане на сериали, филми и музикални видеоклипове."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "Редакторът на възли на библиотеката ви позволява да създавате и персонализирате лични видео и музикални възли в Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Показване на наложена маркерна информация за гледани, негледани и започнати медийни елементи."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Скрипт за редактиране на вградената RSS лента на Kodi."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Версия на темата и опции за възстановяване. Възстановява всички първоначални стойности по подразбиране."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Добавки"