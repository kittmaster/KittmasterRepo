msgid "Customise 720p flag:"
msgstr "Prilagodi zastavico 720p:"

#: /16x9/includes.xml
msgctxt "#31563"
msgid "Customise DVD / SD flag:"
msgstr "Prilagodi zastavico DVD / SD:"

#: /16x9/includes.xml
msgctxt "#31564"
msgid "Category filter:"
msgstr "Filter kategorij:"

#: /16x9/includes.xml
msgctxt "#31565"
msgid "Restore default:"
msgstr "Obnovi privzeto:"

#: /16x9/includes.xml
msgctxt "#31566"
msgid "Toggle Color Scheme:"
msgstr "Preklopi barvno shemo:"

# --- Body texts: top row category selectors (controls 901–904, 905) ---

#: /16x9/includes.xml
msgctxt "#31567"
msgid "Highlight a logo from the palette below and click to assign it to 4K / UHD video files."
msgstr "Označite logotip s spodnje palete in kliknite, da ga dodelite video datotekam 4K / UHD."

#: /16x9/includes.xml
msgctxt "#31568"
msgid "Highlight a logo from the palette below and click to assign it to WebDL and streaming video sources."
msgstr "Označite logotip s spodnje palete in kliknite, da ga dodelite WebDL in pretočnim virom videa."

#: /16x9/includes.xml
msgctxt "#31569"
msgid "Highlight a logo from the palette below and click to assign it to 1080p Full HD video files."
msgstr "Označite logotip s spodnje palete in kliknite, da ga dodelite video datotekam 1080p Full HD."

#: /16x9/includes.xml
msgctxt "#31570"
msgid "Highlight a logo from the palette below and click to assign it to 720p HD video files."
msgstr "Označite logotip s spodnje palete in kliknite, da ga dodelite video datotekam 720p HD."

#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "Označite logotip s spodnje palete in kliknite, da ga dodelite DVD in video datotekam standardne ločljivosti."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "V mrežni paleti si oglejte samo logotipe izjemno visoke ločljivosti in 4K."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "V mrežni paleti si oglejte samo logotipe kodekov HEVC in H.265."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "V mrežni paleti si oglejte samo logotipe kodekov AVC in H.264."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "V mrežni paleti si oglejte samo logotipe formatov DivX, XviD in starejših MPEG-4."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "V mrežni paleti si oglejte samo klasične logotipe MPEG, DVD in standardnih televizijskih prenosov."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "V mrežni paleti si oglejte samo logotipe kodekov Windows Media Video in VC-1."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "V mrežni paleti si oglejte samo logotipe vsebnikov, formatov diskov in druge razne logotipe."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Zaprite to pogovorno okno za prilagajanje zastavic in se vrnite v nastavitve."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Označite kateri koli logotip v osrednji mreži in kliknite, da ga shranite kot svojo zastavico po meri za aktivno kategorijo."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Počistite izbiro zastavice po meri in obnovite to kategorijo na privzeto samodejno logiko zastavic preobleke."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Preklopite globalno grafiko zastavic med barvnim dizajnom in enobarvno privzeto belo."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Za krmarjenje med možnostmi uporabite smerne tipke. Pritisnite Nazaj ali izberite Izhod kadar koli za zapiranje brez sprememb."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Izberite za spremembo"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Prilagajanje domačega zaslona, gradnikov in menija z bližnjicami."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Skript za oblikovalce preoblek, ki uporabnikom omogoča izbiro slikovnega dodatka."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Samodejno doda dodatno slikovno gradivo za medije v vaših medijskih knjižnicah."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Besedila za glasbo. Zahtevano za omogočanje animiranih besedil."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Sinhronizirajte svojo zbirko in stanje ogleda s trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Ustvarite priljubljeno po meri iz izbranih priljubljenih v Kodiju."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Uredite meni domačega zaslona, gradnike, ozadja in informacijske vrstice."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Ponastavite meni domačega zaslona, gradnike, ozadja in informacijske vrstice na privzete vrednosti."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Ustvarite priljubljeno po meri iz izbranih priljubljenih v Kodiju. Za uporabo v gradnikih glavnega menija. Zahteva nameščen skript za priljubljene."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Ustvarite priljubljen dodatek po meri iz nameščenih dodatkov. Za uporabo v gradnikih glavnega menija."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Ponastavi temo preobleke in barve na privzete vrednosti."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Izberite s seznama vnaprej določenih tem."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Zaklenite nastavitve, da onemogočite način pogleda, možnosti pogleda, informacijsko pogovorno okno in celozaslonske nastavitve."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Prilagodite domači zaslon, priljubljene, vnaprej določene teme in način kiosk."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Spremenite teksture teme preobleke."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Prilagodite barve tekstur preobleke."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Prilagodite ozadje in zasilne možnosti za določena območja preobleke."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Omogočite ali onemogočite različne funkcije preobleke."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Prilagodite slikovno gradivo in namestite podprte pakete slik."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Namestite in konfigurirajte podprte dodatke."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Omogočite in onemogočite poglede knjižnice. Onemogočanje pogledov knjižnice na manj zmogljivih sistemih lahko izboljša delovanje."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Prikaže črko za drsenje pri pomikanju v pogledih knjižnice."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Prikaže abecedo za skok na določen položaj vsebnikа. Deluje le pri privzetih metodah razvrščanja (A-Z)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Prikaže kratek opis vsebine za TV oddaje in filme, če je na voljo, sicer pa privzeto vsebino."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Samodejno premikaj vsebino, če ne ustreza dimenzijam kontrolnika."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Omogočite meni bližnjic za takojšen dostop do določenih območij preobleke. V medijskem meniju kliknite levo, da ga odprete, ali kliknite ikono bližnjice."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Uredi meni bližnjic."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Omogočite in onemogočite elemente zgornje vrstice."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Spremenite nastavitve video informacij."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Spremenite nastavitve informacij o glasbi."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Spremenite celozaslonske video nastavitve."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Spremenite celozaslonske zvočne nastavitve."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Zmanjšajte velikost pojavnih obvestil."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Zatemni zaslon za pogovornimi pojavnimi okni. Ne velja za celozaslonski video ali zvok."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Omogoči barvne ikone za zgornjo vrstico, medijske informacije in poglede knjižnice."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Omogoči barvne, HDR, bitne globine in jezikovne medijske zastavice."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Zasilna slika avdio diska po celotni preobleki."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Zasilna slika video diska po celotni preobleki."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Izberite in namestite paket vremenskih ikon za zgornjo vrstico, gradnike in vreme."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Izberite in namestite paket vremenskih ozadij (fanart) za ozadja, gradnike in vreme."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Namestite bele ikone studiev za uporabo v celotni preobleki."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Namestite barvne ikone studiev za uporabo v celotni preobleki."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Namestite ikone založb za uporabo v celotni preobleki."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Namestite jezikovne zastave za poglede knjižnice in izbiro podnapisov."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Namestite ikone glasbenih žanrov za glasbo in glasbene videoposnetke."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Namestite barvne ikone filmskih žanrov za filme in TV oddaje."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Namestite črno-bele ikone filmskih žanrov za filme in TV oddaje."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Namestite ikone držav za vozlišče držav v filmih."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Nastavite zakasnitev med prehodi ozadij (fanart) po celotni preobleki."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Padajoči učinki ozadja. Sneg, listje itd."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Prikaži ozadje (fanart) trenutno predvajane glasbe po celotni preobleki. Prepiše ozadja knjižnice."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Omogoči glasbeno vizualizacijo v ozadju med predvajanjem glasbe. Zahteva omogočeno vizualizacijo v Nastavitvah predvajalnika > Glasba."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Prikaži trenutno predvajani video v ozadju med brskanjem po knjižnici. Prepiše ozadje knjižnice."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Prenesi slike in dodatne informacije s fanart.tv in theaudiodb.com za trenutno predvajanega izvajalca. Za celozaslonsko glasbo, internetne tokove in radio."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Nastavitve skripta za predstavitev izvajalca."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "Bližnjica do video seznama predvajanja, če ta ni prazen."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "Bližnjica do glasbenega seznama predvajanja, če ta ni prazen."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Bližnjica do celozaslonskega prikaza, ko se medij predvaja."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Kliknite, da odprete meni bližnjic."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Kontrole predvajalnika, ko se medij predvaja."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Samodejno predvajaj naslednjo epizodo TV oddaje."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Predvajaj glasbene teme med brskanjem po TV oddajah, filmih in glasbenih videoposnetkih."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "Urednik vozlišč knjižnice vam omogoča ustvarjanje in prilagajanje video in glasbenih vozlišč v Kodiju."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Prikaži prekrivne informacije oznak za ogledane, neogledane in začete medijske vsebine."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Skript za urejanje vgrajenega Kodijevega RSS traku."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Različica preobleke in možnosti obnovitve. Obnovi vse privzete nastavitve na začetno delovanje."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Dodatki"