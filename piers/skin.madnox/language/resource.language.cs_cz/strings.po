msgctxt "#31523"
msgid "Display ratings as 10-point numbers"
msgstr "Zobrazit hodnocení jako desetinná čísla (10bodová škála)"

#: /16x9/SkinSettings.xml
msgctxt "#31524"
msgid "Allows changes to the ratings to convert between floating numbers or as a percentage. Affects TMDb & IMDb, all others remain as their default display."
msgstr "Umožňuje převod hodnocení mezi desetinnými čísly nebo procenty. Ovlivňuje TMDb a IMDb, ostatní zůstávají ve výchozím zobrazení."

