#: /16x9/includes.xml
msgctxt "#31559"
msgid "Customise 4K / UHD flag:"
msgstr "Přizpůsobit značku 4K / UHD:"

#: /16x9/includes.xml
msgctxt "#31560"
msgid "Customise WebDL flag:"
msgstr "Přizpůsobit značku WebDL:"

#: /16x9/includes.xml
msgctxt "#31561"
msgid "Customise 1080p flag:"
msgstr "Přizpůsobit značku 1080p:"

#: /16x9/includes.xml
msgctxt "#31562"
msgid "Customise 720p flag:"
msgstr "Přizpůsobit značku 720p:"

#: /16x9/includes.xml
msgctxt "#31563"
msgid "Customise DVD / SD flag:"
msgstr "Přizpůsobit značku DVD / SD:"

#: /16x9/includes.xml
msgctxt "#31564"
msgid "Category filter:"
msgstr "Filtr kategorií:"

#: /16x9/includes.xml
