msgid "Toggle Color Scheme:"
msgstr "Přepnout barevné schéma:"

# --- Body texts: top row category selectors (controls 901–904, 905) ---

#: /16x9/includes.xml
msgctxt "#31567"
msgid "Highlight a logo from the palette below and click to assign it to 4K / UHD video files."
msgstr "Zvýrazněte logo z palety níže a kliknutím jej přiřaďte k video souborům 4K / UHD."

#: /16x9/includes.xml
msgctxt "#31568"
msgid "Highlight a logo from the palette below and click to assign it to WebDL and streaming video sources."
msgstr "Zvýrazněte logo z palety níže a kliknutím jej přiřaďte ke zdrojům videa WebDL a streamování."

#: /16x9/includes.xml
msgctxt "#31569"
msgid "Highlight a logo from the palette below and click to assign it to 1080p Full HD video files."
msgstr "Zvýrazněte logo z palety níže a kliknutím jej přiřaďte k video souborům 1080p Full HD."

#: /16x9/includes.xml
msgctxt "#31570"
msgid "Highlight a logo from the palette below and click to assign it to 720p HD video files."
msgstr "Zvýrazněte logo z palety níže a kliknutím jej přiřaďte k video souborům 720p HD."

#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "Zvýrazněte logo z palety níže a kliknutím jej přiřaďte k video souborům DVD a ve standardním rozlišení."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "Zobrazit v mřížce palety pouze loga ultra vysokého rozlišení a 4K."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "Zobrazit v mřížce palety pouze loga kodeků HEVC a H.265."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Zobrazit v mřížce palety pouze loga kodeků AVC a H.264."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Zobrazit v mřížce palety pouze loga starších formátů DivX, XviD a MPEG-4."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Zobrazit v mřížce palety klasická loga formátů MPEG, DVD a standardního televizního vysílání."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Zobrazit v mřížce palety loga kodeků Windows Media Video a VC-1."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Zobrazit v mřížce palety loga kontejnerů, diskových formátů a další různé návrhy."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Zavřít tento dialog přizpůsobení značek a vrátit se do nastavení."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Zvýrazněte jakékoli logo ve středové mřížce a kliknutím jej uložte jako vlastní značku pro aktivní kategorii."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Vymazat vlastní výběr značky a obnovit u této kategorie automatickou výchozí logiku vzhledu."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Přepnout globální styl značek mezi barevným designem a jednobarevnou výchozí bílou."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "K navigaci v možnostech použijte směrové klávesy. Chcete-li dialog zavřít bez změn, stiskněte kdykoli klávesu Zpět nebo zvolte Ukončit."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Vyberte pro úpravu"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Přizpůsobení domovské obrazovky, widgetů a nabídky zkratek."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Skript pro tvůrce vzhledů, který uživatelům umožňuje vybrat doplněk pro obrázky."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Automaticky přidává další grafiku pro média ve vašich knihovnách médií."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Texty pro hudbu. Vyžadováno pro povolení animovaných textů."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Synchronizujte svou sbírku a stav zhlédnutí s trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Vytvořit vlastní oblíbené z vybraných oblíbených položek Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Upravit nabídku domovské obrazovky, widgety, pozadí a informační řádky."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Obnovit nabídku domovské obrazovky, widgety, pozadí a informační řádky na výchozí hodnoty."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Vytvořit vlastní oblíbené z vybraných oblíbených položek Kodi. Pro použití ve widgetech hlavní nabídky. Vyžaduje nainstalovaný skript oblíbených položek."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Vytvořit vlastní oblíbený doplněk z nainstalovaných doplňků. Pro použití ve widgetech hlavní nabídky."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Obnovit motiv a barvy vzhledu na výchozí."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Vybrat ze seznamu předdefinovaných motivů."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Uzamknout předvolby pro zakázání režimu zobrazení, možností zobrazení, informačních dialogů a nastavení celé obrazovky."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Přizpůsobit domovskou obrazovku, oblíbené, předdefinované motivy a režim kiosek."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Změnit textury motivu vzhledu."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Přizpůsobit barvy textur vzhledu."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Přizpůsobit pozadí a zálohy pro specifické oblasti vzhledu."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Povolit nebo zakázat různé funkce vzhledu."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Přizpůsobit grafiku a nainstalovat podporované balíčky grafiky."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Instalovat a konfigurovat podporované doplňky."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Povolit a zakázat zobrazení knihovny. Zakázání zobrazení knihovny na méně výkonných systémech může zlepšit výkon."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Zobrazuje písmeno při posouvání v zobrazeních knihovny."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Zobrazuje abecedu pro rychlý přechod na pozici v kontejneru. Funguje pouze u výchozích metod řazení (A-Z)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Zobrazuje stručný děj pro seriály a filmy, pokud je k dispozici, jinak se zobrazí výchozí popis děje."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Automaticky posouvat popis děje, pokud se nevejde do rozměrů prvku."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Povolit nabídku zkratek pro okamžitý přístup ke specifickým oblastem vzhledu. V nabídce médií klikněte vlevo pro otevření nebo klikněte na ikonu zkratky."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Upravit nabídku zkratek."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Povolit a zakázat prvky horního panelu."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Změnit nastavení informací o videu."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Změnit nastavení informací o hudbě."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Změnit nastavení videa na celé obrazovce."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Změnit nastavení zvuku na celé obrazovce."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Zmenšit velikost vyskakovacích oznámení."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Ztmaví obrazovku za dialogovými okny. Neplatí pro video nebo zvuk na celé obrazovce."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Povolit barevné ikony pro horní panel, informace o médiích a zobrazení knihovny."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Povolit barevné, HDR, bitové hloubky a jazykové značky médií."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Záložní CD art v celém vzhledu."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Záložní disk art pro video v celém vzhledu."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Vybrat a nainstalovat balíček ikon počasí pro horní panel, widgety a počasí."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Vybrat a nainstalovat balíček fanartů počasí pro pozadí, widgety a počasí."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Instalovat bílé ikony studií pro použití v celém vzhledu."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Instalovat barevné ikony studií pro použití v celém vzhledu."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Instalovat ikony hudebních vydavatelství pro použití v celém vzhledu."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Instalovat jazykové vlajky pro zobrazení knihovny a výběr titulků."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Instalovat ikony hudebních žánrů pro hudbu a hudební videa."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Instalovat barevné ikony filmových žánrů pro filmy a seriály."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Instalovat černobílé ikony filmových žánrů pro filmy a seriály."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Instalovat ikony zemí pro uzel zemí u filmů."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Nastavit zpoždění mezi přechody fanartů v celém vzhledu."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Efekty padajícího pozadí. Sníh, listí atd."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Zobrazovat hudební fanart právě přehrávané položky v celém vzhledu. Přepisuje fanart knihovny."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Povolí vizualizaci hudby na pozadí během přehrávání hudby. Vyžaduje, aby byla vizualizace povolena v Nastavení - Nastavení přehrávače/Hudba."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Zobrazovat právě přehrávané video na pozadí při procházení knihovny. Přepisuje fanart knihovny."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Stahovat obrázky a dodatečné informace z fanart.tv a theaudiodb.com o právě hrajícím interpretovi. Pro hudbu na celé obrazovce, internetové streamy a rádio."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Nastavení skriptu prezentace interpreta (Artist Slideshow)."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "Zkratka na seznam stop videa, pokud není prázdný."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "Zkratka na seznam stop hudby, pokud není prázdný."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Zkratka na celou obrazovku při přehrávání médií."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Kliknutím otevřete nabídku zkratek."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Ovládací prvky přehrávače při přehrávání médií."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Automaticky přehrát další epizodu seriálu."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Přehrávat znělky při procházení seriálů, filmů a hudebních videí."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "Editor uzlů knihovny (Library Node Editor) vám umožňuje vytvářet a upravovat vlastní uzly videa a hudby v Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Zobrazit překryvné značky s informacemi o zhlédnutých, nezhlédnutých a rozpracovaných položkách médií."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Skript pro úpravu vestavěného RSS pásu v Kodi."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Verze vzhledu a možnosti obnovení. Obnoví všechny výchozí hodnoty do stavu po instalaci."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Doplňky"