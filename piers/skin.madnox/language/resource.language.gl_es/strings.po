#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Amosar só deseños de logotipos de códecs AVC e H.264 na cuadrícula da paleta."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Amosar só deseños de logotipos de formatos DivX, XviD e MPEG-4 antigos na cuadrícula da paleta."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Amosar deseños clásicos de logotipos de MPEG, DVD e emisións de TV estándar na cuadrícula da paleta."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Amosar deseños de logotipos de códecs Windows Media Video e VC-1 na cuadrícula da paleta."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Amosar deseños de logotipos de formatos de contedor, discos e outros elementos varios na cuadrícula da paleta."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Pechar este diálogo de personalización de etiquetas e volver aos axustes."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Resalta calquera logotipo na cuadrícula central e preme para gardalo como a túa etiqueta personalizada para a categoría activa."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Borrar a túa elección de etiqueta personalizada e restablecer esta categoría á lóxica de etiquetas automáticas por defecto do tema."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Alternar a imaxe das etiquetas globais entre deseños en cor e o branco monocromático por defecto."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Usa as frechas de dirección para navegar polas opcións. Preme Atrás ou selecciona Saír en calquera momento para pechar sen aplicar cambios."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Seleccionar para modificar"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Personalización da pantalla de inicio, widgets e menú de atallos."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Script para desenvolvedores de temas que permite aos usuarios seleccionar un complemento de recursos de imaxe."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Engade automaticamente imaxes de arte adicionais para os elementos das túas bibliotecas multimedia."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Letras de cancións. Requirido para habilitar as letras animadas."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Sincroniza a túa colección e o estado de visto con trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Crea un favorito personalizado a partir dos favoritos seleccionados de Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Edita o menú da pantalla de inicio, widgets, fondos e liñas de información."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Restablece o menú da pantalla de inicio, widgets, fondos e liñas de información aos valores por defecto."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Crea un favorito personalizado a partir dos favoritos seleccionados de Kodi para usar nos widgets do menú principal. Require o script de favoritos instalado."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Crea un complemento favorito personalizado a partir dos complementos instalados para usar nos widgets do menú principal."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Restablece o tema e as cores do deseño aos valores por defecto."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Selecciona desde unha lista de temas predefinidos."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Bloquea as preferencias para desactivar o modo de vista, as opcións de visualización, o diálogo de información e os axustes de pantalla completa."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Personaliza a pantalla de inicio, favoritos, temas predefinidos e o modo quiosco."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Cambia as texturas do tema."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Personaliza as cores das texturas do tema."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Personaliza o fondo e as alternativas para áreas específicas do tema."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Activa ou desactiva varias características do tema."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Personaliza as imaxes de arte e instala paquetes de arte compatibles."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Instala e configura complementos compatibles."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Activa ou desactiva vistas de biblioteca. Desactivalas en sistemas con baixas prestacións pode mellorar o rendemento."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Amosa a letra de desprazamento ao navegar polas vistas da biblioteca."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Amosa o abecedario para saltar a unha posición do contedor. Só funcionará cos métodos de ordenación por defecto (A-Z)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Amosa un resumo da sinopse de películas e series se está dispoñible; de non selo, amosará a sinopse por defecto."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Desprazar automaticamente a sinopse se non cabe nas dimensións do cadro."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Activa o menú de atallos para un acceso instantáneo a áreas específicas do tema. No menú multimedia, move á esquerda para abrilo ou preme na icona de atallo."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Edita o menú de atallos."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Activa e desactiva elementos da barra superior."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Cambia os axustes de información de vídeo."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Cambia os axustes de información de música."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Cambia os axustes de vídeo a pantalla completa."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Cambia os axustes de audio a pantalla completa."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Reduce o tamanho das notificacións emerxentes."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Escurece a pantalla por detrás dos diálogos emerxentes. Non aplicable a reproducións de vídeo ou audio a pantalla completa."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Activa as iconas de cores para a barra superior, información multimedia e vistas de biblioteca."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Activa as etiquetas de cor, HDR, profundidade de bits e idioma para os medios."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Fondo alternativo de disco de audio para todo o tema."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Fondo alternativo de disco de vídeo para todo o tema."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Selecciona e instala un paquete de iconas do tempo para a barra superior, widgets e clima."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Selecciona e instala un paquete de fanart do tempo para fondos, widgets e clima."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Instala as iconas de estudio en branco para usalas por todo o tema."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Instala as iconas de estudio en cor para usalas por todo o tema."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Instala as iconas de discográficas para usalas por todo o tema."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Instala as bandeiras de idiomas para as vistas de biblioteca e a selección de subtítulos."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Instala iconas de xéneros de música para música e videoclips."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Instala iconas de xéneros de películas en cor para películas e series."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Instala iconas de xéneros de películas en branco e negro para películas e series."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Instala iconas de países para o nodo de países de películas."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Establece o tempo de transición entre fanarts para todo o tema."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Efectos de fondo de caída (neve, follas, etc.)."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Amosa o fanart do elemento de música en reprodución en todo o tema, substituíndo o fanart da biblioteca."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Activa a visualización de música de fondo mentres se reproduce. Require activar a visualización en Axustes > Axustes de reprodutor > Música."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Amosa o vídeo en reprodución de fondo mentres exploras a biblioteca. Substitúe ao fanart da biblioteca."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Descarga imaxes e información adicional de fanart.tv e theaudiodb.com do artista en reprodución actual. Aplicable a música a pantalla completa, transmisións de Internet e radio."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Axustes do script de presentación de artistas."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "Atallo á lista de reprodución de vídeo se non está baleira."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "Atallo á lista de reprodución de música se non está baleira."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Atallo a pantalla completa cando hai algo en reprodución."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Preme para abrir o menú de atallos."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Controis do reprodutor cando hai elementos en reprodución."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Reproducir automaticamente o seguinte episodio da serie."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Reproducir os temas musicais ao navegar por series, películas e videoclips."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "O editor de nodos da biblioteca permíteche crear e personalizar nodos de vídeo e música en Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Amosar marcas de información de elementos vistos, sen ver e en progreso."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Script para editar o feed RSS integrado de Kodi."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Versión do tema e opcións de recuperación. Restablece todos os valores por defecto do primeiro día."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Complementos"