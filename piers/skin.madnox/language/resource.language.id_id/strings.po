#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Hanya tampilkan desain logo format DivX, XviD, dan MPEG-4 lama di kisi palet."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Hanya tampilkan desain logo siaran TV klasik MPEG, DVD, dan standar di kisi palet."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Hanya tampilkan desain logo kodek Windows Media Video dan VC-1 di kisi palet."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Hanya tampilkan desain logo kontainer pembungkus, format cakram, dan desain lainnya di kisi palet."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Tutup dialog penyesuaian bendera ini dan kembali ke pengaturan."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Sorot desain logo apa pun di kisi tengah dan klik untuk menyimpannya sebagai bendera kustom Anda untuk kategori aktif."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Hapus pilihan bendera kustom Anda dan pulihkan kategori ini ke logika bendera bawaan otomatis skin."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Alihkan karya seni bendera global antara desain berwarna dan putih monokrom bawaan."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Gunakan tombol arah Anda untuk menavigasi opsi. Tekan Kembali atau pilih Keluar kapan saja untuk menutup tanpa perubahan."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Pilih untuk memodifikasi"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Penyesuaian layar beranda, widget, dan menu pintasan."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Skrip untuk perancang skin agar pengguna dapat memilih pengaya sumber daya gambar."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Secara otomatis menambahkan karya seni ekstra untuk media di pustaka media Anda."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Lirik untuk musik. Diperlukan untuk mengaktifkan lirik animasi."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Sinkronkan koleksi dan status ditonton Anda dengan trakt.tv."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Buat favorit kustom dari favorit kodi yang dipilih."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Ubah menu layar beranda, widget, latar belakang, dan baris info."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Reset menu layar beranda, widget, latar belakang, dan baris info ke bawaan."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Buat favorit kustom dari favorit kodi yang dipilih. Untuk digunakan di widget menu utama. Membutuhkan skrip favorit terinstal."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Buat pengaya favorit kustom dari pengaya yang diinstal. Untuk digunakan di widget menu utama."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Reset tema dan warna skin ke bawaan."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Pilih dari daftar tema yang telah ditentukan."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Kunci preferensi untuk menonaktifkan mode tampilan, opsi tampilan, dialog info, dan pengaturan layar penuh."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Sesuaikan layar beranda, favorit, tema yang telah ditentukan, dan mode kios."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Ubah tekstur tema skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Sesuaikan warna tekstur skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Sesuaikan latar belakang dan cadangan untuk area skin tertentu."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Aktifkan atau nonaktifkan berbagai fitur skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Sesuaikan karya seni dan instal paket karya seni yang didukung."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Instal dan konfigurasikan pengaya yang didukung."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Aktifkan dan nonaktifkan tampilan pustaka. Menonaktifkan tampilan pustaka pada sistem berspesifikasi rendah dapat meningkatkan performa."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Menampilkan huruf gulir saat menggulir di tampilan pustaka."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Menampilkan alfabet untuk melompat ke posisi kontainer. Hanya akan berfungsi untuk metode pengurutan bawaan (A-Z)."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Menampilkan garis besar plot untuk acara TV dan film jika tersedia, jika tidak akan menampilkan plot bawaan."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Gulir otomatis plot jika tidak sesuai dengan dimensi kontrol."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Aktifkan menu pintasan untuk akses instan ke area skin tertentu. Di menu media, klik kiri untuk membuka atau klik ikon pintasan."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Ubah menu pintasan."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Aktifkan dan nonaktifkan elemen bilah atas."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Ubah pengaturan info video."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Ubah pengaturan info musik."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Ubah pengaturan video layar penuh."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Ubah pengaturan audio layar penuh."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Kurangi ukuran notifikasi pop-up."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Menggelapkan layar di belakang pop-up dialog. Tidak berlaku untuk video atau audio layar penuh."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Aktifkan ikon berwarna untuk bilah atas, informasi media, dan tampilan pustaka."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Aktifkan bendera media berwarna, HDR, kedalaman bit, dan bahasa."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Seni CD audio cadangan untuk seluruh skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Seni CD video cadangan untuk seluruh skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Pilih dan pasang paket ikon cuaca untuk bilah atas, widget, dan cuaca."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Pilih dan pasang paket fanart cuaca untuk latar belakang, widget, dan cuaca."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Instal ikon studio putih untuk digunakan di seluruh skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Instal ikon studio berwarna untuk digunakan di seluruh skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Instal ikon label rekaman untuk digunakan di seluruh skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Instal bendera bahasa untuk tampilan pustaka dan pemilihan subtitel."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Instal ikon genre musik untuk musik dan video musik."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Instal ikon genre film berwarna untuk film dan acara TV."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Instal ikon genre film hitam-putih untuk film dan acara TV."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Instal ikon negara untuk simpul negara film."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Atur penundaan antara transisi fanart untuk seluruh skin."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Efek latar belakang jatuh. Salju, Daun, dll."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Tampilkan fanart musik dari item yang sedang diputar untuk seluruh skin. Menimpa fanart pustaka."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Mengaktifkan visualisasi musik di latar belakang saat memutar musik. Memerlukan visualisasi diaktifkan di pengaturan - Pengaturan pemutar/Musik."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Tampilkan video yang sedang diputar di latar belakang saat menelusuri pustaka. Menimpa fanart pustaka."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Unduh gambar dan informasi tambahan dari fanart.tv and theaudiodb.com dari artis yang sedang diputar. Untuk musik layar penuh, aliran internet, dan radio."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Pengaturan skrip salindia artis."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "Pintasan ke daftar putar video jika tidak kosong."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "Pintasan ke daftar putar musik jika tidak kosong."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Pintasan ke layar penuh saat media sedang diputar."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Klik untuk membuka menu pintasan."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Kontrol pemutar saat media sedang diputar."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "Putar episode acara TV berikutnya secara otomatis."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "Putar lagu tema saat menavigasi Acara TV, Film, dan Video Musik."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "Library Node Editor memungkinkan Anda membuat dan menyesuaikan simpul video kustom dan simpul musik kustom di dalam Kodi."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Tampilkan informasi penanda hamparan untuk item media yang ditonton, belum ditonton, dan sedang berjalan."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Skrip untuk mengedit Ticker RSS bawaan Kodi."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Versi skin dan opsi pemulihan. Memulihkan semua pengaturan bawaan ke awal pemasangan."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Pengaya"