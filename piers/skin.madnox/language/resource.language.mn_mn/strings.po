# --- Body texts: top row category selectors (controls 901–904, 905) ---

#: /16x9/includes.xml
msgctxt "#31567"
msgid "Highlight a logo from the palette below and click to assign it to 4K / UHD video files."
msgstr "Доорх палитраас логог тодруулж, 4K / UHD видео файлуудад оноохын тулд товшино уу."

#: /16x9/includes.xml
msgctxt "#31568"
msgid "Highlight a logo from the palette below and click to assign it to WebDL and streaming video sources."
msgstr "Доорх палитраас логог тодруулж, WebDL болон урсгал видео эх сурвалжид оноохын тулд товшино уу."

#: /16x9/includes.xml
msgctxt "#31569"
msgid "Highlight a logo from the palette below and click to assign it to 1080p Full HD video files."
msgstr "Доорх palett-аас логог тодруулж, 1080p Full HD видео файлуудад оноохын тулд товшино уу."

#: /16x9/includes.xml
msgctxt "#31570"
msgid "Highlight a logo from the palette below and click to assign it to 720p HD video files."
msgstr "Доорх палитраас логог тодруулж, 720p HD видео файлуудад оноохын тулд товшино уу."

#: /16x9/includes.xml
msgctxt "#31571"
msgid "Highlight a logo from the palette below and click to assign it to DVD and standard-definition video files."
msgstr "Доорх палитраас логог тодруулж, DVD болон стандарт нарийвчлалтай видео файлуудад оноохын тулд товшино уу."

# --- Body texts: left menu category buttons (controls 91–97) ---

#: /16x9/includes.xml
msgctxt "#31572"
msgid "View only ultra-high-definition and 4K logo designs in the palette grid."
msgstr "Палитр сүлжээнээс зөвхөн хэт өндөр нарийвчлалтай болон 4K логоны загваруудыг үзэх."

#: /16x9/includes.xml
msgctxt "#31573"
msgid "View only HEVC and H.265 codec logo designs in the palette grid."
msgstr "Палитр сүлжээнээс зөвхөн HEVC болон H.265 кодек логоны загваруудыг үзэх."

#: /16x9/includes.xml
msgctxt "#31574"
msgid "View only AVC and H.264 codec logo designs in the palette grid."
msgstr "Палитр сүлжээнээс зөвхөн AVC болон H.264 кодек логоны загваруудыг үзэх."

#: /16x9/includes.xml
msgctxt "#31575"
msgid "View only DivX, XviD, and legacy MPEG-4 format logo designs in the palette grid."
msgstr "Палитр сүлжээнээс зөвхөн DivX, XviD болон хуучин MPEG-4 форматын логоны загваруудыг үзэх."

#: /16x9/includes.xml
msgctxt "#31576"
msgid "View classic MPEG, DVD, and standard TV broadcast logo designs in the palette grid."
msgstr "Палитр сүлжээнээс классик MPEG, DVD болон стандарт ТВ нэвтрүүлгийн логоны загваруудыг үзэх."

#: /16x9/includes.xml
msgctxt "#31577"
msgid "View Windows Media Video and VC-1 codec logo designs in the palette grid."
msgstr "Палитр сүлжээнээс Windows Media Video болон VC-1 кодек логоны загваруудыг үзэх."

#: /16x9/includes.xml
msgctxt "#31578"
msgid "View container wrappers, disk formats, and other miscellaneous logo designs in the palette grid."
msgstr "Палитр сүлжээнээс контейнер, дискний формат болон бусад холимог логоны загваруудыг үзэх."

# --- Standalone entries (no colored prefix) ---

#: /16x9/includes.xml
msgctxt "#31579"
msgid "Close this flag customization dialog and return to settings."
msgstr "Энэхүү туг өөрчлөх харилцах цонхыг хааж тохиргоо руу буцах."

#: /16x9/includes.xml
msgctxt "#31580"
msgid "Highlight any logo design in the center grid and click to save it as your custom flag for the active category."
msgstr "Төв сүлжээнээс дурын логоны загварыг тодруулж, идэвхтэй ангиллын өөрийн сонгосон туг болгон хадгалахын тулд товшино уу."

# --- Body texts: right panel actions (controls 801, 98) ---

#: /16x9/includes.xml
msgctxt "#31581"
msgid "Clear your custom flag choice and restore this category to the skin's automatic default flag logic."
msgstr "Өөрийн сонгосон тугийг арилгаж, энэ ангиллыг арьсны автомат үндсэн туг горимд шилжүүлэх."

#: /16x9/includes.xml
msgctxt "#31582"
msgid "Toggle global flag artwork between colored designs and monochromatic default white."
msgstr "Нийт тугуудын дизайныг өнгөт болон нэг өнгөт цагаан хооронд шилжүүлэх."

# --- Default / idle state ---

#: /16x9/includes.xml
msgctxt "#31583"
msgid "Use your directional keys to navigate options. Press Back or select Exit at any time to close without changes."
msgstr "Чиглүүлэх товчлууруудыг ашиглан сонголтуудыг гүйлгэнэ үү. Өөрчлөлт оруулахгүйгээр хаахын тулд Буцах товчлуур дарах эсвэл Гарах-ыг сонгоно уу."

#: /16x9/SkinSettings.xml
msgctxt "#31584"
msgid "Select to modify"
msgstr "Засахын тулд сонгоно уу"

#: /16x9/Includes_Settings.xml
msgctxt "#31901"
msgid "Customisation of the home screen, widgets and shortcuts menu."
msgstr "Нүүр дэлгэц, виджетүүд болон товчлууруудын цэсийг өөрчлөх."

#: /16x9/Includes_Settings.xml
msgctxt "#31904"
msgid "Script for skinners to let users select an image resource addon."
msgstr "Хэрэглэгчдэд зургийн нөөцийн нэмэлтийг сонгох боломжийг олгох арьс бүтээгчдэд зориулсан скрипт."

#: /16x9/Includes_Settings.xml
msgctxt "#31905"
msgid "Automatically adds extra artwork for media in your media libraries."
msgstr "Таны медиа сангаас медиад зориулж нэмэлт зургуудыг автоматаар нэмнэ."

#: /16x9/Includes_Settings.xml
msgctxt "#31907"
msgid "Lyrics for music. Required to enable animated lyrics."
msgstr "Хөгжмийн дууны үг. Хөдөлгөөнт дууны үгийг идэвхжүүлэхэд шаардлагатай."

#: /16x9/Includes_Settings.xml
msgctxt "#31908"
msgid "Sync your collection and watched status with trakt.tv."
msgstr "Өөрийн цуглуулга болон үзсэн төлөвийг trakt.tv-тэй синхрончлох."

#: /16x9/Includes_Settings.xml
msgctxt "#31910"
msgid "Create a custom favourite from selected kodi favourites."
msgstr "Сонгосон коди дуртай зүйлсээс өөрийн хүссэн дуртай зүйлсийг үүсгэх."

#: /16x9/Includes_Settings.xml
msgctxt "#31911"
msgid "Edit the home screen menu, widgets, backgrounds and infolines."
msgstr "Нүүр дэлгэцийн цэс, виджет, арын дэвсгэр болон мэдээллийн мөрүүдийг засах."

#: /16x9/Includes_Settings.xml
msgctxt "#31912"
msgid "Reset the home screen menu, widgets, backgrounds and infolines to default."
msgstr "Нүүр дэлгэцийн цэс, виджет, арын дэвсгэр болон мэдээллийн мөрүүдийг үндсэн тохиргоонд нь буцаах."

#: /16x9/Includes_Settings.xml
msgctxt "#31913"
msgid "Create a custom favourite from selected kodi favourites. For use in main menu widgets. Requires script favourites to be installed."
msgstr "Сонгосон коди дуртай зүйлсээс өөрийн хүссэн дуртай зүйлсийг үүсгэх. Үндсэн цэсний виджетүүдэд ашиглахад зориулагдсан. Дуртай скриптийг суулгасан байх шаардлагатай."

#: /16x9/Includes_Settings.xml
msgctxt "#31914"
msgid "Create a custom addon favourite from installed addons. For use in main menu widgets."
msgstr "Суулгасан нэмэлтүүдээс өөрийн хүссэн нэмэлтийн дуртай зүйлийг үүсгэх. Үндсэн цэсний виджетүүдэд ашиглахад зориулагдсан."

#: /16x9/Includes_Settings.xml
msgctxt "#31915"
msgid "Reset the skin theme and colours to default."
msgstr "Арьсны сэдэв болон өнгөнүүдийг үндсэн тохиргоонд нь оруулах."

#: /16x9/Includes_Settings.xml
msgctxt "#31916"
msgid "Select from a list of pre-defined themes."
msgstr "Урьдчилан тодорхойлсон сэдвүүдийн жагсаалтаас сонгох."

#: /16x9/Includes_Settings.xml
msgctxt "#31917"
msgid "Lock preferences to disable view mode, view options, info dialog and fullscreen settings."
msgstr "Харагдах горим, харагдацын сонголтууд, мэдээллийн харилцах цонх болон бүтэн дэлгэцийн тохиргоог идэвхгүй болгохын тулд тохиргоог түгжих."

#: /16x9/Includes_Settings.xml
msgctxt "#31918"
msgid "Customise the home screen, favourites, predefined themes and kiosk mode."
msgstr "Нүүр дэлгэц, дуртай зүйлс, урьдчилан тодорхойлсон сэдэв болон ТҮЦ горимыг өөрчлөх."

#: /16x9/Includes_Settings.xml
msgctxt "#31919"
msgid "Change skin theme textures."
msgstr "Арьсны сэдвийн текстурыг өөрчлөх."

#: /16x9/Includes_Settings.xml
msgctxt "#31920"
msgid "Customise the skin texture colours."
msgstr "Арьсны текстурын өнгийг өөрчлөх."

#: /16x9/Includes_Settings.xml
msgctxt "#31921"
msgid "Customise the background and fallbacks for specific skin areas."
msgstr "Арьсны тодорхой хэсэгт зориулсан арын дэвсгэр болон орлуулагчийг өөрчлөх."

#: /16x9/Includes_Settings.xml
msgctxt "#31922"
msgid "Enable or disable various skin features."
msgstr "Арьсны төрөл бүрийн функцуудыг идэвхжүүлэх эсвэл идэвхгүй болгох."

#: /16x9/Includes_Settings.xml
msgctxt "#31923"
msgid "Customise artwork and install supported artwork packs."
msgstr "Зургийн бүтээлийг өөрчлөх болон дэмжигдсэн зургийн багцуудыг суулгах."

#: /16x9/Includes_Settings.xml
msgctxt "#31924"
msgid "Install and configure supported addons."
msgstr "Дэмжигдсэн нэмэлтүүдийг суулгах, тохируулах."

#: /16x9/Includes_Settings.xml
msgctxt "#31925"
msgid "Enable and disable library views. Disabling library views on low spec systems may improve performance."
msgstr "Сангийн харагдацуудыг идэвхжүүлэх, идэвхгүй болгох. Хүчин чадал багатай системүүд дээр сангийн харагдацыг идэвхгүй болгох нь ажиллагааг сайжруулж магадгүй."

#: /16x9/Includes_Settings.xml
msgctxt "#31926"
msgid "Shows scroll letter when scrolling in library views."
msgstr "Сангийн харагдац дотор гүйлгэх үед гүйлгэх үсгийг харуулна."

#: /16x9/Includes_Settings.xml
msgctxt "#31927"
msgid "Shows the alphabet to jump to a position of the container. Will only work for default sorting methods (A-Z)."
msgstr "Контейнерын байршил руу шууд очих цагаан толгойг харуулна. Зөвхөн үндсэн эрэмбэлэх аргуудад (A-Z) ажиллана."

#: /16x9/Includes_Settings.xml
msgctxt "#31928"
msgid "Shows plot outline for tv shows and movies if available, otherwise will display the default plot."
msgstr "Боломжтой бол ТВ шоу болон киноны үйл явдлын тоймыг харуулах бөгөөд үгүй бол үндсэн үйл явдлыг харуулна."

#: /16x9/Includes_Settings.xml
msgctxt "#31929"
msgid "Auto scroll the plot if it does not fit the control dimensions."
msgstr "Үйл явдлын тойм хэмжээнд багтахгүй бол автоматаар гүйлгэнэ."

#: /16x9/Includes_Settings.xml
msgctxt "#31930"
msgid "Enable the shortcut menu for instant access to specific skin areas. In the media menu click left to open or click on the shortcut icon."
msgstr "Арьсны тодорхой хэсэгт шууд хандахын тулд товчлуурын цэсийг идэвхжүүлнэ. Медиа цэснээс зүүн тийш дарж нээх эсвэл товчлуурын дүрс дээр дарна уу."

#: /16x9/Includes_Settings.xml
msgctxt "#31931"
msgid "Edit the shortcut menu."
msgstr "Товчлуурын цэсийг засах."

#: /16x9/Includes_Settings.xml
msgctxt "#31932"
msgid "Enable and disable the topbar elements."
msgstr "Дээд мөрний элементүүдийг идэвхжүүлэх болон идэвхгүй болгох."

#: /16x9/Includes_Settings.xml
msgctxt "#31933"
msgid "Change video info settings."
msgstr "Видео мэдээллийн тохиргоог өөрчлөх."

#: /16x9/Includes_Settings.xml
msgctxt "#31934"
msgid "Change music info settings."
msgstr "Хөгжмийн мэдээллийн тохиргоог өөрчлөх."

#: /16x9/Includes_Settings.xml
msgctxt "#31935"
msgid "Change fullscreen video settings."
msgstr "Бүтэн дэлгэцийн видеоны тохиргоог өөрчлөх."

#: /16x9/Includes_Settings.xml
msgctxt "#31936"
msgid "Change fullscreen audio settings."
msgstr "Бүтэн дэлгэцийн аудионы тохиргоог өөрчлөх."

#: /16x9/Includes_Settings.xml
msgctxt "#31937"
msgid "Reduce the size of pop up notifications."
msgstr "Гарч ирдэг мэдэгдлийн хэмжээг багасгах."

#: /16x9/Includes_Settings.xml
msgctxt "#31938"
msgid "Darkens the screen behind dialog popups. Not applicable for fullscreen video or audio."
msgstr "Гарч ирэх харилцах цонхны арын дэлгэцийг бараантуулна. Бүтэн дэлгэцийн видео эсвэл аудиод хамаарахгүй."

#: /16x9/Includes_Settings.xml
msgctxt "#31940"
msgid "Enable coloured icons for the topbar, media information and library views."
msgstr "Дээд мөр, медиа мэдээлэл болон сангийн харагдацуудад зориулж өнгөт дүрснүүдийг идэвхжүүлнэ."

#: /16x9/Includes_Settings.xml
msgctxt "#31941"
msgid "Enable coloured, HDR, bit depth and language media flags."
msgstr "Өнгөт, HDR, битийн гүн болон хэлний медиа тугуудыг идэвхжүүлнэ."

#: /16x9/Includes_Settings.xml
msgctxt "#31943"
msgid "Audio cd art fallback skin wide."
msgstr "Арьсны хэмжээнд аудио CD-ний зургийг орлуулах."

#: /16x9/Includes_Settings.xml
msgctxt "#31944"
msgid "Video cd art fallback skin wide."
msgstr "Арьсны хэмжээнд видео CD-ний зургийг орлуулах."

#: /16x9/Includes_Settings.xml
msgctxt "#31945"
msgid "Select and install a weather icon pack for the topbar, widgets and weather."
msgstr "Дээд мөр, виджет болон цаг агаарт зориулсан цаг агаарын дүрсийн багцыг сонгож суулгана уу."

#: /16x9/Includes_Settings.xml
msgctxt "#31946"
msgid "Select and install a weather fanart pack for the backgrounds, widgets and weather."
msgstr "Арын дэвсгэр, виджет болон цаг агаарт зориулсан цаг агаарын фан-арт багцыг сонгож суулгана уу."

#: /16x9/Includes_Settings.xml
msgctxt "#31947"
msgid "Install white studio icons for use throughout the skin."
msgstr "Арьсны хэмжээнд ашиглах цагаан студийн дүрснүүдийг суулгах."

#: /16x9/Includes_Settings.xml
msgctxt "#31948"
msgid "Install coloured studio icons for use throughout the skin."
msgstr "Арьсны хэмжээнд ашиглах өнгөт студийн дүрснүүдийг суулгах."

#: /16x9/Includes_Settings.xml
msgctxt "#31949"
msgid "Install record label icons for use throughout the skin."
msgstr "Арьсны хэмжээнд ашиглах дуу бичлэгийн студийн логоны дүрснүүдийг суулгах."

#: /16x9/Includes_Settings.xml
msgctxt "#31950"
msgid "Install language flags for library views and subtitle selection."
msgstr "Сангийн харагдац болон хадмал орчуулга сонгоход зориулж хэлний тугуудыг суулгах."

#: /16x9/Includes_Settings.xml
msgctxt "#31951"
msgid "Install music genre icons for music and music videos."
msgstr "Хөгжим болон хөгжмийн видеонуудад зориулж хөгжмийн төрөл жанрын дүрснүүдийг суулгах."

#: /16x9/Includes_Settings.xml
msgctxt "#31952"
msgid "Install coloured movie genre icons for movies and tv shows."
msgstr "Кино болон ТВ шоунуудад зориулж өнгөт киноны төрөл жанрын дүрснүүдийг суулгах."

#: /16x9/Includes_Settings.xml
msgctxt "#31953"
msgid "Install black and white movie genre icons for movies and tv shows."
msgstr "Кино болон ТВ шоунуудад зориулж хар цагаан киноны төрөл жанрын дүрснүүдийг суулгах."

#: /16x9/Includes_Settings.xml
msgctxt "#31954"
msgid "Install country icons for movies country node."
msgstr "Киноны улс орны зангилаанд зориулж улс орны дүрснүүдийг суулгах."

#: /16x9/Includes_Settings.xml
msgctxt "#31955"
msgid "Set the delay between fanart transitions skin wide."
msgstr "Арьсны хэмжээнд фан-арт шилжилт хоорондын саатлыг тохируулна."

#: /16x9/Includes_Settings.xml
msgctxt "#31956"
msgid "Falling background effects. Snow, Leaves etc."
msgstr "Унаж буй арын дэвсгэрийн эффектүүд. Цас, Навчис г.м."

#: /16x9/Includes_Settings.xml
msgctxt "#31957"
msgid "Show music fanart of currently playing item skin wide. Overrides library fanart."
msgstr "Одоо тоглуулж буй хөгжмийн фан-артыг арьсны хэмжээнд харуулна. Сангийн фан-артыг даран ажиллана."

#: /16x9/Includes_Settings.xml
msgctxt "#31958"
msgid "Enables music visualisation in background while playing music. Requires visualisation to be enabled in settings - Player settings/Music."
msgstr "Хөгжим тоглож байх үед арын дэвсгэрт хөгжмийн дүрслэлийг идэвхжүүлнэ. Тохиргоо - Тоглуулагчийн тохиргоо/Хөгжим хэсэгт дүрслэлийг идэвхжүүлсэн байх шаардлагатай."

#: /16x9/Includes_Settings.xml
msgctxt "#31959"
msgid "Show now playing video in background while browsing library. Overrides library fanart."
msgstr "Санд хайлт хийж байх хооронд одоо тоглож буй видеог арын дэвсгэрт харуулна. Сангийн фан-артыг даран ажиллана."

#: /16x9/Includes_Settings.xml
msgctxt "#31960"
msgid "Download images and additional information from fanart.tv and theaudiodb.com of the currently playing artist. For fullscreen music, internet streams and radio."
msgstr "Одоо тоглож буй уран бүтээлчийн зураг болон нэмэлт мэдээллийг fanart.tv болон theaudiodb.com-оос татаж авна. Бүтэн дэлгэцийн хөгжим, интернэт урсгал болон радиод зориулагдсан."

#: /16x9/Includes_Settings.xml
msgctxt "#31962"
msgid "Artist slideshow script settings."
msgstr "Уран бүтээлчийн слайд шоу скрипт тохиргоо."

#: /16x9/Includes_Settings.xml
msgctxt "#31963"
msgid "A shortcut to the video playlist if not empty."
msgstr "Хоосон биш бол видео тоглуулах жагсаалт руу очих товчлуур."

#: /16x9/Includes_Settings.xml
msgctxt "#31964"
msgid "A shortcut to the music playlist if not empty."
msgstr "Хоосон биш бол хөгжмийн тоглуулах жагсаалт руу очих товчлуур."

#: /16x9/Includes_Settings.xml
msgctxt "#31965"
msgid "Shortcut to fullscreen when media is playing."
msgstr "Медиа тоглож байх үед бүтэн дэлгэц рүү шилжих товчлуур."

#: /16x9/Includes_Settings.xml
msgctxt "#31966"
msgid "Click to open shortcut menu."
msgstr "Товчлуурын цэсийг нээхийн тулд дарна уу."

#: /16x9/Includes_Settings.xml
msgctxt "#31967"
msgid "Player controls when media is playing."
msgstr "Медиа тоглож байх үед тоглуулагчийг удирдах хэсэг."

#: /16x9/Includes_Settings.xml
msgctxt "#31968"
msgid "Play the next TV show episode automatically."
msgstr "ТВ шоуны дараагийн ангийг автоматаар тоглуулна."

#: /16x9/Includes_Settings.xml
msgctxt "#31969"
msgid "Play themes while navigating TV Shows, Movies and Music Videos."
msgstr "ТВ шоу, Кино болон Хөгжмийн видеонууд хооронд шилжих үед сэдэв ая тоглуулна."

#: /16x9/Includes_Settings.xml
msgctxt "#31970"
msgid "The Library Node Editor allows you to create and customise custom video nodes and music nodes within Kodi."
msgstr "Сангийн зангилаа засагч нь Коди дотор өөрийн хүссэн видео зангилаа болон хөгжмийн зангилааг үүсгэх, өөрчлөх боломжийг олгодог."

#: /16x9/Includes_Settings.xml
msgctxt "#31971"
msgid "Show overlay marker information for watched, unwatched, and in progress media items."
msgstr "Үзсэн, үзээгүй, болон үзэж буй медиа зүйлсийн хувьд давхарласан тэмдэглэгээний мэдээллийг харуулна."

#: /16x9/Includes_Settings.xml
msgctxt "#31972"
msgid "A script for editing Kodi's built in RSS Ticker."
msgstr "Коди-ийн суурилуулсан RSS урсгал мөрийг засахад зориулсан скрипт."

#: /16x9/SkinSettings.xml
msgctxt "#31973"
msgid "Skin version and recovery options. Restores all defaults to day one operation."
msgstr "Арьсны хувилбар болон сэргээх сонголтууд. Бүх үндсэн тохиргоог анх суулгасан өдрийн байдалд оруулна."

#: /16x9/SkinSettings.xml
msgctxt "#31974"
msgid "Addons"
msgstr "Нэмэлтүүд"