msgctxt "#31521"
msgid "Madnox image resource addon"
msgstr "Madnox зургийн нөөцийн нэмэлт"

#: /16x9/SkinSettings.xml
msgctxt "#31522"
msgid "Images"
msgstr "Зургууд"

