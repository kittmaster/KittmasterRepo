<?xml version="1.0" encoding="utf-8"?>
<addon id="resource.images.skin.madnox" version="1.0.0" name="Madnox Image Resources" provider-name="Kittmaster">
    <requires>
        <!-- This is the core Kodi requirement for resource addons -->
        <import addon="kodi.resource" version="1.0.0"/>
    </requires>
    
    <extension point="kodi.resource.images" compile="false" />
    
    <extension point="xbmc.addon.metadata">
        <summary lang="en_gb">Image resources and extras for the Madnox skin</summary>
        <description lang="en_gb">This addon contains the extra backgrounds, cdart, icons, and genres required by the Madnox skin. It has been separated to optimize the main skin installation size.</description>
        <platform>all</platform>
        <license>CC BY-SA 4.0, GNU GENERAL PUBLIC LICENSE Version 2.0</license>
        <forum>https://forum.kodi.tv/forumdisplay.php?fid=314</forum>
        <source>https://github.com/kittmaster/KittmasterRepo</source>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>